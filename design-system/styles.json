        "customize": "Use Tailwind utilities: class='btn px-10 shadow-xl'",
        "override": "Use ! for specificity: class='btn bg-red-500!'"
      },
      "sizes": {
        "xs": "Extra small size variant",
        "sm": "Small size variant",
        "md": "Medium size variant (often default)",
        "lg": "Large size variant",
        "xl": "Extra large size variant"
      },
      "colors": {
        "neutral": "Neutral color from theme",
        "primary": "Primary brand color",
        "secondary": "Secondary brand color",
        "accent": "Accent brand color",
        "info": "Informational state",
        "success": "Success state",
        "warning": "Warning state",
        "error": "Error/danger state"
      }
    }
