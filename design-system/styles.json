  "typography": {
    "fontFamily": {
      "primary": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "fallback": "sans-serif"
    },
    "fontWeights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSizes": {
      "xs": "0.8125rem",
      "sm": "0.875rem",
      "base": "0.9375rem",
      "md": "1rem",
      "lg": "1.0625rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem",
      "_note": "Readability-adjusted: min 13px (0.8125rem) for improved typography"
    },
    "lineHeights": {
      "none": "1",
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.625"
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em"
    },
    "_premiumLabelStyles": {
      "textTransform": "uppercase",
      "letterSpacing": "0.1em",
      "fontSize": "0.8125rem",
      "_note": "Premium label styles for stat/category badges (13px, uppercase, widest tracking)"
    }
  },
  "spacing": {
    "0": "0",
    "0.5": "0.125rem",
    "1": "0.25rem",
    "1.5": "0.375rem",
    "2": "0.5rem",
    "2.5": "0.625rem",
    "3": "0.75rem",
    "3.5": "0.875rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "7": "1.75rem",
    "8": "2rem",
    "9": "2.25rem",
    "10": "2.5rem",
    "12": "3rem",
    "24": "6rem",
    "cardLg": "2rem",
    "_note": "cardLg is 2rem (32px) for large card padding matching PoC design"
  },
  "borderRadius": {
    "sm": "0.125rem",
    "md": "0.375rem",
    "lg": "0.5rem",
    "xl": "0.75rem",
    "2xl": "1rem",
    "full": "9999px",
    "premium": "0.75rem",
    "premiumLg": "1.25rem",
    "_note": "Use rounded-card utility class for premiumLg (1.25rem)"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "premium": "0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px 0 rgba(0, 0, 0, 0.03)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
    "2xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
    "accentGlow": "0 10px 15px -3px rgba(21, 128, 61, 0.25)",
    "accentGlowLg": "0 25px 50px -12px rgba(21, 128, 61, 0.3)",
    "premiumLg": "0 20px 25px -5px rgba(0, 0, 0, 0.1)"
  },
  "effects": {
    "blur": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "24px",
      "3xl": "48px"
    },
    "backdropBlur": {
      "glass": "12px"
    },
    "transitions": {
      "fast": "150ms",
      "base": "300ms",
      "slow": "500ms",
      "slower": "1000ms"
    },
    "opacity": {
      "glass": {
        "light": "0.8",
        "dark": "0.8"
      },
      "overlay": "0.1",
      "disabled": "0.5"
    }
  },
  "components": {
    "button": {
      "sizes": {
        "sm": {
          "padding": "0.375rem 0.75rem",
          "fontSize": "0.8125rem",
          "height": "2rem"
        },
        "md": {
          "padding": "0.625rem 1.25rem",
          "fontSize": "0.9375rem",
          "height": "2.5rem"
        },
        "lg": {
          "padding": "0.75rem 1.5rem",
          "fontSize": "0.9375rem",
          "height": "3rem"
        }
      },
      "variants": {
        "primary": {
          "background": "#15803d",
          "color": "#ffffff",
          "shadow": "0 10px 15px -3px rgba(21, 128, 61, 0.25)"
        },
        "secondary": {
          "background": "#0f172a",
          "color": "#ffffff"
        },
        "ghost": {
          "background": "transparent",
          "border": "1px solid #e2e8f0"
        }
      }
    },
    "card": {
      "padding": "1.75rem",
      "borderRadius": "var(--radius-box)",
      "border": "1px solid",
      "borderColor": {
        "light": "#e2e8f0",
        "dark": "#1e293b"
      },
      "background": {
        "light": "#ffffff",
        "dark": "#0f172a"
      },
      "shadow": "0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px 0 rgba(0, 0, 0, 0.03)"
    },
    "input": {
      "height": "2.5rem",
      "padding": "0.5rem 2.5rem 0.5rem 0.75rem",
      "fontSize": "0.8125rem",
      "borderRadius": "var(--radius-field)",
      "background": {
        "light": "#f1f5f9",
        "dark": "#1e293b"
      },
      "focusRing": "2px solid rgba(21, 128, 61, 0.25)"
    },
    "badge": {
      "padding": "0.25rem 0.625rem",
      "fontSize": "0.8125rem",
      "borderRadius": "var(--radius-selector)",
      "fontWeight": 700,
      "_note": "Readability-adjusted: 13px (0.8125rem) minimum"
    },
    "sidebar": {
      "width": "16rem",
      "background": {
        "light": "#ffffff",
        "dark": "#0f172a"
      },
      "border": {
        "light": "#e2e8f0",
        "dark": "#1e293b"
      },
      "navItem": {
        "padding": "0.625rem 1rem",
        "gap": "0.75rem",
        "iconSize": "22px"
      },
      "activeGradient": "linear-gradient(90deg, rgba(21, 128, 61, 0.1) 0%, rgba(21, 128, 61, 0) 100%)",
      "activeBorder": "2px solid #15803d"
    },
    "table": {
      "headerBackground": {
        "light": "rgba(248, 250, 252, 0.5)",
        "dark": "rgba(30, 41, 59, 0.5)"
      },
      "rowHover": {
        "light": "#f8fafc",
        "dark": "rgba(30, 41, 59, 0.4)"
      },
      "cellPadding": "1rem 1.5rem",
      "iconSize": "22px"
    }
  },
  "layout": {
    "container": {
      "maxWidth": "1400px",
      "padding": {
        "mobile": "1.5rem",
        "desktop": "3rem"
      }
    },
    "header": {
      "height": "5rem",
      "padding": "1.25rem"
    },
    "bottomNav": {
      "height": "4rem",
      "padding": "0.75rem 1rem"
