  "daisyui": {
    "version": "5.5.x",
    "docs": "https://daisyui.com",
    "config": {
      "themes": ["light", "dark"],
      "defaultTheme": "light",
      "darkTheme": "dark",
      "location": "src/styles/globals.css"
    },
    "usage": {
      "semanticColors": "Use DaisyUI semantic colors (primary, secondary, accent, neutral, base-100/200/300, success, warning, error, info) instead of Tailwind color names for theme compatibility",
      "components": "Use DaisyUI component classes (btn, card, input, etc.) with utility classes for customization",
      "theming": "Colors automatically change based on active theme - no need for dark: variants"
    },
    "colors": {
      "semantic": {
        "primary": "Primary brand color - main color of your brand",
        "primaryContent": "Foreground content color to use on primary color",
        "secondary": "Secondary brand color - optional secondary color",
        "secondaryContent": "Foreground content color to use on secondary color",
        "accent": "Accent brand color - optional accent color",
        "accentContent": "Foreground content color to use on accent color",
        "neutral": "Neutral dark color - for non-saturated parts of UI",
        "neutralContent": "Foreground content color to use on neutral color",
        "base100": "Base surface color of page - used for blank backgrounds",
        "base200": "Base color, darker shade - to create elevations",
        "base300": "Base color, even darker shade - to create elevations",
        "baseContent": "Foreground content color to use on base color",
        "info": "Info color - for informative/helpful messages",
        "infoContent": "Foreground content color to use on info color",
        "success": "Success color - for success/safe messages",
        "successContent": "Foreground content color to use on success color",
        "warning": "Warning color - for warning/caution messages",
        "warningContent": "Foreground content color to use on warning color",
        "error": "Error color - for error/danger/destructive messages",
        "errorContent": "Foreground content color to use on error color"
      },
      "usage": {
        "background": "bg-primary, bg-base-100, bg-neutral",
        "text": "text-primary, text-base-content, text-error",
        "border": "border-primary, border-base-300"
      },
      "rules": [
        "Use DaisyUI semantic colors for theme compatibility",
        "Avoid Tailwind color names (red-500, gray-800) which don't change with themes",
        "Use *-content colors for good contrast against their base colors",
        "No need for dark: variants when using DaisyUI colors"
      ]
    },
    "themes": {
      "light": {
        "description": "Default light theme - clean and modern",
        "usage": "Active by default"
      },
      "dark": {
        "description": "Default dark theme - comfortable for low-light environments",
        "usage": "Active when prefers-color-scheme: dark"
      }
    },
    "customTheme": {
      "description": "Create custom themes using @plugin 'daisyui/theme'",
      "location": "Define in src/styles/globals.css",
      "structure": {
        "colorVariables": [
          "--color-base-100",
          "--color-base-200",
          "--color-base-300",
          "--color-base-content",
          "--color-primary",
          "--color-primary-content",
          "--color-secondary",
          "--color-secondary-content",
          "--color-accent",
          "--color-accent-content",
          "--color-neutral",
          "--color-neutral-content",
          "--color-info",
          "--color-info-content",
          "--color-success",
          "--color-success-content",
          "--color-warning",
          "--color-warning-content",
          "--color-error",
          "--color-error-content"
        ],
        "designVariables": {
          "radiusSelector": "Border radius of selectors (checkbox, toggle, badge) - 0rem, 0.25rem, 0.5rem, 1rem, 2rem",
          "radiusField": "Border radius of fields (button, input, select, tab) - 0rem, 0.25rem, 0.5rem, 1rem, 2rem",
          "radiusBox": "Border radius of boxes (card, modal, alert) - 0rem, 0.25rem, 0.5rem, 1rem, 2rem",
          "sizeSelector": "Base size of selectors (checkbox, toggle, badge) - 0.25rem default",
          "sizeField": "Base size of fields (button, input, select, tab) - 0.25rem default",
          "border": "Border size - 1px default",
          "depth": "Adds shadow and 3D depth effect - 0 or 1",
          "noise": "Adds subtle grain effect - 0 or 1"
        },
        "designVariableValues": {
          "radiusSelector": "1rem",
          "radiusField": "0rem",
          "radiusBox": "0.5rem",
          "sizeSelector": "0.25rem",
          "sizeField": "0.25rem",
          "border": "1px",
          "depth": "1",
          "noise": "0"
        },
        "example": "@plugin 'daisyui/theme' { name: 'mytheme'; default: true; --color-primary: oklch(55% 0.3 240); --radius-box: 1rem; --depth: 1; }"
      }
    },
    "components": {
      "naming": {
        "component": "Required component class (btn, card, input)",
        "part": "Child part of component (card-body, modal-box)",
        "style": "Specific style variant (btn-outline, alert-soft)",
        "behavior": "Changes behavior (btn-active, modal-open)",
        "color": "Semantic color (btn-primary, badge-error)",
        "size": "Size variant (btn-sm, input-lg)",
        "placement": "Position (dropdown-end, indicator-top)",
        "direction": "Orientation (menu-horizontal, timeline-vertical)",
