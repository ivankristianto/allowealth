---
/**
 * Auth Layout
 *
 * Minimal layout for authentication pages (login, signup) without sidebar navigation.
 * Features centered card container with logo/branding header and footer.
 */

import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
}

const { title = 'Finance Manager - Login' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="min-h-screen flex flex-col bg-base-200">
    <!-- Header with Logo/Branding -->
    <header class="p-4 lg:p-6">
      <div class="container mx-auto">
        <div class="flex items-center gap-2">
          <div class="w-10 h-10 rounded-lg bg-primary flex items-center justify-center">
            <span class="text-white font-bold text-xl">FM</span>
          </div>
          <h1 class="text-xl font-bold text-base-content">Finance Manager</h1>
        </div>
      </div>
    </header>

    <!-- Main Content - Centered Card Container -->
    <main class="flex-1 flex items-center justify-center p-4">
      <div class="w-full max-w-md">
        <slot />
      </div>
    </main>

    <!-- Footer with Copyright -->
    <footer class="p-4 text-center text-sm text-base-content/70">
      <p>&copy; 2026 Finance Manager. All rights reserved.</p>
    </footer>
  </div>
</BaseLayout>
