---
/**
 * Auth Layout
 *
 * Minimal layout for authentication pages (login, signup) without sidebar navigation.
 * Features centered card container with logo/branding header and footer.
 */

import BaseLayout from './BaseLayout.astro';

interface Props {
  title?: string;
}

const { title = 'Finance Manager - Login' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="min-h-screen flex items-center justify-center bg-base-200 p-4">
    <div class="w-full max-w-md">
      <!-- Logo/Branding -->
      <div class="text-center mb-8">
        <div class="flex items-center justify-center gap-3 mb-2">
          <div class="w-12 h-12 rounded-lg bg-primary flex items-center justify-center">
            <span class="text-white font-bold text-2xl">FM</span>
          </div>
          <h1 class="text-2xl font-bold text-base-content">Finance Manager</h1>
        </div>
        <p class="text-sm text-base-content/70 mt-2">Manage your finances with ease</p>
      </div>

      <!-- Main Content -->
      <slot />

      <!-- Footer -->
      <p class="text-center text-xs text-base-content/60 mt-8">
        &copy; 2026 Finance Manager. All rights reserved.
      </p>
    </div>
  </div>
</BaseLayout>
