---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import ToastContainer from '@/components/molecules/ToastContainer.astro';

interface Props {
  title?: string;
}

const { title = 'allowealth' } = Astro.props;

// Construct browser title: "Page Title | allowealth" or just "allowealth" for home
const browserTitle = title && title !== 'allowealth' ? `${title} | allowealth` : 'allowealth';

// Get CSP nonce from middleware for inline scripts
const cspNonce = Astro.locals.cspNonce || '';

// Get perf collector for debug output (only when PERF_DEBUG=true)
const perf = Astro.locals.perf;
const perfDebugComment = perf ? perf.toHtmlComment() : '';
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{browserTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <ClientRouter />
    <!-- Prevent flash of wrong theme by setting data-theme early -->
    <script is:inline nonce={cspNonce}>
      (function () {
        function applyTheme() {
          var savedTheme = localStorage.getItem('theme');
          if (savedTheme) {
            document.documentElement.setAttribute('data-theme', savedTheme);
          } else if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            document.documentElement.setAttribute('data-theme', 'dark');
          }
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <ToastContainer />
    {perfDebugComment && <Fragment set:html={perfDebugComment} />}
  </body>
</html>
