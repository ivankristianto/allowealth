---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import ToastContainer from '@/components/molecules/ToastContainer.astro';

interface Props {
  title?: string;
  ssrTheme?: string;
}

const { title = 'allowealth', ssrTheme } = Astro.props;

// Construct browser title: "Page Title | allowealth" or just "allowealth" for home
const browserTitle = title && title !== 'allowealth' ? `${title} | allowealth` : 'allowealth';
const hasServerTheme = Boolean(ssrTheme && ssrTheme !== 'system');

// Get perf collector for debug output (only when PERF_DEBUG=true)
const perf = Astro.locals.perf;
const perfDebugComment = perf ? perf.toHtmlComment() : '';
---

<!doctype html>
<html
  lang="en"
  data-theme={hasServerTheme ? ssrTheme : 'light'}
  data-theme-server={hasServerTheme ? 'true' : undefined}
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{browserTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Keep theme bootstrap external so prerendered pages can use static CSP headers. -->
    <script src="/scripts/theme-init.js" is:inline></script>
    <ClientRouter />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
    <ToastContainer />
    {perfDebugComment && <Fragment set:html={perfDebugComment} />}
  </body>
</html>
