---
/**
 * Main Layout
 *
 * Primary application layout with sidebar navigation, header, and main content area.
 * Responsive: Sidebar is visible on desktop, collapsible drawer on mobile.
 * Passes user authentication context to Header and child components.
 */

import BaseLayout from './BaseLayout.astro';
import Navigation from '../components/layouts/Navigation.astro';
import Header from '../components/layouts/Header.astro';
import Footer from '../components/layouts/Footer.astro';

interface Props {
  title?: string;
  currentPath?: string;
  user?: any | null;
}

const { title = 'Finance Manager', currentPath = '/', user } = Astro.props;
---

<BaseLayout title={title}>
  <div
    class="drawer lg:drawer-open group transition-none data-[sidebar-ready=true]:transition-all data-[sidebar-ready=true]:duration-300"
    data-sidebar-root
    data-sidebar-collapsed="false"
    data-sidebar-ready="false"
  >
    <input id="drawer-toggle" type="checkbox" class="drawer-toggle" />

    <!-- Page content -->
    <div
      class="drawer-content flex flex-col transition-none data-[sidebar-ready=true]:transition-all data-[sidebar-ready=true]:duration-300"
    >
      <!-- Header -->
      <Header currentPath={currentPath} user={user} />

      <!-- Main content -->
      <main class="flex-1 p-4 lg:p-6 bg-base-200 min-h-screen">
        <slot />
      </main>

      <!-- Footer -->
      <Footer />
    </div>

    <!-- Sidebar navigation -->
    <div class="drawer-side overflow-visible z-50">
      <label for="drawer-toggle" aria-label="close sidebar" class="drawer-overlay"></label>
      <Navigation currentPath={currentPath} user={user} />
    </div>
  </div>
</BaseLayout>
