---
/**
 * PublicLayout
 *
 * Layout for public-facing pages (landing, terms, privacy, contact).
 * Includes PublicNavbar, PublicFooter, dynamic background, and theme toggle.
 */

import BaseLayout from './BaseLayout.astro';
import PublicNavbar from '@/components/layouts/PublicNavbar.astro';
import PublicFooter from '@/components/layouts/PublicFooter.astro';
import { Moon, Sun } from '@lucide/astro';
import type { User } from '@/lib/auth/lucia';

interface Props {
  title?: string;
  user?: User | null;
  showBackground?: boolean;
}

const { title = 'allowealth', user, showBackground = true } = Astro.props;
---

<BaseLayout title={title}>
  <!-- Skip to content link for accessibility -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg focus:font-bold"
  >
    Skip to content
  </a>

  <!-- Dynamic Background -->
  {
    showBackground && (
      <div class="fixed inset-0 overflow-hidden pointer-events-none z-0" aria-hidden="true">
        <div class="absolute top-[-10%] left-[-10%] w-[60%] h-[60%] bg-primary/10 blur-[140px] rounded-full animate-pulse" />
        <div class="absolute bottom-[-10%] right-[-10%] w-[50%] h-[50%] bg-accent/10 blur-[140px] rounded-full animate-bounce-slow" />
      </div>
    )
  }

  <!-- Navigation -->
  <PublicNavbar user={user} />

  <!-- Main Content -->
  <main id="main-content" class="relative z-10 min-h-screen">
    <slot />
  </main>

  <!-- Footer -->
  <PublicFooter />

  <!-- Floating Theme Toggle -->
  <button
    type="button"
    id="floating-theme-toggle"
    class="fixed bottom-6 right-6 z-50 w-12 h-12 rounded-full bg-base-100 border border-base-300 shadow-lg flex items-center justify-center text-neutral hover:text-primary hover:scale-110 active:scale-95 transition-all focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
    aria-label="Toggle dark mode"
    title="Toggle dark mode"
  >
    <Moon size={20} class="stroke-current floating-theme-icon-light" aria-hidden="true" />
    <Sun size={20} class="stroke-current floating-theme-icon-dark hidden" aria-hidden="true" />
  </button>
</BaseLayout>

<style is:global>
  /* Smooth scroll for anchor links */
  html {
    scroll-behavior: smooth;
  }

  /* Custom animation for slow bounce */
  @keyframes bounce-slow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  /* Apply animations only when user prefers motion */
  @media (prefers-reduced-motion: no-preference) {
    .animate-bounce-slow {
      animation: bounce-slow 8s ease-in-out infinite;
    }
  }

  /* Ensure anchor targets account for fixed navbar */
  [id] {
    scroll-margin-top: 100px;
  }
</style>

<script>
  // Theme toggle functionality
  const floatingThemeToggle = document.getElementById('floating-theme-toggle');

  function updateFloatingThemeIcons() {
    const theme = document.documentElement.getAttribute('data-theme');
    const lightIcon = document.querySelector('.floating-theme-icon-light');
    const darkIcon = document.querySelector('.floating-theme-icon-dark');

    if (theme === 'dark') {
      lightIcon?.classList.add('hidden');
      darkIcon?.classList.remove('hidden');
      floatingThemeToggle?.setAttribute('aria-label', 'Switch to light mode');
    } else {
      lightIcon?.classList.remove('hidden');
      darkIcon?.classList.add('hidden');
      floatingThemeToggle?.setAttribute('aria-label', 'Switch to dark mode');
    }
  }

  floatingThemeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') as 'light' | 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateFloatingThemeIcons();
  });

  // Initialize theme icons on load
  updateFloatingThemeIcons();

  // Listen for theme changes from other sources
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        updateFloatingThemeIcons();
      }
    });
  });
  observer.observe(document.documentElement, { attributes: true });
</script>
