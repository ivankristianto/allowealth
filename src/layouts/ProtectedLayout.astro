---
/**
 * Protected Layout
 *
 * Protected route layout that wraps MainLayout for pages requiring authentication.
 * Authentication is enforced at the middleware level for protected routes.
 *
 * Usage:
 * ```astro
 * ---
 * import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
 * ---
 * <ProtectedLayout title="My Page" currentPath="/my-page" subtitle="Page description">
 *   <YourContent />
 * </ProtectedLayout>
 * ```
 *
 * Features:
 * - Middleware redirects unauthenticated users before page execution
 * - Passes authenticated user and title/subtitle to MainLayout and Header
 * - Provides consistent layout for protected pages
 * - Includes global TransactionDrawer accessible from the "New Transaction" header button
 * - Makes userSettings available via Astro.locals.userSettings (frozen to prevent mutation)
 *
 * Note: This layout should only be used for pages under protected route prefixes:
 * /dashboard, /transactions, /budget, /accounts, /reports, /forecast, /calculators, /settings, /profile, /security
 *
 * @param title - Page title displayed in header (defaults to "Finance Manager")
 * @param currentPath - Current route path for navigation highlighting
 * @param subtitle - Optional page subtitle displayed below title in header
 */

import MainLayout from './MainLayout.astro';
import TransactionDrawer from '@/components/organisms/TransactionDrawer.astro';
import {
  categoryService,
  accountService,
  userMetaService,
  transactionService,
  workspaceMetaService,
} from '@/services';
import { DEFAULT_USER_SETTINGS, type UserSettings } from '@/lib/constants/user-meta-keys';
import { getCacheManager, CacheKeys, CacheTags } from '@/lib/cache';
import { isValidCurrency, type Currency } from '@/lib/constants/currency';

interface LayoutData {
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  accounts: Array<{ id: string; name: string; type: string; account_class: string }>;
  userSettings: UserSettings;
  categoryUsageCounts: Array<{ category_id: string; count: number }>;
  workspaceCurrencies: { primary: Currency; secondary: Currency | null };
}

interface Props {
  title?: string;
  currentPath?: string;
  subtitle?: string;
  userName?: string;
  currentDate?: Date;
}

const {
  title = 'Finance Manager',
  currentPath = '/',
  subtitle,
  userName,
  currentDate,
} = Astro.props;

// User is authenticated (enforced by middleware)
const user = Astro.locals.user!;

// Fetch categories, accounts, and user settings for global transaction drawer
// Use cache to reduce database round-trips (saves ~400ms per page load)
let categories: Array<{ id: string; name: string; type: string; currency?: string }> = [];
let accounts: Array<{
  id: string;
  name: string;
  type: string;
  account_class: string;
  currency?: string;
}> = [];
let userSettings: UserSettings = { ...DEFAULT_USER_SETTINGS };
let categoryUsageCounts: Array<{ category_id: string; count: number }> = [];
let workspaceCurrencies: { primary: Currency; secondary: Currency | null } = {
  primary: 'IDR' as Currency,
  secondary: null,
};

// Try to get from cache first (fail-silent: cache errors should never break the page)
let cached: LayoutData | null = null;
let cache: ReturnType<typeof getCacheManager> | null = null;
let cacheKey: string | null = null;

try {
  cache = getCacheManager();
  cacheKey = CacheKeys.layout(user.workspaceId, user.id);
  cached = await cache.get<LayoutData>(cacheKey);
} catch (cacheReadErr) {
  console.warn('Cache read failed, falling back to database:', cacheReadErr);
  // Continue to DB fetch path
}

if (cached) {
  categories = cached.categories;
  accounts = cached.accounts;
  userSettings = cached.userSettings;
  categoryUsageCounts = cached.categoryUsageCounts;
  workspaceCurrencies = cached.workspaceCurrencies ?? workspaceCurrencies;
} else {
  try {
    [categories, accounts, userSettings, categoryUsageCounts, workspaceCurrencies] =
      await Promise.all([
        categoryService.findAll(user.workspaceId, { is_active: true }),
        accountService.findAll(user.workspaceId),
        userMetaService.getUserSettings(user.id),
        transactionService.getCategoryUsageCounts(user.workspaceId, user.id),
        workspaceMetaService.getWorkspaceCurrencies(user.workspaceId),
      ]);
    // Cache the results (5 minutes TTL — reduced cache miss frequency on Workers)
    try {
      if (cache && cacheKey) {
        await cache.set<LayoutData>(
          cacheKey,
          { categories, accounts, userSettings, categoryUsageCounts, workspaceCurrencies },
          {
            ttl: 300,
            tags: [
              CacheTags.workspace(user.workspaceId),
              CacheTags.user(user.id),
              CacheTags.LAYOUT,
              CacheTags.CATEGORIES,
              CacheTags.ACCOUNTS,
              CacheTags.SETTINGS,
            ],
          }
        );
      }
    } catch (cacheWriteErr) {
      console.warn('Cache write failed:', cacheWriteErr);
      // Non-critical: DB-fetched data is still returned
    }
  } catch (err) {
    console.error('Error loading transaction drawer data:', err);
    // Non-critical: drawer won't have options but pages still work
  }
}

// Make userSettings available to child pages via Astro.locals (frozen to prevent mutation)
Astro.locals.userSettings = Object.freeze({ ...userSettings });
Astro.locals.layoutCategories = Object.freeze(
  categories.map((category) => ({
    id: category.id,
    name: category.name,
    type: category.type,
    currency: category.currency,
  }))
);
Astro.locals.layoutAccounts = Object.freeze(
  accounts.map((account) => ({
    id: account.id,
    name: account.name,
    type: account.type,
    currency: account.currency,
    account_class: account.account_class,
  }))
);

// Determine active currency from cookie (for transaction drawer default account selection)
let activeCurrency: Currency = workspaceCurrencies.primary;
const currencyCookieValue = Astro.cookies.get('activeCurrency')?.value;
if (
  currencyCookieValue &&
  isValidCurrency(currencyCookieValue) &&
  (currencyCookieValue === workspaceCurrencies.primary ||
    currencyCookieValue === workspaceCurrencies.secondary)
) {
  activeCurrency = currencyCookieValue;
}
---

<MainLayout
  title={title}
  currentPath={currentPath}
  user={user}
  subtitle={subtitle}
  userName={userName}
  currentDate={currentDate}
  primaryCurrency={workspaceCurrencies.primary}
  secondaryCurrency={workspaceCurrencies.secondary}
>
  <slot name="header" slot="header" />
  <slot />
</MainLayout>

<!-- Horizontal scroll hints for tables -->
<script>
  import '@/components/atoms/ScrollHint.client';
</script>

<!-- Bulk Transaction Drawer -->
<TransactionDrawer
  categories={categories}
  accounts={accounts}
  categoryUsageCounts={categoryUsageCounts}
  activeCurrency={activeCurrency}
/>
