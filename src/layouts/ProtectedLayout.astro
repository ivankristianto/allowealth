---
/**
 * Protected Layout
 *
 * Protected route layout that wraps MainLayout for pages requiring authentication.
 * Authentication is enforced at the middleware level for protected routes.
 *
 * Usage:
 * ```astro
 * ---
 * import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
 * ---
 * <ProtectedLayout title="My Page" currentPath="/my-page" subtitle="Page description">
 *   <YourContent />
 * </ProtectedLayout>
 * ```
 *
 * Features:
 * - Middleware redirects unauthenticated users before page execution
 * - Passes authenticated user and title/subtitle to MainLayout and Header
 * - Provides consistent layout for protected pages
 * - Includes global TransactionDrawer accessible from the "New Transaction" header button
 * - Makes userSettings available via Astro.locals.userSettings (frozen to prevent mutation)
 *
 * Note: This layout should only be used for pages under protected route prefixes:
 * /dashboard, /transactions, /budget, /assets, /reports, /forecast, /calculators, /settings, /profile, /security
 *
 * @param title - Page title displayed in header (defaults to "Finance Manager")
 * @param currentPath - Current route path for navigation highlighting
 * @param subtitle - Optional page subtitle displayed below title in header
 */

import MainLayout from './MainLayout.astro';
import TransactionDrawer from '@/components/organisms/TransactionDrawer.astro';
import { categoryService, assetService, userMetaService } from '@/services';
import { DEFAULT_USER_SETTINGS, type UserSettings } from '@/lib/constants/user-meta-keys';
import { getCacheManager, CacheKeys, CacheTags } from '@/lib/cache';

interface LayoutData {
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  assets: Array<{ id: string; name: string; type: string }>;
  userSettings: UserSettings;
}

interface Props {
  title?: string;
  currentPath?: string;
  subtitle?: string;
}

const { title = 'Finance Manager', currentPath = '/', subtitle } = Astro.props;

// User is authenticated (enforced by middleware)
const user = Astro.locals.user!;

// Fetch categories, assets, and user settings for global transaction drawer
// Use cache to reduce database round-trips (saves ~400ms per page load)
let categories: Array<{ id: string; name: string; type: string; currency?: string }> = [];
let assets: Array<{ id: string; name: string; type: string }> = [];
let userSettings: UserSettings = { ...DEFAULT_USER_SETTINGS };

// Try to get from cache first (fail-silent: cache errors should never break the page)
let cached: LayoutData | null = null;
let cache: ReturnType<typeof getCacheManager> | null = null;
let cacheKey: string | null = null;

try {
  cache = getCacheManager();
  cacheKey = CacheKeys.layout(user.workspaceId, user.id);
  cached = await cache.get<LayoutData>(cacheKey);
} catch (cacheReadErr) {
  console.warn('Cache read failed, falling back to database:', cacheReadErr);
  // Continue to DB fetch path
}

if (cached) {
  categories = cached.categories;
  assets = cached.assets;
  userSettings = cached.userSettings;
} else {
  try {
    [categories, assets, userSettings] = await Promise.all([
      categoryService.findAll(user.workspaceId, { is_active: true }),
      assetService.findAll(user.workspaceId),
      userMetaService.getUserSettings(user.id),
    ]);
    // Cache the results (60 seconds TTL) - fail-silent
    try {
      if (cache && cacheKey) {
        await cache.set<LayoutData>(
          cacheKey,
          { categories, assets, userSettings },
          {
            ttl: 60,
            tags: [
              CacheTags.workspace(user.workspaceId),
              CacheTags.user(user.id),
              CacheTags.LAYOUT,
              CacheTags.CATEGORIES,
              CacheTags.ASSETS,
              CacheTags.SETTINGS,
            ],
          }
        );
      }
    } catch (cacheWriteErr) {
      console.warn('Cache write failed:', cacheWriteErr);
      // Non-critical: DB-fetched data is still returned
    }
  } catch (err) {
    console.error('Error loading transaction drawer data:', err);
    // Non-critical: drawer won't have options but pages still work
  }
}

// Make userSettings available to child pages via Astro.locals (frozen to prevent mutation)
Astro.locals.userSettings = Object.freeze({ ...userSettings });
---

<MainLayout title={title} currentPath={currentPath} user={user} subtitle={subtitle}>
  <slot />
</MainLayout>

<!-- Bulk Transaction Drawer -->
<TransactionDrawer categories={categories} assets={assets} />
