---
/**
 * Calculators Page
 *
 * Financial tools page with compound interest calculator.
 * Features tabbed interface for different calculator types.
 *
 * @route /calculators
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import TabSwitcher from '@/components/molecules/TabSwitcher.astro';
import Label from '@/components/atoms/Label.astro';
import Button from '@/components/atoms/Button.astro';
import Input from '@/components/atoms/Input.astro';
import AmountInput from '@/components/atoms/AmountInput.astro';
import type { Tab } from '@/components/molecules/TabSwitcher.astro';
import { workspaceMetaService } from '@/services';
import type { Currency } from '@/lib/constants/currency';

const currentPath = '/calculators';
const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}
const primaryCurrency: Currency = await workspaceMetaService.getCurrency(user.workspaceId);

// Tab configuration - icons must match the keys in TabSwitcher's iconMap
const tabs: Tab[] = [
  { id: 'compound', label: 'Compound Interest', icon: 'trending_up' },
  { id: 'loan', label: 'Loan & Mortgage', icon: 'home' },
  { id: 'savings', label: 'Savings Goal', icon: 'piggy_bank' },
];
---

<ProtectedLayout title="Calculators" currentPath={currentPath} subtitle="Financial planning tools">
  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8">
    <!-- Tab Switcher -->
    <TabSwitcher activeTab="compound" tabs={tabs} />

    <!-- Calculator Content -->
    <div data-calculator-content>
      <!-- Compound Interest Calculator -->
      <section
        id="compound-panel"
        role="tabpanel"
        aria-labelledby="compound-tab"
        data-calculator="compound"
        class="space-y-8"
      >
        <form id="compound-calculator-form" data-primary-currency={primaryCurrency}>
          <!-- Input Form Card -->
          <div class="bg-base-100 p-6 sm:p-8 rounded-card border border-base-300 shadow-sm">
            <div class="mb-6">
              <h3 class="text-xl font-bold text-base-content tracking-tight leading-none">
                Compound Interest Calculator
              </h3>
              <p class="text-sm text-base-content/60 mt-3 font-medium">
                Calculate how your investments grow over time.
              </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
              <!-- Principal Amount Input -->
              <div class="form-control">
                <Label
                  htmlFor="principal"
                  className="text-xs font-bold uppercase tracking-widest ml-1"
                >
                  Principal Amount
                </Label>
                <AmountInput
                  id="principal"
                  name="principal"
                  currency={primaryCurrency}
                  placeholder="Enter amount"
                  required
                  className="input-bordered h-10 rounded-lg border border-base-300 bg-base-200 pt-2 pb-2 pl-3 pr-10 text-xs focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                />
              </div>

              <!-- Annual Interest Rate Input -->
              <div class="form-control">
                <Label htmlFor="rate" className="text-xs font-bold uppercase tracking-widest ml-1">
                  Annual Interest Rate (%)
                </Label>
                <Input
                  id="rate"
                  name="rate"
                  type="number"
                  placeholder="Enter rate"
                  min="0"
                  step="0.01"
                  required
                  className="bg-base-200"
                />
              </div>

              <!-- Time Period Input -->
              <div class="form-control">
                <Label htmlFor="years" className="text-xs font-bold uppercase tracking-widest ml-1">
                  Time Period (years)
                </Label>
                <Input
                  id="years"
                  name="years"
                  type="number"
                  placeholder="Enter years"
                  min="1"
                  step="1"
                  required
                  className="bg-base-200"
                />
              </div>
            </div>

            <Button
              type="submit"
              variant="primary"
              className="mt-6 h-12 w-full rounded-xl px-6 md:w-auto"
            >
              Calculate
            </Button>
          </div>
        </form>

        <!-- Results Section (hidden by default, populated by API) -->
        <div id="results-container" class="hidden" aria-live="polite"></div>
      </section>

      <!-- Placeholder: Loan & Mortgage Calculator -->
      <section
        id="loan-panel"
        role="tabpanel"
        aria-labelledby="loan-tab"
        class="hidden"
        data-calculator="loan"
      >
        <div class="bg-base-100 p-8 rounded-card border border-base-300 text-center py-16">
          <p class="text-base-content/60 font-medium">Loan & Mortgage Calculator</p>
          <p class="text-sm text-base-content/40 mt-2">Coming soon...</p>
        </div>
      </section>

      <!-- Placeholder: Savings Goal Calculator -->
      <section
        id="savings-panel"
        role="tabpanel"
        aria-labelledby="savings-tab"
        class="hidden"
        data-calculator="savings"
      >
        <div class="bg-base-100 p-8 rounded-card border border-base-300 text-center py-16">
          <p class="text-base-content/60 font-medium">Savings Goal Calculator</p>
          <p class="text-sm text-base-content/40 mt-2">Coming soon...</p>
        </div>
      </section>
    </div>
  </div>
</ProtectedLayout>

<script src="../../components/organisms/CalculatorsPage.client.ts"></script>

<script>
  // Tab switching
  const panels = {
    compound: document.getElementById('compound-panel'),
    loan: document.getElementById('loan-panel'),
    savings: document.getElementById('savings-panel'),
  };

  document.addEventListener('tab-change', (e: Event) => {
    const event = e as CustomEvent<{ tabId: string }>;

    // Hide all panels
    Object.values(panels).forEach((panel) => {
      panel?.classList.add('hidden');
    });

    // Show selected panel
    panels[event.detail.tabId as keyof typeof panels]?.classList.remove('hidden');
  });
</script>
