---
import Breadcrumb from '@/components/atoms/Breadcrumb.astro';
import ForecastCashflowChart from '@/components/organisms/ForecastCashflowChart.astro';
import type { ForecastChartDataPoint } from '@/components/organisms/ForecastCashflowChart.astro';
import ForecastTable from '@/components/organisms/ForecastTable.astro';
import MultiSelectDropdown from '@/components/molecules/MultiSelectDropdown.astro';
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { isValidCurrency, type Currency } from '@/lib/constants/currency';
import { formatMonthHeader } from '@/lib/formatting';
import { getAccountTypeLabel } from '@/lib/types/account';
import { buildForecastFilters } from '@/lib/utils/recurring-forecast-filters';
import { accountService, recurringForecastService, workspaceMetaService } from '@/services';
import { Wallet } from '@lucide/astro';

const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}

const { monthCount, ...filters } = buildForecastFilters(Astro.url.searchParams);

const perf = Astro.locals.perf;

const [forecast, accounts, currencyConfig] = await Promise.all([
  recurringForecastService.getForecast(user.workspaceId, filters, monthCount, perf),
  accountService.findAll(user.workspaceId, undefined, perf),
  workspaceMetaService.getWorkspaceCurrencies(user.workspaceId),
]);

const activeCurrencyCookie = Astro.cookies.get('activeCurrency')?.value || '';
const workspaceCurrencies = [
  currencyConfig.primary,
  ...(currencyConfig.secondary ? [currencyConfig.secondary] : []),
];
const activeCurrency: Currency =
  activeCurrencyCookie &&
  isValidCurrency(activeCurrencyCookie) &&
  workspaceCurrencies.includes(activeCurrencyCookie)
    ? activeCurrencyCookie
    : currencyConfig.primary;

const activeTotals = forecast.totals.find((total) => total.currency === activeCurrency);
const chartData: ForecastChartDataPoint[] = activeTotals
  ? forecast.monthKeys.map((key) => {
      const month = activeTotals.months[key];

      return {
        name: formatMonthHeader(key),
        income: Number.parseFloat(month.income),
        expenses: Number.parseFloat(month.expense),
        net: Number.parseFloat(month.net),
      };
    })
  : [];

const selectedAccounts = filters.accountIds ?? [];
const liquidLabels = new Set(['Cash', 'Bank Account', 'E-Wallet', 'Credit Card']);
const forecastAccounts = accounts
  .map((account) => ({
    id: account.id,
    name: account.name,
    group: getAccountTypeLabel(account.type),
  }))
  .sort((a, b) => {
    const aIsLiquid = liquidLabels.has(a.group);
    const bIsLiquid = liquidLabels.has(b.group);

    if (aIsLiquid && !bIsLiquid) return -1;
    if (!aIsLiquid && bIsLiquid) return 1;
    return a.name.localeCompare(b.name);
  });

function buildFilterUrl(overrides: Record<string, string | undefined>): string {
  const params = new URLSearchParams();

  if (filters.type) params.set('type', filters.type);
  if (selectedAccounts.length > 0) params.set('accounts', selectedAccounts.join(','));
  if (filters.status === 'all') params.set('status', 'all');

  for (const [key, value] of Object.entries(overrides)) {
    if (value === undefined || value === '') {
      params.delete(key);
      continue;
    }

    params.set(key, value);
  }

  const qs = params.toString();
  return qs ? `/recurring/forecast?${qs}` : '/recurring/forecast';
}

const showPaused = filters.status === 'all';
const typeFilter = filters.type ?? '';

const rangeOptions = [
  { value: 3, label: '3M' },
  { value: 6, label: '6M' },
  { value: 12, label: '12M' },
  { value: 24, label: '24M' },
];

const typeOptions = [
  { value: '', label: 'All' },
  { value: 'income', label: 'Income' },
  { value: 'expense', label: 'Expense' },
];
---

<ProtectedLayout title="Recurring Forecast" currentPath="/recurring/forecast">
  <div class="mx-auto max-w-7xl space-y-5 px-1 pb-10 sm:space-y-6 sm:px-2 lg:px-6">
    <Breadcrumb items={[{ label: 'Recurring', href: '/recurring' }, { label: 'Forecast' }]} />

    <section
      class="sticky top-0 z-30 rounded-3xl border border-base-300 bg-base-100 p-4 shadow-sm sm:p-5"
    >
      <form
        id="forecast-filters"
        method="get"
        action="/recurring/forecast"
        class="flex flex-col gap-3 sm:gap-4"
        role="search"
        aria-label="Filter recurring forecast"
      >
        <div class="flex flex-wrap items-center gap-2 sm:gap-3">
          {/* Type filter pills */}
          <div
            class="flex bg-base-200 p-1 rounded-xl sm:rounded-2xl shrink-0"
            role="group"
            aria-label="Filter by type"
          >
            {
              typeOptions.map((opt) => (
                <button
                  type="button"
                  class:list={[
                    'px-3 sm:px-5 py-2 sm:py-2.5 min-h-[44px] min-w-[44px] text-xs font-bold rounded-lg sm:rounded-xl transition-all focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2',
                    typeFilter === opt.value
                      ? 'bg-base-100 shadow text-primary'
                      : 'text-base-content/50 hover:text-base-content/70',
                  ]}
                  data-filter-type-btn={opt.value}
                  aria-pressed={typeFilter === opt.value}
                >
                  {opt.label}
                </button>
              ))
            }
          </div>

          {/* Account dropdown */}
          <MultiSelectDropdown
            id="forecast-account"
            label="All Accounts"
            inputName="accounts"
            selectedIds={selectedAccounts}
            items={forecastAccounts}
            searchable={true}
            searchPlaceholder="Search accounts..."
            filterEventType="accounts"
          >
            <Wallet
              size={16}
              class="stroke-current text-base-content/40"
              aria-hidden="true"
              slot="icon"
            />
          </MultiSelectDropdown>

          {/* Range pills */}
          <div
            class="flex gap-0.5 rounded-xl bg-base-200 p-1 shrink-0"
            role="group"
            aria-label="Forecast range"
          >
            {
              rangeOptions.map((opt) => (
                <a
                  href={buildFilterUrl({
                    monthCount: opt.value === 12 ? undefined : String(opt.value),
                  })}
                  class:list={[
                    'flex min-h-11 items-center rounded-lg px-3 py-1.5 text-xs font-bold transition-all',
                    monthCount === opt.value
                      ? 'bg-base-100 text-primary shadow'
                      : 'text-base-content/50 hover:text-base-content/70',
                  ]}
                  aria-current={monthCount === opt.value ? 'page' : undefined}
                >
                  {opt.label}
                </a>
              ))
            }
          </div>

          {/* Include Paused toggle */}
          <label
            class="flex cursor-pointer items-center gap-2 shrink-0 ml-auto"
            for="show-paused-toggle"
          >
            <span class="text-xs font-bold text-base-content/50">Include Paused</span>
            <input
              type="checkbox"
              id="show-paused-toggle"
              class="toggle toggle-sm toggle-accent"
              role="switch"
              checked={showPaused}
              data-show-paused
            />
          </label>

          {/* Hidden inputs for form state */}
          <input type="hidden" name="type" value={typeFilter} id="forecast-type-hidden" />
          {monthCount !== 12 && <input type="hidden" name="monthCount" value={monthCount} />}
          {
            showPaused && (
              <input type="hidden" name="status" value="all" id="forecast-status-hidden" />
            )
          }
        </div>
      </form>
    </section>

    {
      forecast.rows.length > 0 && (
        <ForecastCashflowChart data={chartData} currency={activeCurrency} />
      )
    }

    <ForecastTable rows={forecast.rows} totals={forecast.totals} monthKeys={forecast.monthKeys} />
  </div>
</ProtectedLayout>

<script>
  const CONTROLLER_KEY = '__forecastFiltersController';
  const LIFECYCLE_KEY = '__forecastFiltersLifecycleBound';

  type ForecastFilterChangeDetail = {
    type?: string;
    value?: string[];
  };

  type ForecastFiltersWindow = Window & {
    [CONTROLLER_KEY]?: AbortController;
    [LIFECYCLE_KEY]?: boolean;
  };

  function isForecastFilterChangeDetail(value: unknown): value is ForecastFilterChangeDetail {
    if (!value || typeof value !== 'object') return false;

    const detail = value as { type?: unknown; value?: unknown };
    const validType = detail.type === undefined || typeof detail.type === 'string';
    const validValue =
      detail.value === undefined ||
      (Array.isArray(detail.value) && detail.value.every((item) => typeof item === 'string'));

    return validType && validValue;
  }

  function initForecastFilters(): void {
    if (typeof window === 'undefined' || typeof document === 'undefined') return;

    const forecastWindow = window as ForecastFiltersWindow;
    forecastWindow[CONTROLLER_KEY]?.abort();

    const controller = new AbortController();
    forecastWindow[CONTROLLER_KEY] = controller;
    const { signal } = controller;

    const form = document.getElementById('forecast-filters');
    if (!(form instanceof HTMLFormElement)) return;

    const typeHidden = document.getElementById('forecast-type-hidden') as HTMLInputElement | null;

    // Type filter pill buttons
    document.querySelectorAll<HTMLButtonElement>('[data-filter-type-btn]').forEach((btn) => {
      btn.addEventListener(
        'click',
        () => {
          const newType = btn.dataset.filterTypeBtn ?? '';
          if (typeHidden) typeHidden.value = newType;

          // Update visual state
          document.querySelectorAll<HTMLButtonElement>('[data-filter-type-btn]').forEach((b) => {
            const isActive = b.dataset.filterTypeBtn === newType;
            b.setAttribute('aria-pressed', String(isActive));
            b.classList.toggle('bg-base-100', isActive);
            b.classList.toggle('shadow', isActive);
            b.classList.toggle('text-primary', isActive);
            b.classList.toggle('text-base-content/50', !isActive);
            b.classList.toggle('hover:text-base-content/70', !isActive);
          });

          form.requestSubmit();
        },
        { signal }
      );
    });

    // Include Paused toggle
    const showPausedToggle = document.querySelector<HTMLInputElement>('[data-show-paused]');
    if (showPausedToggle) {
      showPausedToggle.addEventListener(
        'change',
        () => {
          if (showPausedToggle.checked) {
            if (!document.getElementById('forecast-status-hidden')) {
              const input = document.createElement('input');
              input.type = 'hidden';
              input.name = 'status';
              input.value = 'all';
              input.id = 'forecast-status-hidden';
              form.appendChild(input);
            }
          } else {
            document.getElementById('forecast-status-hidden')?.remove();
          }
          form.requestSubmit();
        },
        { signal }
      );
    }

    // Account filter change
    const handleFilterChange = (event: Event) => {
      if (!(event instanceof CustomEvent) || !isForecastFilterChangeDetail(event.detail)) return;
      if (event.detail.type === 'accounts') {
        form.requestSubmit();
      }
    };

    window.addEventListener('filterChange', handleFilterChange, { signal });
  }

  function setupForecastFiltersLifecycle(): void {
    if (typeof window === 'undefined' || typeof document === 'undefined') return;

    const forecastWindow = window as ForecastFiltersWindow;

    if (!forecastWindow[LIFECYCLE_KEY]) {
      forecastWindow[LIFECYCLE_KEY] = true;

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initForecastFilters, { once: true });
      }

      document.addEventListener('astro:page-load', initForecastFilters);
    }

    if (document.readyState !== 'loading') {
      initForecastFilters();
    }
  }

  setupForecastFiltersLifecycle();
</script>
