---
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import PeriodNavigator, { type PeriodOption } from '@/components/molecules/PeriodNavigator.astro';
import RecurringSectionActionBar from '@/components/molecules/RecurringSectionActionBar.astro';
import ConfirmationModal from '@/components/molecules/ConfirmationModal.astro';
import RecurringPendingList from '@/components/organisms/RecurringPendingList.astro';
import RecurringTemplateList from '@/components/organisms/RecurringTemplateList.astro';
import RecurringCalendar from '@/components/organisms/RecurringCalendar.astro';
import RecurringTemplateForm from '@/components/organisms/RecurringTemplateForm.astro';
import RecurringConfirmModal from '@/components/organisms/RecurringConfirmModal.astro';
import RecurringSkipModal from '@/components/organisms/RecurringSkipModal.astro';
import RecurringStatsPartial from '@/components/partials/RecurringStatsPartial.astro';
import { DEFAULT_CURRENCY } from '@/lib/constants/currency';
import { buildRecurringMonthlySummary } from '@/lib/utils/recurring-summary';
import {
  recurringTemplateService,
  recurringOccurrenceService,
  categoryService,
  accountService,
} from '@/services';

const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}

const url = Astro.url;
const view = url.searchParams.get('view') === 'calendar' ? 'calendar' : 'list';

const now = new Date();
const currentMonth = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}`;
const monthParam = url.searchParams.get('month') || currentMonth;
const monthMatch = monthParam.match(/^(\d{4})-(\d{2})$/);
const safeMonth = monthMatch ? monthParam : currentMonth;
const [year, month] = safeMonth.split('-').map(Number);

const periodOptions: PeriodOption[] = [];
for (let offset = -1; offset <= 18; offset += 1) {
  const date = new Date(now.getFullYear(), now.getMonth() - offset, 1);
  const value = `${String(date.getMonth() + 1).padStart(2, '0')}-${date.getFullYear()}`;
  const label = date.toLocaleDateString('en-US', {
    month: 'long',
    year: 'numeric',
  });
  periodOptions.push({ value, label });
}

const selectedPeriod = `${String(month).padStart(2, '0')}-${year}`;
const selectedMonthLabel = new Date(year, month - 1, 1).toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});

interface RecurringTemplatePrefill {
  name: string;
  type: 'expense' | 'income';
  amount: string;
  currency: string;
  category_id: string;
  account_id: string;
  day_of_month: number;
  start_month: string;
  description?: string;
}

function parseRecurringTemplatePrefill(inputUrl: URL): RecurringTemplatePrefill | null {
  if (inputUrl.searchParams.get('convert') !== '1') return null;

  const type = inputUrl.searchParams.get('tx_type');
  const name = inputUrl.searchParams.get('tx_name');
  const amount = inputUrl.searchParams.get('tx_amount');
  const currency = inputUrl.searchParams.get('tx_currency');
  const categoryId = inputUrl.searchParams.get('tx_category_id');
  const accountId = inputUrl.searchParams.get('tx_account_id');
  const dayRaw = Number(inputUrl.searchParams.get('tx_day'));
  const startMonth = inputUrl.searchParams.get('tx_start_month');
  const description = inputUrl.searchParams.get('tx_description') || undefined;

  if (
    (type !== 'expense' && type !== 'income') ||
    !name ||
    !amount ||
    !currency ||
    !categoryId ||
    !accountId ||
    !startMonth ||
    !/^\d{4}-\d{2}$/.test(startMonth) ||
    !Number.isFinite(dayRaw) ||
    dayRaw < 1 ||
    dayRaw > 31
  ) {
    return null;
  }

  return {
    name,
    type,
    amount,
    currency,
    category_id: categoryId,
    account_id: accountId,
    day_of_month: dayRaw,
    start_month: startMonth,
    description,
  };
}

const perf = Astro.locals.perf;

const [templateResult, pendingResult, categories, accounts] = await Promise.all([
  recurringTemplateService.findAll(user.workspaceId, { status: 'all', page: 1, limit: 20 }, perf),
  recurringOccurrenceService.findPending(user.workspaceId, {
    month: safeMonth,
    status: 'pending',
  }),
  categoryService.findAll(user.workspaceId, { is_active: true }, perf),
  accountService.findAll(user.workspaceId, undefined, perf),
]);

const initialCalendarLoading = view === 'calendar';
const summary = buildRecurringMonthlySummary(pendingResult.occurrences);
const convertPrefill = parseRecurringTemplatePrefill(url);

const currencies = Array.from(new Set(accounts.map((account) => account.currency))).filter(Boolean);
---

<ProtectedLayout title="Recurring" currentPath="/recurring" subtitle={selectedMonthLabel}>
  <PeriodNavigator
    slot="header"
    options={periodOptions}
    selected={selectedPeriod}
    ariaLabel="Select month"
    inputName="month"
    className="mx-auto lg:mx-0"
    newestFirst
    compactMobile
  />

  <div
    id="recurring-page"
    class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-5 sm:space-y-7 pb-10"
    data-initial-view={view}
    data-initial-month={safeMonth}
    data-convert-prefill={convertPrefill ? JSON.stringify(convertPrefill) : undefined}
  >
    <div id="recurring-stats-container">
      <RecurringStatsPartial summary={summary} />
    </div>

    {/* Pending list — always visible */}
    <div id="recurring-pending-list-container">
      <RecurringPendingList
        occurrences={pendingResult.occurrences}
        hasTemplates={templateResult.total > 0}
        monthLabel={selectedMonthLabel}
      />
    </div>

    {/* Section header: title + view toggle + new button */}
    <div class="pt-2">
      <RecurringSectionActionBar view={view} total={templateResult.total} />
    </div>

    {/* Template list — visible in list view */}
    <div
      id="recurring-list-view"
      role="region"
      aria-hidden={view !== 'list'}
      class:list={[view !== 'list' && 'hidden']}
    >
      <div id="recurring-template-list-container">
        <RecurringTemplateList
          templates={templateResult.templates}
          total={templateResult.total}
          page={1}
          limit={20}
        />
      </div>
    </div>

    {/* Calendar view — visible in calendar view */}
    <div
      id="recurring-calendar-view"
      role="region"
      aria-hidden={view !== 'calendar'}
      class:list={[view !== 'calendar' && 'hidden']}
    >
      <div id="recurring-calendar-container">
        <RecurringCalendar
          calendarData={[]}
          year={year}
          month={month}
          loading={initialCalendarLoading}
        />
      </div>
    </div>
  </div>

  <RecurringTemplateForm categories={categories} accounts={accounts} currencies={currencies} />
  <RecurringConfirmModal
    categories={categories}
    accounts={accounts}
    defaultCurrency={currencies[0] ?? DEFAULT_CURRENCY}
  />
  <RecurringSkipModal />

  <ConfirmationModal
    id="recurring-cancel-modal"
    title="Cancel recurring transaction"
    description="This removes only future pending occurrences."
    cancelLabel="Keep"
    confirmLabel="Cancel"
    confirmVariant="error"
    confirmLoadingLabel="Cancelling..."
  />
</ProtectedLayout>

<script>
  import '@/components/organisms/RecurringPage.client';
</script>
