---
import MainLayout from '../../layouts/MainLayout.astro';

const currentPath = '/assets/history';
---

<MainLayout title="Asset History - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    <h2 class="text-2xl font-bold">Asset History</h2>

    <div class="tabs">
      <a class="tab" href="/assets">List</a>
      <a class="tab" href="/assets/add">Add New</a>
      <a class="tab tab-active" href="/assets/history">History</a>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <p class="text-neutral-500">No asset history available yet.</p>
      </div>
    </div>
  </div>
</MainLayout>
