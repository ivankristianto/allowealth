---
/**
 * Asset History Page
 *
 * Page for viewing an asset's balance history.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { assetService } from '@/services';
import { formatCurrency } from '@/lib/formatting';
import { formatAssetType } from '@/lib/tokens';
import EmptyState from '@/components/atoms/EmptyState.astro';
import { ArrowLeft, TrendingUp } from '@lucide/astro';
import type { AssetHistoryOutput } from '@/lib/types/asset';

const user = Astro.locals.user!;

// Get asset ID from URL params
const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

// Load existing asset
const asset = await assetService.findById(id, user.workspaceId);

if (!asset) {
  // Asset not found or doesn't belong to user
  return Astro.redirect('/404');
}

// Load asset history
const history = await assetService.getHistory(id, user.workspaceId);

// Transform history for display
const historyEntries: AssetHistoryOutput[] = history.map((entry) => ({
  id: entry.id,
  asset_id: entry.asset_id,
  balance: entry.balance,
  notes: entry.notes,
  recorded_at: entry.recorded_at,
}));
---

<ProtectedLayout
  title="Asset History"
  currentPath="/assets"
  subtitle={`${asset.name} balance changes`}
>
  <div class="space-y-6">
    {/* Header */}
    <div class="flex items-center gap-4">
      <a href="/assets" class="btn btn-ghost btn-circle btn-sm">
        <ArrowLeft size={18} class="stroke-current" aria-hidden="true" />
      </a>
      <div>
        <h2 class="text-2xl font-bold">{asset.name} - History</h2>
        <p class="text-base-content/70">
          {formatAssetType(asset.type)} • {asset.currency}
        </p>
      </div>
    </div>

    {/* Current Balance Card */}
    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body py-4">
        <div class="flex items-center justify-between">
          <span class="text-base-content/70">Current Balance</span>
          <span
            class={`text-3xl font-bold ${asset.currency === 'IDR' ? 'text-success' : 'text-info'}`}
          >
            {formatCurrency(asset.balance, asset.currency)}
          </span>
        </div>
        <div class="text-sm text-base-content/60 mt-2">
          Last updated: {new Date(asset.last_updated).toLocaleString()}
        </div>
      </div>
    </div>

    {/* History Table */}
    {
      historyEntries.length > 0 ? (
        <div class="card bg-base-100 shadow border border-base-300">
          <div class="card-body p-0">
            <div class="px-6 py-4 bg-base-200 border-b border-base-300">
              <h3 class="font-semibold flex items-center gap-2">
                <TrendingUp size={18} class="stroke-current" aria-hidden="true" />
                Balance History ({historyEntries.length} entries)
              </h3>
            </div>

            {/* Mobile View - Card Layout */}
            <div class="divide-y divide-base-200 lg:hidden">
              {historyEntries.map((entry, index) => (
                <div class="px-6 py-4 space-y-2">
                  <div class="flex items-center justify-between">
                    <span class="text-sm text-base-content/60">
                      Entry #{historyEntries.length - index}
                    </span>
                    <span
                      class={`font-semibold ${asset.currency === 'IDR' ? 'text-success' : 'text-info'}`}
                    >
                      {formatCurrency(entry.balance, asset.currency)}
                    </span>
                  </div>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-base-content/70">Date</span>
                    <span>{new Date(entry.recorded_at).toLocaleString()}</span>
                  </div>
                  {entry.notes && (
                    <div class="text-sm">
                      <span class="text-base-content/70">Notes:</span>
                      <span class="ml-2">{entry.notes}</span>
                    </div>
                  )}
                </div>
              ))}
            </div>

            {/* Desktop View - Table Layout */}
            <div class="hidden lg:table">
              <table class="table table-zebra w-full">
                <thead>
                  <tr class="bg-base-200">
                    <th class="w-20">#</th>
                    <th>Date & Time</th>
                    <th>Balance</th>
                    <th>Notes</th>
                  </tr>
                </thead>
                <tbody>
                  {historyEntries.map((entry, index) => (
                    <tr>
                      <td class="text-base-content/60">{historyEntries.length - index}</td>
                      <td>{new Date(entry.recorded_at).toLocaleString()}</td>
                      <td
                        class={`font-semibold ${asset.currency === 'IDR' ? 'text-success' : 'text-info'}`}
                      >
                        {formatCurrency(entry.balance, asset.currency)}
                      </td>
                      <td class="text-base-content/70">{entry.notes || '-'}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      ) : (
        // Empty state
        <div class="card bg-base-100 shadow border border-base-300">
          <div class="card-body">
            <EmptyState
              title="No history available"
              message="Balance updates will be tracked here. Update the asset balance to start tracking history."
              actionLabel="Back to Assets"
              actionHref="/assets"
            />
          </div>
        </div>
      )
    }
  </div>
</ProtectedLayout>
