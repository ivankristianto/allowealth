---
/**
 * Closed Assets Page
 *
 * Shows all closed asset accounts with metadata (closed date, closed by).
 * Admins can reopen accounts from this page.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import AssetReopenModal from '@components/organisms/AssetReopenModal.astro';
import EmptyState from '@components/atoms/EmptyState.astro';
import { ArrowLeft, RotateCcw, Clock } from '@lucide/astro';
import { assetService, assetCategoryService } from '@/services';
import { formatAssetType } from '@/lib/types/asset';
import { formatCurrency } from '@/lib/formatting';

const user = Astro.locals.user!;
const currentPath = '/assets';
const isAdmin = user.role === 'admin';

// Fetch closed assets
const closedAssets = await assetService.findAllClosed(user.workspaceId);
const categories = await assetCategoryService.findAll(user.workspaceId);
const categoriesById = new Map(categories.map((c) => [c.id, c]));

// Format closed date for display
const formatClosedDate = (date: Date | null): string => {
  if (!date) return 'Unknown';
  return new Date(date).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<ProtectedLayout
  title="Closed Accounts"
  currentPath={currentPath}
  subtitle="Previously closed accounts"
>
  <div
    class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8"
    data-testid="closed-assets-page"
  >
    {/* Back link */}
    <div class="px-4 sm:px-0">
      <a
        href="/assets"
        class="inline-flex items-center gap-1.5 text-sm font-medium text-base-content/60 hover:text-base-content transition-colors"
      >
        <ArrowLeft size={16} class="stroke-current" aria-hidden="true" />
        Back to Active Accounts
      </a>
    </div>

    {/* Page title */}
    <div class="px-4 sm:px-0">
      <h1 class="text-2xl lg:text-3xl font-bold text-base-content tracking-tight">
        Closed Accounts
      </h1>
      <p class="text-sm text-base-content/50 mt-1">
        {closedAssets.length}
        {closedAssets.length === 1 ? 'account' : 'accounts'} closed
      </p>
    </div>

    {
      closedAssets.length > 0 ? (
        <div class="space-y-3">
          {closedAssets.map((asset) => {
            const categoryName = asset.category_id
              ? categoriesById.get(asset.category_id)?.name || formatAssetType(asset.type)
              : formatAssetType(asset.type);
            const currencyBadgeClasses =
              asset.currency === 'IDR' ? 'bg-success/10 text-success' : 'bg-info/10 text-info';

            return (
              <div
                class="card bg-base-100 shadow border border-base-300 rounded-card opacity-60 hover:opacity-80 transition-opacity"
                data-testid="closed-asset-item"
                data-asset-id={asset.id}
              >
                <div class="card-body p-4 lg:px-8 lg:py-5">
                  <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    {/* Asset Info */}
                    <div class="flex-1 min-w-0">
                      <h3 class="text-base lg:text-lg font-bold text-base-content leading-none tracking-tight truncate">
                        {asset.name}
                      </h3>
                      <div class="flex items-center gap-3 mt-2 lg:mt-3">
                        <span
                          class:list={[
                            'px-2 py-0.5 rounded-md text-xs font-bold tracking-wider uppercase',
                            currencyBadgeClasses,
                          ]}
                        >
                          {asset.currency}
                        </span>
                        <span class="text-xs text-base-content/40 font-medium">{categoryName}</span>
                        <span class="inline-flex items-center gap-1 text-xs text-base-content/40 font-medium">
                          <Clock size={10} class="stroke-current" aria-hidden="true" />
                          Closed {formatClosedDate(asset.closed_at)}
                        </span>
                      </div>
                    </div>

                    {/* Balance and Actions */}
                    <div class="flex items-center gap-6">
                      <div class="text-right">
                        <p class="text-lg font-bold text-base-content/40 tracking-tight leading-none">
                          {formatCurrency(parseFloat(asset.balance), asset.currency)}
                        </p>
                      </div>

                      {/* Reopen button (admin only) */}
                      {isAdmin && (
                        <div class="tooltip tooltip-bottom" data-tip="Reopen account">
                          <button
                            type="button"
                            class="btn btn-ghost btn-sm gap-1.5 text-accent hover:bg-accent/10 rounded-xl"
                            aria-label={`Reopen ${asset.name}`}
                            data-reopen-asset={asset.id}
                            data-asset-name={asset.name}
                            data-asset-type={categoryName}
                            data-asset-currency={asset.currency}
                            data-asset-closed-at={asset.closed_at?.toISOString() || ''}
                            data-testid="asset-reopen-btn"
                          >
                            <RotateCcw size={16} class="stroke-current" aria-hidden="true" />
                            <span class="hidden sm:inline">Reopen</span>
                          </button>
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      ) : (
        <div class="card bg-base-100 shadow border border-base-300 rounded-card">
          <div class="card-body">
            <EmptyState
              title="No closed accounts"
              message="When you close asset accounts, they'll appear here. Closed accounts preserve their transaction history."
              actionLabel="Back to Active Accounts"
              actionHref="/assets"
            />
          </div>
        </div>
      )
    }
  </div>

  {/* Reopen Modal (admin only) */}
  {isAdmin && <AssetReopenModal id="asset-reopen-modal" />}
</ProtectedLayout>

<script>
  const initializedReopenButtons = new WeakSet<Element>();

  function initReopenButtons() {
    document.querySelectorAll('[data-reopen-asset]').forEach((button) => {
      if (initializedReopenButtons.has(button)) return;
      initializedReopenButtons.add(button);

      button.addEventListener('click', (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();

        const btn = button as HTMLElement;
        const assetId = btn.getAttribute('data-reopen-asset');
        const assetName = btn.getAttribute('data-asset-name') || 'Asset';
        const assetType = btn.getAttribute('data-asset-type') || 'Unknown';
        const assetCurrency = btn.getAttribute('data-asset-currency') || 'IDR';
        const assetClosedAt = btn.getAttribute('data-asset-closed-at') || '';

        if (!assetId) return;

        document.dispatchEvent(
          new CustomEvent('open-asset-reopen', {
            detail: {
              id: assetId,
              name: assetName,
              type: assetType,
              currency: assetCurrency,
              closedAt: assetClosedAt,
            },
          })
        );
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReopenButtons);
  } else {
    initReopenButtons();
  }

  document.addEventListener('astro:page-load', initReopenButtons);
</script>
