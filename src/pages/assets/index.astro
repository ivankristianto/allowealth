---
/**
 * Assets List Page
 *
 * Main page for viewing and managing assets with filtering.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import AssetList from '@/components/organisms/AssetList.astro';
import { assetService } from '@/services';
import type { AssetOutput } from '@/lib/types/asset';

const user = Astro.locals.user!;
const currentPath = '/assets';

// Get query parameters for filtering
const url = new URL(Astro.url);
const searchParams = Object.fromEntries(url.searchParams.entries());

// Build filters for service
const filters: {
  user_id: string;
  type?: 'bank_account' | 'mutual_fund' | 'bond' | 'crypto' | 'stock' | 'other';
  currency?: 'IDR' | 'USD';
} = {
  user_id: user.id,
};

if (searchParams.type) {
  filters.type = searchParams.type as any;
}
if (searchParams.currency === 'IDR' || searchParams.currency === 'USD') {
  filters.currency = searchParams.currency;
}

// Fetch assets from database
const rawAssets = await assetService.findAll(user.id, filters);

// Transform to AssetOutput format
const assets: AssetOutput[] = rawAssets.map((asset) => ({
  id: asset.id,
  name: asset.name,
  type: asset.type,
  balance: asset.balance,
  currency: asset.currency,
  last_updated: asset.last_updated,
  created_at: asset.created_at,
  updated_at: asset.updated_at,
}));
---

<ProtectedLayout title="Assets - Finance Manager" currentPath={currentPath}>
  <AssetList
    assets={assets}
    currency={filters.currency}
    type={filters.type}
    baseUrl={currentPath}
  />
</ProtectedLayout>
