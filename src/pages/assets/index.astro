---
/**
 * Assets List Page (Global Portfolio)
 *
 * Main page for viewing and managing assets with portfolio summary.
 * Redesigned as part of the Global Portfolio page update.
 * Includes modals for add, edit, delete, and history actions.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import AssetPageHeader from '@components/organisms/AssetPageHeader.astro';
import AssetPortfolioSummary from '@components/organisms/AssetPortfolioSummary.astro';
import AssetGroupCard from '@components/organisms/AssetGroupCard.astro';
import AssetItemRow from '@components/organisms/AssetItemRow.astro';
import AssetFormModal from '@components/organisms/AssetFormModal.astro';
import AssetDeleteConfirmModal from '@components/organisms/AssetDeleteConfirmModal.astro';
import AssetHistoryModal from '@components/organisms/AssetHistoryModal.astro';
import AssetCategoryModal from '@components/organisms/AssetCategoryModal.astro';
import EmptyState from '@components/atoms/EmptyState.astro';
import { assetService, assetCategoryService } from '@/services';
import type { AssetOutput, AssetType } from '@/lib/types/asset';
import { formatAssetType } from '@/lib/types/asset';
import {
  calculateAssetAllocation,
  calculatePortfolioTotals,
  groupAssetsByType,
  calculateGroupTotals,
} from '@/lib/utils/asset';

const user = Astro.locals.user!;
const currentPath = '/assets';

// Valid asset types for filtering
const VALID_ASSET_TYPES = [
  'cash',
  'bank_account',
  'e_wallet',
  'mutual_fund',
  'bond',
  'crypto',
  'stock',
  'other',
  'credit_card',
  'loan',
] as const;

// Get query parameters for filtering
const url = new URL(Astro.url);
const searchParams = Object.fromEntries(url.searchParams.entries());

// Build filters for service with validation
const filters: {
  user_id: string;
  type?: AssetType;
  category_id?: string;
  currency?: 'IDR' | 'USD';
} = {
  user_id: user.workspaceId,
};

// Validate asset type parameter before assignment
if (searchParams.type && VALID_ASSET_TYPES.includes(searchParams.type as AssetType)) {
  filters.type = searchParams.type as AssetType;
}
if (searchParams.categoryId) {
  filters.category_id = searchParams.categoryId;
}
if (searchParams.currency === 'IDR' || searchParams.currency === 'USD') {
  filters.currency = searchParams.currency;
}

// Fetch assets and categories from database
const categories = await assetCategoryService.findAll(user.workspaceId);
const categoriesById = new Map(categories.map((category) => [category.id, category]));
const defaultCategoryId =
  categories.find((category) => category.is_system && !category.is_liability)?.id ||
  categories[0]?.id ||
  '';
const rawAssets = await assetService.findAll(user.workspaceId, filters);

// Transform to AssetOutput format
const assets: AssetOutput[] = rawAssets.map((asset) => {
  const categoryName = asset.category_id
    ? categoriesById.get(asset.category_id)?.name || null
    : formatAssetType(asset.type);

  return {
    id: asset.id,
    name: asset.name,
    type: asset.type,
    category_id: asset.category_id,
    category_name: categoryName,
    balance: asset.balance,
    currency: asset.currency,
    last_updated: asset.last_updated,
    created_at: asset.created_at,
    updated_at: asset.updated_at,
  };
});

// Calculate portfolio totals and allocation
// @TODO: Wire with backend - Consider moving calculations to service layer
const portfolioTotals = calculatePortfolioTotals(assets);
const assetAllocation = calculateAssetAllocation(assets);

// Group assets by type for display
const assetsByType = groupAssetsByType(assets);
const sortedGroups = Object.entries(assetsByType)
  .map(([groupKey, groupAssets]) => {
    const category = categoriesById.get(groupKey);
    const label = category?.name || formatAssetType(groupAssets[0]?.type as AssetType);
    return {
      groupKey,
      label,
      sortOrder: category?.sort_order ?? 999,
      isSystem: category?.is_system ?? false,
      assets: groupAssets,
    };
  })
  .sort((a, b) => {
    if (a.isSystem !== b.isSystem) return a.isSystem ? -1 : 1;
    if (a.sortOrder !== b.sortOrder) return a.sortOrder - b.sortOrder;
    return a.label.localeCompare(b.label);
  });
---

<ProtectedLayout title="Assets" currentPath={currentPath} subtitle="Your financial portfolio">
  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8" data-testid="assets-page">
    {/* Page Header */}
    <AssetPageHeader defaultCategoryId={defaultCategoryId} />

    {
      assets.length > 0 ? (
        <>
          {/* Portfolio Summary */}
          <AssetPortfolioSummary
            totalIdr={portfolioTotals.totalIdr}
            totalUsd={portfolioTotals.totalUsd}
            distribution={assetAllocation}
            loading={false}
          />

          {/* Asset Groups */}
          <div class="space-y-6">
            {sortedGroups.map((group) => {
              const groupTotals = calculateGroupTotals(group.assets);

              return (
                <AssetGroupCard
                  type={group.label}
                  count={group.assets.length}
                  totalIdr={groupTotals.idr}
                  totalUsd={groupTotals.usd}
                  groupId={group.groupKey}
                  defaultExpanded={true}
                >
                  {group.assets.map((asset) => (
                    <AssetItemRow
                      id={asset.id}
                      name={asset.name}
                      type={asset.type}
                      categoryId={asset.category_id}
                      categoryName={asset.category_name}
                      currency={asset.currency}
                      balance={parseFloat(asset.balance)}
                      lastUpdated={asset.last_updated}
                    />
                  ))}
                </AssetGroupCard>
              );
            })}
          </div>
        </>
      ) : (
        <div class="card bg-base-100 shadow border border-base-300 rounded-3xl">
          <div class="card-body">
            <EmptyState
              title="No assets tracked yet"
              message="Add your first asset to start tracking your net worth across different types and currencies."
            />
            <div class="flex justify-center mt-4">
              <button type="button" class="btn btn-accent gap-2 rounded-2xl" data-add-asset-btn>
                Add Your First Asset
              </button>
            </div>
          </div>
        </div>
      )
    }
  </div>

  {/* Asset Modals */}
  <AssetFormModal id="asset-form-modal" mode="add" categories={categories} />
  <AssetCategoryModal id="asset-category-modal" />
  <AssetDeleteConfirmModal id="asset-delete-modal" />
  <AssetHistoryModal id="asset-history-modal" />
</ProtectedLayout>
