---
/**
 * Assets List Page (Global Portfolio)
 *
 * Main page for viewing and managing assets with portfolio summary.
 * Redesigned as part of the Global Portfolio page update.
 * Includes modals for add, edit, delete, and history actions.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import AssetPageHeader from '@components/molecules/AssetPageHeader.astro';
import AssetPortfolioSummary from '@components/organisms/AssetPortfolioSummary.astro';
import AssetActions from '@components/organisms/AssetActions.astro';
import AssetGroupCard from '@components/organisms/AssetGroupCard.astro';
import AssetItemRow from '@components/molecules/AssetItemRow.astro';
import AssetFormModal from '@components/organisms/AssetFormModal.astro';
import AssetTransferModal from '@components/organisms/AssetTransferModal.astro';
import AssetDeleteConfirmModal from '@components/organisms/AssetDeleteConfirmModal.astro';
import AssetHistoryModal from '@components/organisms/AssetHistoryModal.astro';
import AssetUpdateValueModal from '@components/organisms/AssetUpdateValueModal.astro';
import AssetCategoryModal from '@components/organisms/AssetCategoryModal.astro';
import EmptyState from '@components/atoms/EmptyState.astro';
import { CalendarDays, Search } from '@lucide/astro';
import { assetService, assetCategoryService } from '@/services';
import type { AssetOutput, AssetType } from '@/lib/types/asset';
import { formatAssetType } from '@/lib/types/asset';
import {
  calculateAssetAllocation,
  calculatePortfolioTotals,
  groupAssetsByType,
  calculateGroupTotals,
} from '@/lib/utils/asset';

const user = Astro.locals.user!;
const currentPath = '/assets';

// Valid asset types for filtering
const VALID_ASSET_TYPES = [
  'cash',
  'bank_account',
  'e_wallet',
  'mutual_fund',
  'bond',
  'crypto',
  'stock',
  'other',
  'credit_card',
  'loan',
] as const;

// Get query parameters for filtering
const url = new URL(Astro.url);
const searchParams = Object.fromEntries(url.searchParams.entries());

// Build filters for service with validation
const filters: {
  user_id: string;
  type?: AssetType;
  category_id?: string;
  currency?: 'IDR' | 'USD';
} = {
  user_id: user.workspaceId,
};

// Validate asset type parameter before assignment
if (searchParams.type && VALID_ASSET_TYPES.includes(searchParams.type as AssetType)) {
  filters.type = searchParams.type as AssetType;
}
if (searchParams.categoryId) {
  filters.category_id = searchParams.categoryId;
}
if (searchParams.currency === 'IDR' || searchParams.currency === 'USD') {
  filters.currency = searchParams.currency;
}

// Month navigation parameters
const yearParam = url.searchParams.get('year');
const monthParam = url.searchParams.get('month');
const now = new Date();
const selectedYear = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const selectedMonth = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;
const isViewingCurrentMonth = !yearParam && !monthParam;

// Build month navigation URL helper
const buildMonthUrl = (year: number, month: number) => {
  const params = new URLSearchParams();
  params.set('year', year.toString());
  params.set('month', month.toString());
  // Preserve existing filters
  if (searchParams.type) params.set('type', searchParams.type);
  if (searchParams.categoryId) params.set('categoryId', searchParams.categoryId);
  if (searchParams.currency) params.set('currency', searchParams.currency);
  return `/assets?${params.toString()}`;
};

// Calculate prev/next month dates
const prevMonthDate = new Date(selectedYear, selectedMonth - 2, 1);
const nextMonthDate = new Date(selectedYear, selectedMonth, 1);
const isNextMonthFuture = nextMonthDate > now;

// Format current month for display
const currentMonthDisplay = new Date(selectedYear, selectedMonth - 1).toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});

// Get closed account count for navigation link
const closedCount = await assetService.countClosed(user.workspaceId);

// Fetch assets and categories from database
const categories = await assetCategoryService.findAll(user.workspaceId);
const categoriesById = new Map(categories.map((category) => [category.id, category]));
const defaultCategoryId =
  categories.find((category) => category.is_system && !category.is_liability)?.id ||
  categories[0]?.id ||
  '';
// Fetch assets - use snapshot for historical views, current data for present
let assets: AssetOutput[];

if (!isViewingCurrentMonth) {
  // Historical view: get snapshot for the selected month
  const snapshots = await assetService.getSnapshotForMonth(
    user.workspaceId,
    selectedYear,
    selectedMonth,
    filters,
    Astro.locals.perf
  );
  assets = snapshots.map((snapshot) => {
    const categoryName = snapshot.category_id
      ? categoriesById.get(snapshot.category_id)?.name || null
      : formatAssetType(snapshot.type);

    return {
      id: snapshot.id,
      name: snapshot.name,
      type: snapshot.type,
      category_id: snapshot.category_id,
      category_name: categoryName,
      balance: snapshot.snapshot_balance,
      initial_balance: snapshot.initial_balance || null,
      currency: snapshot.currency,
      status: snapshot.status ?? 'active',
      closed_at: snapshot.closed_at ?? null,
      closed_by_user_id: snapshot.closed_by_user_id ?? null,
      last_updated: snapshot.snapshot_date || snapshot.last_updated,
      created_at: snapshot.created_at,
      updated_at: snapshot.updated_at,
    };
  });
} else {
  // Current view: use latest balance
  const rawAssets = await assetService.findAll(user.workspaceId, filters, Astro.locals.perf);
  assets = rawAssets.map((asset) => {
    const categoryName = asset.category_id
      ? categoriesById.get(asset.category_id)?.name || null
      : formatAssetType(asset.type);

    return {
      id: asset.id,
      name: asset.name,
      type: asset.type,
      category_id: asset.category_id,
      category_name: categoryName,
      balance: asset.balance,
      initial_balance: asset.initial_balance || null,
      currency: asset.currency,
      status: asset.status ?? 'active',
      closed_at: asset.closed_at ?? null,
      closed_by_user_id: asset.closed_by_user_id ?? null,
      last_updated: asset.last_updated,
      created_at: asset.created_at,
      updated_at: asset.updated_at,
    };
  });
}

// Calculate portfolio totals and allocation
// @TODO: Wire with backend - Consider moving calculations to service layer
const portfolioTotals = calculatePortfolioTotals(assets);
const assetAllocation = calculateAssetAllocation(assets);

// Find latest update date across all assets
const latestUpdate = assets.reduce<Date | null>((latest, asset) => {
  const updated = new Date(asset.last_updated);
  return !latest || updated > latest ? updated : latest;
}, null);

// Group assets by type for display
const assetsByType = groupAssetsByType(assets);
const sortedGroups = Object.entries(assetsByType)
  .map(([groupKey, groupAssets]) => {
    const category = categoriesById.get(groupKey);
    const label = category?.name || formatAssetType(groupAssets[0]?.type as AssetType);
    return {
      groupKey,
      label,
      sortOrder: category?.sort_order ?? 999,
      isSystem: category?.is_system ?? false,
      assets: groupAssets,
    };
  })
  .sort((a, b) => {
    if (a.isSystem !== b.isSystem) return a.isSystem ? -1 : 1;
    if (a.sortOrder !== b.sortOrder) return a.sortOrder - b.sortOrder;
    return a.label.localeCompare(b.label);
  });
---

<ProtectedLayout title="Assets" currentPath={currentPath} subtitle="Your financial portfolio">
  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8" data-testid="assets-page">
    {/* Page Header */}
    <AssetPageHeader
      currentMonth={currentMonthDisplay}
      prevMonthUrl={buildMonthUrl(prevMonthDate.getFullYear(), prevMonthDate.getMonth() + 1)}
      nextMonthUrl={!isNextMonthFuture
        ? buildMonthUrl(nextMonthDate.getFullYear(), nextMonthDate.getMonth() + 1)
        : undefined}
      isNextDisabled={isNextMonthFuture}
      currentMonthResetUrl={!isViewingCurrentMonth ? '/assets' : undefined}
    />

    {/* Historical view indicator */}
    {
      !isViewingCurrentMonth && (
        <div class="bg-warning/10 border border-warning/20 rounded-card px-4 py-3 text-sm text-warning font-medium flex items-center gap-2">
          <CalendarDays size={16} class="stroke-current shrink-0" />
          Showing portfolio values as of {currentMonthDisplay}. Update actions are disabled for
          historical views.
        </div>
      )
    }

    {
      assets.length > 0 ? (
        <>
          {/* Portfolio Summary */}
          <AssetPortfolioSummary
            totalIdr={portfolioTotals.totalIdr}
            totalUsd={portfolioTotals.totalUsd}
            distribution={assetAllocation}
            loading={false}
            latestUpdate={latestUpdate}
            isHistoricalView={!isViewingCurrentMonth}
          />

          {/* Action Buttons */}
          <AssetActions
            isHistoricalView={!isViewingCurrentMonth}
            defaultCategoryId={defaultCategoryId}
            closedCount={closedCount}
          />

          {/* Search Filter */}
          <div class="relative">
            <Search
              size={18}
              class="absolute left-3 top-1/2 -translate-y-1/2 stroke-current text-base-content/40 pointer-events-none"
              aria-hidden="true"
            />
            <input
              type="search"
              data-asset-search
              placeholder="Search assets by name…"
              class="input input-bordered w-full pl-10 rounded-xl bg-base-100 text-sm"
              aria-label="Search assets by name"
            />
          </div>

          {/* Asset Groups */}
          <div class="space-y-6">
            {sortedGroups.map((group) => {
              const groupTotals = calculateGroupTotals(group.assets);

              return (
                <AssetGroupCard
                  type={group.label}
                  count={group.assets.length}
                  totalIdr={groupTotals.idr}
                  totalUsd={groupTotals.usd}
                  groupId={group.groupKey}
                  defaultExpanded={true}
                >
                  {group.assets.map((asset) => (
                    <AssetItemRow
                      id={asset.id}
                      name={asset.name}
                      type={asset.type}
                      categoryId={asset.category_id}
                      categoryName={asset.category_name}
                      currency={asset.currency}
                      balance={parseFloat(asset.balance)}
                      initialBalance={
                        asset.initial_balance ? parseFloat(asset.initial_balance) : undefined
                      }
                      lastUpdated={asset.last_updated}
                      isHistoricalView={!isViewingCurrentMonth}
                    />
                  ))}
                </AssetGroupCard>
              );
            })}
          </div>

          {/* No results message (hidden by default, shown by client script) */}
          <div
            data-asset-search-no-results
            class="text-center py-8 text-base-content/50 text-sm font-medium hidden"
          >
            No assets match your search.
          </div>
        </>
      ) : (
        <div class="card bg-base-100 shadow border border-base-300 rounded-card">
          <div class="card-body">
            <EmptyState
              title="No assets tracked yet"
              message="Add your first asset to start tracking your net worth across different types and currencies."
            />
            <div class="flex justify-center mt-4">
              <button
                type="button"
                class="btn btn-accent gap-2 rounded-2xl"
                data-add-asset-btn
                data-add-first-asset-btn
                data-default-category-id={defaultCategoryId}
              >
                Add Your First Asset
              </button>
            </div>
          </div>
        </div>
      )
    }
  </div>

  {/* Asset Modals */}
  <AssetTransferModal
    id="asset-transfer-modal"
    assets={assets.map((a) => ({
      id: a.id,
      name: a.name,
      currency: a.currency,
      balance: a.balance,
    }))}
  />
  <AssetFormModal id="asset-form-modal" mode="add" categories={categories} />
  <AssetCategoryModal id="asset-category-modal" />
  <AssetDeleteConfirmModal id="asset-delete-modal" />
  <AssetHistoryModal id="asset-history-modal" />
  <AssetUpdateValueModal id="asset-update-value-modal" />
</ProtectedLayout>

<script>
  import { initInlineHistory } from '@/components/molecules/AssetInlineHistory.client';
  import { initAssetSearch } from '@/components/organisms/AssetSearch.client';

  const firstAssetButtonHandlers = new WeakMap<HTMLElement, (event: Event) => void>();

  function openAssetForm(defaultCategoryId = '') {
    document.dispatchEvent(
      new CustomEvent('open-asset-form', {
        detail: {
          name: '',
          categoryId: defaultCategoryId,
          currency: 'IDR',
          balance: '',
        },
      })
    );
  }

  function initFirstAssetButton() {
    document.querySelectorAll<HTMLElement>('[data-add-first-asset-btn]').forEach((button) => {
      if (firstAssetButtonHandlers.has(button)) return;

      const handler = () => {
        const defaultCategoryId = button.getAttribute('data-default-category-id') || '';
        openAssetForm(defaultCategoryId);
      };

      firstAssetButtonHandlers.set(button, handler);
      button.addEventListener('click', handler);
    });
  }

  function openOnboardingAssetModal() {
    const url = new URL(window.location.href);
    if (url.searchParams.get('onboarding') !== 'add-asset') return;

    const modal = document.getElementById('asset-form-modal') as HTMLDialogElement | null;
    if (modal?.open) return;

    const defaultCategoryId =
      document
        .querySelector<HTMLElement>('[data-add-first-asset-btn],[data-add-asset-btn]')
        ?.getAttribute('data-default-category-id') || '';

    // Delay to ensure modal listeners are attached before dispatching.
    requestAnimationFrame(() => openAssetForm(defaultCategoryId));

    url.searchParams.delete('onboarding');
    const query = url.searchParams.toString();
    window.history.replaceState({}, '', `${url.pathname}${query ? `?${query}` : ''}`);
  }

  function cleanupFirstAssetButton() {
    document.querySelectorAll<HTMLElement>('[data-add-first-asset-btn]').forEach((button) => {
      const handler = firstAssetButtonHandlers.get(button);
      if (!handler) return;
      button.removeEventListener('click', handler);
      firstAssetButtonHandlers.delete(button);
    });
  }

  function init() {
    initInlineHistory();
    initAssetSearch();
    initFirstAssetButton();
    openOnboardingAssetModal();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener('astro:before-swap', cleanupFirstAssetButton, { once: true });
</script>
