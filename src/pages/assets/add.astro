---
/**
 * Add Asset Page
 *
 * Page for adding a new asset.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import AssetForm from '@/components/molecules/AssetForm.astro';

const currentPath = '/assets/add';
---

<ProtectedLayout title="Add Asset - Finance Manager" currentPath={currentPath}>
  <div class="max-w-2xl">
    <div class="mb-6">
      <h2 class="text-2xl font-bold">Add New Asset</h2>
      <p class="text-neutral-500">Track your assets across different types and currencies</p>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <AssetForm
          action="/api/assets"
          method="POST"
          submitLabel="Save Asset"
          cancelUrl="/assets"
        />
      </div>
    </div>
  </div>
</ProtectedLayout>
