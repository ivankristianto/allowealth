---
/**
 * Add Asset Page
 *
 * Page for adding a new asset.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import AssetForm from '@/components/molecules/AssetForm.astro';
import { assetCategoryService } from '@/services';

const currentPath = '/assets/add';
const user = Astro.locals.user!;
const categories = await assetCategoryService.findAll(user.id);
---

<ProtectedLayout title="Add Asset" currentPath={currentPath} subtitle="Register a new account">
  <div class="max-w-2xl">
    <div class="mb-6">
      <h2 class="text-2xl font-bold">Add New Asset</h2>
      <p class="text-base-content/60">Track your assets across different types and currencies</p>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <AssetForm
          action="/api/assets"
          method="POST"
          categories={categories}
          submitLabel="Save Asset"
          cancelUrl="/assets"
        />
      </div>
    </div>
  </div>
</ProtectedLayout>
