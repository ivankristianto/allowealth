---
/**
 * Manage Account Page
 *
 * Allows users to update profile, preferences, and password settings.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import ManageAccountForms from '@/components/organisms/ManageAccountForms.astro';
import type { User } from '@/lib/auth/lucia';

const currentPath = '/profile';

// User is authenticated (enforced by ProtectedLayout)
const user = Astro.locals.user! as User;
---

<ProtectedLayout title="Profile" currentPath={currentPath} subtitle="Manage your account details">
  <div class="max-w-4xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8">
    <div>
      <h2 class="text-2xl font-bold">Account Settings</h2>
      <p class="text-base-content/60">Manage your personal information and security preferences.</p>
    </div>

    <ManageAccountForms user={user} />
  </div>
</ProtectedLayout>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { setButtonLoading } from '@/lib/client-utils';

  const API_PROFILE_URL = '/api/user/profile';
  const API_SETTINGS_URL = '/api/user/settings';

  // ==================== PROFILE FORM ====================
  const profileForm = document.getElementById('profile-form');
  const profileNameInput = document.getElementById('full-name');
  const profileEmailInput = document.getElementById('email');
  const profileCurrencyInput = document.getElementById('currency');
  const profileSubmitButton = profileForm?.querySelector('button[type="submit"]');

  let isFetchingSettings = false;
  const fetchCurrentSettings = async () => {
    if (isFetchingSettings || !(profileCurrencyInput instanceof HTMLSelectElement)) return;
    isFetchingSettings = true;
    try {
      const response = await fetch(API_SETTINGS_URL, {
        method: 'GET',
        credentials: 'include',
      });

      if (response.ok) {
        const result = await response.json();
        if (result.success && result.data) {
          profileCurrencyInput.value = result.data.primaryCurrency || profileCurrencyInput.value;
        }
      }
    } catch (error) {
      console.error('Error fetching user settings:', error);
    } finally {
      isFetchingSettings = false;
    }
  };

  fetchCurrentSettings();

  if (
    profileForm instanceof HTMLFormElement &&
    profileNameInput instanceof HTMLInputElement &&
    profileEmailInput instanceof HTMLInputElement &&
    profileCurrencyInput instanceof HTMLSelectElement &&
    profileSubmitButton instanceof HTMLButtonElement
  ) {
    profileForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const errors = [];

      if (!profileNameInput.value || !profileNameInput.value.trim()) {
        errors.push('Please enter your name');
      }

      if (!profileEmailInput.value || !profileEmailInput.checkValidity()) {
        errors.push('Please enter a valid email address');
      }

      if (!profileCurrencyInput.value) {
        errors.push('Please select a currency');
      }

      if (errors.length > 0) {
        addToast(errors.join('. '), 'error');
        return;
      }

      setButtonLoading(profileSubmitButton, true);

      try {
        const formData = new FormData(profileForm);
        const profileData = {
          name: formData.get('name'),
          email: formData.get('email'),
        };

        // @TODO: Wire phone and bio updates with backend.
        const settingsData = {
          primaryCurrency: formData.get('primaryCurrency'),
        };

        const [profileResponse, settingsResponse] = await Promise.all([
          fetch(API_PROFILE_URL, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            credentials: 'include',
            body: JSON.stringify(profileData),
          }),
          fetch(API_SETTINGS_URL, {
            method: 'PUT',
            headers: {
              'Content-Type': 'application/json',
            },
            credentials: 'include',
            body: JSON.stringify(settingsData),
          }),
        ]);

        const profileResult = await profileResponse.json();
        const settingsResult = await settingsResponse.json();

        const errorMessages = [];

        if (!profileResponse.ok || !profileResult.success) {
          errorMessages.push(
            profileResult.error?.message || 'Failed to update profile. Please try again.'
          );
        }

        if (!settingsResponse.ok || !settingsResult.success) {
          errorMessages.push(
            settingsResult.error?.message || 'Failed to save settings. Please try again.'
          );
        }

        if (errorMessages.length > 0) {
          addToast(errorMessages.join(' '), 'error');
          return;
        }

        addToast('Profile updated successfully!', 'success');
      } catch (error) {
        console.error('Profile update error:', error);
        addToast('An error occurred. Please check your connection and try again.', 'error');
      } finally {
        setButtonLoading(profileSubmitButton, false);
      }
    });
  }
</script>
