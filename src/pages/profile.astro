---
/**
 * Manage Account Page
 *
 * Allows users to update profile, preferences, and password settings.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import ManageAccountForms from '@/components/organisms/ManageAccountForms.astro';
import type { User } from '@/lib/auth/lucia';

const currentPath = '/profile';

// User is authenticated (enforced by ProtectedLayout)
const user = Astro.locals.user! as User;
---

<ProtectedLayout title="Profile" currentPath={currentPath} subtitle="Manage your account details">
  <div class="max-w-4xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8">
    <ManageAccountForms user={user} />
  </div>
</ProtectedLayout>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { setButtonLoading } from '@/lib/client-utils';
  import { getCsrfHeaders } from '@/lib/csrf-client';

  const API_PROFILE_URL = '/api/user/profile';

  // ==================== PROFILE FORM ====================
  const profileForm = document.getElementById('profile-form');
  const profileNameInput = document.getElementById('full-name');
  const profileEmailInput = document.getElementById('email');
  const profileSubmitButton = profileForm?.querySelector('button[type="submit"]');

  if (
    profileForm instanceof HTMLFormElement &&
    profileNameInput instanceof HTMLInputElement &&
    profileEmailInput instanceof HTMLInputElement &&
    profileSubmitButton instanceof HTMLButtonElement
  ) {
    profileForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const errors = [];

      if (!profileNameInput.value || !profileNameInput.value.trim()) {
        errors.push('Please enter your name');
      }

      if (!profileEmailInput.value || !profileEmailInput.checkValidity()) {
        errors.push('Please enter a valid email address');
      }

      if (errors.length > 0) {
        addToast(errors.join('. '), 'error');
        return;
      }

      setButtonLoading(profileSubmitButton, true);

      try {
        const formData = new FormData(profileForm);

        // All profile data in one request
        const profileData = {
          name: formData.get('name'),
          email: formData.get('email'),
          phone: formData.get('phone') || '',
          bio: formData.get('bio') || '',
        };

        const response = await fetch(API_PROFILE_URL, {
          method: 'PUT',
          headers: getCsrfHeaders({ 'Content-Type': 'application/json' }),
          credentials: 'include',
          body: JSON.stringify(profileData),
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          addToast(result.error?.message || 'Failed to update profile.', 'error');
          return;
        }

        addToast('Profile updated successfully!', 'success');
      } catch (error) {
        console.error('Profile update error:', error);
        addToast('An error occurred. Please check your connection and try again.', 'error');
      } finally {
        setButtonLoading(profileSubmitButton, false);
      }
    });
  }
</script>
