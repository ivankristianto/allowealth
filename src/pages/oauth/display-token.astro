---
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { getAuthBaseURL } from '@/lib/auth/server';
import { logError } from '@/lib/logger';

const code = Astro.url.searchParams.get('code');
// The OAuth redirect returns `code` and `state` but NOT `client_id`.
// We pass client_id through the `state` parameter in the connect URL.
const clientId = Astro.url.searchParams.get('state') ?? 'mcp-generic';
const error = Astro.url.searchParams.get('error');

let accessToken: string | null = null;
let exchangeError: string | null = null;

if (error) {
  exchangeError = 'Authorization was denied.';
} else if (code) {
  try {
    const baseUrl = getAuthBaseURL();
    // All seeded clients are public — no client_secret is sent.
    const response = await fetch(`${baseUrl}/api/auth/oauth2/token`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
      body: new URLSearchParams({
        grant_type: 'authorization_code',
        code,
        client_id: clientId,
        redirect_uri: `${baseUrl}/oauth/display-token`,
      }),
    });

    if (response.ok) {
      const data = (await response.json()) as { access_token?: string };
      accessToken = data.access_token ?? null;
    } else {
      logError(
        'OAuth token exchange failed',
        new Error(`Token endpoint returned HTTP ${response.status}`)
      );
      exchangeError = 'Failed to exchange code for token. Try again.';
    }
  } catch (error) {
    logError('OAuth token exchange failed', error);
    exchangeError = 'Network error during token exchange. Try again.';
  }
} else {
  exchangeError = 'No authorization code received.';
}
---

<ProtectedLayout title="Access Token" currentPath="/oauth/display-token">
  <div class="flex min-h-screen items-center justify-center p-4">
    <div class="card bg-base-100 shadow-xl w-full max-w-lg">
      <div class="card-body gap-6">
        {
          exchangeError ? (
            <div class="alert alert-error">
              <span>{exchangeError}</span>
            </div>
          ) : accessToken ? (
            <>
              <div class="text-center">
                <h1 class="text-xl font-bold">Your Access Token</h1>
                <p class="text-base-content/60 text-sm mt-1">
                  Copy this token and paste it into your MCP client config as{' '}
                  <code class="font-mono">ALLOWEALTH_ACCESS_TOKEN</code>. It will not be shown
                  again.
                </p>
              </div>

              <div class="join w-full">
                <input
                  id="token-value"
                  type="text"
                  readonly
                  value={accessToken}
                  class="input input-bordered join-item font-mono text-xs flex-1 min-w-0"
                />
                <button type="button" id="copy-token-button" class="btn btn-primary join-item">
                  Copy
                </button>
              </div>

              <p class="text-base-content/50 text-xs text-center">
                Token expires in 24 hours. Return here to get a new one.
              </p>
            </>
          ) : (
            <div class="alert alert-warning">
              <span>No token available.</span>
            </div>
          )
        }
      </div>
    </div>
  </div>
</ProtectedLayout>

<script>
  const copyButton = document.getElementById('copy-token-button');
  const tokenInput = document.getElementById('token-value') as HTMLInputElement | null;

  copyButton?.addEventListener('click', async () => {
    if (!tokenInput?.value) return;

    await navigator.clipboard.writeText(tokenInput.value);
    copyButton.textContent = 'Copied!';
  });
</script>
