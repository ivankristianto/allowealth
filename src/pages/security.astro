---
/**
 * Security Page
 *
 * Frontend-only security settings screen.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import SecurityConnectedAccountsCard from '@/components/molecules/SecurityConnectedAccountsCard.astro';
import SecurityConnectedAppsCard from '@/components/molecules/SecurityConnectedAppsCard.astro';
import SecurityMfaCard from '@/components/molecules/SecurityMfaCard.astro';
import SecurityPasskeysCard from '@/components/molecules/SecurityPasskeysCard.astro';
import SecuritySessionsCard from '@/components/molecules/SecuritySessionsCard.astro';
import MfaSetupModal from '@/components/organisms/MfaSetupModal.astro';
import MfaConfirmModal from '@/components/organisms/MfaConfirmModal.astro';
import MfaBackupCodesModal from '@/components/organisms/MfaBackupCodesModal.astro';
import Button from '@/components/atoms/Button.astro';
import { History } from '@lucide/astro';
import { SessionManagementService } from '@/services/session-management.service';
import type { NormalizedSession } from '@/lib/auth/types';
import { auth } from '@/lib/auth/server';
import { isDemoMode } from '@/lib/demo-mode';
import { getMcpOAuthClientName, getMcpOAuthRedirectUri } from '@/lib/mcp-oauth';
import { db, getActiveSchema } from '@/db';
import { account as authAccount, twoFactor, passkey as passkeyTable } from '@/db/schema/sqlite';
import { and, eq, gt } from 'drizzle-orm';
import { logError } from '@/lib/utils';

const currentPath = '/security';
const redirectUri = getMcpOAuthRedirectUri();

const user = Astro.locals.user;
const schema = getActiveSchema();

let connectedApps: Array<{
  tokenId: string;
  clientName: string;
  clientId: string;
  createdAt: Date;
  accessTokenExpiresAt: Date;
}> = [];

if (user?.id) {
  const tokens = await db
    .select({
      id: schema.oauthAccessToken.id,
      clientId: schema.oauthAccessToken.clientId,
      createdAt: schema.oauthAccessToken.createdAt,
      accessTokenExpiresAt: schema.oauthAccessToken.accessTokenExpiresAt,
    })
    .from(schema.oauthAccessToken)
    .where(
      and(
        eq(schema.oauthAccessToken.userId, user.id),
        gt(schema.oauthAccessToken.accessTokenExpiresAt, new Date())
      )
    );

  connectedApps = tokens.map((token) => ({
    tokenId: token.id,
    clientName: getMcpOAuthClientName(token.clientId),
    clientId: token.clientId,
    createdAt: token.createdAt,
    accessTokenExpiresAt: token.accessTokenExpiresAt,
  }));
}

let connectedAccounts: Array<{
  id: string;
  provider: string;
  email?: string;
  accountId?: string;
  connected: boolean;
  canUnlink: boolean;
}> = [];
let mfaStatus = { enabled: false, hasBackupCodes: false, backupCodesRemaining: 0 };

function getBackupCodeCount(serializedBackupCodes: string | null | undefined): number {
  if (!serializedBackupCodes) {
    return 0;
  }

  try {
    const parsed = JSON.parse(serializedBackupCodes);
    return Array.isArray(parsed) ? parsed.length : 0;
  } catch {
    return 0;
  }
}

if (user?.id) {
  const [authAccounts, authSession, twoFactorState] = await Promise.all([
    db.query.account.findMany({
      where: eq(authAccount.userId, user.id),
    }),
    auth.api.getSession({ headers: Astro.request.headers }).catch(() => null),
    db.query.twoFactor.findFirst({
      where: eq(twoFactor.userId, user.id),
    }),
  ]);

  const googleAccount = authAccounts.find((authProvider) => authProvider.providerId === 'google');
  const canUnlinkGoogleAccount = Boolean(googleAccount) && authAccounts.length > 1;

  connectedAccounts = [
    {
      id: 'google',
      provider: 'Google',
      email: user.email,
      accountId: googleAccount?.accountId,
      connected: !!googleAccount,
      canUnlink: canUnlinkGoogleAccount,
    },
  ];

  mfaStatus.enabled = Boolean(authSession?.user?.twoFactorEnabled);
  mfaStatus.backupCodesRemaining = mfaStatus.enabled
    ? getBackupCodeCount(twoFactorState?.backupCodes)
    : 0;
  mfaStatus.hasBackupCodes = mfaStatus.backupCodesRemaining > 0;
}

// Fetch active sessions for the current user
let activeSessions: NormalizedSession[] = [];
if (user?.id) {
  try {
    const rawSessions = await auth.api.listSessions({
      headers: Astro.request.headers,
    });
    const currentToken = Astro.locals.session?.token ?? '';
    activeSessions = SessionManagementService.listForUser(rawSessions, currentToken);
  } catch (err) {
    logError('Failed to list sessions', err);
  }
}

// Fetch registered passkeys for the current user
let passkeys: Array<{
  id: string;
  name: string | null;
  deviceType: string;
  createdAt: Date;
}> = [];
if (user?.id) {
  try {
    passkeys = await db.query.passkey.findMany({
      where: eq(passkeyTable.userId, user.id),
      columns: { id: true, name: true, deviceType: true, createdAt: true },
    });
  } catch (err) {
    logError('Failed to fetch passkeys', err);
  }
}

// @TODO: Wire with backend for security activity.
const securityEvents = [
  {
    id: 'evt-1',
    label: 'Successful login from New York, US',
    timestamp: 'Today, 2:45 PM',
    tone: 'success',
  },
  {
    id: 'evt-2',
    label: 'Passkey registered',
    timestamp: 'Jan 15, 2024',
    tone: 'info',
  },
  {
    id: 'evt-3',
    label: 'MFA setup initiated',
    timestamp: 'Jan 12, 2024',
    tone: 'warning',
  },
];

const toneDotClasses: Record<string, string> = {
  success: 'bg-success',
  info: 'bg-info',
  warning: 'bg-warning',
};
const demoMode = isDemoMode();
---

<ProtectedLayout
  title="Security"
  currentPath={currentPath}
  subtitle="Protect your account and devices"
>
  <div class="max-w-4xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8">
    <div class="space-y-6">
      <SecurityConnectedAccountsCard accounts={connectedAccounts} />
      {
        demoMode ? (
          <div class="card border border-base-300 bg-base-200/60 shadow">
            <div class="card-body p-6">
              <p class="text-center text-sm text-base-content/60">
                Security settings are disabled in demo mode.
              </p>
            </div>
          </div>
        ) : (
          <>
            <SecurityMfaCard
              enabled={mfaStatus.enabled}
              backupCodesRemaining={mfaStatus.backupCodesRemaining}
            />
            <SecuritySessionsCard sessions={activeSessions} />
          </>
        )
      }
      <SecurityPasskeysCard passkeys={passkeys} demoMode={demoMode} />
      <SecurityConnectedAppsCard apps={connectedApps} redirectUri={redirectUri} />

      <section class="card bg-base-200/60 border border-base-300 shadow">
        <div class="card-body p-6 space-y-5">
          <div class="flex items-center gap-2 text-base-content/70">
            <History size={18} class="stroke-current" aria-hidden="true" />
            <h3 class="text-sm font-semibold">Recent Security Events</h3>
            <span class="badge badge-outline badge-sm text-base-content/50 whitespace-nowrap"
              >Under Development</span
            >
          </div>

          <div class="space-y-4">
            {
              securityEvents.map((event) => (
                <div class="flex items-center justify-between gap-4 text-sm">
                  <div class="flex items-center gap-3">
                    <span class={`w-2 h-2 rounded-full ${toneDotClasses[event.tone]}`} />
                    <span class="text-base-content/70">{event.label}</span>
                  </div>
                  <span class="text-xs text-base-content/50 uppercase tracking-wide">
                    {event.timestamp}
                  </span>
                </div>
              ))
            }
          </div>

          <Button
            type="button"
            variant="outline"
            size="sm"
            className="w-full text-xs uppercase tracking-widest"
            disabled
          >
            Download Security Audit
          </Button>
        </div>
      </section>
    </div>
  </div>

  <MfaSetupModal />
  <MfaConfirmModal />
  <MfaBackupCodesModal />
  <script src="./security-mfa-client.ts"></script>
  <script>
    import '../components/molecules/security-passkeys.client.ts';
  </script>
</ProtectedLayout>
