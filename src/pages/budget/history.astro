---
/**
 * Budget History Page
 *
 * Shows budget performance over multiple months with:
 * - Year-based filtering via segmented toggle
 * - Interactive table with month-over-month comparison
 * - Mobile-responsive card layout
 * Protected by authentication.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import BudgetHistoryTablePartial from '@/components/partials/BudgetHistoryTablePartial.astro';
import YearToggle from '@/components/molecules/YearToggle.astro';
import { budgetService, workspaceMetaService, type MonthlyBudgetHistory } from '@/services';
import { isValidCurrency } from '@/lib/constants/currency';
import Breadcrumb from '@/components/atoms/Breadcrumb.astro';
import { CircleX, History as HistoryIcon } from '@lucide/astro';

const user = Astro.locals.user!;
const currentPath = '/budget/history';

// Get query parameters
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get('year');
const viewParam = url.searchParams.get('view');
const initialViewMode = viewParam === 'trends' ? ('trends' as const) : ('monthly' as const);

// Current date info
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();

// Default to current year, parse from URL if provided
const selectedYear = yearParam ? parseInt(yearParam, 10) : currentYear;

const workspaceCurrencyConfig = await workspaceMetaService.getWorkspaceCurrencies(user.workspaceId);
const workspaceCurrencies = [
  workspaceCurrencyConfig.primary,
  ...(workspaceCurrencyConfig.secondary ? [workspaceCurrencyConfig.secondary] : []),
];
const activeCurrencyCookie = Astro.cookies.get('activeCurrency')?.value || '';
const selectedCurrency =
  activeCurrencyCookie &&
  isValidCurrency(activeCurrencyCookie) &&
  workspaceCurrencies.includes(activeCurrencyCookie)
    ? activeCurrencyCookie
    : workspaceCurrencyConfig.primary;

// Get budget history from service (24 months to cover 2 years)
let historyData: MonthlyBudgetHistory[] = [];
let error: string | null = null;

try {
  const allHistory = await budgetService.getBudgetHistory(user.workspaceId, selectedCurrency, 24);

  // Filter by selected year
  historyData = allHistory.filter((h) => h.year === selectedYear);
} catch (err) {
  console.error('Error fetching budget history:', err);
  error = err instanceof Error ? err.message : 'Failed to fetch budget history';
}

// Get available years from history data (for toggle)
const allYears = new Set<number>();
try {
  const fullHistory = await budgetService.getBudgetHistory(user.workspaceId, selectedCurrency, 24);
  fullHistory.forEach((h) => allYears.add(h.year));
} catch {
  // If we can't get history, at least show current year
  allYears.add(currentYear);
}

// Sort years descending (newest first)
const availableYears = Array.from(allYears).sort((a, b) => b - a);

// SSR data for client-side hydration
const ssrData = {
  selectedYear,
  availableYears,
  currency: selectedCurrency,
  viewMode: initialViewMode,
  monthRange: 6 as const,
};
---

<ProtectedLayout
  title="Budget History"
  currentPath={currentPath}
  subtitle="Compare spending over time"
>
  <div
    id="budget-history-page"
    class="@container max-w-7xl mx-auto @sm:px-2 @3xl:px-6 space-y-6 @sm:space-y-8"
    data-ssr-data={JSON.stringify(ssrData)}
  >
    {/* Breadcrumb */}
    <Breadcrumb items={[{ label: 'Budget', href: '/budget' }, { label: 'History' }]} />

    {/* Tab Bar & Controls */}
    <div class="flex flex-col @sm:flex-row items-start @sm:items-center justify-between gap-4">
      {/* View Mode Tabs */}
      <div
        class="flex bg-base-200 p-1 rounded-xl shrink-0"
        role="tablist"
        aria-label="History view mode"
        data-view-tabs
      >
        <button
          type="button"
          role="tab"
          aria-selected={initialViewMode === 'monthly'}
          class:list={[
            'px-4 py-2.5 min-h-11 text-xs font-bold rounded-lg transition-all',
            initialViewMode === 'monthly'
              ? 'bg-base-100 shadow text-primary'
              : 'text-base-content/50 hover:text-base-content/70',
          ]}
          data-view-tab="monthly"
        >
          Monthly Totals
        </button>
        <button
          type="button"
          role="tab"
          aria-selected={initialViewMode === 'trends'}
          class:list={[
            'px-4 py-2.5 min-h-11 text-xs font-bold rounded-lg transition-all',
            initialViewMode === 'trends'
              ? 'bg-base-100 shadow text-primary'
              : 'text-base-content/50 hover:text-base-content/70',
          ]}
          data-view-tab="trends"
        >
          Category Trends
        </button>
      </div>

      {/* Right-side controls: year toggle (monthly) or month range (trends) */}
      <div class="flex items-center">
        {/* Year Toggle (shown when monthly tab active) */}
        {
          availableYears.length > 1 && (
            <YearToggle
              years={availableYears}
              selectedYear={selectedYear}
              className={initialViewMode !== 'monthly' ? 'hidden' : ''}
            />
          )
        }

        {/* Month Range Selector (shown when trends tab active) */}
        <div
          class:list={[initialViewMode !== 'trends' && 'hidden']}
          data-month-range-group
          role="group"
          aria-label="Month range"
        >
          <div class="flex bg-base-200 p-1 rounded-xl shrink-0">
            {
              [3, 6, 12].map((range) => (
                <button
                  type="button"
                  class:list={[
                    'px-3 py-2 min-h-9 text-xs font-bold rounded-lg transition-all',
                    range === 6
                      ? 'bg-base-100 shadow text-primary'
                      : 'text-base-content/50 hover:text-base-content/70',
                  ]}
                  data-month-range={range}
                  aria-pressed={range === 6 ? 'true' : 'false'}
                >
                  {range}mo
                </button>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    {/* Error State */}
    {
      error ? (
        <div class="alert alert-error" role="alert">
          <CircleX size={24} class="shrink-0" aria-hidden="true" />
          <span>{error}</span>
        </div>
      ) : (
        /* Table Card */
        <div class="@container bg-base-100 rounded-card border border-base-300 shadow-sm">
          {/* Desktop Header Row (monthly view only) */}
          <div data-monthly-header>
            <div class="hidden @3xl:grid grid-cols-7 border-b border-base-200">
              <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest">
                Month
              </div>
              <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
                Budget
              </div>
              <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
                Spent
              </div>
              <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
                Balance
              </div>
              <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-center">
                Status
              </div>
              <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
                Change
              </div>
              <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-center">
                Actions
              </div>
            </div>
          </div>

          {/* Table Body (injectable) */}
          <div id="budget-history-table-body" class="transition-opacity duration-200">
            <BudgetHistoryTablePartial
              history={historyData}
              currency={selectedCurrency}
              currentMonth={currentMonth}
              currentYear={currentYear}
            />
          </div>
        </div>
      )
    }

    {/* Visual Footnote */}
    <div class="flex justify-center py-12 opacity-30">
      <div class="flex flex-col items-center gap-4">
        <span
          data-loading-spinner
          class="loading loading-spinner loading-lg hidden"
          aria-hidden="true"></span>
        <HistoryIcon size={40} class="stroke-current" data-history-icon aria-hidden="true" />
        <p class="text-xs font-bold uppercase tracking-widest text-center">
          Historical data sync is managed automatically based on month close-out.
        </p>
      </div>
    </div>

    {/* Live region for screen reader announcements */}
    <div id="budget-history-live-region" class="sr-only" aria-live="polite" aria-atomic="true">
    </div>
  </div>
</ProtectedLayout>

<script>
  import { initBudgetHistoryPage } from '@/components/organisms/BudgetHistoryPage.client';
  initBudgetHistoryPage();
</script>
