---
import MainLayout from '../../layouts/MainLayout.astro';

const currentPath = '/budget/history';
---

<MainLayout title="Budget History - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    <h2 class="text-2xl font-bold">Budget History</h2>

    <div class="tabs">
      <a class="tab" href="/budget">Overview</a>
      <a class="tab tab-active" href="/budget/history">History</a>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <p class="text-neutral-500">No budget history available yet.</p>
      </div>
    </div>
  </div>
</MainLayout>
