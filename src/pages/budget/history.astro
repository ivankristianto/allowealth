---
/**
 * Budget History Page
 *
 * Shows budget performance over multiple months with:
 * - Year-based filtering via segmented toggle
 * - Interactive table with month-over-month comparison
 * - Mobile-responsive card layout
 * Protected by authentication.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import BudgetHistoryTablePartial from '@/components/partials/BudgetHistoryTablePartial.astro';
import YearToggle from '@/components/molecules/YearToggle.astro';
import { budgetService, type MonthlyBudgetHistory } from '@/services';
import { CircleX, Download, History as HistoryIcon } from '@lucide/astro';

const user = Astro.locals.user!;
const currentPath = '/budget/history';

// Get query parameters
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get('year');

// Current date info
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();

// Default to current year, parse from URL if provided
const selectedYear = yearParam ? parseInt(yearParam, 10) : currentYear;

// Default currency (could be user preference in the future)
const selectedCurrency: 'IDR' | 'USD' = 'IDR';

// Get budget history from service (24 months to cover 2 years)
let historyData: MonthlyBudgetHistory[] = [];
let error: string | null = null;

try {
  const allHistory = await budgetService.getBudgetHistory(user!.id, selectedCurrency, 24);

  // Filter by selected year
  historyData = allHistory.filter((h) => h.year === selectedYear);
} catch (err) {
  console.error('Error fetching budget history:', err);
  error = err instanceof Error ? err.message : 'Failed to fetch budget history';
}

// Get available years from history data (for toggle)
const allYears = new Set<number>();
try {
  const fullHistory = await budgetService.getBudgetHistory(user!.id, selectedCurrency, 24);
  fullHistory.forEach((h) => allYears.add(h.year));
} catch {
  // If we can't get history, at least show current year
  allYears.add(currentYear);
}

// Sort years descending (newest first)
const availableYears = Array.from(allYears).sort((a, b) => b - a);

// SSR data for client-side hydration
const ssrData = {
  selectedYear,
  availableYears,
  currency: selectedCurrency,
};
---

<ProtectedLayout
  title="Budget History"
  currentPath={currentPath}
  subtitle="Compare spending over time"
>
  <div
    id="budget-history-page"
    class="@container max-w-7xl mx-auto @sm:px-2 @3xl:px-6 space-y-6 @sm:space-y-8"
    data-ssr-data={JSON.stringify(ssrData)}
  >
    {/* Header Section */}
    <div class="flex flex-col @2xl:flex-row justify-between items-start @2xl:items-center gap-6">
      <div>
        <h2 class="text-2xl font-bold tracking-tight leading-none">Budget History</h2>
        <p class="text-sm text-base-content/50 mt-2 font-medium">
          Compare your budget performance over time
        </p>
      </div>

      <div class="flex items-center gap-4">
        {/* Year Toggle */}
        {
          availableYears.length > 1 && (
            <YearToggle years={availableYears} selectedYear={selectedYear} />
          )
        }

        {/* Export Button (disabled, coming soon) */}
        <div class="relative">
          <button
            class="flex items-center gap-2 px-5 py-2.5 bg-base-200 text-base-content/40 rounded-2xl text-xs font-bold border border-base-300 cursor-not-allowed"
            disabled
            title="Coming soon"
          >
            <Download size={18} class="stroke-current" aria-hidden="true" />
            <span class="hidden @sm:inline">Export Report</span>
          </button>
          <span
            class="absolute -top-2 -right-2 bg-base-content/50 text-base-100 text-xs px-1.5 py-0.5 rounded-full font-bold uppercase tracking-widest shadow-lg"
          >
            Soon
          </span>
        </div>
      </div>
    </div>

    {/* Error State */}
    {
      error ? (
        <div class="alert alert-error" role="alert">
          <CircleX size={24} class="shrink-0" aria-hidden="true" />
          <span>{error}</span>
        </div>
      ) : (
        /* Table Card */
        <div class="@container bg-base-100 rounded-card border border-base-300 shadow-sm">
          {/* Desktop Header Row */}
          <div class="hidden @3xl:grid grid-cols-7 border-b border-base-200">
            <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest">
              Month
            </div>
            <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
              Budget
            </div>
            <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
              Spent
            </div>
            <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
              Balance
            </div>
            <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-center">
              Status
            </div>
            <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
              Change
            </div>
            <div class="px-4 @4xl:px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-center">
              Actions
            </div>
          </div>

          {/* Table Body (injectable) */}
          <div id="budget-history-table-body" class="transition-opacity duration-200">
            <BudgetHistoryTablePartial
              history={historyData}
              currency={selectedCurrency}
              currentMonth={currentMonth}
              currentYear={currentYear}
            />
          </div>
        </div>
      )
    }

    {/* Visual Footnote */}
    <div class="flex justify-center py-12 opacity-30">
      <div class="flex flex-col items-center gap-4">
        <span
          data-loading-spinner
          class="loading loading-spinner loading-lg hidden"
          aria-hidden="true"></span>
        <HistoryIcon size={40} class="stroke-current" data-history-icon aria-hidden="true" />
        <p class="text-xs font-bold uppercase tracking-widest text-center">
          Historical data sync is managed automatically based on month close-out.
        </p>
      </div>
    </div>

    {/* Live region for screen reader announcements */}
    <div id="budget-history-live-region" class="sr-only" aria-live="polite" aria-atomic="true">
    </div>
  </div>
</ProtectedLayout>

<script>
  import { initBudgetHistoryPage } from '@/components/organisms/BudgetHistoryPage.client';
  initBudgetHistoryPage();
</script>
