---
/**
 * Budget History Page
 *
 * Shows budget performance over multiple months with:
 * - Month-over-month comparison
 * - Trend indicators
 * - Export functionality (future)
 * Protected by authentication.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import BudgetHistoryComparison from '../../components/organisms/BudgetHistoryComparison.astro';
import { budgetService, type MonthlyBudgetHistory } from '@/services';
import { SlidersHorizontal, CircleX } from '@lucide/astro';

const user = Astro.locals.user!;
const currentPath = '/budget/history';

// Get query parameters
const url = new URL(Astro.request.url);
const monthsParam = url.searchParams.get('months');
const currencyParam = url.searchParams.get('currency') as 'IDR' | 'USD' | null;

// Default to 12 months and IDR currency
const selectedMonths = monthsParam ? parseInt(monthsParam, 10) : 12;
const selectedCurrency = currencyParam || 'IDR';

// Get budget history from service
let historyData: MonthlyBudgetHistory[] = [];
let error: string | null = null;

try {
  historyData = await budgetService.getBudgetHistory(user!.id, selectedCurrency, selectedMonths);
} catch (err) {
  console.error('Error fetching budget history:', err);
  error = err instanceof Error ? err.message : 'Failed to fetch budget history';
}

// Current month for highlighting
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();
---

<ProtectedLayout title="Budget History - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    {/* Header with controls */}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div>
        <h2 class="text-2xl font-bold">Budget History</h2>
        <p class="text-neutral-600">Compare your budget performance over time</p>
      </div>

      <div class="flex items-center gap-2">
        {/* Currency Selector */}
        <div class="dropdown dropdown-end">
          <label tabindex="0" class="btn btn-outline btn-sm gap-2">
            <SlidersHorizontal size={16} class="stroke-current shrink-0" aria-hidden="true" />
            {selectedCurrency}
          </label>
          <ul
            tabindex="0"
            class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-32"
          >
            <li>
              <a
                href={`/budget/history?months=${selectedMonths}&currency=IDR`}
                class={selectedCurrency === 'IDR' ? 'active' : ''}
              >
                IDR
              </a>
            </li>
            <li>
              <a
                href={`/budget/history?months=${selectedMonths}&currency=USD`}
                class={selectedCurrency === 'USD' ? 'active' : ''}
              >
                USD
              </a>
            </li>
          </ul>
        </div>

        {/* Months Selector */}
        <div class="dropdown dropdown-end">
          <label tabindex="0" class="btn btn-outline btn-sm">
            {selectedMonths} months
          </label>
          <ul
            tabindex="0"
            class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-40"
          >
            <li>
              <a
                href={`/budget/history?months=6&currency=${selectedCurrency}`}
                class={selectedMonths === 6 ? 'active' : ''}>6 months</a
              >
            </li>
            <li>
              <a
                href={`/budget/history?months=12&currency=${selectedCurrency}`}
                class={selectedMonths === 12 ? 'active' : ''}>12 months</a
              >
            </li>
            <li>
              <a
                href={`/budget/history?months=18&currency=${selectedCurrency}`}
                class={selectedMonths === 18 ? 'active' : ''}>18 months</a
              >
            </li>
            <li>
              <a
                href={`/budget/history?months=24&currency=${selectedCurrency}`}
                class={selectedMonths === 24 ? 'active' : ''}>24 months</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>

    {/* Tabs */}
    <div class="tabs">
      <a class="tab" href="/budget"> Overview </a>
      <a class="tab tab-active" href="/budget/history"> History </a>
    </div>

    {/* Error State */}
    {
      error ? (
        <div class="alert alert-error" role="alert">
          <CircleX size={24} class="shrink-0" aria-hidden="true" />
          <span>{error}</span>
        </div>
      ) : (
        /* Budget History Comparison */
        <BudgetHistoryComparison
          history={historyData}
          currency={selectedCurrency}
          currentMonth={currentMonth}
          currentYear={currentYear}
        />
      )
    }
  </div>
</ProtectedLayout>
