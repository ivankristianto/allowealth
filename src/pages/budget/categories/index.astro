---
/**
 * Categories Management Page
 *
 * Full CRUD interface for managing expense/income categories.
 * Features: expense/income filtering, search, create, edit, and delete actions.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { categoryService } from '@/services';
import ActionBar from '@components/molecules/ActionBar.astro';
import { Plus, Search, Pencil, Trash2, ListPlus, ArrowLeft } from '@lucide/astro';
import CategoryIcon from '@/components/atoms/CategoryIcon.astro';
import TabToggle from '@/components/atoms/TabToggle.astro';
import CategoryModal from '@/components/organisms/CategoryModal.astro';
import CategoryDeleteDialog from '@/components/organisms/CategoryDeleteDialog.astro';
import { accentGhostBtn, ghostBtn } from '@/lib/ui/action-button-classes';

const user = Astro.locals.user!;
const currentPath = '/budget/categories';

// Fetch active categories only
const allCategories = await categoryService.findAll(user.workspaceId, { is_active: true });

// Get filters from query params
const url = new URL(Astro.url);
const typeFilter = (url.searchParams.get('type') as 'expense' | 'income') || 'expense';
const searchQuery = url.searchParams.get('search') || '';

// Apply search filter only — type filtering is done client-side for instant tab switching
let filteredCategories = allCategories;
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredCategories = filteredCategories.filter((c) => c.name.toLowerCase().includes(query));
}
---

<ProtectedLayout
  title="Categories"
  currentPath={currentPath}
  subtitle="Manage your transaction labels"
>
  <div
    class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8"
    data-testid="categories-page"
  >
    <!-- Page Intro -->
    <div>
      <div>
        <h2 class="text-2xl font-bold text-base-content tracking-tight leading-none">
          Manage Categories
        </h2>
        <p class="text-sm text-base-content/60 mt-2 font-medium">
          Organizing {allCategories.length} custom labels for your family ledger
        </p>
      </div>
    </div>

    <ActionBar ariaLabel="Budget category actions" edgeBleed>
      <a href="/budget" class={ghostBtn} aria-label="Back to budget">
        <ArrowLeft size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <ArrowLeft size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="text-xs md:text-sm">Back</span>
      </a>

      <button
        class={ghostBtn}
        data-action="bulk-add-categories"
        data-type={typeFilter}
        data-testid="bulk-add-btn"
        aria-label="Bulk add categories"
      >
        <ListPlus size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <ListPlus size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="text-xs md:text-sm">Bulk Add</span>
      </button>

      <button
        slot="primary"
        class={accentGhostBtn}
        data-action="create-category"
        data-type={typeFilter}
        data-testid="create-category-btn"
        aria-label="Create category"
      >
        <Plus size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <Plus size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="text-xs md:text-sm">Create Category</span>
      </button>
    </ActionBar>

    <!-- Search and Filters -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <!-- Type Filter Toggle -->
      <TabToggle
        activeTab={typeFilter}
        option1Value="expense"
        option1Label="Expense"
        option2Value="income"
        option2Label="Income"
        name="type"
        clientFilter
      />

      <!-- Search Bar -->
      <form id="search-form" class="relative flex-1 w-full max-w-md">
        <span
          class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40"
          aria-hidden="true"
        >
          <Search size={20} />
        </span>
        <input
          type="search"
          name="search"
          placeholder="Search categories..."
          value={searchQuery}
          class="w-full pl-12 pr-6 py-3.5 bg-base-100 border border-base-300 focus:border-primary focus:ring-0 rounded-2xl text-base font-medium text-base-content shadow-sm"
          data-testid="category-search-input"
        />
        <input type="hidden" name="type" value={typeFilter} />
      </form>
    </div>

    <!-- Categories Table -->
    <div class="bg-base-100 rounded-card border border-base-300 shadow-sm overflow-hidden">
      <div class="table-scroll-hint">
        <div class="overflow-x-auto">
          {
            filteredCategories.some((c) => c.type === typeFilter) ? (
              <table
                class="w-full text-left border-collapse"
                role="table"
                data-testid="categories-table"
              >
                <caption class="sr-only">Categories list</caption>
                <thead>
                  <tr class="border-b border-base-200 bg-base-200/50">
                    <th
                      scope="col"
                      class="px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest"
                    >
                      Icon
                    </th>
                    <th
                      scope="col"
                      class="px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest"
                    >
                      Category Name
                    </th>
                    <th
                      scope="col"
                      class="px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest hidden md:table-cell"
                    >
                      Description
                    </th>
                    <th
                      scope="col"
                      class="px-8 py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right"
                    >
                      Actions
                    </th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-base-200" data-category-tbody>
                  {filteredCategories.map((category) => (
                    <tr
                      class={`group hover:bg-base-200/50 transition-colors ${category.type !== typeFilter ? 'hidden' : ''}`}
                      data-testid="category-item"
                      data-category-id={category.id}
                      data-category-type={category.type}
                    >
                      <td class="px-8 py-5">
                        <CategoryIcon
                          icon={category.icon}
                          color={category.color}
                          size="md"
                          className="group-hover:scale-110"
                        />
                      </td>
                      <td class="px-8 py-5">
                        <span
                          class="text-base font-bold text-base-content tracking-tight leading-none"
                          data-testid="category-name"
                        >
                          {category.name}
                        </span>
                        {category.type === 'income' && (
                          <span class="badge badge-sm badge-ghost ml-2">
                            {category.income_source_type}
                          </span>
                        )}
                      </td>
                      <td class="px-8 py-5 hidden md:table-cell">
                        <span
                          class="text-sm text-base-content/60 font-medium"
                          data-testid="category-description"
                        >
                          {category.description || '—'}
                        </span>
                      </td>
                      <td class="px-8 py-5 text-right">
                        <div class="flex items-center justify-end gap-2">
                          <button
                            type="button"
                            title="Edit category"
                            class="min-h-[44px] min-w-[44px] p-2 text-base-content/30 hover:text-primary hover:bg-primary/10 rounded-xl transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
                            data-action="edit"
                            data-category-id={category.id}
                            aria-label={`Edit ${category.name} category`}
                            data-testid="category-edit-btn"
                          >
                            <Pencil size={18} class="stroke-current" aria-hidden="true" />
                          </button>
                          <button
                            type="button"
                            title="Delete category"
                            class="min-h-[44px] min-w-[44px] p-2 text-base-content/30 hover:text-error hover:bg-error/10 rounded-xl transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-error focus-visible:ring-offset-2"
                            data-action="delete"
                            data-category-id={category.id}
                            data-category-name={category.name}
                            data-category-icon={category.icon}
                            data-category-color={category.color}
                            aria-label={`Delete ${category.name} category`}
                            data-testid="category-delete-btn"
                          >
                            <Trash2 size={18} class="stroke-current" aria-hidden="true" />
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            ) : (
              <div class="py-24 text-center">
                <div class="w-20 h-20 bg-base-200/50 mx-auto rounded-3xl flex items-center justify-center text-base-content/30 mb-6 shadow-inner">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="40"
                    height="40"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  >
                    <title>No categories</title>
                    <path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z" />
                    <path d="M7 7h.01" />
                  </svg>
                </div>
                <h4 class="text-lg font-bold text-base-content mb-2">No categories found</h4>
                <p class="text-base-content/40 font-medium">Try adjusting your search terms.</p>
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>

  <!-- Category Modal -->
  <CategoryModal id="category-modal" />

  <!-- Bulk Add Modal -->
  <dialog id="bulk-add-modal" class="modal" data-testid="bulk-add-modal">
    <div class="modal-box max-w-lg rounded-card border border-base-300 shadow-xl p-0">
      <div class="p-6 flex flex-col gap-6">
        <!-- Header -->
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center bg-accent/10">
            <ListPlus size={24} class="stroke-current text-accent" aria-hidden="true" />
          </div>
          <div class="flex-1">
            <h2 class="text-2xl font-bold tracking-tight text-primary leading-none">
              Bulk Add Categories
            </h2>
            <p class="text-neutral text-sm mt-2 font-medium">
              Type one category name per line. They will be created as <strong data-bulk-type-label
                >{typeFilter}</strong
              > categories.
            </p>
          </div>
        </div>

        <!-- Textarea -->
        <div class="form-control">
          <label class="label py-1" for="bulk-categories-input">
            <span class="text-xs uppercase tracking-widest text-base-content/50 font-medium">
              Category Names (one per line)
            </span>
          </label>
          <textarea
            id="bulk-categories-input"
            class="textarea textarea-bordered w-full h-40 text-sm bg-base-200 focus:ring-2 focus:ring-accent focus:ring-opacity-20 focus:outline-none focus:ring-offset-2 rounded-xl"
            placeholder={'Food & Groceries\nTransportation\nUtilities\nEntertainment\nHealth & Fitness'}
            data-testid="bulk-categories-textarea"></textarea>
          <span class="text-base-content/40 text-xs mt-1">
            Default icon and color will be assigned. You can customize each category later.
          </span>
        </div>

        <!-- Preview area -->
        <div id="bulk-preview" class="hidden">
          <p class="text-xs uppercase tracking-widest text-base-content/50 font-medium mb-2">
            Preview (<span data-bulk-count>0</span> categories)
          </p>
          <div class="flex flex-wrap gap-2" data-bulk-preview-tags></div>
        </div>

        <!-- Error -->
        <div id="bulk-error" class="hidden alert alert-error text-sm rounded-xl" role="alert"></div>

        <!-- Actions -->
        <div class="flex gap-4 pt-2">
          <button
            type="button"
            class="flex-1 btn btn-ghost h-14 rounded-2xl font-bold"
            data-bulk-cancel
          >
            Cancel
          </button>
          <button
            type="button"
            class="flex-[2] btn btn-accent h-14 rounded-2xl font-bold"
            data-bulk-submit
            data-testid="bulk-submit-btn"
          >
            <span data-bulk-submit-text>Create Categories</span>
          </button>
        </div>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  <!-- Delete Confirmation Dialog -->
  <CategoryDeleteDialog id="delete-dialog" />
</ProtectedLayout>

<script src="./categories-client.ts"></script>
