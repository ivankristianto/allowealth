---
/**
 * Budget Overview Page
 *
 * Main budget page showing current month's budget overview.
 * Displays premium card grid with categories, spending, and progress.
 * Protected by authentication.
 *
 * Redesigned as part of Task 15 & 16 (Budget Page - Card Grid & Header).
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import BudgetCardGrid from '@components/organisms/BudgetCardGrid.astro';
import BudgetPageHeader from '@components/organisms/BudgetPageHeader.astro';
import BudgetAdviceBanner from '@components/organisms/BudgetAdviceBanner.astro';
import { budgetService, type BudgetSummary } from '@/services';
import { formatCurrency } from '@/lib/tokens';
import { ChevronDown, CircleX, Info } from '@lucide/astro';

const user = Astro.locals.user!;
const currentPath = '/budget';

// Get query parameters for month/year selection
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get('year');
const monthParam = url.searchParams.get('month');
const currencyParam = url.searchParams.get('currency') as 'IDR' | 'USD' | null;

// Default to current month if not specified
const now = new Date();
const selectedYear = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const selectedMonth = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;
const selectedCurrency = currencyParam || 'IDR';

// Get budget data from service
let budgetData: BudgetSummary | null = null;
let error: string | null = null;

try {
  budgetData = await budgetService.getMonthlyOverview(
    user!.id,
    selectedYear,
    selectedMonth,
    selectedCurrency
  );
} catch (err) {
  console.error('Error fetching budget data:', err);
  error = err instanceof Error ? err.message : 'Failed to fetch budget data';
}

// Month names for display
const monthNames = [
  'January',
  'February',
  'March',
  'April',
  'May',
  'June',
  'July',
  'August',
  'September',
  'October',
  'November',
  'December',
];

const currentMonthName = monthNames[selectedMonth - 1];
const currentMonthDisplay = `${currentMonthName} ${selectedYear}`;

// Build URLs for month navigation
const buildMonthUrl = (year: number, month: number) => {
  const params = new URLSearchParams();
  params.set('year', year.toString());
  params.set('month', month.toString());
  params.set('currency', selectedCurrency);
  return `/budget?${params.toString()}`;
};

// Previous and next month
const prevMonthDate = new Date(selectedYear, selectedMonth - 2, 1);
const nextMonthDate = new Date(selectedYear, selectedMonth, 1);

const prevMonthYear = prevMonthDate.getFullYear();
const prevMonth = prevMonthDate.getMonth() + 1;
const nextMonthYear = nextMonthDate.getFullYear();
const nextMonth = nextMonthDate.getMonth() + 1;

// Don't allow navigating to future months
const nowDate = new Date();
const maxYear = nowDate.getFullYear();
const maxMonth = nowDate.getMonth() + 1;
const isNextMonthInFuture =
  nextMonthYear > maxYear || (nextMonthYear === maxYear && nextMonth > maxMonth);

// Get budget alerts for generating advice
let alerts: Awaited<ReturnType<typeof budgetService.getAlerts>> = [];
if (budgetData) {
  try {
    alerts = await budgetService.getAlerts(user!.id, selectedCurrency);
  } catch (err) {
    console.error('Error fetching budget alerts:', err);
    alerts = [];
  }
}

// Generate structured advice data based on alerts (XSS-safe)
interface AdviceData {
  categoryName: string;
  status: 'exceeded' | 'warning';
  amount: string;
  percentageUsed?: number;
}

const generateAdviceData = (): AdviceData | null => {
  if (alerts.length === 0) return null;

  const exceededCategories = alerts.filter((a) => a.status === 'exceeded');
  const warningCategories = alerts.filter((a) => a.status === 'warning');

  if (exceededCategories.length > 0) {
    const category = exceededCategories[0];
    const overage = formatCurrency(category.overage, selectedCurrency);
    return {
      categoryName: category.category_name,
      status: 'exceeded',
      amount: overage,
    };
  }

  if (warningCategories.length > 0) {
    const category = warningCategories[0];
    const budgetAmount = parseFloat(category.budget_amount);
    const spentAmount = parseFloat(category.spent_amount);
    const percentageUsed = budgetAmount > 0 ? Math.round((spentAmount / budgetAmount) * 100) : 0;
    const remaining = budgetAmount - spentAmount;
    const remainingFormatted = formatCurrency(Math.max(0, remaining), selectedCurrency);
    return {
      categoryName: category.category_name,
      status: 'warning',
      amount: remainingFormatted,
      percentageUsed,
    };
  }

  return null;
};

const adviceData = generateAdviceData();

// Fetch all categories for the edit modal
import { categoryService } from '@/services';
const allCategories = await categoryService.findAll(user!.id, { is_active: true });
const expenseCategories = allCategories.filter((c) => c.type === 'expense');

// Count budgets with actual limits set
const budgetCount =
  budgetData?.categories.filter((c) => parseFloat(c.budget_amount) > 0).length || 0;
---

<ProtectedLayout title={`Budget - ${currentMonthName} ${selectedYear}`} currentPath={currentPath}>
  <div
    class="max-w-7xl mx-auto px-6 lg:px-10 py-8 space-y-8"
    data-budget-container
    data-expense-categories={JSON.stringify(expenseCategories)}
    data-currency={selectedCurrency}
  >
    {/* Premium Header with Month Navigation and Actions */}
    <BudgetPageHeader
      title="Family Spending Targets"
      budgetCount={budgetCount}
      currentMonth={currentMonthDisplay}
      prevMonthUrl={buildMonthUrl(prevMonthYear, prevMonth)}
      nextMonthUrl={!isNextMonthInFuture ? buildMonthUrl(nextMonthYear, nextMonth) : undefined}
      isNextDisabled={isNextMonthInFuture}
      newBudgetUrl="/settings/categories"
      showAiRebalancer={budgetCount > 0}
    />

    {/* Currency Selector (compact) */}
    <div class="flex items-center gap-4">
      <div class="tabs">
        <a class="tab tab-active" href="/budget">Overview</a>
        <a class="tab" href="/budget/history">History</a>
      </div>

      <div class="ml-auto">
        <div class="dropdown dropdown-end">
          <button
            type="button"
            tabindex="0"
            class="btn btn-ghost btn-sm gap-2"
            aria-haspopup="listbox"
            aria-label="Select currency"
          >
            <ChevronDown size={16} class="stroke-current" aria-hidden="true" />
            {selectedCurrency}
          </button>
          <ul
            tabindex="0"
            role="listbox"
            class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-32"
          >
            <li role="option" aria-selected={selectedCurrency === 'IDR'}>
              <a
                href={`/budget?year=${selectedYear}&month=${selectedMonth}&currency=IDR`}
                class={selectedCurrency === 'IDR' ? 'active' : ''}
              >
                IDR
              </a>
            </li>
            <li role="option" aria-selected={selectedCurrency === 'USD'}>
              <a
                href={`/budget?year=${selectedYear}&month=${selectedMonth}&currency=USD`}
                class={selectedCurrency === 'USD' ? 'active' : ''}
              >
                USD
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    {/* Error State */}
    {
      error ? (
        <div class="alert alert-error" role="alert">
          <CircleX size={24} class="stroke-current shrink-0" aria-hidden="true" />
          <span>{error}</span>
        </div>
      ) : (
        <>
          {/* Budget Card Grid */}
          <BudgetCardGrid
            budgets={budgetData?.categories || []}
            currency={selectedCurrency}
            loading={false}
          />

          {/* AI Advice Banner */}
          {adviceData && (
            <BudgetAdviceBanner
              categoryName={adviceData.categoryName}
              status={adviceData.status}
              amount={adviceData.amount}
              percentageUsed={adviceData.percentageUsed}
              ctaText="Review spending"
              ctaUrl="/transactions"
              show={true}
              dismissible={true}
            />
          )}
        </>
      )
    }
  </div>
</ProtectedLayout>

<!-- Quick Edit Budget Modal -->
<dialog id="quick-edit-budget-modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 class="font-bold text-lg">Edit Budget Allocation</h3>
    <form id="quick-edit-budget-form" class="py-4 space-y-4">
      <input type="hidden" name="category_id" value="" />

      <div class="form-control">
        <label class="label" for="category-name">
          <span class="label-text">Category</span>
        </label>
        <input
          type="text"
          name="category-name"
          id="category-name"
          class="input input-bordered input-ghost"
          disabled
          readonly
        />
      </div>

      <div class="form-control">
        <label class="label" for="edit-budget-amount">
          <span class="label-text">Monthly Budget Amount</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <input
          type="number"
          name="budget_amount"
          id="edit-budget-amount"
          class="input input-bordered"
          required
          min="0"
          step="0.01"
        />
        <label class="label">
          <span class="label-text-alt">Fixed monthly budget for this category</span>
        </label>
        <div class="text-sm text-neutral-600 flex items-center gap-2">
          <Info size={16} class="stroke-current shrink-0" aria-hidden="true" />
          Allocation: <span id="calculated-percentage" class="font-medium">--%</span>
          <span class="label-text-alt">(auto-calculated from budget amount)</span>
        </div>
      </div>

      <div class="form-control">
        <label class="label" for="edit-currency">
          <span class="label-text">Currency</span>
        </label>
        <input
          type="text"
          name="currency"
          id="edit-currency"
          class="input input-bordered input-ghost"
          disabled
          readonly
        />
      </div>

      <div id="quick-edit-form-error" class="hidden alert alert-error text-sm" role="alert"></div>

      <div class="modal-action">
        <button type="button" id="quick-edit-cancel-btn" class="btn btn-ghost">Cancel</button>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script>
  // Handle edit budget button clicks from BudgetCard components
  document.querySelectorAll('[data-edit-budget]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const categoryId = btn.getAttribute('data-edit-budget');
      if (!categoryId) return;

      const container = document.querySelector('[data-budget-container]');
      const currency = container?.getAttribute('data-currency') || 'IDR';
      const categoriesJson = container?.getAttribute('data-expense-categories');

      if (!categoriesJson) return;

      try {
        const categories = JSON.parse(categoriesJson);
        const category = categories.find(
          (c: { id: string; name: string; budget_amount: string }) => c.id === categoryId
        );

        if (!category) return;

        const modal = document.getElementById('quick-edit-budget-modal') as HTMLDialogElement;
        const form = document.getElementById('quick-edit-budget-form') as HTMLFormElement;

        if (!modal || !form) return;

        // Populate form fields
        (form.querySelector('[name="category_id"]') as HTMLInputElement).value = categoryId;
        (form.querySelector('[name="category-name"]') as HTMLInputElement).value = category.name;
        (form.querySelector('[name="budget_amount"]') as HTMLInputElement).value =
          category.budget_amount || '0';
        (form.querySelector('[name="currency"]') as HTMLInputElement).value = currency;

        modal.showModal();
      } catch (err) {
        console.error('Error opening edit modal:', err);
      }
    });
  });

  // Handle cancel button
  document.getElementById('quick-edit-cancel-btn')?.addEventListener('click', () => {
    const modal = document.getElementById('quick-edit-budget-modal') as HTMLDialogElement;
    modal?.close();
  });

  // Handle form submission
  document.getElementById('quick-edit-budget-form')?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const form = e.target as HTMLFormElement;
    const formData = new FormData(form);
    const categoryId = formData.get('category_id');
    const budgetAmount = formData.get('budget_amount');
    const currency = formData.get('currency');
    const errorDiv = document.getElementById('quick-edit-form-error');

    try {
      const response = await fetch(`/api/categories/${categoryId}`, {
        method: 'PATCH',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          budget_amount: budgetAmount,
          currency: currency,
        }),
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.message || 'Failed to update budget');
      }

      // Success - reload page
      window.location.reload();
    } catch (err) {
      if (errorDiv) {
        errorDiv.textContent = err instanceof Error ? err.message : 'Failed to update budget';
        errorDiv.classList.remove('hidden');
      }
    }
  });
</script>
