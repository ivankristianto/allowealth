---
/**
 * Budget Overview Page
 *
 * Main budget page showing current month's budget overview.
 * Displays budget table with categories, spending, and alerts.
 * Protected by authentication.
 */

import MainLayout from '../../layouts/MainLayout.astro';
import { requireAuth } from '@/lib/auth/requireAuth';
import BudgetOverviewTable from '../../components/organisms/BudgetOverviewTable.astro';
import { budgetService, type BudgetSummary } from '@/services';
import Icon from '../../components/atoms/Icon.astro';
import Badge from '../../components/atoms/Badge.astro';
import { formatCurrency } from '@/lib/tokens';

// Check authentication - redirect to login if not authenticated
const redirectResponse = requireAuth(Astro);
if (redirectResponse) {
  return redirectResponse;
}

// User is authenticated - get user data
const user = Astro.locals.user;
const currentPath = '/budget';

// Get query parameters for month/year selection
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get('year');
const monthParam = url.searchParams.get('month');
const currencyParam = url.searchParams.get('currency') as 'IDR' | 'USD' | null;
const sortByParam = url.searchParams.get('sort') as
  | 'category'
  | 'percentage'
  | 'budget'
  | 'spent'
  | 'balance'
  | 'status'
  | null;
const sortOrderParam = url.searchParams.get('order') as 'asc' | 'desc' | null;

// Default to current month if not specified
const now = new Date();
const selectedYear = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const selectedMonth = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;
const selectedCurrency = currencyParam || 'IDR';
const sortBy = sortByParam || 'category';
const sortOrder = sortOrderParam || 'asc';

// Get budget data from service
let budgetData: BudgetSummary | null = null;
let error: string | null = null;

try {
  budgetData = await budgetService.getMonthlyOverview(
    user!.id,
    selectedYear,
    selectedMonth,
    selectedCurrency
  );
} catch (err) {
  console.error('Error fetching budget data:', err);
  error = err instanceof Error ? err.message : 'Failed to fetch budget data';
}

// Month names for display
const monthNames = [
  'January',
  'February',
  'March',
  'April',
  'May',
  'June',
  'July',
  'August',
  'September',
  'October',
  'November',
  'December',
];

const currentMonthName = monthNames[selectedMonth - 1];

// Build URLs for month navigation
const buildMonthUrl = (year: number, month: number) => {
  const params = new URLSearchParams();
  params.set('year', year.toString());
  params.set('month', month.toString());
  params.set('currency', selectedCurrency);
  params.set('sort', sortBy);
  params.set('order', sortOrder);
  return `/budget?${params.toString()}`;
};

// Build base URL for sorting (preserves current month and currency)
const buildSortBaseUrl = () => {
  const params = new URLSearchParams();
  params.set('year', selectedYear.toString());
  params.set('month', selectedMonth.toString());
  params.set('currency', selectedCurrency);
  // Keep the path as /budget?params so the component can replace with /api/budget/export?
  return `/budget?${params.toString()}`;
};

const sortBaseUrl = buildSortBaseUrl();

// Previous and next month
const prevMonthDate = new Date(selectedYear, selectedMonth - 2, 1);
const nextMonthDate = new Date(selectedYear, selectedMonth, 1);

const prevMonthYear = prevMonthDate.getFullYear();
const prevMonth = prevMonthDate.getMonth() + 1;
const nextMonthYear = nextMonthDate.getFullYear();
const nextMonth = nextMonthDate.getMonth() + 1;

// Don't allow navigating to future months
const nowDate = new Date();
const maxYear = nowDate.getFullYear();
const maxMonth = nowDate.getMonth() + 1;
const isNextMonthInFuture =
  nextMonthYear > maxYear || (nextMonthYear === maxYear && nextMonth > maxMonth);

// Get budget alerts for the current month using budgetService.getAlerts()
let alerts: Awaited<ReturnType<typeof budgetService.getAlerts>> = [];
if (budgetData) {
  try {
    alerts = await budgetService.getAlerts(user!.id, selectedCurrency);
  } catch (err) {
    console.error('Error fetching budget alerts:', err);
    // Fallback to empty array if getAlerts fails
    alerts = [];
  }
}
---

<MainLayout
  title={`Budget - ${currentMonthName} ${selectedYear}`}
  currentPath={currentPath}
  user={user}
>
  <div class="space-y-6">
    {/* Header with month navigation */}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
      <div class="flex items-center gap-4">
        <h2 class="text-2xl font-bold">Budget</h2>
        <div class="dropdown dropdown-end">
          <label tabindex="0" class="btn btn-outline btn-sm gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"
              ></path>
            </svg>
            {selectedCurrency}
          </label>
          <ul
            tabindex="0"
            class="dropdown-content z-[1] menu p-2 shadow bg-base-100 rounded-box w-32"
          >
            <li>
              <a
                href={`/budget?year=${selectedYear}&month=${selectedMonth}&currency=IDR`}
                class={selectedCurrency === 'IDR' ? 'active' : ''}
              >
                IDR
              </a>
            </li>
            <li>
              <a
                href={`/budget?year=${selectedYear}&month=${selectedMonth}&currency=USD`}
                class={selectedCurrency === 'USD' ? 'active' : ''}
              >
                USD
              </a>
            </li>
          </ul>
        </div>
      </div>

      <div class="flex items-center gap-2">
        <a
          href={buildMonthUrl(prevMonthYear, prevMonth)}
          class="btn btn-ghost btn-sm btn-circle"
          aria-label="Previous month"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M15 19l-7-7 7-7"></path>
          </svg>
        </a>

        <span class="px-4 py-2 bg-base-200 rounded-lg font-medium min-w-[160px] text-center">
          {currentMonthName}
          {selectedYear}
        </span>

        <button
          class="btn btn-ghost btn-sm btn-circle"
          disabled={isNextMonthInFuture}
          aria-label="Next month"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
            ></path>
          </svg>
        </button>
      </div>
    </div>

    {/* Tabs */}
    <div class="tabs">
      <a class="tab tab-active" href="/budget"> Overview </a>
      <a class="tab" href="/budget/history"> History </a>
    </div>

    {/* Error State */}
    {
      error ? (
        <div class="alert alert-error" role="alert">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="stroke-current shrink-0 h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
            />
          </svg>
          <span>{error}</span>
        </div>
      ) : (
        <>
          {/* Budget Alerts Section */}
          {alerts.length > 0 && (
            <div class="card bg-base-100 shadow border border-base-300">
              <div class="card-body">
                <h3 class="card-title flex items-center gap-2">
                  <Icon name="alert" size="md" className="text-warning" />
                  Budget Alerts
                </h3>
                <div class="overflow-x-auto">
                  <table class="table table-sm">
                    <thead>
                      <tr>
                        <th>Category</th>
                        <th>Status</th>
                        <th class="text-right">Budget</th>
                        <th class="text-right">Spent</th>
                        <th class="text-right">Overage</th>
                        <th />
                      </tr>
                    </thead>
                    <tbody>
                      {alerts.map((alert) => (
                        <tr>
                          <td>
                            <span class="font-medium">{alert.category_name}</span>
                          </td>
                          <td>
                            <Badge
                              variant={alert.status === 'exceeded' ? 'error' : 'warning'}
                              size="sm"
                            >
                              {alert.status === 'exceeded' ? 'Exceeded' : 'Warning'}
                            </Badge>
                          </td>
                          <td class="text-right">
                            {formatCurrency(parseFloat(alert.budget_amount), selectedCurrency)}
                          </td>
                          <td class="text-right">
                            {formatCurrency(parseFloat(alert.spent_amount), selectedCurrency)}
                          </td>
                          <td class="text-right">
                            {alert.overage > 0 && (
                              <span class="text-error font-semibold">
                                +{formatCurrency(alert.overage, selectedCurrency)}
                              </span>
                            )}
                          </td>
                          <td>
                            <a
                              href={`/transactions?category_id=${alert.category_id}`}
                              class="btn btn-ghost btn-xs"
                            >
                              View
                            </a>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          )}

          {/* Budget Overview Table */}
          {budgetData && (
            <BudgetOverviewTable
              summary={budgetData}
              currency={selectedCurrency}
              sortBy={sortBy}
              sortOrder={sortOrder}
              baseUrl={sortBaseUrl}
            />
          )}
        </>
      )
    }

    {/* Quick Actions */}
    <div class="flex flex-wrap gap-3">
      <a href="/transactions/add" class="btn btn-primary gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        Add Expense
      </a>
      <a href="/settings/categories" class="btn btn-outline gap-2">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"
          ></path>
        </svg>
        Manage Categories
      </a>
    </div>
  </div>
</MainLayout>
