---
/**
 * Budget Overview Page
 *
 * Main budget page showing current month's budget overview.
 * Displays premium card grid with categories, spending, and progress.
 * Protected by authentication.
 *
 * Redesigned as part of Task 15 & 16 (Budget Page - Card Grid & Header).
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import BudgetPageHeader from '@components/organisms/BudgetPageHeader.astro';
import SetNewBudgetModal from '@components/organisms/SetNewBudgetModal.astro';
import CopyBudgetModal from '@components/organisms/CopyBudgetModal.astro';
import BudgetImportModal from '@components/organisms/BudgetImportModal.astro';
import BudgetTable from '@components/organisms/BudgetTable.astro';

// Partials for Interactive Page Architecture
import BudgetSummaryPartial from '@components/partials/BudgetSummaryPartial.astro';
import BudgetCardGridPartial from '@components/partials/BudgetCardGridPartial.astro';
import BudgetAdviceBannerPartial from '@components/partials/BudgetAdviceBannerPartial.astro';
import {
  budgetService,
  categoryService,
  type BudgetSummary as BudgetSummaryType,
} from '@/services';
import { formatCurrency } from '@/lib/formatting';
import { calculateAllocationDistribution } from '@/lib/utils/budget';
import { MONTH_NAMES } from '@/lib/utils/date';
import { CircleX, Search, LayoutGrid, Table as TableIcon } from '@lucide/astro';

const user = Astro.locals.user;
const currentPath = '/budget';

// Early guard clause - redirect to login if user is not authenticated
// This should never happen due to ProtectedLayout, but provides type safety
if (!user) {
  return Astro.redirect('/login');
}

// Get query parameters for month/year selection
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get('year');
const monthParam = url.searchParams.get('month');
const currencyParam = url.searchParams.get('currency') as 'IDR' | 'USD' | null;

// Default to current month if not specified
const now = new Date();
const selectedYear = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const parsedMonth = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;
const selectedMonth =
  Number.isInteger(parsedMonth) && parsedMonth >= 1 && parsedMonth <= 12
    ? parsedMonth
    : now.getMonth() + 1;
const selectedCurrency = currencyParam || 'IDR';

// Get budget data from service
let budgetData: BudgetSummaryType | null = null;
let error: string | null = null;

try {
  budgetData = await budgetService.getMonthlyOverview(
    user.workspaceId,
    selectedYear,
    selectedMonth,
    selectedCurrency,
    Astro.locals.perf
  );
} catch (err) {
  console.error('Error fetching budget data:', err);
  error = err instanceof Error ? err.message : 'Failed to fetch budget data';
}

// Calculate allocation distribution for BudgetSummary component
// @TODO: Wire with backend - consider moving this calculation to the service layer
const allocationDistribution = budgetData
  ? calculateAllocationDistribution(
      budgetData.categories.map((cat) => ({
        name: cat.category_name,
        budget_amount: cat.budget_amount,
        spent_amount: cat.spent_amount,
      }))
    )
  : [];

const currentMonthName = MONTH_NAMES[selectedMonth - 1];
const currentMonthDisplay = `${currentMonthName} ${selectedYear}`;

// Build URLs for month navigation
const buildMonthUrl = (year: number, month: number) => {
  const params = new URLSearchParams();
  params.set('year', year.toString());
  params.set('month', month.toString());
  params.set('currency', selectedCurrency);
  return `/budget?${params.toString()}`;
};

// Previous and next month
const prevMonthDate = new Date(selectedYear, selectedMonth - 2, 1);
const nextMonthDate = new Date(selectedYear, selectedMonth, 1);

const prevMonthYear = prevMonthDate.getFullYear();
const prevMonth = prevMonthDate.getMonth() + 1;
const nextMonthYear = nextMonthDate.getFullYear();
const nextMonth = nextMonthDate.getMonth() + 1;

// Check if we're viewing the current month (for showing "Current Month" button)
const nowDate = new Date();
const currentYear = nowDate.getFullYear();
const currentMonth = nowDate.getMonth() + 1;
const isViewingCurrentMonth = selectedYear === currentYear && selectedMonth === currentMonth;

// Check if next month is in the future
const isNextMonthInFuture =
  nextMonthYear > currentYear || (nextMonthYear === currentYear && nextMonth > currentMonth);

// If next month is in the future, check if it has budget data
// Allow navigation to future months if they have existing budget data
let allowNextMonthNavigation = !isNextMonthInFuture;
if (isNextMonthInFuture) {
  try {
    const hasNextMonthBudgets = await budgetService.hasBudgetsForMonth(
      user.workspaceId,
      nextMonthYear,
      nextMonth,
      selectedCurrency
    );
    allowNextMonthNavigation = hasNextMonthBudgets;
  } catch (err) {
    console.error('Error checking next month budgets:', err);
    // Default to not allowing navigation on error
    allowNextMonthNavigation = false;
  }
}

// Get budget alerts for generating advice
let alerts: Awaited<ReturnType<typeof budgetService.getAlerts>> = [];
if (budgetData) {
  try {
    alerts = await budgetService.getAlerts(user.workspaceId, selectedCurrency);
  } catch (err) {
    console.error('Error fetching budget alerts:', err);
    alerts = [];
  }
}

// Generate structured advice data based on alerts (XSS-safe)
interface AdviceData {
  categoryName: string;
  status: 'exceeded' | 'warning';
  amount: string;
  percentageUsed?: number;
}

const generateAdviceData = (): AdviceData | null => {
  if (alerts.length === 0) return null;

  const exceededCategories = alerts.filter((a) => a.status === 'exceeded');
  const warningCategories = alerts.filter((a) => a.status === 'warning');

  if (exceededCategories.length > 0) {
    const category = exceededCategories[0];
    const overage = formatCurrency(category.overage, selectedCurrency);
    return {
      categoryName: category.category_name,
      status: 'exceeded',
      amount: overage,
    };
  }

  if (warningCategories.length > 0) {
    const category = warningCategories[0];
    const budgetAmount = parseFloat(category.budget_amount);
    const spentAmount = parseFloat(category.spent_amount);
    const percentageUsed = budgetAmount > 0 ? Math.round((spentAmount / budgetAmount) * 100) : 0;
    const remaining = budgetAmount - spentAmount;
    const remainingFormatted = formatCurrency(Math.max(0, remaining), selectedCurrency);
    return {
      categoryName: category.category_name,
      status: 'warning',
      amount: remainingFormatted,
      percentageUsed,
    };
  }

  return null;
};

const adviceData = generateAdviceData();

// Fetch all categories for the edit modal
const allCategories = await categoryService.findAll(user.workspaceId, { is_active: true });
const expenseCategories = allCategories.filter((c) => c.type === 'expense');

// Fetch existing budgets for this month (for SetNewBudgetModal to determine create vs update)
const existingBudgets = await budgetService.findAllBudgets(
  user.workspaceId,
  selectedMonth,
  selectedYear,
  selectedCurrency
);

// Map budgets to the format needed by SetNewBudgetModal
const budgetsForModal = existingBudgets.map((b) => ({
  id: b.id,
  category_id: b.category_id,
  budget_amount: b.budget_amount,
}));

// Create a map of budget amounts by category_id for easy lookup
const budgetAmountsByCategory = new Map(
  existingBudgets.map((b) => [b.category_id, b.budget_amount])
);

// Merge budget amounts into expense categories for the edit handler
const expenseCategoriesWithBudgets = expenseCategories.map((cat) => ({
  ...cat,
  budget_amount: budgetAmountsByCategory.get(cat.id) || '0',
}));

// Count budgets with actual limits set
const budgetCount =
  budgetData?.categories.filter((c) => parseFloat(c.budget_amount) > 0).length || 0;
---

<ProtectedLayout
  title="Budget"
  currentPath={currentPath}
  subtitle={`${currentMonthName} ${selectedYear} overview`}
>
  <div
    class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8"
    data-budget-page
    data-testid="budget-page"
    data-budget-container
    data-year={selectedYear}
    data-month={selectedMonth}
    data-currency={selectedCurrency}
    data-expense-categories={JSON.stringify(expenseCategoriesWithBudgets)}
  >
    {/* Premium Header with Month Navigation and Actions */}
    <BudgetPageHeader
      title="Family Spending Targets"
      budgetCount={budgetCount}
      currentMonth={currentMonthDisplay}
      prevMonthUrl={buildMonthUrl(prevMonthYear, prevMonth)}
      nextMonthUrl={allowNextMonthNavigation ? buildMonthUrl(nextMonthYear, nextMonth) : undefined}
      isNextDisabled={!allowNextMonthNavigation}
      showAiRebalancer={budgetCount > 0}
      showCopyButton={budgetCount > 0}
      currentMonthResetUrl={!isViewingCurrentMonth
        ? buildMonthUrl(currentYear, currentMonth)
        : undefined}
    />

    {/* Error State */}
    {
      error ? (
        <div class="alert alert-error" role="alert">
          <CircleX size={24} class="stroke-current shrink-0" aria-hidden="true" />
          <span>{error}</span>
        </div>
      ) : (
        <>
          {/* Budget Summary Overview - Container for HTML injection */}
          <div id="budget-summary-container" data-testid="budget-summary-container">
            {budgetData && (
              <BudgetSummaryPartial
                totalAllocated={parseFloat(budgetData.total_budget || '0')}
                totalSpent={parseFloat(budgetData.total_spent || '0')}
                distribution={allocationDistribution}
                currency={selectedCurrency}
              />
            )}
          </div>

          {/* Budget Filter and View Toggle */}
          {budgetData && budgetData.categories.length > 0 && (
            <div class="flex items-center gap-3">
              <div class="relative flex-1">
                <span
                  class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40 pointer-events-none"
                  aria-hidden="true"
                >
                  <Search size={20} />
                </span>
                <input
                  type="search"
                  id="budget-filter-input"
                  data-testid="budget-filter-input"
                  placeholder="Filter budgets..."
                  class="w-full pl-12 pr-4 py-3 bg-base-100 border border-base-300 focus:border-primary focus:ring-0 rounded-2xl text-base font-medium text-base-content shadow-sm"
                  aria-label="Filter budgets by category name"
                />
              </div>
              <select
                id="budget-sort-select"
                class="select select-bordered select-sm rounded-xl bg-base-100 text-xs font-bold uppercase tracking-wider min-w-[140px]"
                aria-label="Sort budgets"
              >
                <option value="budget-desc">Budget ↓</option>
                <option value="spent-desc">Spent ↓</option>
                <option value="title-asc">Title A-Z</option>
                <option value="title-desc">Title Z-A</option>
              </select>
              <div
                class="flex items-center gap-1 bg-base-100 border border-base-300 rounded-xl p-1"
                data-view-toggle
              >
                <button
                  type="button"
                  class="btn btn-sm btn-ghost rounded-lg btn-active"
                  data-view-mode="card"
                  aria-label="Card view"
                  aria-pressed="true"
                >
                  <LayoutGrid size={16} class="stroke-current" aria-hidden="true" />
                </button>
                <button
                  type="button"
                  class="btn btn-sm btn-ghost rounded-lg"
                  data-view-mode="table"
                  aria-label="Table view"
                  aria-pressed="false"
                >
                  <TableIcon size={16} class="stroke-current" aria-hidden="true" />
                </button>
              </div>
            </div>
          )}

          {/* Budget Card Grid - Container for HTML injection */}
          <div id="budget-cards-container">
            <div data-view="card">
              <BudgetCardGridPartial
                budgets={budgetData?.categories || []}
                currency={selectedCurrency}
                month={selectedMonth}
                year={selectedYear}
              />
            </div>
            <div data-view="table" class="hidden">
              <BudgetTable
                budgets={budgetData?.categories || []}
                currency={selectedCurrency}
                month={selectedMonth}
                year={selectedYear}
              />
            </div>
          </div>

          {/* AI Advice Banner - Container for HTML injection */}
          <div id="budget-advice-container">
            <BudgetAdviceBannerPartial adviceData={adviceData} />
          </div>
        </>
      )
    }
  </div>

  {/* Set New Budget Modal */}
  <SetNewBudgetModal
    id="set-new-budget-modal"
    categories={expenseCategories}
    currency={selectedCurrency}
    month={selectedMonth}
    year={selectedYear}
    budgets={budgetsForModal}
  />

  {/* Copy Budget Modal */}
  <CopyBudgetModal
    id="copy-budget-modal"
    sourceMonth={selectedMonth}
    sourceYear={selectedYear}
    targetMonth={nextMonth}
    targetYear={nextMonthYear}
    budgetCount={budgetCount}
  />

  {/* Budget Import Modal */}
  <BudgetImportModal
    id="budget-import-modal"
    month={selectedMonth}
    year={selectedYear}
    currency={selectedCurrency}
  />
</ProtectedLayout>

<script>
  /**
   * Budget Page Client-Side Orchestration
   *
   * Uses the Interactive Page Architecture pattern for server-rendered HTML updates.
   * See: docs/architecture/002-interactive-pages.md
   *
   * The BudgetPage.client.ts module handles:
   * - budget-updated event: Refreshes the budget view using server-rendered HTML
   * - budgets-copied event: Navigates to the target month
   * - Edit budget handlers: Opens the modal with pre-filled data
   */
  import { initBudgetPage, cleanup } from '@components/organisms/BudgetPage.client';
  import { addToast } from '@/lib/stores/toastStore';

  // Track if page-load listener is registered to prevent accumulation
  const PAGE_LOAD_KEY = '__budgetPageLoadListenerRegistered';

  function initBudgetExtras() {
    // Export button
    const exportBtn = document.querySelector('[data-budget-export-btn]');
    if (exportBtn && !(exportBtn as HTMLElement).dataset.initialized) {
      (exportBtn as HTMLElement).dataset.initialized = 'true';
      exportBtn.addEventListener('click', async () => {
        const container = document.querySelector('[data-budget-page]') as HTMLElement;
        const year = container?.dataset.year;
        const month = container?.dataset.month;
        const currency = container?.dataset.currency || 'IDR';

        try {
          const res = await fetch(
            `/api/budget/export?year=${year}&month=${month}&currency=${currency}`
          );
          if (!res.ok) throw new Error('Export failed');
          const blob = await res.blob();
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = `budget_${year}-${String(month).padStart(2, '0')}.csv`;
          a.click();
          URL.revokeObjectURL(url);
          addToast('Budget exported successfully!', 'success');
        } catch {
          addToast('Failed to export budget.', 'error');
        }
      });
    }

    // Import button
    const importBtn = document.querySelector('[data-budget-import-btn]');
    if (importBtn && !(importBtn as HTMLElement).dataset.initialized) {
      (importBtn as HTMLElement).dataset.initialized = 'true';
      importBtn.addEventListener('click', () => {
        const modal = document.getElementById('budget-import-modal') as HTMLDialogElement;
        if (modal) modal.showModal();
      });
    }

    // View toggle (Card/Table)
    const viewToggle = document.querySelector('[data-view-toggle]');
    if (viewToggle && !(viewToggle as HTMLElement).dataset.initialized) {
      (viewToggle as HTMLElement).dataset.initialized = 'true';
      viewToggle.querySelectorAll<HTMLButtonElement>('button').forEach((btn) => {
        btn.addEventListener('click', () => {
          const mode = btn.dataset.viewMode;
          const cardView = document.querySelector('[data-view="card"]') as HTMLElement;
          const tableView = document.querySelector('[data-view="table"]') as HTMLElement;

          if (mode === 'table') {
            cardView?.classList.add('hidden');
            tableView?.classList.remove('hidden');
          } else {
            cardView?.classList.remove('hidden');
            tableView?.classList.add('hidden');
          }

          // Update aria-pressed and active state
          viewToggle.querySelectorAll<HTMLButtonElement>('button').forEach((b) => {
            b.setAttribute('aria-pressed', b.dataset.viewMode === mode ? 'true' : 'false');
            b.classList.toggle('btn-active', b.dataset.viewMode === mode);
          });

          // Persist preference
          localStorage.setItem('budget-view-mode', mode || 'card');
        });
      });

      // Restore preference
      const savedMode = localStorage.getItem('budget-view-mode');
      if (savedMode === 'table') {
        const tableBtn = viewToggle.querySelector('[data-view-mode="table"]') as HTMLButtonElement;
        tableBtn?.click();
      }
    }
  }

  // Initialize the budget page orchestrator
  initBudgetPage();
  initBudgetExtras();

  // Register cleanup handler (must re-register after each page load since it's once)
  function registerCleanup() {
    document.addEventListener('astro:before-swap', cleanup, { once: true });
  }
  registerCleanup();

  // Re-initialize on Astro page load (after navigation) - only register once
  if (!(window as unknown as Record<string, boolean>)[PAGE_LOAD_KEY]) {
    (window as unknown as Record<string, boolean>)[PAGE_LOAD_KEY] = true;
    document.addEventListener('astro:page-load', () => {
      initBudgetPage();
      initBudgetExtras();
      registerCleanup();
    });
  }
</script>
