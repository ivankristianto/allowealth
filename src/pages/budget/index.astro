---
/**
 * Budget Overview Page
 *
 * Main budget page showing current month's budget overview.
 * Displays premium card grid with categories, spending, and progress.
 * Protected by authentication.
 *
 * Redesigned as part of Task 15 & 16 (Budget Page - Card Grid & Header).
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import BudgetCardGrid from '@components/organisms/BudgetCardGrid.astro';
import BudgetPageHeader from '@components/organisms/BudgetPageHeader.astro';
import BudgetAdviceBanner from '@components/organisms/BudgetAdviceBanner.astro';
import BudgetSummary from '@components/organisms/BudgetSummary.astro';
import SetNewBudgetModal from '@components/organisms/SetNewBudgetModal.astro';
import {
  budgetService,
  categoryService,
  type BudgetSummary as BudgetSummaryType,
} from '@/services';
import { formatCurrency } from '@/lib/tokens';
import { calculateAllocationDistribution } from '@/lib/utils/budget';
import { CircleX } from '@lucide/astro';

const user = Astro.locals.user;
const currentPath = '/budget';

// Early guard clause - redirect to login if user is not authenticated
// This should never happen due to ProtectedLayout, but provides type safety
if (!user) {
  return Astro.redirect('/login');
}

// Get query parameters for month/year selection
const url = new URL(Astro.request.url);
const yearParam = url.searchParams.get('year');
const monthParam = url.searchParams.get('month');
const currencyParam = url.searchParams.get('currency') as 'IDR' | 'USD' | null;

// Default to current month if not specified
const now = new Date();
const selectedYear = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const selectedMonth = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;
const selectedCurrency = currencyParam || 'IDR';

// Get budget data from service
let budgetData: BudgetSummaryType | null = null;
let error: string | null = null;

try {
  budgetData = await budgetService.getMonthlyOverview(
    user.id,
    selectedYear,
    selectedMonth,
    selectedCurrency
  );
} catch (err) {
  console.error('Error fetching budget data:', err);
  error = err instanceof Error ? err.message : 'Failed to fetch budget data';
}

// Calculate allocation distribution for BudgetSummary component
// @TODO: Wire with backend - consider moving this calculation to the service layer
const allocationDistribution = budgetData
  ? calculateAllocationDistribution(
      budgetData.categories.map((cat) => ({
        name: cat.category_name,
        budget_amount: cat.budget_amount,
        spent_amount: cat.spent_amount,
      }))
    )
  : [];

// Month names for display
const monthNames = [
  'January',
  'February',
  'March',
  'April',
  'May',
  'June',
  'July',
  'August',
  'September',
  'October',
  'November',
  'December',
];

const currentMonthName = monthNames[selectedMonth - 1];
const currentMonthDisplay = `${currentMonthName} ${selectedYear}`;

// Build URLs for month navigation
const buildMonthUrl = (year: number, month: number) => {
  const params = new URLSearchParams();
  params.set('year', year.toString());
  params.set('month', month.toString());
  params.set('currency', selectedCurrency);
  return `/budget?${params.toString()}`;
};

// Previous and next month
const prevMonthDate = new Date(selectedYear, selectedMonth - 2, 1);
const nextMonthDate = new Date(selectedYear, selectedMonth, 1);

const prevMonthYear = prevMonthDate.getFullYear();
const prevMonth = prevMonthDate.getMonth() + 1;
const nextMonthYear = nextMonthDate.getFullYear();
const nextMonth = nextMonthDate.getMonth() + 1;

// Don't allow navigating to future months
const nowDate = new Date();
const maxYear = nowDate.getFullYear();
const maxMonth = nowDate.getMonth() + 1;
const isNextMonthInFuture =
  nextMonthYear > maxYear || (nextMonthYear === maxYear && nextMonth > maxMonth);

// Get budget alerts for generating advice
let alerts: Awaited<ReturnType<typeof budgetService.getAlerts>> = [];
if (budgetData) {
  try {
    alerts = await budgetService.getAlerts(user.id, selectedCurrency);
  } catch (err) {
    console.error('Error fetching budget alerts:', err);
    alerts = [];
  }
}

// Generate structured advice data based on alerts (XSS-safe)
interface AdviceData {
  categoryName: string;
  status: 'exceeded' | 'warning';
  amount: string;
  percentageUsed?: number;
}

const generateAdviceData = (): AdviceData | null => {
  if (alerts.length === 0) return null;

  const exceededCategories = alerts.filter((a) => a.status === 'exceeded');
  const warningCategories = alerts.filter((a) => a.status === 'warning');

  if (exceededCategories.length > 0) {
    const category = exceededCategories[0];
    const overage = formatCurrency(category.overage, selectedCurrency);
    return {
      categoryName: category.category_name,
      status: 'exceeded',
      amount: overage,
    };
  }

  if (warningCategories.length > 0) {
    const category = warningCategories[0];
    const budgetAmount = parseFloat(category.budget_amount);
    const spentAmount = parseFloat(category.spent_amount);
    const percentageUsed = budgetAmount > 0 ? Math.round((spentAmount / budgetAmount) * 100) : 0;
    const remaining = budgetAmount - spentAmount;
    const remainingFormatted = formatCurrency(Math.max(0, remaining), selectedCurrency);
    return {
      categoryName: category.category_name,
      status: 'warning',
      amount: remainingFormatted,
      percentageUsed,
    };
  }

  return null;
};

const adviceData = generateAdviceData();

// Fetch all categories for the edit modal
const allCategories = await categoryService.findAll(user.id, { is_active: true });
const expenseCategories = allCategories.filter((c) => c.type === 'expense');

// Count budgets with actual limits set
const budgetCount =
  budgetData?.categories.filter((c) => parseFloat(c.budget_amount) > 0).length || 0;
---

<ProtectedLayout title={`Budget - ${currentMonthName} ${selectedYear}`} currentPath={currentPath}>
  <div
    class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8"
    data-budget-container
    data-expense-categories={JSON.stringify(expenseCategories)}
    data-currency={selectedCurrency}
  >
    {/* Premium Header with Month Navigation and Actions */}
    <BudgetPageHeader
      title="Family Spending Targets"
      budgetCount={budgetCount}
      currentMonth={currentMonthDisplay}
      prevMonthUrl={buildMonthUrl(prevMonthYear, prevMonth)}
      nextMonthUrl={!isNextMonthInFuture ? buildMonthUrl(nextMonthYear, nextMonth) : undefined}
      isNextDisabled={isNextMonthInFuture}
      showAiRebalancer={budgetCount > 0}
    />

    {/* Error State */}
    {
      error ? (
        <div class="alert alert-error" role="alert">
          <CircleX size={24} class="stroke-current shrink-0" aria-hidden="true" />
          <span>{error}</span>
        </div>
      ) : (
        <>
          {/* Budget Summary Overview */}
          {budgetData && (
            <BudgetSummary
              totalAllocated={parseFloat(budgetData.total_budget || '0')}
              totalSpent={parseFloat(budgetData.total_spent || '0')}
              distribution={allocationDistribution}
              currency={selectedCurrency}
              loading={false}
            />
          )}

          {/* Budget Card Grid */}
          <BudgetCardGrid
            budgets={budgetData?.categories || []}
            currency={selectedCurrency}
            loading={false}
          />

          {/* AI Advice Banner */}
          {adviceData && (
            <BudgetAdviceBanner
              categoryName={adviceData.categoryName}
              status={adviceData.status}
              amount={adviceData.amount}
              percentageUsed={adviceData.percentageUsed}
              ctaText="Review spending"
              ctaUrl="/transactions"
              show={true}
              dismissible={true}
            />
          )}
        </>
      )
    }
  </div>

  {/* Set New Budget Modal */}
  <SetNewBudgetModal
    id="set-new-budget-modal"
    categories={expenseCategories}
    currency={selectedCurrency}
  />
</ProtectedLayout>

<script>
  function initBudgetPageHandlers() {
    // Handle edit budget button clicks from BudgetCard components
    // Reuse the SetNewBudgetModal for editing
    document.querySelectorAll('[data-edit-budget]').forEach((btn) => {
      btn.addEventListener('click', (e: Event) => {
        e.stopPropagation();

        const categoryId = btn.getAttribute('data-edit-budget');
        if (!categoryId) return;

        const container = document.querySelector('[data-budget-container]');
        const categoriesJson = container?.getAttribute('data-expense-categories');
        if (!categoriesJson) return;

        try {
          const categories = JSON.parse(categoriesJson);
          const category = categories.find(
            (c: { id: string; name: string; budget_amount: string }) => c.id === categoryId
          );

          if (!category) return;

          // Use the SetNewBudgetModal
          const modal = document.getElementById('set-new-budget-modal') as HTMLDialogElement;
          const form = document.getElementById('set-new-budget-modal-form') as HTMLFormElement;
          const categorySelect = document.getElementById(
            'set-new-budget-modal-category'
          ) as HTMLSelectElement;
          const amountInput = document.getElementById(
            'set-new-budget-modal-amount'
          ) as HTMLInputElement;

          if (!modal || !form || !categorySelect || !amountInput) return;

          // Pre-select the category and set amount
          categorySelect.value = categoryId;
          amountInput.value = category.budget_amount || '';

          modal.showModal();
        } catch (err) {
          console.error('Error opening edit modal:', err);
        }
      });
    });
  }

  /**
   * Client-Side Helper Functions
   *
   * ARCHITECTURAL NOTE: These functions duplicate logic from @/lib/tokens.ts
   * and @/lib/utils/budget.ts. This duplication is INTENTIONAL and NECESSARY because:
   *
   * 1. Astro's inline <script> tags run in the browser
   * 2. Browser scripts cannot import from server-side TypeScript modules
   * 3. These functions are needed for real-time DOM updates when budgets change
   *
   * The server-side equivalents are:
   * - formatCurrencyClient → @/lib/tokens.ts:formatCurrency()
   * - getStatus → @/lib/tokens.ts:getBudgetStatusClass() (returns different format)
   * - getStatusBadgeClasses → @/lib/tokens.ts:getStatusBadgeClasses()
   * - getProgressColorClass → Uses DaisyUI semantic colors
   *
   * Keep these in sync with server-side utilities when updating.
   * See CLAUDE.md "Astro Files - DO NOT mix define:vars with npm imports"
   */

  // Format currency for display (mirrors @/lib/tokens.ts:formatCurrency)
  function formatCurrencyClient(amount: number, currency: string): string {
    if (currency === 'IDR') {
      return new Intl.NumberFormat('id-ID', {
        style: 'currency',
        currency: 'IDR',
        minimumFractionDigits: 0,
        maximumFractionDigits: 0,
      }).format(amount);
    }
    return new Intl.NumberFormat('en-US', {
      style: 'currency',
      currency: 'USD',
      minimumFractionDigits: 2,
      maximumFractionDigits: 2,
    }).format(amount);
  }

  // Get status based on percentage (mirrors @/lib/tokens.ts:getBudgetStatusClass logic)
  function getStatus(percentage: number): 'ok' | 'warning' | 'exceeded' {
    if (percentage >= 100) return 'exceeded';
    if (percentage >= 80) return 'warning';
    return 'ok';
  }

  // Get status badge classes (mirrors @/lib/tokens.ts:getStatusBadgeClasses pattern)
  function getStatusBadgeClasses(status: 'ok' | 'warning' | 'exceeded'): string {
    const statusMap: Record<string, string> = {
      ok: 'bg-success/10 text-success',
      warning: 'bg-warning/10 text-warning',
      exceeded: 'bg-error/10 text-error',
    };
    return statusMap[status] || statusMap.ok;
  }

  // Get progress bar status color class (uses DaisyUI semantic colors)
  function getProgressColorClass(status: 'ok' | 'warning' | 'exceeded'): string {
    const colorMap: Record<string, string> = {
      ok: 'bg-success',
      warning: 'bg-warning',
      exceeded: 'bg-error',
    };
    return colorMap[status] || colorMap.ok;
  }

  // Handle budget-updated event to update BudgetCard interactively
  function handleBudgetUpdated(
    event: CustomEvent<{ categoryId: string; budgetAmount: string; currency: string }>
  ) {
    const { categoryId, budgetAmount, currency } = event.detail;
    const newBudget = parseFloat(budgetAmount);

    // Find the budget card for this category
    const card = document.querySelector(`[data-budget-card="${categoryId}"]`) as HTMLElement;
    if (!card) return;

    // Get spent amount from the card
    const spent = parseFloat(card.dataset.spent || '0');

    // Calculate new values
    const percentage = newBudget > 0 ? Math.round((spent / newBudget) * 100) : 0;
    const remaining = newBudget - spent;
    const isOver = remaining < 0;
    const status = getStatus(percentage);

    // Update status badge
    const statusBadge = card.querySelector('[data-status-badge]');
    if (statusBadge) {
      statusBadge.textContent = `${percentage}% Used`;
      statusBadge.className = `inline-block mt-2 px-2 py-0.5 rounded-md text-[10px] font-bold uppercase tracking-wider ${getStatusBadgeClasses(status)}`;
    }

    // Update budget amount display
    const budgetAmountEl = card.querySelector('[data-budget-amount]');
    if (budgetAmountEl) {
      budgetAmountEl.textContent = formatCurrencyClient(newBudget, currency);
    }

    // Update progress bar
    const progressContainer = card.querySelector('[data-progress-container]');
    if (progressContainer) {
      const progressBar = progressContainer.querySelector('[role="progressbar"]');
      const progressFill = progressBar?.querySelector('div');
      if (progressBar && progressFill) {
        const clampedValue = Math.min(percentage, 100);
        progressBar.setAttribute('aria-valuenow', String(clampedValue));
        progressFill.style.width = `${clampedValue}%`;
        // Update color class using classList API
        progressFill.classList.remove('bg-success', 'bg-warning', 'bg-error');
        progressFill.classList.add(getProgressColorClass(status));
      }
    }

    // Update footer
    const footer = card.querySelector('[data-footer]') as HTMLElement;
    if (footer) {
      // Update footer container classes
      footer.className = `p-4 rounded-2xl border ${
        isOver
          ? 'bg-error/5 border-error/10 text-error'
          : 'bg-base-200/50 border-base-300 text-base-content/60'
      }`;

      // Update label
      const footerLabel = footer.querySelector('[data-footer-label]');
      if (footerLabel) {
        footerLabel.textContent = isOver ? 'Over budget by' : 'Left to spend';
      }

      // Update amount
      const footerAmount = footer.querySelector('[data-footer-amount]');
      if (footerAmount) {
        footerAmount.textContent = formatCurrencyClient(Math.abs(remaining), currency);
        footerAmount.className = isOver ? 'text-error' : 'text-base-content';
      }
    }

    // Update the data-expense-categories to keep it in sync
    const container = document.querySelector('[data-budget-container]');
    const categoriesJson = container?.getAttribute('data-expense-categories');
    if (categoriesJson) {
      try {
        const categories = JSON.parse(categoriesJson);
        const categoryIndex = categories.findIndex((c: { id: string }) => c.id === categoryId);
        if (categoryIndex !== -1) {
          categories[categoryIndex].budget_amount = budgetAmount;
          container?.setAttribute('data-expense-categories', JSON.stringify(categories));
        }
      } catch (err) {
        console.error('Error updating categories data:', err);
      }
    }
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBudgetPageHandlers);
  } else {
    initBudgetPageHandlers();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initBudgetPageHandlers);

  // Listen for budget updates
  document.addEventListener('budget-updated', handleBudgetUpdated as EventListener);

  // Cleanup event listeners on Astro page transitions
  document.addEventListener(
    'astro:before-swap',
    () => {
      document.removeEventListener('budget-updated', handleBudgetUpdated as EventListener);
    },
    { once: true }
  );
</script>
