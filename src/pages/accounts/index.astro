---
/**
 * Accounts List Page (Global Accounts)
 *
 * Main page for viewing and managing accounts with portfolio summary.
 * Redesigned as part of the Global Accounts page update.
 * Includes modals for add, edit, delete, and history actions.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import AccountPortfolioSummary from '@components/organisms/AccountPortfolioSummary.astro';
import AccountReconciliationCard from '@components/organisms/AccountReconciliationCard.astro';
import AccountActions from '@components/organisms/AccountActions.astro';
import AccountTable from '@/components/organisms/AccountTable.astro';
import AccountGroupCard from '@components/organisms/AccountGroupCard.astro';
import AccountFilterControls from '@/components/molecules/AccountFilterControls.astro';
import AccountItemRow from '@components/molecules/AccountItemRow.astro';
import AccountFormModal from '@components/organisms/AccountFormModal.astro';
import AccountTransferModal from '@components/organisms/AccountTransferModal.astro';
import AccountDeleteConfirmModal from '@components/organisms/AccountDeleteConfirmModal.astro';
import AccountHistoryModal from '@components/organisms/AccountHistoryModal.astro';
import AccountUpdateValueModal from '@components/organisms/AccountUpdateValueModal.astro';
import AccountCategoryModal from '@components/organisms/AccountCategoryModal.astro';
import PeriodicSelector, { type PeriodOption } from '@/components/molecules/PeriodicSelector.astro';
import EmptyState from '@components/atoms/EmptyState.astro';
import Button from '@/components/atoms/Button.astro';
import { CalendarDays, Info, ListPlus, Plus } from '@lucide/astro';
import {
  accountService,
  accountCategoryService,
  transactionService,
  workspaceMetaService,
  workspaceService,
} from '@/services';
import type { AccountOutput, AccountType, AccountClass } from '@/lib/types/account';
import { formatAccountType, deriveAccountClass, ACCOUNT_CLASS_LABELS } from '@/lib/types/account';
import { formatMonthYear } from '@/lib/utils/date';
import { PERIOD_SELECTOR_MONTH_LIMIT } from '@/lib/constants/period';
import { isValidCurrency, type Currency } from '@/lib/constants/currency';
import {
  calculateAccountAllocation,
  calculateAccountTotalsByCurrency,
  calculateDebtTotalsByCurrency,
  groupAccountsByClass,
  calculateGroupTotalsByCurrency,
  calculateReconciliation,
} from '@/lib/utils/account';

const user = Astro.locals.user!;
const currentPath = '/accounts';

// Valid account types for filtering
const VALID_ACCOUNT_TYPES = [
  'cash',
  'bank_account',
  'e_wallet',
  'mutual_fund',
  'bond',
  'crypto',
  'stock',
  'other',
  'credit_card',
  'loan',
] as const;

// Get query parameters for filtering
const url = new URL(Astro.url);
const searchParams = Object.fromEntries(url.searchParams.entries());
const workspaceMembers = await workspaceService.getMembers(user.workspaceId);
const ownerUserIdParam = url.searchParams.get('user_id');
const isLegacyPersonalView = url.searchParams.get('view') === 'mine';
const ownerUserIdRaw = ownerUserIdParam || (isLegacyPersonalView ? user.id : undefined);
const ownerUserId = ownerUserIdRaw
  ? workspaceMembers.some((member) => member.id === ownerUserIdRaw)
    ? ownerUserIdRaw
    : undefined
  : undefined;
const isPersonalView = ownerUserId === user.id;

// Build filters for service with validation
const filters: {
  user_id: string;
  type?: AccountType;
  category_id?: string;
  currency?: Currency;
  owner_user_id?: string;
} = {
  user_id: user.workspaceId,
};

// Validate account type parameter before assignment
if (searchParams.type && VALID_ACCOUNT_TYPES.includes(searchParams.type as AccountType)) {
  filters.type = searchParams.type as AccountType;
}
if (searchParams.categoryId) {
  filters.category_id = searchParams.categoryId;
}
if (searchParams.currency && isValidCurrency(searchParams.currency)) {
  filters.currency = searchParams.currency;
}
if (ownerUserId) {
  filters.owner_user_id = ownerUserId;
}

// Month navigation parameters
const yearParam = url.searchParams.get('year');
const monthParam = url.searchParams.get('month');
const now = new Date();
const selectedYear = yearParam ? parseInt(yearParam, 10) : now.getFullYear();
const selectedMonth = monthParam ? parseInt(monthParam, 10) : now.getMonth() + 1;
const isViewingCurrentMonth = !yearParam && !monthParam;

// Format current month for display
const currentMonthDisplay = new Date(selectedYear, selectedMonth - 1).toLocaleDateString('en-US', {
  month: 'long',
  year: 'numeric',
});
const selectedPeriod = `${selectedYear}-${selectedMonth.toString().padStart(2, '0')}`;
const periodStartDate = new Date(selectedYear, selectedMonth - 1, 1);
const periodEndDate = new Date(selectedYear, selectedMonth, 0, 23, 59, 59, 999);
const currentMonthUrl = new URL(url);
currentMonthUrl.searchParams.delete('year');
currentMonthUrl.searchParams.delete('month');
const currentMonthHref = `${currentMonthUrl.pathname}${currentMonthUrl.search}`;

// Build "view all accounts" URL while preserving active filters and period.
const allAccountsUrl = new URL(url);
allAccountsUrl.searchParams.delete('user_id');
allAccountsUrl.searchParams.delete('view');
const allAccountsHref = `${allAccountsUrl.pathname}${allAccountsUrl.search}`;
const hasActiveAccountFilters = Boolean(
  searchParams.search ||
  searchParams.type ||
  searchParams.categoryId ||
  searchParams.currency ||
  ownerUserIdParam ||
  isLegacyPersonalView
);

// Generate monthly period options (latest -> oldest, capped by shared selector window)
const monthlyPeriodOptions: PeriodOption[] = Array.from(
  { length: PERIOD_SELECTOR_MONTH_LIMIT },
  (_, i) => {
    const monthsBack = i;
    const date = new Date(now.getFullYear(), now.getMonth() - monthsBack, 1);
    const year = date.getFullYear();
    const month = date.getMonth() + 1;
    const monthStr = month.toString().padStart(2, '0');

    return {
      value: `${year}-${monthStr}`,
      label: formatMonthYear(date),
    };
  }
);

if (!monthlyPeriodOptions.some((period) => period.value === selectedPeriod)) {
  monthlyPeriodOptions.push({
    value: selectedPeriod,
    label: currentMonthDisplay,
  });
  monthlyPeriodOptions.sort((a, b) => b.value.localeCompare(a.value));
}

// Get closed account count for navigation link
const closedCount = await accountService.countClosed(user.workspaceId, ownerUserId);

// Fetch accounts and categories from database
const categories = await accountCategoryService.findAll(user.workspaceId);
const isAdmin = user.role === 'admin';
const memberNamesById = new Map(workspaceMembers.map((m) => [m.id, m.name]));
const workspaceCurrencyConfig = await workspaceMetaService.getWorkspaceCurrencies(user.workspaceId);
const workspaceCurrencies = [
  workspaceCurrencyConfig.primary,
  ...(workspaceCurrencyConfig.secondary ? [workspaceCurrencyConfig.secondary] : []),
];
const orderedWorkspaceCurrencies = workspaceCurrencies.filter((currency): currency is Currency =>
  isValidCurrency(currency)
);
const categoriesById = new Map(categories.map((category) => [category.id, category]));
const defaultCategoryId =
  categories.find((category) => category.is_system && !category.is_liability)?.id ||
  categories[0]?.id ||
  '';
// Fetch accounts - use snapshot for historical views, current data for present
let accounts: AccountOutput[];
let reconciliationAccounts: AccountOutput[];

if (!isViewingCurrentMonth) {
  // Historical view: get snapshot for the selected month
  const snapshots = await accountService.getSnapshotForMonth(
    user.workspaceId,
    selectedYear,
    selectedMonth,
    filters,
    Astro.locals.perf
  );
  accounts = snapshots.map((snapshot) => {
    const categoryName = snapshot.category_id
      ? categoriesById.get(snapshot.category_id)?.name || null
      : formatAccountType(snapshot.type);

    return {
      id: snapshot.id,
      name: snapshot.name,
      type: snapshot.type,
      account_class: snapshot.account_class ?? deriveAccountClass(snapshot.type),
      category_id: snapshot.category_id,
      category_name: categoryName,
      balance: snapshot.snapshot_balance,
      initial_balance: snapshot.initial_balance || null,
      currency: snapshot.currency,
      status: snapshot.status ?? 'active',
      closed_at: snapshot.closed_at ?? null,
      closed_by_user_id: snapshot.closed_by_user_id ?? null,
      created_by_user_id: snapshot.created_by_user_id,
      last_updated: snapshot.snapshot_date || snapshot.last_updated,
      created_at: snapshot.created_at,
      updated_at: snapshot.updated_at,
    };
  });
  reconciliationAccounts = accounts;
} else {
  // Current view: use latest balance
  const [rawAccounts, rawReconciliationAccounts] = await Promise.all([
    accountService.findAll(user.workspaceId, filters, Astro.locals.perf),
    accountService.findAll(
      user.workspaceId,
      { ...filters, includeInactive: true },
      Astro.locals.perf
    ),
  ]);
  accounts = rawAccounts.map((account) => {
    const categoryName = account.category_id
      ? categoriesById.get(account.category_id)?.name || null
      : formatAccountType(account.type);

    return {
      id: account.id,
      name: account.name,
      type: account.type,
      account_class: account.account_class,
      category_id: account.category_id,
      category_name: categoryName,
      balance: account.balance,
      initial_balance: account.initial_balance || null,
      currency: account.currency,
      status: account.status ?? 'active',
      closed_at: account.closed_at ?? null,
      closed_by_user_id: account.closed_by_user_id ?? null,
      created_by_user_id: account.created_by_user_id,
      last_updated: account.last_updated,
      created_at: account.created_at,
      updated_at: account.updated_at,
    };
  });
  reconciliationAccounts = rawReconciliationAccounts.map((account) => {
    const categoryName = account.category_id
      ? categoriesById.get(account.category_id)?.name || null
      : formatAccountType(account.type);

    return {
      id: account.id,
      name: account.name,
      type: account.type,
      account_class: account.account_class,
      category_id: account.category_id,
      category_name: categoryName,
      balance: account.balance,
      initial_balance: account.initial_balance || null,
      currency: account.currency,
      status: account.status ?? 'active',
      closed_at: account.closed_at ?? null,
      closed_by_user_id: account.closed_by_user_id ?? null,
      created_by_user_id: account.created_by_user_id,
      last_updated: account.last_updated,
      created_at: account.created_at,
      updated_at: account.updated_at,
    };
  });
}

const accountsWithDisplay = accounts.map((account) => ({
  ...account,
  owner_name: memberNamesById.get(account.created_by_user_id),
}));

const reconciliationAccountIds = reconciliationAccounts.map((account) => account.id);
const reconciliation =
  reconciliationAccountIds.length === 0
    ? []
    : await (async () => {
        const [startSnapshots, txSummaries] = await Promise.all([
          // filters is passed as-is; getSnapshotForMonth always adds
          // includeInactive: true internally so closed accounts are included.
          accountService.getSnapshotForMonth(
            user.workspaceId,
            selectedYear,
            selectedMonth - 1,
            filters,
            Astro.locals.perf
          ),
          Promise.all(
            orderedWorkspaceCurrencies.map((currency) =>
              transactionService
                .getMonthSummary(
                  {
                    workspace_id: user.workspaceId,
                    created_by_user_id: ownerUserId,
                    currency,
                    account_ids: reconciliationAccountIds,
                    start_date: periodStartDate,
                    end_date: isViewingCurrentMonth ? now : periodEndDate,
                  },
                  Astro.locals.perf
                )
                .then((summary) => ({ currency, ...summary }))
            )
          ),
        ]);

        return calculateReconciliation({
          currencies: orderedWorkspaceCurrencies,
          startSnapshots: startSnapshots.map((snapshot) => ({
            currency: snapshot.currency,
            balance: snapshot.snapshot_balance,
            account_class: snapshot.account_class ?? deriveAccountClass(snapshot.type),
          })),
          endAccounts: reconciliationAccounts.map((account) => ({
            currency: account.currency,
            balance: account.balance,
            account_class: account.account_class,
          })),
          transactionSummaries: txSummaries,
        });
      })();

// Calculate portfolio totals and allocation
// @TODO: Wire with backend - Consider moving calculations to service layer
const accountTotalsByCurrency = calculateAccountTotalsByCurrency(
  accounts,
  orderedWorkspaceCurrencies
);
const debtTotalsByCurrency = calculateDebtTotalsByCurrency(accounts, orderedWorkspaceCurrencies);
const allocationCurrency =
  orderedWorkspaceCurrencies.find((currency) =>
    accounts.some((account) => {
      if (account.account_class === 'debt') return false;
      if (account.currency !== currency) return false;
      const balance = parseFloat(account.balance || '0');
      return Number.isFinite(balance) && balance > 0;
    })
  ) ?? orderedWorkspaceCurrencies[0];
const accountAllocation = calculateAccountAllocation(accounts, allocationCurrency);

// Find latest update date across all accounts
const latestUpdate = accounts.reduce<Date | null>((latest, account) => {
  const updated = new Date(account.last_updated);
  return !latest || updated > latest ? updated : latest;
}, null);

// Group accounts by account class for display (Liquid -> Debt -> Non-Liquid)
const accountsByClass = groupAccountsByClass(accounts);
const CLASS_ORDER: AccountClass[] = ['liquid', 'debt', 'non_liquid'];
const sortedGroups = CLASS_ORDER.filter((cls) => accountsByClass[cls].length > 0).map((cls) => ({
  groupKey: cls,
  label: ACCOUNT_CLASS_LABELS[cls],
  accounts: accountsByClass[cls],
}));
---

<ProtectedLayout title="Accounts" currentPath={currentPath} subtitle={currentMonthDisplay}>
  <div
    slot="header"
    class="relative flex w-full items-center justify-center py-1 sm:gap-2 lg:w-auto lg:justify-start"
    data-account-header-controls
  >
    <PeriodicSelector
      options={monthlyPeriodOptions}
      selected={selectedPeriod}
      ariaLabel="Select account month"
      inputName="account-period"
      className="shrink-0"
      newestFirst
    />

    {
      !isViewingCurrentMonth && (
        <a
          href={currentMonthHref}
          class="btn btn-sm bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all gap-1 absolute right-0 lg:static lg:ml-1"
          aria-label="Go to current month"
          data-testid="account-current-month-btn"
        >
          <CalendarDays size={16} class="stroke-current" aria-hidden="true" />
          <span class="text-xs">Today</span>
        </a>
      )
    }
  </div>

  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8" data-testid="accounts-page">
    {/* Historical view indicator */}
    {
      !isViewingCurrentMonth && (
        <div class="bg-warning/10 border border-warning/20 rounded-card px-4 py-3 text-sm text-warning font-medium flex items-center gap-2">
          <CalendarDays size={16} class="stroke-current shrink-0" />
          Showing portfolio values as of {currentMonthDisplay}. Update actions are disabled for
          historical views.
        </div>
      )
    }

    {/* Personal view indicator */}
    {
      isPersonalView && (
        <div
          class="bg-info/10 border border-info/20 rounded-card px-4 py-3 text-sm text-info font-medium flex items-center gap-2"
          data-testid="personal-view-banner"
        >
          <Info size={16} class="stroke-current shrink-0" />
          <span>
            Showing your accounts only. Values reflect your portfolio.
            <a href={allAccountsHref} class="underline font-bold ml-1">
              View all accounts &rarr;
            </a>
          </span>
        </div>
      )
    }

    {
      accounts.length > 0 ? (
        <>
          {/* Accounts Summary */}
          <AccountPortfolioSummary
            accountTotals={accountTotalsByCurrency}
            debtTotals={debtTotalsByCurrency}
            distribution={accountAllocation}
            loading={false}
            latestUpdate={latestUpdate}
            isHistoricalView={!isViewingCurrentMonth}
          />

          <AccountReconciliationCard
            reconciliation={reconciliation}
            periodLabel={currentMonthDisplay}
            periodStart={new Date(selectedYear, selectedMonth - 1, 0)}
            periodEnd={isViewingCurrentMonth ? now : periodEndDate}
          />

          {/* Action Buttons - after allocation, before filter */}
          <AccountActions
            isHistoricalView={!isViewingCurrentMonth}
            defaultCategoryId={defaultCategoryId}
            closedCount={closedCount}
          />

          {/* Filter Bar */}
          <AccountFilterControls
            searchValue={searchParams.search || ''}
            members={workspaceMembers.map((member) => ({ id: member.id, name: member.name }))}
            userId={ownerUserId || ''}
            currentUserId={user.id}
            currentSearchParams={url.search}
            baseUrl="/accounts"
          />

          {/* Account Groups */}
          <div data-view="card">
            <div class="space-y-6">
              {sortedGroups.map((group) => {
                const groupTotals = calculateGroupTotalsByCurrency(
                  group.accounts,
                  orderedWorkspaceCurrencies
                );

                return (
                  <AccountGroupCard
                    type={group.label}
                    accountClass={group.groupKey}
                    count={group.accounts.length}
                    totals={groupTotals}
                    groupId={group.groupKey}
                    isDebt={group.groupKey === 'debt'}
                    defaultExpanded={true}
                  >
                    {group.accounts.map((account) => (
                      <AccountItemRow
                        id={account.id}
                        name={account.name}
                        type={account.type}
                        accountClass={account.account_class}
                        categoryId={account.category_id}
                        categoryName={account.category_name}
                        currency={account.currency}
                        balance={parseFloat(account.balance)}
                        initialBalance={
                          account.initial_balance ? parseFloat(account.initial_balance) : undefined
                        }
                        ownerUserId={account.created_by_user_id}
                        ownerName={memberNamesById.get(account.created_by_user_id)}
                        lastUpdated={account.last_updated}
                        isHistoricalView={!isViewingCurrentMonth}
                      />
                    ))}
                  </AccountGroupCard>
                );
              })}
            </div>
          </div>

          <div data-view="table" class="hidden">
            <AccountTable
              accounts={accountsWithDisplay}
              primaryCurrency={
                filters.currency ?? allocationCurrency ?? orderedWorkspaceCurrencies[0] ?? 'IDR'
              }
              currencyOrder={orderedWorkspaceCurrencies}
              isHistoricalView={!isViewingCurrentMonth}
            />
          </div>

          {/* No results message (hidden by default, shown by client script) */}
          <div
            data-account-search-no-results
            class="text-center py-8 text-base-content/50 text-sm font-medium hidden"
          >
            No accounts match your search.
          </div>
        </>
      ) : (
        <div class="card bg-base-100 shadow border border-base-300 rounded-card">
          <div class="card-body">
            <EmptyState
              title={
                hasActiveAccountFilters
                  ? 'No accounts match current filters'
                  : 'No accounts tracked yet'
              }
              message={
                hasActiveAccountFilters
                  ? 'Try changing owner or filter criteria to view matching accounts.'
                  : 'Add your first account to start tracking your net worth across different types and currencies.'
              }
            />
            {hasActiveAccountFilters ? (
              <div class="flex justify-center mt-4">
                <a href={allAccountsHref} class="btn btn-outline gap-2 rounded-2xl">
                  View all accounts
                </a>
              </div>
            ) : (
              <div class="flex justify-center mt-4">
                <Button
                  type="button"
                  variant="primary"
                  className="gap-2"
                  data-add-account-btn
                  data-add-first-account-btn
                  data-default-category-id={defaultCategoryId}
                >
                  Add Your First Account
                </Button>
              </div>
            )}
          </div>
        </div>
      )
    }
  </div>

  {/* Account Modals */}
  <AccountTransferModal
    id="account-transfer-modal"
    accounts={accounts.map((a) => ({
      id: a.id,
      name: a.name,
      currency: a.currency,
      balance: a.balance,
    }))}
  />
  <AccountFormModal
    id="account-form-modal"
    mode="add"
    availableCurrencies={workspaceCurrencies}
    categories={categories}
    members={isAdmin
      ? workspaceMembers.map((member) => ({ id: member.id, name: member.name }))
      : []}
    isAdmin={isAdmin}
  />
  <AccountCategoryModal id="account-category-modal" />
  <AccountDeleteConfirmModal id="account-delete-modal" />
  <AccountHistoryModal id="account-history-modal" />
  <AccountUpdateValueModal id="account-update-value-modal" />

  {/* Bulk Add Accounts Modal */}
  <dialog id="bulk-add-accounts-modal" class="modal" data-testid="bulk-add-accounts-modal">
    <div class="modal-box max-w-4xl rounded-card border border-base-300 shadow-xl p-0">
      <div class="p-6 flex flex-col gap-5">
        {/* Header */}
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center bg-accent/10">
            <ListPlus size={24} class="stroke-current text-accent" aria-hidden="true" />
          </div>
          <div class="flex-1">
            <h2 class="text-2xl font-bold tracking-tight text-primary leading-none">
              Bulk Add Accounts
            </h2>
            <p class="text-neutral text-sm mt-2 font-medium">
              Add accounts row by row. Balance defaults to 0.
            </p>
          </div>
        </div>

        {/* Table */}
        <div class="overflow-hidden rounded-2xl border border-base-300 bg-base-100">
          <div class="overflow-x-auto max-h-[50vh] overflow-y-auto">
            <table class="table table-sm table-fixed w-full">
              <thead>
                <tr class="text-xs uppercase tracking-widest text-base-content/50">
                  <th class="w-[34%]">Name</th>
                  <th class="w-[26%]">Type</th>
                  <th class="w-[18%]">Currency</th>
                  <th class="w-[18%] text-right">Balance</th>
                  <th class="w-12"></th>
                </tr>
              </thead>
              <tbody
                data-bulk-rows
                data-valid-currencies={orderedWorkspaceCurrencies.join(',')}
                data-account-types={JSON.stringify(
                  VALID_ACCOUNT_TYPES.map((t) => ({
                    value: t,
                    label: formatAccountType(t),
                  }))
                )}
              >
                {/* Rows added dynamically by client script */}
              </tbody>
            </table>
          </div>
        </div>

        {/* Add Row button */}
        <Button
          type="button"
          variant="ghost"
          size="sm"
          className="self-start rounded-lg border-0 gap-2 min-h-[44px] sm:rounded-xl"
          data-bulk-add-row
        >
          <Plus size={16} class="stroke-current" aria-hidden="true" />
          Add Row
        </Button>

        {/* Error */}
        <div
          id="bulk-accounts-error"
          class="hidden alert alert-error text-sm rounded-xl"
          role="alert"
        >
        </div>

        {/* Actions */}
        <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:justify-end">
          <Button
            type="button"
            variant="ghost"
            className="w-full min-h-[44px] border-0 font-bold sm:min-w-28 sm:w-auto"
            data-bulk-accounts-cancel
          >
            Cancel
          </Button>
          <Button
            type="button"
            variant="primary"
            className="w-full min-h-[44px] font-bold sm:min-w-48 sm:w-auto"
            data-bulk-accounts-submit
            data-testid="bulk-accounts-submit-btn"
          >
            <span data-bulk-accounts-submit-text>Create 1 Account</span>
          </Button>
        </div>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</ProtectedLayout>

<script>
  import { PERIOD_CHANGE_EVENT } from '@/lib/constants/events';
  import { initInlineHistory } from '@/components/molecules/AccountInlineHistory.client';
  import { initAccountSearch } from '@/components/organisms/AccountSearch.client';
  import { initAccountsTableClient } from '@/components/organisms/accounts-table.client';
  import { initBulkAddAccounts } from './bulk-add-accounts.client';

  const firstAccountButtonHandlers = new WeakMap<HTMLElement, (event: Event) => void>();

  function openAccountForm(defaultCategoryId = '') {
    document.dispatchEvent(
      new CustomEvent('open-account-form', {
        detail: {
          name: '',
          categoryId: defaultCategoryId,
          balance: '',
        },
      })
    );
  }

  function initFirstAccountButton() {
    document.querySelectorAll<HTMLElement>('[data-add-first-account-btn]').forEach((button) => {
      if (firstAccountButtonHandlers.has(button)) return;

      const handler = () => {
        const defaultCategoryId = button.getAttribute('data-default-category-id') || '';
        openAccountForm(defaultCategoryId);
      };

      firstAccountButtonHandlers.set(button, handler);
      button.addEventListener('click', handler);
    });
  }

  function cleanupFirstAccountButton() {
    document.querySelectorAll<HTMLElement>('[data-add-first-account-btn]').forEach((button) => {
      const handler = firstAccountButtonHandlers.get(button);
      if (!handler) return;
      button.removeEventListener('click', handler);
      firstAccountButtonHandlers.delete(button);
    });
  }

  let periodChangeController: AbortController | null = null;

  function initAccountPeriodSelector() {
    periodChangeController?.abort();
    periodChangeController = new AbortController();

    const controls = document.querySelector('[data-account-header-controls]');
    if (!controls) return;

    window.addEventListener(
      PERIOD_CHANGE_EVENT,
      (event: Event) => {
        const period = (event as CustomEvent<{ period?: string }>).detail?.period;
        if (!period || !/^\d{4}-\d{2}$/.test(period)) return;

        const [year, month] = period.split('-');
        const periodYear = parseInt(year, 10);
        const periodMonth = parseInt(month, 10);
        const now = new Date();
        const currentYear = now.getFullYear();
        const currentMonth = now.getMonth() + 1;
        const nextUrl = new URL(window.location.href);

        if (periodYear === currentYear && periodMonth === currentMonth) {
          nextUrl.searchParams.delete('year');
          nextUrl.searchParams.delete('month');
        } else {
          nextUrl.searchParams.set('year', String(periodYear));
          nextUrl.searchParams.set('month', String(periodMonth));
        }

        if (nextUrl.toString() !== window.location.href) {
          window.location.assign(nextUrl.toString());
        }
      },
      { signal: periodChangeController.signal }
    );
  }

  function init() {
    initInlineHistory();
    initAccountSearch();
    initAccountsTableClient();
    initFirstAccountButton();
    initAccountPeriodSelector();
    initBulkAddAccounts();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }

  document.addEventListener('astro:page-load', init);
  document.addEventListener(
    'astro:before-swap',
    () => {
      cleanupFirstAccountButton();
      periodChangeController?.abort();
    },
    { once: true }
  );
</script>
