---
/**
 * CSV Import Page
 *
 * Page for importing transactions from CSV files.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import CSVImportForm from '../../components/molecules/CSVImportForm.astro';
import { Info, Download } from '@lucide/astro';

const currentPath = '/transactions/import';

// TODO: In Phase 2/3, this will:
// 1. Handle CSV file upload
// 2. Parse and preview data
// 3. Allow column mapping
// 4. Validate and import via service layer
---

<ProtectedLayout title="Import Transactions - Finance Manager" currentPath={currentPath}>
  <div class="max-w-4xl">
    <div class="mb-6">
      <h2 class="text-2xl font-bold">Import Transactions from CSV</h2>
      <p class="text-neutral-500">Bulk import transactions from a CSV file</p>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <!-- Instructions -->
        <div class="alert alert-info mb-6">
          <Info size={16} class="stroke-current shrink-0" aria-hidden="true" />
          <div>
            <h3 class="font-bold">CSV Format Requirements</h3>
            <div class="text-sm mt-2">
              <p class="mb-2">Your CSV file should include these columns:</p>
              <ul class="list-disc list-inside space-y-1">
                <li><strong>date:</strong> Transaction date (YYYY-MM-DD format)</li>
                <li><strong>type:</strong> "expense" or "income"</li>
                <li><strong>amount:</strong> Transaction amount (e.g., 100000.00)</li>
                <li><strong>currency:</strong> "IDR" or "USD"</li>
                <li><strong>category:</strong> Category name (must match existing categories)</li>
                <li>
                  <strong>asset:</strong> Asset name (must match existing assets)
                </li>
                <li><strong>description:</strong> Optional notes</li>
              </ul>
            </div>
          </div>
        </div>

        <!-- Import Form -->
        <CSVImportForm action="/transactions/import" />

        <!-- Download Template -->
        <div class="mt-6 pt-6 border-t border-base-300">
          <h3 class="font-semibold mb-2">Need a template?</h3>
          <p class="text-sm text-neutral-500 mb-3">
            Download a sample CSV file to see the expected format.
          </p>
          <a href="/transactions/template.csv" class="btn btn-outline btn-sm">
            <Download size={16} class="stroke-current" aria-hidden="true" />
            Download CSV Template
          </a>
        </div>
      </div>
    </div>
  </div>
</ProtectedLayout>
