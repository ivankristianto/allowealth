---
/**
 * CSV Import Page
 *
 * Page for importing transactions from CSV files.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import CSVImportForm from '../../components/molecules/CSVImportForm.astro';
import { Download } from '@lucide/astro';

const currentPath = '/transactions/import';
---

<ProtectedLayout title="Import" currentPath={currentPath} subtitle="Upload transactions">
  <div class="max-w-4xl mx-auto">
    <div class="mb-6">
      <h2 class="text-2xl font-bold">Import Transactions from CSV</h2>
      <p class="text-base-content/60">Bulk import transactions from a CSV file</p>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <!-- Import Form -->
        <CSVImportForm action="/api/transactions/import" />

        <!-- Download Template -->
        <div class="mt-6 pt-6 border-t border-base-300">
          <h3 class="font-semibold mb-2">Need a template?</h3>
          <p class="text-sm text-base-content/60 mb-3">
            Download a sample CSV file to see the expected format.
          </p>
          <a
            href="/api/transactions/template"
            class="btn btn-ghost btn-sm gap-1 rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200"
          >
            <Download size={16} class="stroke-current" aria-hidden="true" />
            Download CSV Template
          </a>
        </div>
      </div>
    </div>
  </div>
</ProtectedLayout>
