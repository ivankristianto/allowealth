---
/**
 * Transactions List Page
 *
 * Redesigned transactions page with summary cards, filter bar, and transaction list.
 * Matches POC design with premium styling.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import TransactionRow from '@/components/molecules/TransactionRow.astro';
import TransactionSummaryCards from '@/components/organisms/TransactionSummaryCards.astro';
import TransactionFiltersBar from '@/components/organisms/TransactionFiltersBar.astro';
import { Receipt, RotateCcw } from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';
import { transactionService, categoryService } from '@/services';

const user = Astro.locals.user!;
const currentPath = '/transactions';

// Get query parameters for filtering
const url = new URL(Astro.url);
const searchParams = Object.fromEntries(url.searchParams.entries());

// Pagination
const page = parseInt(searchParams.page || '1');
const pageSize = 50;
const offset = (page - 1) * pageSize;

// Get filter values
const typeFilter = (searchParams.type || 'all') as 'all' | 'income' | 'expense';
const categoryId = searchParams.category_id || '';
const searchValue = searchParams.search || '';
const selectedMonth = searchParams.month || '';

// Build filters for service
const filters = {
  user_id: user.id,
  type: typeFilter === 'all' ? undefined : (typeFilter as 'expense' | 'income' | undefined),
  category_id: categoryId || undefined,
  payment_method_id: searchParams.payment_method_id,
  currency: searchParams.currency as 'IDR' | 'USD' | undefined,
  start_date: searchParams.start_date ? new Date(searchParams.start_date) : undefined,
  end_date: searchParams.end_date ? new Date(searchParams.end_date) : undefined,
  search: searchValue || undefined,
  limit: pageSize,
  offset,
};

// Fetch transactions from database
const rawTransactions = await transactionService.findAll(filters);

// Transform Drizzle result to TransactionOutput format
const transactions: TransactionOutput[] = rawTransactions.map((t: any) => ({
  id: t.id,
  type: t.type,
  amount: t.amount,
  currency: t.currency,
  description: t.description,
  transaction_date: t.transaction_date,
  deleted_at: t.deleted_at,
  created_at: t.created_at,
  updated_at: t.updated_at,
  category: {
    id: t.category.id,
    name: t.category.name,
    type: t.category.type,
  },
  payment_method: {
    id: t.paymentMethod.id,
    name: t.paymentMethod.name,
    type: t.paymentMethod.type,
  },
}));

// Get total count for pagination (without limit/offset)
const { limit, offset: _, ...countFilters } = filters;
const total = await transactionService.count(countFilters);

// Fetch categories for filter dropdowns
const categories = await categoryService.findAll(user.id, { is_active: true });

// For month selector, fetch all months available (optimized query)
const allUserTransactions = await transactionService.findAll({
  user_id: user.id,
  limit: 10000,
});

// Build available months list from transactions using YYYY-MM for consistent sorting
const monthMap = new Map<string, string>();
allUserTransactions.forEach((t: any) => {
  const date = new Date(t.transaction_date);
  const yearMonth = `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}`;
  const monthLabel = date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
  monthMap.set(yearMonth, monthLabel);
});

const availableMonths = Array.from(monthMap.keys())
  .sort()
  .map((key) => monthMap.get(key)!);

// Calculate summary from filtered transactions
let monthlyIncome = 0;
let monthlyExpenses = 0;
let expenseCount = 0;

rawTransactions.forEach((t: any) => {
  if (t.type === 'income') {
    monthlyIncome += parseFloat(t.amount);
  } else {
    monthlyExpenses += Math.abs(parseFloat(t.amount));
    expenseCount++;
  }
});

const currentMonthLabel =
  availableMonths[availableMonths.length - 1] ||
  new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

// Build base URL for navigation
const buildBaseUrl = () => {
  const params = new URLSearchParams();
  if (typeFilter !== 'all') params.set('type', typeFilter);
  if (searchValue) params.set('search', searchValue);
  if (categoryId) params.set('category_id', categoryId);
  const queryString = params.toString();
  return queryString ? `/transactions?${queryString}` : '/transactions';
};

const baseUrl = buildBaseUrl();
---

<ProtectedLayout title="Transactions - Finance Manager" currentPath={currentPath}>
  <div class="animate-in fade-in slide-in-from-bottom-4 duration-500 space-y-8">
    <!-- Summary Cards -->
    <TransactionSummaryCards
      monthlyIncome={monthlyIncome}
      monthlyExpenses={monthlyExpenses}
      transactionCount={expenseCount}
      periodLabel={currentMonthLabel.toUpperCase()}
      currency="IDR"
    />

    <!-- Filters & Transaction List -->
    <div class="space-y-6">
      <!-- Filter Bar -->
      <TransactionFiltersBar
        typeFilter={typeFilter}
        searchValue={searchValue}
        categoryId={categoryId}
        categories={categories}
        showCategoryFilter={true}
        monthSelector={true}
        availableMonths={availableMonths}
        selectedMonth={selectedMonth || currentMonthLabel}
        baseUrl={baseUrl}
      />

      <!-- Transaction List Card -->
      <div class="card bg-base-100 border border-base-300 rounded-3xl shadow-sm overflow-hidden">
        <div class="divide-y divide-base-200">
          {
            transactions.length > 0 ? (
              transactions.map((transaction) => (
                <TransactionRow
                  transaction={transaction}
                  editUrl={`/transactions/edit/${transaction.id}`}
                  deleteUrl={`/transactions/delete/${transaction.id}`}
                  showActions={true}
                />
              ))
            ) : (
              <div class="py-24 text-center">
                <div class="w-20 h-20 bg-base-200 mx-auto rounded-3xl flex items-center justify-center text-base-content/30 mb-6 shadow-inner">
                  <Receipt size={40} class="stroke-current" aria-hidden="true" />
                </div>
                <h4 class="text-lg font-bold text-base-content mb-2">No matching transactions</h4>
                <p class="text-base-content/60 font-medium max-w-xs mx-auto mb-6">
                  Try adjusting your filters or search terms to find what you're looking for.
                </p>
                <a href="/transactions" class="btn btn-outline btn-sm gap-2">
                  <RotateCcw size={16} class="stroke-current" aria-hidden="true" />
                  Reset filters
                </a>
              </div>
            )
          }
        </div>

        <!-- Pagination -->
        {
          total > pageSize && (
            <div class="flex items-center justify-between px-6 py-4 border-t border-base-200">
              <div class="text-sm text-base-content/60">
                Showing {(page - 1) * pageSize + 1} to {Math.min(page * pageSize, total)} of {total}{' '}
                transactions
              </div>
              <div class="flex gap-2">
                {page > 1 ? (
                  <a href={`${baseUrl}&page=${page - 1}`} class="btn btn-sm btn-outline">
                    Previous
                  </a>
                ) : (
                  <button class="btn btn-sm btn-outline" disabled>
                    Previous
                  </button>
                )}

                <span class="btn btn-sm btn-ghost">
                  Page {page} of {Math.ceil(total / pageSize)}
                </span>

                {page < Math.ceil(total / pageSize) ? (
                  <a href={`${baseUrl}&page=${page + 1}`} class="btn btn-sm btn-outline">
                    Next
                  </a>
                ) : (
                  <button class="btn btn-sm btn-outline" disabled>
                    Next
                  </button>
                )}
              </div>
            </div>
          )
        }
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Dialog -->
  <dialog id="delete-dialog" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Delete Transaction</h3>
      <p class="py-4">
        Are you sure you want to delete this transaction? This action cannot be undone.
      </p>
      <div id="delete-dialog-details" class="bg-base-200 rounded-lg p-3 mb-4 text-sm">
        <!-- Transaction details will be inserted here -->
      </div>
      <div id="delete-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn">Cancel</button>
        </form>
        <button id="confirm-delete-btn" class="btn btn-error">Delete Transaction</button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>
</ProtectedLayout>

<script>
  // Delete transaction handling
  const deleteDialog = document.getElementById('delete-dialog') as HTMLDialogElement;
  const deleteButtons = document.querySelectorAll('[data-delete-transaction]');
  const confirmDeleteBtn = document.getElementById('confirm-delete-btn') as HTMLButtonElement;
  const deleteDetails = document.getElementById('delete-dialog-details');
  const deleteError = document.getElementById('delete-error');

  // Helper function to escape HTML
  const escapeHtml = (text: string): string => {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  };

  deleteButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const transactionId = button.getAttribute('data-delete-transaction');
      const transactionDetails = button.getAttribute('data-transaction-details');

      if (transactionDetails && deleteDetails) {
        const tx = JSON.parse(transactionDetails);
        const description = escapeHtml(tx.description || tx.category?.name || '');
        const amount = parseFloat(tx.amount).toLocaleString();
        const currency = escapeHtml(tx.currency || '');
        const date = new Date(tx.transaction_date).toLocaleDateString();

        // Use textContent for safe rendering
        deleteDetails.innerHTML = '';
        const list = document.createElement('dl');
        list.className = 'grid grid-cols-[auto_1fr] gap-2 text-sm';

        const descDt = document.createElement('dt');
        descDt.className = 'font-semibold';
        descDt.textContent = 'Description:';
        const descDd = document.createElement('dd');
        descDd.textContent = description;

        const amountDt = document.createElement('dt');
        amountDt.className = 'font-semibold';
        amountDt.textContent = 'Amount:';
        const amountDd = document.createElement('dd');
        amountDd.textContent = `${currency} ${amount}`;

        const dateDt = document.createElement('dt');
        dateDt.className = 'font-semibold';
        dateDt.textContent = 'Date:';
        const dateDd = document.createElement('dd');
        dateDd.textContent = date;

        list.append(descDt, descDd, amountDt, amountDd, dateDt, dateDd);
        deleteDetails.appendChild(list);
      }

      if (confirmDeleteBtn && transactionId) {
        confirmDeleteBtn.onclick = async () => {
          try {
            const response = await fetch(`/api/transactions/${transactionId}`, {
              method: 'DELETE',
            });

            if (!response.ok) {
              const error = await response.json();
              throw new Error(error.message || 'Failed to delete transaction');
            }

            // Reload page on success
            window.location.reload();
          } catch (err) {
            if (deleteError) {
              deleteError.textContent =
                err instanceof Error ? err.message : 'Failed to delete transaction';
              deleteError.classList.remove('hidden');
            }
          }
        };
      }

      deleteDialog?.showModal();
    });
  });
</script>
