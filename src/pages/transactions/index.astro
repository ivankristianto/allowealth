---
import MainLayout from '../../layouts/MainLayout.astro';

const currentPath = '/transactions';
---

<MainLayout title="Transactions - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h2 class="text-2xl font-bold">Transactions</h2>
      <a href="/transactions/add" class="btn btn-primary">Add Transaction</a>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <div class="flex items-center justify-center py-12">
          <div class="text-center">
            <p class="text-neutral-500">No transactions yet</p>
            <a href="/transactions/add" class="btn btn-primary mt-4">Add Your First Transaction</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</MainLayout>
