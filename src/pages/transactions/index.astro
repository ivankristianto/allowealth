---
/**
 * Transactions List Page
 *
 * Redesigned transactions page with summary cards, filter bar, and transaction list.
 * Matches POC design with premium styling.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import TransactionRow from '@/components/molecules/TransactionRow.astro';
import TransactionSummaryCards from '@/components/organisms/TransactionSummaryCards.astro';
import TransactionActionsBar from '@/components/organisms/TransactionActionsBar.astro';
import TransactionFiltersBar from '@/components/organisms/TransactionFiltersBar.astro';
import DeleteConfirmationModal from '@/components/organisms/DeleteConfirmationModal.astro';
import { Receipt, RotateCcw } from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';
import { transactionService, categoryService } from '@/services';
import {
  parseMonthKey,
  formatMonthKey,
  getCurrentMonthKey,
  createMonthKey,
  safeParseAmount,
} from '@/lib/utils';
import { PAGINATION } from '@/lib/constants/pagination';

const user = Astro.locals.user!;
const currentPath = '/transactions';

// Get query parameters for filtering
const url = new URL(Astro.url);
const searchParams = Object.fromEntries(url.searchParams.entries());

// Pagination
const page = parseInt(searchParams.page || '1');
const pageSize = PAGINATION.DEFAULT_PAGE_SIZE;
const offset = (page - 1) * pageSize;

// Get filter values - default to 'expense' (no 'all' option)
const typeFilter = (searchParams.type === 'income' ? 'income' : 'expense') as 'income' | 'expense';
const categoryId = searchParams.category_id || '';
const categoryIdsParam = searchParams.category_ids || '';
const categoryIds = categoryIdsParam ? categoryIdsParam.split(',').filter(Boolean) : [];
const searchValue = searchParams.search || '';
const selectedMonth = searchParams.month || '';

// Calculate current month key from today's date (used as default)
const todayMonthKey = getCurrentMonthKey();

// Determine effective month (from URL or default to today's month)
const effectiveMonth = selectedMonth || todayMonthKey;
const monthDateRange = parseMonthKey(effectiveMonth);

// Build filters for service - ALWAYS filter by month
const filters = {
  user_id: user.id,
  type: typeFilter as 'expense' | 'income',
  category_id: categoryId || undefined,
  category_ids: categoryIds.length > 0 ? categoryIds : undefined,
  payment_method_id: searchParams.payment_method_id,
  currency: searchParams.currency as 'IDR' | 'USD' | undefined,
  start_date: monthDateRange?.start,
  end_date: monthDateRange?.end,
  search: searchValue || undefined,
  limit: pageSize,
  offset,
};

// Fetch transactions from database
const rawTransactions = await transactionService.findAll(filters);

// Transform Drizzle result to TransactionOutput format
const transactions: TransactionOutput[] = rawTransactions.map((t: any) => ({
  id: t.id,
  type: t.type,
  amount: t.amount,
  currency: t.currency,
  description: t.description,
  transaction_date: t.transaction_date,
  deleted_at: t.deleted_at,
  created_at: t.created_at,
  updated_at: t.updated_at,
  category: {
    id: t.category.id,
    name: t.category.name,
    type: t.category.type,
  },
  payment_method: {
    id: t.paymentMethod.id,
    name: t.paymentMethod.name,
    type: t.paymentMethod.type,
  },
}));

// Get total count for pagination (without limit/offset)
const { limit, offset: _, ...countFilters } = filters;
const total = await transactionService.count(countFilters);

// Fetch categories for filter dropdowns
const categories = await categoryService.findAll(user.id, { is_active: true });

// For month selector, fetch all months available (optimized query)
const allUserTransactions = await transactionService.findAll({
  user_id: user.id,
  limit: PAGINATION.MAX_MONTH_TRANSACTIONS,
});

// Build available months list from transactions
// Key: MM-YYYY (for API), Label: MMMM YYYY (for display)
const monthMap = new Map<string, string>();
allUserTransactions.forEach((t: any) => {
  const date = new Date(t.transaction_date);
  const key = createMonthKey(date);
  const label = formatMonthKey(key);
  monthMap.set(key, label);
});

// Sort months chronologically
const availableMonths = Array.from(monthMap.keys()).sort((a, b) => {
  const [monthA, yearA] = a.split('-').map(Number);
  const [monthB, yearB] = b.split('-').map(Number);
  return yearA !== yearB ? yearA - yearB : monthA - monthB;
});

// Current month key - prefer latest available month, fallback to today's month
const currentMonthKey = availableMonths[availableMonths.length - 1] || todayMonthKey;

// Calculate summary from ALL transactions in the selected month (not filtered)
// Summary only changes when month changes, not when filters change
let monthlyIncome = 0;
let monthlyExpenses = 0;
let expenseCount = 0;

// Calculate from all user transactions for the selected month
allUserTransactions.forEach((t: any) => {
  const txDate = new Date(t.transaction_date);
  const txMonthKey = createMonthKey(txDate);

  if (txMonthKey === effectiveMonth) {
    const amount = safeParseAmount(t.amount);
    if (t.type === 'income') {
      monthlyIncome += amount;
    } else {
      monthlyExpenses += Math.abs(amount);
      expenseCount++;
    }
  }
});

// Build base URL for navigation
const buildBaseUrl = () => {
  const params = new URLSearchParams();
  params.set('type', typeFilter);
  if (searchValue) params.set('search', searchValue);
  if (categoryIds.length > 0) params.set('category_ids', categoryIds.join(','));
  const queryString = params.toString();
  return queryString ? `/transactions?${queryString}` : '/transactions';
};

const baseUrl = buildBaseUrl();

// Build available months with keys for client-side use
// Key: MM-YYYY (for API), Label: MMMM YYYY (for display)
const availableMonthsWithKeys = availableMonths.map((key) => ({
  key,
  label: monthMap.get(key) || key,
}));

// Serialize SSR data for client-side hydration
const ssrData = {
  transactions,
  pagination: {
    total,
    limit: pageSize,
    offset,
    page,
    totalPages: Math.ceil(total / pageSize),
  },
  summary: {
    income: monthlyIncome,
    expenses: monthlyExpenses,
    transactionCount: expenseCount,
    periodLabel: formatMonthKey(effectiveMonth),
  },
  filters: {
    type: typeFilter,
    search: searchValue,
    category_id: categoryId,
    category_ids: categoryIds,
    month: selectedMonth || currentMonthKey,
    page,
  },
  currentMonth: currentMonthKey,
  categories: categories.map((c) => ({ id: c.id, name: c.name, type: c.type })),
  availableMonths: availableMonthsWithKeys,
  currency: 'IDR' as const,
};
---

<ProtectedLayout title="Transactions - Finance Manager" currentPath={currentPath}>
  <div
    id="transactions-page"
    class="max-w-7xl mx-auto px-6 lg:px-10 py-8 space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-500"
    data-ssr-data={JSON.stringify(ssrData)}
  >
    <!-- Summary Cards -->
    <TransactionSummaryCards
      monthlyIncome={monthlyIncome}
      monthlyExpenses={monthlyExpenses}
      transactionCount={expenseCount}
      periodLabel={formatMonthKey(effectiveMonth)}
      currency="IDR"
    />

    <!-- Filters & Transaction List -->
    <div class="space-y-6">
      <!-- Actions Bar (Scan Receipt, Import/Export CSV) -->
      <TransactionActionsBar />

      <!-- Filter Bar -->
      <TransactionFiltersBar
        typeFilter={typeFilter}
        searchValue={searchValue}
        categoryIds={categoryIds}
        categories={categories}
        showCategoryFilter={true}
        monthSelector={true}
        availableMonths={availableMonthsWithKeys}
        selectedMonth={selectedMonth || currentMonthKey}
        currentMonth={currentMonthKey}
        baseUrl={baseUrl}
      />

      <!-- Transaction List Card -->
      <div
        id="transaction-list-card"
        class="card bg-base-100 border border-base-300 rounded-3xl shadow-sm overflow-hidden"
      >
        <!-- Loading Skeleton (hidden by default, shown during fetch) -->
        <div id="transaction-list-skeleton" class="divide-y divide-base-200 hidden">
          {
            Array.from({ length: 5 }).map(() => (
              <div class="flex items-center gap-5 p-5 animate-pulse">
                <div class="flex-shrink-0 w-24">
                  <div class="h-4 bg-base-200 rounded w-20" />
                </div>
                <div class="flex-1 flex items-center gap-4">
                  <div class="w-10 h-10 bg-base-200 rounded-2xl" />
                  <div class="flex-1">
                    <div class="h-4 bg-base-200 rounded w-32 mb-2" />
                    <div class="h-3 bg-base-200 rounded w-20" />
                  </div>
                </div>
                <div class="flex-shrink-0 hidden sm:block">
                  <div class="h-3 bg-base-200 rounded w-16" />
                </div>
                <div class="flex-shrink-0 w-28">
                  <div class="h-5 bg-base-200 rounded w-24 ml-auto" />
                </div>
              </div>
            ))
          }
        </div>

        <!-- Transaction List -->
        <div id="transaction-list" class="divide-y divide-base-200">
          {
            transactions.length > 0 ? (
              transactions.map((transaction) => (
                <TransactionRow transaction={transaction} showActions={true} />
              ))
            ) : (
              <div id="empty-state" class="py-24 text-center">
                <div class="w-20 h-20 bg-base-200 mx-auto rounded-3xl flex items-center justify-center text-base-content/30 mb-6 shadow-inner">
                  <Receipt size={40} class="stroke-current" aria-hidden="true" />
                </div>
                <h4 class="text-lg font-bold text-base-content mb-2">No matching transactions</h4>
                <p class="text-base-content/60 font-medium max-w-xs mx-auto mb-6">
                  Try adjusting your filters or search terms to find what you're looking for.
                </p>
                <a href="/transactions" class="btn btn-outline btn-sm gap-2" data-reset-filters>
                  <RotateCcw size={16} class="stroke-current" aria-hidden="true" />
                  Reset filters
                </a>
              </div>
            )
          }
        </div>

        <!-- Pagination -->
        <div
          id="pagination-container"
          class={`flex items-center justify-between px-6 py-4 border-t border-base-200 ${total <= pageSize ? 'hidden' : ''}`}
          data-pagination
          data-total={total}
          data-page-size={pageSize}
          data-current-page={page}
        >
          <div class="text-sm text-base-content/60" data-pagination-info>
            Showing {(page - 1) * pageSize + 1} to {Math.min(page * pageSize, total)} of {total}{
              ' '
            }
            transactions
          </div>
          <div class="flex gap-2">
            <button
              class="btn btn-sm btn-outline"
              disabled={page <= 1}
              data-pagination-prev
              aria-label="Previous page"
            >
              Previous
            </button>

            <span class="btn btn-sm btn-ghost" data-pagination-current>
              Page {page} of {Math.ceil(total / pageSize)}
            </span>

            <button
              class="btn btn-sm btn-outline"
              disabled={page >= Math.ceil(total / pageSize)}
              data-pagination-next
              aria-label="Next page"
            >
              Next
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <DeleteConfirmationModal
    id="delete-dialog"
    title="Delete Transaction"
    description="Are you sure you want to delete this transaction? This action cannot be undone."
    confirmLabel="Delete Transaction"
    cancelLabel="Cancel"
  />
</ProtectedLayout>

<script>
  // Initialize the interactive transactions page
  import { initTransactionsPage } from '@/components/organisms/TransactionsPage.client';
  initTransactionsPage();
</script>
