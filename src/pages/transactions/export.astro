---
/**
 * CSV Export Page
 *
 * Page for exporting transactions to CSV files with filter support.
 * Wires to real API endpoint for export.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import TransactionFilters from '../../components/molecules/TransactionFilters.astro';
import { Info, Download } from '@lucide/astro';
import { categoryService, assetService } from '@/services';

const user = Astro.locals.user!;
const currentPath = '/transactions/export';

// Fetch categories and assets for filters
const categories = await categoryService.findAll(user.workspaceId, { is_active: true });
const assets = await assetService.findAll(user.workspaceId);

// Get current filters from query params
const url = new URL(Astro.url);
const currentFilters = {
  search: url.searchParams.get('search') || '',
  type: (url.searchParams.get('type') || '') as 'expense' | 'income' | '',
  currency: (url.searchParams.get('currency') || '') as 'IDR' | 'USD' | '',
  category_id: url.searchParams.get('category_id') || '',
  asset_id: url.searchParams.get('asset_id') || '',
  start_date: url.searchParams.get('start_date') || '',
  end_date: url.searchParams.get('end_date') || '',
};

// Build export URL with current filters
const buildExportUrl = () => {
  const params = new URLSearchParams();
  Object.entries(currentFilters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  return `/api/transactions/export?${params.toString()}`;
};

const exportUrl = buildExportUrl();
---

<ProtectedLayout title="Export" currentPath={currentPath} subtitle="Download your transactions">
  <div class="max-w-4xl">
    <div class="mb-6">
      <h2 class="text-2xl font-bold">Export Transactions to CSV</h2>
      <p class="text-neutral-500">Download your transactions as a CSV file</p>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <!-- Instructions -->
        <div class="alert alert-info mb-6">
          <Info size={16} class="stroke-current shrink-0" aria-hidden="true" />
          <div>
            <h3 class="font-bold">Export Options</h3>
            <div class="text-sm mt-2">
              <p>
                Use filters below to select which transactions to export. All matching transactions
                will be included in the CSV file.
              </p>
            </div>
          </div>
        </div>

        <!-- Filters -->
        <div class="mb-6">
          <h3 class="font-semibold mb-4">Filter Transactions</h3>
          <TransactionFilters
            action="/transactions/export"
            categories={categories}
            assets={assets}
            values={currentFilters}
            count={0}
          />
        </div>

        <!-- Export Info & Action -->
        <div class="border-t border-base-300 pt-6">
          <h3 class="font-semibold mb-2">Export Details</h3>
          <ul class="text-sm text-neutral-500 space-y-1 mb-4">
            <li>Filename format: <code>transactions_YYYY-MM-DD.csv</code></li>
            <li>
              Includes all transaction fields: date, type, amount, currency, category, asset,
              description
            </li>
            <li>Uses current filters to select transactions</li>
          </ul>

          <!-- Export Button -->
          <a href={exportUrl} class="btn btn-accent gap-2" download>
            <Download size={16} class="stroke-current" aria-hidden="true" />
            Download CSV Export
          </a>
        </div>
      </div>
    </div>
  </div>
</ProtectedLayout>
