---
/**
 * Add Transaction Page
 *
 * Page for adding a new transaction.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import TransactionForm from '../../components/molecules/TransactionForm.astro';
import { categoryService, assetService, budgetService } from '@/services';

const user = Astro.locals.user!;
const currentPath = '/transactions/add';

// Fetch categories and assets from database
const categories = await categoryService.findAll(user.id, { is_active: true });
const assets = await assetService.findAll(user.id);

// Get transaction type from query param (default: expense)
const url = new URL(Astro.url);
const transactionType = (url.searchParams.get('type') || 'expense') as 'expense' | 'income';

// Get form values from URL params for pre-filling
const formValues = {
  type: transactionType,
  currency: (url.searchParams.get('currency') || 'IDR') as 'IDR' | 'USD',
  amount: url.searchParams.get('amount') || '',
  category_id: url.searchParams.get('category_id') || '',
  asset_id: url.searchParams.get('asset_id') || '',
  transaction_date: url.searchParams.get('transaction_date') || '',
  description: url.searchParams.get('description') || '',
};

// Get budget remaining for the selected category (for expense type only)
let budgetRemaining = '0';
let budgetRemainingCurrency: 'IDR' | 'USD' = 'IDR';
let budgetInfo: {
  category_id: string;
  remaining: string;
  percentage_used: string;
  budget_amount: string;
} | null = null;

if (transactionType === 'expense' && formValues.category_id) {
  try {
    // Use transaction currency for budget lookup since categories no longer have currency
    const budgetData = await budgetService.getCategoryRemaining(
      formValues.category_id,
      user.id,
      formValues.currency
    );
    budgetRemaining = budgetData.remaining;
    budgetRemainingCurrency = formValues.currency;
    budgetInfo = {
      category_id: budgetData.category_id,
      remaining: budgetData.remaining,
      percentage_used: budgetData.percentage_used,
      budget_amount: budgetData.budget_amount,
    };
  } catch {
    // Category might not have a budget or budget calculation failed
    budgetRemaining = '0';
  }
}
---

<ProtectedLayout title="Add Transaction - Finance Manager" currentPath={currentPath}>
  <div class="max-w-2xl">
    <div class="mb-6">
      <h2 class="text-2xl font-bold">Add Transaction</h2>
      <p class="text-neutral-500">Record a new expense or income</p>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <TransactionForm
          action="/api/transactions"
          method="POST"
          values={formValues}
          categories={categories}
          assets={assets}
          transactionType={transactionType}
          submitLabel="Save Transaction"
          cancelUrl="/transactions"
          showBudgetWarning={transactionType === 'expense'}
          budgetRemaining={budgetRemaining}
          budgetRemainingCurrency={budgetRemainingCurrency}
          budgetInfo={budgetInfo}
        />
      </div>
    </div>
  </div>
</ProtectedLayout>
