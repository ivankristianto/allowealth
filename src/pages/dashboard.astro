---
/**
 * Dashboard Page
 *
 * Main dashboard showing financial overview, quick stats, and recent activity.
 * Protected by authentication.
 *
 * Displays:
 * - Quick actions (Add Expense, Log Income)
 * - Total accounts (IDR + USD)
 * - Monthly spending vs budget
 * - Budget health alerts
 * - Spending summary card with progress
 * - Spending analysis chart
 * - Recent transactions
 * - Net worth widget
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { dashboardService, mfaService, workspaceMetaService, workspaceService } from '@/services';
import type { DashboardData } from '@/services/dashboard.service';
import type { OnboardingStatus } from '@/services/workspace.service';
import SpendingCard from '@/components/organisms/SpendingCard.astro';
import SpendingChart from '@/components/organisms/SpendingChart.astro';
import AccountsWidget from '@/components/organisms/AccountsWidget.astro';
import CashFlowWidget from '@/components/organisms/CashFlowWidget.astro';
import RecentTransactionsList from '@/components/molecules/RecentTransactionsList.astro';
import DashboardError from '@/components/molecules/DashboardError.astro';
import OnboardingChecklist from '@/components/organisms/OnboardingChecklist.astro';
import MfaEnableBanner from '@/components/molecules/MfaEnableBanner.astro';
import type { TransactionOutput } from '@/lib/types/transaction';
import type { CashFlowEntry, CashFlowIconName } from '@/lib/cash-flow';
import { MONTH_NAMES_SHORT } from '@/lib/utils/date';
import { isValidCurrency, type Currency } from '@/lib/constants/currency';

const currentPath = '/dashboard';
const user = Astro.locals.user;
const perf = Astro.locals.perf;

// Get current month and year
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();
const activeCurrencyCookie = Astro.cookies.get('activeCurrency')?.value;

// Check onboarding status and get currency
let onboardingStatus: OnboardingStatus | null = null;
let isOnboardingComplete = false;
let primaryCurrency: Currency | null = null;
let secondaryCurrency: Currency | null = null;
let selectedDetailCurrency: Currency | null = null;
let dashboardData: DashboardData | null = null;
let error: Error | null = null;
let mfaEnabled = false;

try {
  if (!user) {
    throw new Error('User not authenticated. Please log in again.');
  }

  // Get onboarding status (parallel queries)
  onboardingStatus = await workspaceService.getOnboardingStatus(user.workspaceId);

  // Validate currency from workspace meta before computing completion
  if (onboardingStatus.currency) {
    const primaryValue = await workspaceMetaService.getCurrency(user.workspaceId);
    primaryCurrency = isValidCurrency(primaryValue) ? primaryValue : null;

    const secondaryValue = await workspaceMetaService.getSecondaryCurrency(user.workspaceId);
    secondaryCurrency = secondaryValue && isValidCurrency(secondaryValue) ? secondaryValue : null;
  }

  // Tie completion to validated currency so checklist stays visible if currency is unsupported
  isOnboardingComplete =
    Boolean(primaryCurrency) &&
    onboardingStatus.categories &&
    onboardingStatus.budgets &&
    onboardingStatus.accounts &&
    onboardingStatus.transactions;

  // Only fetch dashboard data if currency is set
  if (primaryCurrency) {
    const availableCurrencies = [
      primaryCurrency,
      ...(secondaryCurrency ? [secondaryCurrency] : []),
    ];
    selectedDetailCurrency =
      activeCurrencyCookie &&
      isValidCurrency(activeCurrencyCookie) &&
      availableCurrencies.includes(activeCurrencyCookie)
        ? activeCurrencyCookie
        : primaryCurrency;

    dashboardData = await dashboardService.getDashboardData(
      user.workspaceId,
      currentMonth,
      currentYear,
      selectedDetailCurrency,
      perf
    );
  }

  // Check MFA status for encouragement banner
  try {
    const mfaStatus = await mfaService.getStatus(user.id);
    mfaEnabled = mfaStatus.enabled;
  } catch {
    // Non-critical for dashboard rendering
  }
} catch (err) {
  console.error('Error loading dashboard data:', err);
  error = err instanceof Error ? err : new Error('Unknown error occurred');
  dashboardData = null;
}

// Categories and accounts for transaction modals are provided by ProtectedLayout

// Get month name for remaining label
const currentMonthName = MONTH_NAMES_SHORT[currentMonth - 1];

// Transform recent transactions to match component format
const recentTransactions: TransactionOutput[] =
  dashboardData?.recentTransactions.map((tx) => ({
    id: tx.id,
    type: tx.type,
    amount: tx.amount,
    currency: tx.currency,
    description: tx.description,
    transaction_date: tx.transactionDate,
    updated_by_user_id: null,
    deleted_by_user_id: null,
    deleted_at: null,
    created_at: new Date(),
    updated_at: new Date(),
    category: tx.category
      ? {
          id: tx.category.id,
          name: tx.category.name,
          type: tx.category.type,
          icon: tx.category.icon,
          color: tx.category.color,
        }
      : null,
    account: {
      id: tx.account.id,
      name: tx.account.name,
      type: tx.account.type,
    },
    has_history: tx.hasHistory,
    created_by_user_name: tx.createdByName,
  })) || [];

const formatCashFlowDate = (date: Date | string): string => {
  const d = typeof date === 'string' ? new Date(date) : date;
  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: '2-digit',
    year: 'numeric',
  });
};

// Safe parseFloat helper to prevent NaN propagation
const safeParseFloat = (value: string | undefined | null): number => {
  const parsed = parseFloat(value ?? '0');
  return Number.isFinite(parsed) ? parsed : 0;
};

const accountTotalsByCurrency = (dashboardData?.totalAccounts.byCurrency ?? []).map((row) => ({
  currency: row.currency,
  amount: safeParseFloat(row.amount),
}));
const debtTotalsByCurrency = (dashboardData?.totalDebt.byCurrency ?? []).map((row) => ({
  currency: row.currency,
  amount: safeParseFloat(row.amount),
}));
// Filter out transfer transactions for cash flow widget (only supports income/expense)
const cashFlowItems: CashFlowEntry[] =
  dashboardData?.recentTransactions
    .filter((tx) => tx.type === 'income' || tx.type === 'expense')
    .slice(0, 2)
    .map((tx) => ({
      name: tx.description?.trim() || tx.category.name,
      date: formatCashFlowDate(tx.transactionDate),
      amount: safeParseFloat(tx.amount),
      type: tx.type as 'income' | 'expense',
      icon: (tx.type === 'income' ? 'trending-up' : 'calendar') as CashFlowIconName,
      currency: tx.currency,
    })) || [];

// Get spending categories from dashboard data (top 4 + Other)
const spendingCategories =
  dashboardData?.topCategoryExpenses.map((cat) => ({
    category: cat.category,
    percentage: cat.percentage,
    color: cat.color,
    otherCategoryNames: cat.otherCategoryNames,
  })) ?? [];
---

<ProtectedLayout
  title="Dashboard"
  currentPath={currentPath}
  subtitle={`Welcome back! ${currentMonthName} ${currentYear}`}
>
  <div
    class="@container max-w-7xl mx-auto @sm:px-2 @3xl:px-6 space-y-6 @sm:space-y-8"
    data-testid="dashboard-page"
  >
    <!-- Error State -->
    {
      error && (
        <DashboardError
          message="Unable to load dashboard data. Please try again."
          details={import.meta.env.DEV ? error.message : undefined}
        />
      )
    }

    <!-- Onboarding Checklist (shown when setup is incomplete) -->
    {onboardingStatus && !isOnboardingComplete && <OnboardingChecklist status={onboardingStatus} />}

    {/* MFA Encouragement Banner (shown when MFA not enabled and onboarding is complete) */}
    {isOnboardingComplete && !mfaEnabled && <MfaEnableBanner />}

    <!-- Dashboard Content (only shown when currency is set) -->
    {
      !error && primaryCurrency && (
        <>
          {/* Spending Summary Card & Spending Analysis Chart (side by side) */}
          <div class="grid grid-cols-1 @3xl:grid-cols-2 gap-6 @sm:gap-8">
            <SpendingCard
              spent={safeParseFloat(dashboardData?.monthlySpent.total)}
              budget={safeParseFloat(dashboardData?.monthlySpent.budget)}
              income={safeParseFloat(dashboardData?.monthlyIncome.total)}
              currency={selectedDetailCurrency || primaryCurrency}
              remainingLabel={`Budget Remaining for ${currentMonthName}`}
              loading={!dashboardData}
            />
            <SpendingChart
              data={spendingCategories}
              totalSpent={safeParseFloat(dashboardData?.monthlySpent.total)}
              totalBudget={safeParseFloat(dashboardData?.monthlySpent.budget)}
              loading={!dashboardData}
            />
          </div>

          {/* Recent Transactions & Net Worth Widget (side by side) */}
          <div class="grid grid-cols-1 @min-[52rem]:grid-cols-3 gap-6 @sm:gap-8">
            <div class="@min-[52rem]:col-span-2">
              <RecentTransactionsList
                transactions={recentTransactions}
                loading={!dashboardData}
                viewAllUrl="/transactions"
              />
            </div>

            <div class="space-y-6 @sm:space-y-8">
              <AccountsWidget
                accountTotals={accountTotalsByCurrency}
                debtTotals={debtTotalsByCurrency}
                primaryCurrency={primaryCurrency}
                secondaryCurrency={secondaryCurrency}
                loading={!dashboardData}
              />
              <CashFlowWidget items={cashFlowItems} loading={!dashboardData} />
            </div>
          </div>
        </>
      )
    }
  </div>
</ProtectedLayout>

<style>
  /* Ensure smooth loading transitions */
  [data-recent-transactions-list] {
    transition: opacity 0.2s ease-in-out;
  }
</style>
