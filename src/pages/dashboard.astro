---
/**
 * Dashboard Page
 *
 * Main dashboard showing financial overview, quick stats, and recent activity.
 * Protected by authentication.
 */

import MainLayout from '../layouts/MainLayout.astro';
import { requireAuth } from '@/lib/auth/requireAuth';

// Check authentication - redirect to login if not authenticated
const redirectResponse = requireAuth(Astro);
if (redirectResponse) {
  return redirectResponse;
}

// User is authenticated - get user data
const user = Astro.locals.user;
const currentPath = '/dashboard';
---

<MainLayout title="Dashboard - Finance Manager" currentPath={currentPath} user={user}>
  <div class="space-y-6">
    <!-- Welcome Section -->
    <div class="card bg-base-100 shadow-lg border border-base-300">
      <div class="card-body">
        <h2 class="card-title text-2xl">
          Welcome back, {user?.attributes?.name || 'User'}!
        </h2>
        <p class="text-neutral-600">
          Track your expenses, manage budgets, and monitor your assets.
        </p>
      </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid gap-6 md:grid-cols-3">
      <div class="card bg-base-100 shadow border border-base-300">
        <div class="card-body">
          <h3 class="card-title text-primary">Total Assets</h3>
          <p class="text-2xl font-bold">IDR 100M</p>
          <p class="text-sm text-neutral-500">~USD 6,622</p>
        </div>
      </div>

      <div class="card bg-base-100 shadow border border-base-300">
        <div class="card-body">
          <h3 class="card-title text-warning">This Month</h3>
          <p class="text-2xl font-bold">40.6M / 101M</p>
          <p class="text-sm text-neutral-500">40% of budget</p>
        </div>
      </div>

      <div class="card bg-base-100 shadow border border-base-300">
        <div class="card-body">
          <h3 class="card-title text-error">Alerts</h3>
          <p class="text-2xl font-bold">3</p>
          <p class="text-sm text-neutral-500">Budget warnings</p>
        </div>
      </div>
    </div>

    <!-- Recent Activity Placeholder -->
    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <h3 class="card-title">Recent Activity</h3>
        <p class="text-neutral-500">No recent transactions to display.</p>
      </div>
    </div>
  </div>
</MainLayout>
