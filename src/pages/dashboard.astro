---
/**
 * Dashboard Page
 *
 * Main dashboard showing financial overview, quick stats, and recent activity.
 * Protected by authentication.
 *
 * Displays:
 * - Quick actions (Add Expense, Log Income)
 * - Total assets (IDR + USD)
 * - Monthly spending vs budget
 * - Budget health alerts
 * - Spending summary card with progress
 * - Recent transactions
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { dashboardService } from '@/services';
import type { DashboardData } from '@/services/dashboard.service';
import SummaryCards from '@/components/organisms/SummaryCards.astro';
import SpendingCard from '@/components/organisms/SpendingCard.astro';
import RecentTransactionsList from '@/components/organisms/RecentTransactionsList.astro';
import QuickActions from '@/components/molecules/QuickActions.astro';
import DashboardError from '@/components/organisms/DashboardError.astro';
import type { TransactionOutput } from '@/lib/types/transaction';

const currentPath = '/dashboard';
const user = Astro.locals.user!;

// Get current month and year
const now = new Date();
const currentMonth = now.getMonth() + 1;
const currentYear = now.getFullYear();

// Fetch dashboard data using parallel promises
let dashboardData: DashboardData | null = null;
let error: Error | null = null;

try {
  dashboardData = await dashboardService.getDashboardData(
    user.id,
    currentMonth,
    currentYear,
    'IDR' // Primary currency
  );
} catch (err) {
  console.error('Error loading dashboard data:', err);
  error = err instanceof Error ? err : new Error('Unknown error occurred');
  dashboardData = null;
}

// Transform service data to component formats
const summaryCardsData = dashboardData
  ? {
      totalAssets: {
        idr: dashboardData.totalAssets.idr,
        usd: dashboardData.totalAssets.usd,
        converted: dashboardData.totalAssets.converted,
        convertedCurrency: dashboardData.totalAssets.convertedCurrency,
      },
      monthlySpent: {
        spent: dashboardData.monthlySpent.total,
        budget: dashboardData.monthlySpent.budget,
        currency: 'IDR' as const,
        percentage: dashboardData.monthlySpent.percentage,
      },
      budgetHealth: {
        alertCount: dashboardData.budgetHealth.alertCount,
        status: dashboardData.budgetHealth.status,
      },
    }
  : undefined;

// Get month name for remaining label
const monthNames = [
  'Jan',
  'Feb',
  'Mar',
  'Apr',
  'May',
  'Jun',
  'Jul',
  'Aug',
  'Sep',
  'Oct',
  'Nov',
  'Dec',
];
const currentMonthName = monthNames[currentMonth - 1];

// Transform recent transactions to match component format
const recentTransactions: TransactionOutput[] =
  dashboardData?.recentTransactions.map((tx) => ({
    id: tx.id,
    type: tx.type,
    amount: tx.amount,
    currency: tx.currency,
    description: tx.description,
    transaction_date: tx.transactionDate,
    deleted_at: null,
    created_at: new Date(),
    updated_at: new Date(),
    category: {
      id: tx.category.id,
      name: tx.category.name,
      type: tx.category.type,
    },
    payment_method: {
      id: tx.paymentMethod.id,
      name: tx.paymentMethod.name,
      type: 'other', // Default type for now
    },
  })) || [];
---

<ProtectedLayout title="Dashboard - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    <!-- Error State -->
    {
      error && (
        <DashboardError
          message="Unable to load dashboard data. Please try again."
          details={import.meta.env.DEV ? error.message : undefined}
        />
      )
    }

    <!-- Dashboard Content -->
    {
      !error && (
        <>
          {/* Quick Actions - Direct rendering, no wrapper */}
          <QuickActions />

          {/* Summary Cards */}
          <SummaryCards data={summaryCardsData} loading={!dashboardData} error={false} />

          {/* Main Content Grid */}
          <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            {/* Spending Summary Card (2 columns wide) */}
            <div class="lg:col-span-2">
              <SpendingCard
                spent={parseFloat(dashboardData?.monthlySpent.total ?? '0')}
                budget={parseFloat(dashboardData?.monthlySpent.budget ?? '0')}
                currency="IDR"
                remainingLabel={`Remaining for ${currentMonthName}`}
                alertMessage={
                  dashboardData?.monthlySpent.percentage &&
                  dashboardData.monthlySpent.percentage >= 80
                    ? `You've reached ${Math.round(dashboardData.monthlySpent.percentage)}% of your monthly budget.`
                    : undefined
                }
                loading={!dashboardData}
              />
            </div>
          </div>

          {/* Recent Transactions */}
          <RecentTransactionsList
            transactions={recentTransactions}
            loading={!dashboardData}
            viewAllUrl="/transactions"
          />
        </>
      )
    }
  </div>
</ProtectedLayout>

<style>
  /* Ensure smooth loading transitions */
  [data-summary-cards],
  [data-recent-transactions-list] {
    transition: opacity 0.2s ease-in-out;
  }
</style>
