---
import AuthLayout from '@/layouts/AuthLayout.astro';
import PasswordField from '@/components/atoms/PasswordField.astro';
import Button from '@/components/atoms/Button.astro';
import { CircleCheck, CircleX } from '@lucide/astro';

const token = Astro.url.searchParams.get('token') || '';
const error = Astro.url.searchParams.get('error') || '';

const errorMessages: Record<string, string> = {
  INVALID_TOKEN: 'This reset link is invalid or has expired.',
  invalid_token: 'This reset link is invalid or has expired.',
};

const pageError = errorMessages[error] || '';
---

<AuthLayout title="allowealth - Reset Password">
  <div class="card bg-base-100 shadow-2xl border border-base-300">
    <div class="card-body p-8">
      <h2 class="card-title text-2xl font-bold mb-2 justify-center">Reset Password</h2>
      <p class="text-sm text-base-content/60 mb-6 text-center">
        Create a new password for your account.
      </p>

      <div id="reset-password-messages" aria-live="polite" aria-atomic="true">
        {
          pageError && (
            <div role="alert" class="alert alert-error">
              <CircleX size={24} class="shrink-0" aria-hidden="true" />
              <span>{pageError}</span>
            </div>
          )
        }
      </div>

      {
        token ? (
          <form id="reset-password-form" class="space-y-5" novalidate data-token={token}>
            <PasswordField
              id="password"
              name="password"
              label="New Password"
              placeholder="Create a strong password"
              required={true}
              showStrength={true}
              showRequirements={true}
            />

            <PasswordField
              id="confirm-password"
              name="confirm-password"
              label="Confirm Password"
              placeholder="Re-enter your new password"
              required={true}
            />

            <div class="pt-2">
              <Button
                id="reset-password-submit-button"
                type="submit"
                variant="accent"
                className="w-full"
              >
                <span data-button-text>Update Password</span>
                <span data-loading-spinner class="hidden">
                  <span class="loading loading-spinner" />
                  Updating...
                </span>
              </Button>
            </div>

            <div class="text-center text-sm pt-4 border-t border-base-300">
              <a href="/login" class="link link-primary font-semibold ml-1" data-astro-reload>
                Back to sign in
              </a>
            </div>
          </form>
        ) : (
          <div class="space-y-4">
            <div role="alert" class="alert alert-error">
              <CircleX size={24} class="shrink-0" aria-hidden="true" />
              <span>This reset link is invalid or has expired.</span>
            </div>

            <a href="/forgot-password" class="btn btn-accent w-full">
              Request a new reset link
            </a>
          </div>
        )
      }
    </div>
  </div>
</AuthLayout>

<div id="icon-error-template-reset" class="hidden" aria-hidden="true">
  <CircleX size={24} class="shrink-0" />
</div>
<div id="icon-success-template-reset" class="hidden" aria-hidden="true">
  <CircleCheck size={24} class="shrink-0" />
</div>

<script>
  import { authClient } from '@/lib/auth/client';

  const form = document.getElementById('reset-password-form') as HTMLFormElement | null;
  const messagesContainer = document.getElementById('reset-password-messages');
  const passwordInput = document.getElementById('password') as HTMLInputElement | null;
  const confirmPasswordInput = document.getElementById(
    'confirm-password'
  ) as HTMLInputElement | null;
  const submitButton = document.getElementById(
    'reset-password-submit-button'
  ) as HTMLButtonElement | null;
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  const cloneIcon = (templateId: string): HTMLElement | null => {
    const template = document.getElementById(templateId);
    if (!template?.firstElementChild) return null;
    return template.firstElementChild.cloneNode(true) as HTMLElement;
  };

  const showAlert = (message: string, type: 'error' | 'success'): void => {
    if (!messagesContainer) return;

    messagesContainer.innerHTML = '';

    const alertDiv = document.createElement('div');
    alertDiv.setAttribute('role', type === 'error' ? 'alert' : 'status');
    alertDiv.className = type === 'error' ? 'alert alert-error' : 'alert alert-success';

    const icon = cloneIcon(
      type === 'error' ? 'icon-error-template-reset' : 'icon-success-template-reset'
    );
    if (icon) {
      alertDiv.appendChild(icon);
    }

    const textSpan = document.createElement('span');
    textSpan.textContent = message;
    alertDiv.appendChild(textSpan);

    messagesContainer.appendChild(alertDiv);
  };

  if (form && passwordInput && confirmPasswordInput && submitButton) {
    form.addEventListener('submit', async (event) => {
      event.preventDefault();

      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      const password = passwordInput.value.trim();
      const confirmPassword = confirmPasswordInput.value.trim();
      const token = form.dataset.token || '';

      if (!password) {
        showAlert('Please enter a new password.', 'error');
        return;
      }

      if (password !== confirmPassword) {
        showAlert('Passwords do not match.', 'error');
        return;
      }

      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      submitButton.disabled = true;

      try {
        const result = await authClient.resetPassword({
          newPassword: password,
          token,
        });

        if (result.error) {
          showAlert(result.error.message || 'Unable to reset your password.', 'error');
          return;
        }

        showAlert('Password updated. Redirecting to sign in...', 'success');
        setTimeout(() => {
          window.location.href = '/login?password-reset=true';
        }, 800);
      } catch (error) {
        console.error('Reset password error:', error);
        showAlert('Unable to reset your password.', 'error');
      } finally {
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        submitButton.disabled = false;
      }
    });
  }
</script>
