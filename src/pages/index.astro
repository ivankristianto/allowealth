---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatCurrency, formatPercentage } from '../lib/tokens';
---

<BaseLayout title="Finance Manager - Home">
  <div class="min-h-screen bg-base-100">
    <!-- Main container -->
    <div class="container mx-auto px-4 py-8">
      <!-- Header -->
      <header class="mb-8">
        <h1 class="text-5xl font-bold text-primary">Finance Manager</h1>
        <p class="text-lg text-base-content/70 mt-2">Personal & Family Financial Tracking</p>
      </header>

      <!-- Test cards to verify Tailwind + DaisyUI + Design Tokens -->
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Primary card - Total Assets -->
        <div class="card bg-base-100 shadow-lg border border-base-300">
          <div class="card-body">
            <h2 class="card-title text-primary">Total Assets</h2>
            <p class="text-3xl font-mono font-bold currency-idr">IDR 100,000,000</p>
            <p class="text-sm text-base-content/60 currency-usd">~USD 6,622</p>
            <div class="card-actions justify-end">
              <button class="btn btn-primary btn-sm">View Details</button>
            </div>
          </div>
        </div>

        <!-- Warning card - Monthly Budget -->
        <div class="card bg-base-100 shadow-lg border border-base-300">
          <div class="card-body">
            <h2 class="card-title text-warning">This Month Spent</h2>
            <p class="text-3xl font-mono font-bold">40.6M / 101M</p>
            <div class="w-full bg-base-200 rounded-full h-2.5 mt-2">
              <div class="bg-warning h-2.5 rounded-full" style="width: 40%"></div>
            </div>
            <p class="text-sm text-base-content/60">40% of budget used</p>
          </div>
        </div>

        <!-- Alert card - Budget Alerts -->
        <div class="card bg-base-100 shadow-lg border border-base-300">
          <div class="card-body">
            <h2 class="card-title text-error">Budget Alerts</h2>
            <div class="badge badge-error gap-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                ></path>
              </svg>
              2 alerts
            </div>
            <ul class="text-sm mt-2 space-y-1">
              <li class="flex items-center gap-2 status-danger">
                <span class="w-2 h-2 rounded-full bg-error"></span>
                Belanja Rumah exceeded
              </li>
              <li class="flex items-center gap-2 status-warning">
                <span class="w-2 h-2 rounded-full bg-warning"></span>
                Ivan Expenses at 81%
              </li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Design Tokens Verification -->
      <div class="mt-12">
        <h2 class="text-2xl font-bold mb-6">Design System Verification</h2>

        <div class="grid gap-6 md:grid-cols-2">
          <!-- Typography Scale -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h3 class="card-title text-lg">Typography Scale</h3>
              <div class="space-y-2">
                <p class="text-xs">Extra Small (12px)</p>
                <p class="text-sm">Small (14px)</p>
                <p class="text-base">Base (16px)</p>
                <p class="text-lg">Large (18px)</p>
                <p class="text-xl">Extra Large (20px)</p>
                <p class="text-2xl">2XL (24px)</p>
                <p class="font-mono font-compact">Monospace Compact (numbers)</p>
              </div>
            </div>
          </div>

          <!-- Color Palette -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h3 class="card-title text-lg">Color Palette</h3>
              <div class="space-y-2">
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-primary"></div>
                  <span>Primary (Growth)</span>
                </div>
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-warning"></div>
                  <span>Warning (Alerts)</span>
                </div>
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-error"></div>
                  <span>Error (Over Budget)</span>
                </div>
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-success"></div>
                  <span>Success</span>
                </div>
                <div class="flex items-center gap-2">
                  <div class="w-6 h-6 rounded bg-info"></div>
                  <span>Info</span>
                </div>
              </div>
            </div>
          </div>

          <!-- Status Indicators -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h3 class="card-title text-lg">Budget Status Indicators</h3>
              <div class="space-y-2">
                <p class="status-ok font-semibold">● OK - Under 80% spent</p>
                <p class="status-warning font-semibold">● Warning - 80-99% spent</p>
                <p class="status-danger font-semibold">● Danger - Over 100% spent</p>
              </div>
            </div>
          </div>

          <!-- Token Functions -->
          <div class="card bg-base-200">
            <div class="card-body">
              <h3 class="card-title text-lg">Token Functions</h3>
              <div class="space-y-1 text-sm font-mono">
                <p>formatCurrency(1000000) = {formatCurrency(1000000)}</p>
                <p>formatCurrency(5000, 'USD') = {formatCurrency(5000, 'USD')}</p>
                <p>formatCompactNumber(1500000) = {formatCurrency(1500000, 'IDR', true)}</p>
                <p>getBudgetStatusClass(85%) = <span class="status-warning">warning</span></p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Setup Checklist -->
      <div class="mt-12 p-6 bg-base-200 rounded-lg">
        <h3 class="text-lg font-semibold mb-4">Phase 0: Design System Setup Checklist</h3>
        <div class="grid md:grid-cols-2 gap-4">
          <div>
            <h4 class="font-semibold mb-2">✅ Completed</h4>
            <ul class="space-y-1 text-sm">
              <li class="flex items-center gap-2 text-success">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                Bun + Astro project
              </li>
              <li class="flex items-center gap-2 text-success">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                Tailwind CSS v4 + DaisyUI v5
              </li>
              <li class="flex items-center gap-2 text-success">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                Design Tokens (CSS + TS)
              </li>
              <li class="flex items-center gap-2 text-success">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                Folder structure
              </li>
              <li class="flex items-center gap-2 text-success">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M5 13l4 4L19 7"></path></svg
                >
                Base layout
              </li>
            </ul>
          </div>
          <div>
            <h4 class="font-semibold mb-2">🔄 In Progress / Next</h4>
            <ul class="space-y-1 text-sm">
              <li class="flex items-center gap-2 text-warning">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
                Code Quality Tools (ESLint, Prettier)
              </li>
              <li class="flex items-center gap-2 text-base-content/60">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
                Atomic Components (Storybook)
              </li>
              <li class="flex items-center gap-2 text-base-content/60">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
                Layout Components
              </li>
              <li class="flex items-center gap-2 text-base-content/60">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-4 w-4"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg
                >
                Routing & Navigation
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
