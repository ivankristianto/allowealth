---
import MainLayout from '../layouts/MainLayout.astro';

const currentPath = '/';
---

<MainLayout title="Finance Manager" currentPath={currentPath}>
  <div class="hero min-h-screen bg-base-200">
    <div class="hero-content text-center">
      <div class="max-w-md">
        <h1 class="text-5xl font-bold">Finance Manager</h1>
        <p class="py-6">Track expenses, manage budgets, and monitor your assets with ease.</p>
        <a href="/dashboard" class="btn btn-primary">Go to Dashboard</a>
      </div>
    </div>
  </div>
</MainLayout>
