---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Typography Test - Finance Manager">
  <div class="min-h-screen bg-base-100">
    <div class="container mx-auto px-4 py-8">
      <header class="mb-8">
        <h1 class="text-4xl font-bold text-primary">Tailwind Typography Plugin</h1>
        <p class="text-lg text-base-content/70 mt-2">Prose styling for rich content</p>
      </header>

      <!-- Example prose with different content -->
      <div class="grid gap-8 lg:grid-cols-2">
        <div class="card bg-base-100 shadow-lg border border-base-300">
          <div class="card-body">
            <h2 class="card-title text-primary">Default Prose</h2>
            <div class="prose max-w-none">
              <h3>Typography in Finance</h3>
              <p>
                The <strong>typography plugin</strong> provides beautiful default styles for prose content.
                This is perfect for:
              </p>
              <ul>
                <li>Blog posts and articles</li>
                <li>Documentation pages</li>
                <li>Financial reports</li>
                <li>User-generated content</li>
              </ul>
              <blockquote>
                <p>"Good typography is invisible—it lets the content shine through."</p>
              </blockquote>
              <p>
                The <code>prose</code> class automatically styles all child elements with appropriate
                typography scales, colors, and spacing.
              </p>
            </div>
          </div>
        </div>

        <div class="card bg-base-100 shadow-lg border border-base-300">
          <div class="card-body">
            <h2 class="card-title text-primary">Finance Content Example</h2>
            <div class="prose max-w-none">
              <h4>Monthly Budget Report</h4>
              <p>
                In <strong>January 2026</strong>, we tracked our expenses across
                <em>20 budget categories</em>. Here's what we found:
              </p>
              <table>
                <thead>
                  <tr>
                    <th>Category</th>
                    <th>Budget</th>
                    <th>Spent</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <td>Food & Groceries</td>
                    <td>Rp 6.000.000</td>
                    <td>Rp 5.750.000</td>
                  </tr>
                  <tr>
                    <td>Transportation</td>
                    <td>Rp 2.000.000</td>
                    <td>Rp 1.800.000</td>
                  </tr>
                </tbody>
              </table>
              <p>
                <mark>Total savings this month: Rp 95,000,000</mark>
              </p>
              <hr />
              <p><small>Last updated: January 3, 2026</small></p>
            </div>
          </div>
        </div>
      </div>

      <!-- Code example -->
      <div class="mt-8 card bg-base-200">
        <div class="card-body">
          <h3 class="card-title">Usage Example</h3>
          <div class="mockup-code">
            <pre><code>// Apply prose class to any content container
&lt;div class="prose"&gt;
  &lt;h1&gt;Title&lt;/h1&gt;
  &lt;p&gt;Paragraph text...&lt;/p&gt;
  &lt;ul&gt;
    &lt;li&gt;List item&lt;/li&gt;
  &lt;/ul&gt;
&lt;/div&gt;

// With sizing modifiers
&lt;div class="prose prose-sm"&gt;...&lt;/div&gt;
&lt;div class="prose prose-lg"&gt;...&lt;/div&gt;
&lt;div class="prose prose-xl"&gt;...&lt;/div&gt;

// With color theme
&lt;div class="prose prose-neutral"&gt;...&lt;/div&gt;</code></pre>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
