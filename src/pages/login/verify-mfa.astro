---
/**
 * MFA Verification Page
 *
 * Displayed after successful password login when MFA is enabled.
 * User enters their TOTP code or backup code to complete login.
 */

import AuthLayout from '@/layouts/AuthLayout.astro';
import MfaVerifyForm from '@/components/molecules/MfaVerifyForm.astro';
import { sanitizePostAuthRedirect } from '@/lib/auth/redirect';

const url = new URL(Astro.request.url);
const redirect = sanitizePostAuthRedirect(url.searchParams.get('redirect'));
---

<AuthLayout title="allowealth - Verify Identity">
  <MfaVerifyForm redirectTo={redirect} />
</AuthLayout>
