---
/**
 * Signup Page
 *
 * User registration page for creating a new account in the Finance Manager application.
 */

import AuthLayout from '../layouts/AuthLayout.astro';
import Input from '../components/atoms/Input.astro';
import PasswordField from '../components/atoms/PasswordField.astro';
import Label from '../components/atoms/Label.astro';
import Button from '../components/atoms/Button.astro';

// Get error message from query params (if any)
const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');

const errorMessages: Record<string, string> = {
  email_exists: 'An account with this email already exists.',
  weak_password: 'Password must be at least 12 characters long.',
  invalid_email: 'Please enter a valid email address.',
};

const errorMessage = error ? errorMessages[error] || 'An error occurred. Please try again.' : '';
---

<AuthLayout title="Finance Manager - Sign Up">
  <div class="card bg-base-100 shadow-xl">
    <div class="card-body">
      <h2 class="card-title text-2xl font-bold mb-4">Create Account</h2>

      {
        errorMessage && (
          <div class="alert alert-error mb-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="stroke-current shrink-0 h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span>{errorMessage}</span>
          </div>
        )
      }

      <form action="/api/auth/signup" method="POST" class="space-y-4">
        <!-- Name Field -->
        <div class="form-control">
          <Label htmlFor="name" required>Full Name</Label>
          <Input type="text" id="name" name="name" placeholder="John Doe" className="w-full" />
        </div>

        <!-- Email Field -->
        <div class="form-control">
          <Label htmlFor="email" required>Email</Label>
          <Input
            type="email"
            id="email"
            name="email"
            placeholder="you@example.com"
            className="w-full"
          />
        </div>

        <!-- Password Field -->
        <div class="form-control">
          <Label htmlFor="password" required>Password</Label>
          <PasswordField id="password" name="password" placeholder="At least 12 characters" />
          <span class="label-text-alt text-base-content/70 mt-1">
            Must be at least 12 characters long
          </span>
        </div>

        <!-- Confirm Password Field -->
        <div class="form-control">
          <Label htmlFor="confirm-password" required>Confirm Password</Label>
          <PasswordField
            id="confirm-password"
            name="confirm_password"
            placeholder="Re-enter your password"
          />
        </div>

        <!-- Submit Button -->
        <Button type="submit" variant="primary" className="w-full">Create Account</Button>

        <!-- Sign In Link -->
        <div class="text-center text-sm">
          Already have an account?
          <a href="/login" class="text-primary hover:underline font-medium ml-1">Sign in</a>
        </div>
      </form>
    </div>
  </div>
</AuthLayout>
