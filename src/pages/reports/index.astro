---
/**
 * Reports Overview Page
 *
 * Lightweight overview showing:
 * - Summary metrics (income, expenses, savings, savings rate)
 * - Income vs. Expenses trend chart
 * - Preview cards linking to detailed expense and income reports
 *
 * @see docs/architecture/002-interactive-pages.md
 */

import { Info } from '@lucide/astro';
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import ReportSelector from '@/components/molecules/ReportSelector.astro';
import ReportsSectionNav from '@/components/molecules/ReportsSectionNav.astro';

import OverviewSummaryCardsPartial from '@/components/partials/OverviewSummaryCardsPartial.astro';
import OverviewChartsPartial from '@/components/partials/OverviewChartsPartial.astro';
import OverviewPreviewCardsPartial from '@/components/partials/OverviewPreviewCardsPartial.astro';

import { reportService } from '@/services';
import type { OverviewReportData } from '@/services/report.service';
import { safeParseDecimal } from '@/lib/utils/decimal';
import { formatMonthYear } from '@/lib/utils/date';
import { workspaceMetaService } from '@/services';
import { isValidCurrency, type Currency } from '@/lib/constants/currency';

const currentPath = '/reports';

const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}

const url = Astro.url;
const urlRange = url.searchParams.get('range');
const urlPeriod = url.searchParams.get('period');
const workspaceCurrencyConfig = await workspaceMetaService.getWorkspaceCurrencies(user.workspaceId);
const workspaceCurrencies = [
  workspaceCurrencyConfig.primary,
  ...(workspaceCurrencyConfig.secondary ? [workspaceCurrencyConfig.secondary] : []),
];
const activeCurrencyCookie = Astro.cookies.get('activeCurrency')?.value || '';
const selectedCurrency =
  activeCurrencyCookie &&
  isValidCurrency(activeCurrencyCookie) &&
  workspaceCurrencies.includes(activeCurrencyCookie)
    ? activeCurrencyCookie
    : workspaceCurrencyConfig.primary;

const defaultRange: 'monthly' | 'yearly' =
  urlRange === 'yearly' ? 'yearly' : urlRange === 'monthly' ? 'monthly' : 'monthly';

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;

const monthlyPeriods = Array.from({ length: 12 }, (_, i) => {
  const date = new Date(currentYear, currentMonth - 1 - i, 1);
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const monthStr = month.toString().padStart(2, '0');
  return { key: `${year}-${monthStr}`, label: formatMonthYear(date) };
});

const yearlyPeriods = Array.from({ length: 4 }, (_, i) => {
  const year = currentYear - i;
  return { key: year.toString(), label: year.toString() };
});

let defaultPeriod: string;
if (urlPeriod) {
  const isMonthlyFormat = /^\d{4}-\d{2}$/.test(urlPeriod);
  const isYearlyFormat = /^\d{4}$/.test(urlPeriod);
  if (defaultRange === 'monthly' && isMonthlyFormat) {
    defaultPeriod = urlPeriod;
  } else if (defaultRange === 'yearly' && isYearlyFormat) {
    defaultPeriod = urlPeriod;
  } else {
    defaultPeriod = defaultRange === 'monthly' ? monthlyPeriods[0].key : yearlyPeriods[0].key;
  }
} else {
  defaultPeriod = defaultRange === 'monthly' ? monthlyPeriods[0].key : yearlyPeriods[0].key;
}

const currency: Currency = selectedCurrency;

let overviewData: OverviewReportData;
try {
  overviewData = await reportService.getOverviewReport(
    user.workspaceId,
    defaultPeriod,
    defaultRange,
    currency
  );
} catch (error) {
  console.error('Error fetching overview data:', error);
  overviewData = {
    totalIncome: '0',
    totalExpenses: '0',
    netSavings: '0',
    savingsRate: '0',
    trendData: [],
    incomePreview: { topCategories: [], total: '0' },
    expensePreview: { topCategories: [], total: '0' },
  };
}

const trendDataForCharts = overviewData.trendData.map((trend) => ({
  name: trend.name,
  income: safeParseDecimal(trend.income),
  expenses: safeParseDecimal(trend.expenses),
}));

const selectedPeriodLabel =
  defaultRange === 'monthly'
    ? monthlyPeriods.find((period) => period.key === defaultPeriod)?.label || defaultPeriod
    : yearlyPeriods.find((period) => period.key === defaultPeriod)?.label || defaultPeriod;

const reportState = { range: defaultRange, period: defaultPeriod, currency };
---

<ProtectedLayout title="Reports" currentPath={currentPath} subtitle={selectedPeriodLabel}>
  <div slot="header" data-selector-container>
    <ReportSelector
      selectedRange={defaultRange}
      selectedPeriod={defaultPeriod}
      monthlyPeriods={monthlyPeriods}
      yearlyPeriods={yearlyPeriods}
    />
  </div>

  <div
    class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 md:space-y-8 pb-10"
    data-current-currency={currency}
  >
    <ReportsSectionNav activeSection="overview" state={reportState} />

    <section
      class="card border border-base-300 bg-base-100 shadow-sm"
      data-testid="reports-overview-guide"
    >
      <div class="card-body gap-4 p-5 sm:p-6">
        <div class="flex items-start gap-3">
          <span class="mt-0.5 rounded-2xl bg-info/10 p-2 text-info">
            <Info size={18} aria-hidden="true" />
          </span>
          <div class="space-y-3">
            <div class="space-y-1">
              <p class="text-xs font-bold uppercase tracking-[0.2em] text-base-content/50">
                How to use this page
              </p>
              <h2 class="text-lg font-semibold tracking-tight text-primary">
                Start here to understand whether this period is healthy overall.
              </h2>
            </div>
            <p class="max-w-4xl text-sm leading-6 text-base-content/70">
              Use the summary cards to compare income, expenses, and savings at a glance. Review the
              chart for recent movement, then open the Income or Expenses report when you need the
              full breakdown behind each number.
            </p>
            <ul class="grid gap-3 text-sm text-base-content/70 md:grid-cols-3">
              <li class="rounded-2xl bg-base-200 px-4 py-3">
                <span class="font-semibold text-base-content">1. Check coverage</span>
                <p class="mt-1">
                  Confirm that income is still covering spending for the selected period.
                </p>
              </li>
              <li class="rounded-2xl bg-base-200 px-4 py-3">
                <span class="font-semibold text-base-content">2. Review the trend</span>
                <p class="mt-1">
                  Compare recent inflows and outflows to spot improving or weakening months.
                </p>
              </li>
              <li class="rounded-2xl bg-base-200 px-4 py-3">
                <span class="font-semibold text-base-content">3. Use the ranked lists</span>
                <p class="mt-1">
                  Open the detail reports after you identify the biggest income sources or expense
                  drivers.
                </p>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    {/* Summary Metric Cards */}
    <div data-summary-container>
      <OverviewSummaryCardsPartial
        totalIncome={overviewData.totalIncome}
        totalExpenses={overviewData.totalExpenses}
        netSavings={overviewData.netSavings}
        savingsRate={overviewData.savingsRate}
        currency={currency}
      />
    </div>

    {/* Charts */}
    <div data-charts-container>
      <OverviewChartsPartial
        trendData={trendDataForCharts}
        currency={currency}
        subtitle={defaultRange === 'monthly' ? 'TRAILING 3 MONTHS' : 'YEARLY FLOW'}
      />
    </div>

    {/* Preview Cards */}
    <div data-previews-container>
      <OverviewPreviewCardsPartial
        incomePreview={overviewData.incomePreview}
        expensePreview={overviewData.expensePreview}
        currency={currency}
        state={reportState}
      />
    </div>
  </div>
</ProtectedLayout>

<script>
  import '@/components/organisms/OverviewReportsPage.client.ts';
</script>
