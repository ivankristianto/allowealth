---
/**
 * Reports Page
 *
 * Interactive reports page with monthly and yearly views.
 * Financial analysis with:
 * - Summary metrics (income, expenses, savings, budget health)
 * - Expense breakdown donut chart
 * - Income vs. expenses bar chart
 * - Category spending table with drill-down
 *
 * Features:
 * - Interactive range toggle (monthly/yearly)
 * - Period selector dropdown
 * - Dynamic data loading without page reload
 * - Server-rendered HTML fragments for consistency
 * - Real-time data from backend via ReportService
 *
 * @see docs/architecture/002-interactive-pages.md
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import CategoryDrillDownModal from '@/components/organisms/CategoryDrillDownModal.astro';
import ReportSelector from '@/components/molecules/ReportSelector.astro';

// Import partials for SSR
import ReportSummaryCardsPartial from '@/components/partials/ReportSummaryCardsPartial.astro';
import ReportChartsPartial from '@/components/partials/ReportChartsPartial.astro';
import CategoryTablePartial from '@/components/partials/CategoryTablePartial.astro';

// Import report service and types
import { reportService, accountService } from '@/services';
import type { ReportData } from '@/services/report.service';
import { safeParseDecimal } from '@/lib/utils/decimal';
import { formatMonthYear } from '@/lib/utils/date';
import { Users } from '@lucide/astro';

const currentPath = '/reports';

// Ensure user is authenticated
const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}

// Read from URL query params or use defaults
const url = Astro.url;
const urlRange = url.searchParams.get('range');
const urlPeriod = url.searchParams.get('period');

// Default view configuration
const defaultRange: 'monthly' | 'yearly' =
  urlRange === 'yearly' ? 'yearly' : urlRange === 'monthly' ? 'monthly' : 'monthly';

// P2: TODO - Generate available periods dynamically based on user's transaction history
// For now, generate periods based on current date and last 12 months/3 years
const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1; // 0-indexed to 1-indexed

// Generate monthly periods (last 12 months)
const monthlyPeriods = Array.from({ length: 12 }, (_, i) => {
  const monthsBack = i;
  const date = new Date(currentYear, currentMonth - 1 - monthsBack, 1);
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  const monthStr = month.toString().padStart(2, '0');

  const label = formatMonthYear(date);

  return {
    key: `${year}-${monthStr}`,
    label,
  };
});

// Generate yearly periods (last 3 years + current year)
const yearlyPeriods = Array.from({ length: 4 }, (_, i) => {
  const year = currentYear - i;
  return {
    key: year.toString(),
    label: year.toString(),
  };
});

// Set default period based on range and URL
// Validate that period format matches the range (prevent format mismatches)
let defaultPeriod: string;
if (urlPeriod) {
  const isMonthlyFormat = /^\d{4}-\d{2}$/.test(urlPeriod); // YYYY-MM
  const isYearlyFormat = /^\d{4}$/.test(urlPeriod); // YYYY

  // Use urlPeriod only if format matches the range
  if (defaultRange === 'monthly' && isMonthlyFormat) {
    defaultPeriod = urlPeriod;
  } else if (defaultRange === 'yearly' && isYearlyFormat) {
    defaultPeriod = urlPeriod;
  } else {
    // Format mismatch - fall back to default for current range
    defaultPeriod = defaultRange === 'monthly' ? monthlyPeriods[0].key : yearlyPeriods[0].key;
  }
} else {
  // No URL period - use default for current range
  defaultPeriod = defaultRange === 'monthly' ? monthlyPeriods[0].key : yearlyPeriods[0].key;
}

// Fetch report data from backend service
const currency: 'IDR' | 'USD' = 'IDR'; // P2: TODO - Support currency from user preferences (Issue #5 from code review)
let reportData: ReportData;

try {
  if (defaultRange === 'monthly') {
    reportData = await reportService.getMonthlyReport(user.workspaceId, defaultPeriod, currency);
  } else {
    const year = parseInt(defaultPeriod, 10);
    reportData = await reportService.getYearlyReport(user.workspaceId, year, currency);
  }
} catch (error) {
  console.error('Error fetching report data:', error);
  // P2: TODO - Show error page instead of redirecting (Issue #6 from code review)
  return Astro.redirect('/reports?error=failed-to-load');
}

// Fetch account totals by class for summary cards
let totalAccountsIdr = 0;
let totalAccountsUsd = 0;
let totalDebtIdr = 0;
let totalDebtUsd = 0;

try {
  const classTotals = await accountService.getTotalByClass(user.workspaceId);
  for (const row of classTotals) {
    const total = parseFloat(row.total || '0');
    if (isNaN(total)) continue;
    if (row.account_class === 'debt') {
      if (row.currency === 'USD') totalDebtUsd += Math.abs(total);
      else totalDebtIdr += Math.abs(total);
    } else {
      if (row.currency === 'USD') totalAccountsUsd += total;
      else totalAccountsIdr += total;
    }
  }
} catch (error) {
  console.error('Error fetching account totals:', error);
  // Non-critical: continue with zeros
}

// Keep data as strings for formatCurrency utility
// Only convert to numbers for chart rendering (handled by chart components)
const reportDataForPartials = {
  // Summary cards - keep as strings for formatCurrency
  totalIncome: reportData.totalIncome,
  totalExpenses: reportData.totalExpenses,
  netSavings: reportData.netSavings,
  budgetHealth: reportData.budgetHealth,
  expenseCategories: reportData.expenseCategories,
  currency: currency, // Pass currency for formatting
  // Charts - convert to numbers for Chart.js
  expenseByCategory: reportData.expenseByCategory.map((cat: { name: string; value: string }) => ({
    name: cat.name,
    value: safeParseDecimal(cat.value),
  })),
  trendData: reportData.trendData.map(
    (trend: { name: string; income: string; expenses: string }) => ({
      name: trend.name,
      income: safeParseDecimal(trend.income),
      expenses: safeParseDecimal(trend.expenses),
    })
  ),
  // Category intelligence - convert to numbers for table display
  categoryIntelligence: reportData.categoryIntelligence.map(
    (cat: {
      id: string;
      name: string;
      spent: string;
      budgetLimit: string | null;
      icon: string;
      color: string;
    }) => ({
      id: cat.id,
      name: cat.name,
      spent: safeParseDecimal(cat.spent),
      budgetLimit: cat.budgetLimit ? safeParseDecimal(cat.budgetLimit) : null,
      icon: cat.icon,
      color: cat.color,
    })
  ),
};

const selectedPeriodLabel =
  defaultRange === 'monthly'
    ? monthlyPeriods.find((period) => period.key === defaultPeriod)?.label || defaultPeriod
    : yearlyPeriods.find((period) => period.key === defaultPeriod)?.label || defaultPeriod;
---

<ProtectedLayout title="Reports" currentPath={currentPath} subtitle={selectedPeriodLabel}>
  <div slot="header" class="flex items-center gap-2" data-selector-container>
    <a href="/reports/members" class="btn btn-sm btn-ghost gap-2">
      <Users class="w-4 h-4" />
      Member Spending
    </a>
    <ReportSelector
      selectedRange={defaultRange}
      selectedPeriod={defaultPeriod}
      monthlyPeriods={monthlyPeriods}
      yearlyPeriods={yearlyPeriods}
    />
  </div>

  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 md:space-y-8 pb-10">
    {/* Summary Metric Cards Container */}
    <div data-summary-container>
      <ReportSummaryCardsPartial
        totalIncome={reportDataForPartials.totalIncome}
        totalExpenses={reportDataForPartials.totalExpenses}
        netSavings={reportDataForPartials.netSavings}
        budgetHealth={reportDataForPartials.budgetHealth}
        expenseCategories={reportDataForPartials.expenseCategories}
        currency={reportDataForPartials.currency}
        totalAccountsIdr={totalAccountsIdr}
        totalAccountsUsd={totalAccountsUsd}
        totalDebtIdr={totalDebtIdr}
        totalDebtUsd={totalDebtUsd}
      />
    </div>

    {/* Charts Container */}
    <div data-charts-container>
      <ReportChartsPartial
        expenseByCategory={reportDataForPartials.expenseByCategory}
        trendData={reportDataForPartials.trendData}
        resourceAllocationSubtitle={defaultRange === 'monthly'
          ? 'EXPENSE MIX'
          : 'YEARLY EXPENSE MIX'}
        financialVelocitySubtitle={defaultRange === 'monthly' ? 'TRAILING 3 MONTHS' : 'YEARLY FLOW'}
      />
    </div>

    {/* Spending per Category Table Container */}
    <div data-table-container>
      <CategoryTablePartial
        categories={reportDataForPartials.categoryIntelligence}
        subtitle="SORTED BY AMOUNT SPENT"
        range={defaultRange}
      />
    </div>

    {/* Category Drill-Down Modal */}
    <CategoryDrillDownModal id="category-drilldown-modal" />
  </div>
</ProtectedLayout>

<script>
  // Import and initialize reports page orchestrator
  import '@/components/organisms/ReportsPage.client.ts';
</script>
