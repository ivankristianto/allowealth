---
/**
 * Financial Intelligence Page
 *
 * Interactive reports page with monthly and yearly views.
 * Deep analysis of family's resource velocity with:
 * - Summary metrics (income, expenses, savings, budget health)
 * - Resource allocation donut chart
 * - Financial velocity bar chart
 * - Category intelligence table with drill-down
 *
 * Features:
 * - Interactive range toggle (monthly/yearly)
 * - Period selector dropdown
 * - Dynamic data loading without page reload
 * - Server-rendered HTML fragments for consistency
 *
 * @TODO: Wire with backend API for real data
 * @see docs/architecture/002-interactive-pages.md
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import CategoryDrillDownModal from '@/components/organisms/CategoryDrillDownModal.astro';
import ReportSelector from '@/components/molecules/ReportSelector.astro';

// Import partials for SSR
import ReportSummaryCardsPartial from '@/components/partials/ReportSummaryCardsPartial.astro';
import ReportChartsPartial from '@/components/partials/ReportChartsPartial.astro';
import CategoryTablePartial from '@/components/partials/CategoryTablePartial.astro';

const currentPath = '/reports';

// Read from URL query params or use defaults
const url = Astro.url;
const urlRange = url.searchParams.get('range');
const urlPeriod = url.searchParams.get('period');

// Default view configuration
const defaultRange: 'monthly' | 'yearly' =
  urlRange === 'yearly' ? 'yearly' : urlRange === 'monthly' ? 'monthly' : 'monthly';

// Available periods for selector
// @TODO: Dynamic period generation based on available data from backend
const monthlyPeriods = [
  { key: '2023-12', label: 'December 2023' },
  { key: '2024-01', label: 'January 2024' },
  { key: '2024-02', label: 'February 2024' },
];

const yearlyPeriods = [
  { key: '2022', label: '2022' },
  { key: '2023', label: '2023' },
  { key: '2024', label: '2024' },
];

// Set default period based on range and URL
const defaultPeriod =
  urlPeriod ||
  (defaultRange === 'monthly'
    ? monthlyPeriods[monthlyPeriods.length - 1].key
    : yearlyPeriods[yearlyPeriods.length - 1].key);

// @TODO: Replace with API call to get actual data
// Mock data for SSR (February 2024 monthly view)
const mockData = {
  // Summary metrics
  totalIncome: 9750000,
  totalExpenses: 4735000,
  netSavings: 5015000,
  budgetHealth: 8, // percentage
  expenseCategories: 6,

  // Resource Allocation (Expense Mix)
  expenseByCategory: [
    { name: 'Utilities', value: 1850000 },
    { name: 'Dining', value: 905000 },
    { name: 'Health', value: 750000 },
    { name: 'Transport', value: 595000 },
    { name: 'Entertainment', value: 420000 },
    { name: 'Groceries', value: 215000 },
  ],

  // Financial Velocity (Trailing 3 months)
  trendData: [
    { name: 'Dec', income: 25245000, expenses: 33719000 },
    { name: 'Jan', income: 60525000, expenses: 41816000 },
    { name: 'Feb', income: 9750000, expenses: 4735000 },
  ],

  // Category Intelligence
  categoryIntelligence: [
    {
      id: '1',
      name: 'Utilities',
      spent: 1850000,
      budgetLimit: 4000000,
      icon: 'zap',
      color: 'bg-blue-600',
    },
    {
      id: '2',
      name: 'Dining',
      spent: 905000,
      budgetLimit: 3000000,
      icon: 'utensils',
      color: 'bg-orange-500',
    },
    {
      id: '3',
      name: 'Health',
      spent: 750000,
      budgetLimit: null, // Not Set
      icon: 'heart-pulse',
      color: 'bg-cyan-500',
    },
    {
      id: '4',
      name: 'Transport',
      spent: 595000,
      budgetLimit: 2500000,
      icon: 'car',
      color: 'bg-purple-500',
    },
    {
      id: '5',
      name: 'Entertainment',
      spent: 420000,
      budgetLimit: 1500000,
      icon: 'music',
      color: 'bg-pink-500',
    },
    {
      id: '6',
      name: 'Groceries',
      spent: 215000,
      budgetLimit: 8000000,
      icon: 'shopping-basket',
      color: 'bg-blue-500',
    },
    {
      id: '7',
      name: 'Housing',
      spent: 0,
      budgetLimit: 40000000,
      icon: 'home',
      color: 'bg-red-500',
    },
  ],
};
---

<ProtectedLayout title="Financial Intelligence - Finance Manager" currentPath={currentPath}>
  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 md:space-y-8 pb-10">
    {/* Page Header with Report Selector */}
    <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold text-base-content leading-none tracking-tight">
          Financial Intelligence
        </h2>
        <p class="text-sm text-base-content/60 mt-2 font-medium">
          Deep analysis of your family's resource velocity.
        </p>
      </div>

      <ReportSelector
        selectedRange={defaultRange}
        selectedPeriod={defaultPeriod}
        monthlyPeriods={monthlyPeriods}
        yearlyPeriods={yearlyPeriods}
      />
    </div>

    {/* Summary Metric Cards Container */}
    <div data-summary-container>
      <ReportSummaryCardsPartial
        totalIncome={mockData.totalIncome}
        totalExpenses={mockData.totalExpenses}
        netSavings={mockData.netSavings}
        budgetHealth={mockData.budgetHealth}
        expenseCategories={mockData.expenseCategories}
      />
    </div>

    {/* Charts Container */}
    <div data-charts-container>
      <ReportChartsPartial
        expenseByCategory={mockData.expenseByCategory}
        trendData={mockData.trendData}
        resourceAllocationSubtitle="EXPENSE MIX"
        financialVelocitySubtitle="TRAILING 3 MONTHS"
      />
    </div>

    {/* Category Intelligence Table Container */}
    <div data-table-container>
      <CategoryTablePartial
        categories={mockData.categoryIntelligence}
        subtitle="SORTED BY FUNCTIONAL VOLUME"
      />
    </div>

    {/* Category Drill-Down Modal */}
    <CategoryDrillDownModal id="category-drilldown-modal" />

    {
      /* @TODO: Wire with backend API endpoints:
         - GET /api/reports?range=monthly&period=2024-02&_render=html
         - GET /api/reports?range=yearly&period=2024&_render=html
         - GET /api/reports/category-transactions?category=Utilities&period=2024-02
    */
    }
  </div>
</ProtectedLayout>

<script>
  // Import and initialize reports page orchestrator
  import '@/components/organisms/ReportsPage.client.ts';
</script>

<style>
  /* Screen reader only class
   * @TODO: P2 - Use Tailwind's built-in sr-only utility class instead
   * This CSS is duplicated across multiple chart components. Consider removing
   * and using `class="sr-only"` directly from Tailwind.
   */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>
