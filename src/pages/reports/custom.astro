---
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';

const currentPath = '/reports/custom';
---

<ProtectedLayout title="Custom Reports - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    <h2 class="text-2xl font-bold">Custom Reports</h2>

    <div class="tabs">
      <a class="tab" href="/reports">Monthly</a>
      <a class="tab" href="/reports/yearly">Yearly</a>
      <a class="tab tab-active" href="/reports/custom">Custom</a>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <form class="space-y-4">
          <div class="form-control">
            <label class="label" for="start-date"><span class="label-text">Start Date</span></label>
            <input
              type="date"
              id="start-date"
              name="start_date"
              class="input input-bordered"
              required
            />
          </div>

          <div class="form-control">
            <label class="label" for="end-date"><span class="label-text">End Date</span></label>
            <input
              type="date"
              id="end-date"
              name="end_date"
              class="input input-bordered"
              required
            />
          </div>

          <button type="submit" class="btn btn-accent">Generate Report</button>
        </form>
      </div>
    </div>
  </div>
</ProtectedLayout>
