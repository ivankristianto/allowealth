---
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import ReportSelector from '@/components/molecules/ReportSelector.astro';
import ReportSummaryCardsPartial from '@/components/partials/ReportSummaryCardsPartial.astro';
import ReportChartsPartial from '@/components/partials/ReportChartsPartial.astro';
import CategoryTablePartial from '@/components/partials/CategoryTablePartial.astro';
import CategoryDrillDownModal from '@/components/organisms/CategoryDrillDownModal.astro';
import StatCard from '@/components/atoms/StatCard.astro';
import Breadcrumb from '@/components/atoms/Breadcrumb.astro';
import { reportService, workspaceService } from '@/services';
import type { MemberSummaryRow, ReportData } from '@/services/report.service';
import { formatMonthYear } from '@/lib/utils/date';
import { formatCurrency } from '@/lib/formatting';
import { safeParseDecimal } from '@/lib/utils/decimal';
import type { Currency } from '@/lib/enums';
import { ChevronRight, Users } from '@lucide/astro';

const currentPath = '/reports/members';

const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}

const url = Astro.url;
const urlRange = url.searchParams.get('range');
const urlPeriod = url.searchParams.get('period');
const urlCurrency = url.searchParams.get('currency');
const urlUserId = url.searchParams.get('user_id') || '';

const range: 'monthly' | 'yearly' = urlRange === 'yearly' ? 'yearly' : 'monthly';

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth() + 1;

const monthlyPeriods = Array.from({ length: 12 }, (_, i) => {
  const date = new Date(currentYear, currentMonth - 1 - i, 1);
  const year = date.getFullYear();
  const month = date.getMonth() + 1;
  return {
    key: `${year}-${month.toString().padStart(2, '0')}`,
    label: formatMonthYear(date),
  };
});

const yearlyPeriods = Array.from({ length: 4 }, (_, i) => ({
  key: (currentYear - i).toString(),
  label: (currentYear - i).toString(),
}));

let defaultPeriod: string;
if (urlPeriod) {
  const isMonthly = /^\d{4}-\d{2}$/.test(urlPeriod);
  const isYearly = /^\d{4}$/.test(urlPeriod);
  if (range === 'monthly' && isMonthly) defaultPeriod = urlPeriod;
  else if (range === 'yearly' && isYearly) defaultPeriod = urlPeriod;
  else defaultPeriod = range === 'monthly' ? monthlyPeriods[0].key : yearlyPeriods[0].key;
} else {
  defaultPeriod = range === 'monthly' ? monthlyPeriods[0].key : yearlyPeriods[0].key;
}

const currency: Currency = urlCurrency === 'USD' ? 'USD' : 'IDR';

// Period label for header subtitle
const selectedPeriodLabel =
  range === 'monthly'
    ? monthlyPeriods.find((p) => p.key === defaultPeriod)?.label || defaultPeriod
    : yearlyPeriods.find((p) => p.key === defaultPeriod)?.label || defaultPeriod;

let selectedMemberName = '';
let memberSummary: MemberSummaryRow[] = [];
let totals = { income: 0, expenses: 0, count: 0 };

if (urlUserId) {
  const workspaceMembers = await workspaceService.getMembers(user.workspaceId);
  const memberNameMap = new Map(
    workspaceMembers.map((member) => [member.id, member.name || member.email || 'Unknown'])
  );
  selectedMemberName = memberNameMap.get(urlUserId) || 'Unknown';
} else {
  memberSummary = await reportService.getMemberSummary(
    user.workspaceId,
    defaultPeriod,
    range,
    currency
  );
  totals = memberSummary.reduce(
    (acc, row) => ({
      income: acc.income + (safeParseDecimal(row.totalIncome) || 0),
      expenses: acc.expenses + (safeParseDecimal(row.totalExpenses) || 0),
      count: acc.count + row.transactionCount,
    }),
    { income: 0, expenses: 0, count: 0 }
  );
}

let userReportData: ReportData | null = null;
if (urlUserId) {
  if (range === 'monthly') {
    userReportData = await reportService.getMonthlyReport(
      user.workspaceId,
      defaultPeriod,
      currency,
      urlUserId
    );
  } else {
    const year = parseInt(defaultPeriod, 10);
    userReportData = await reportService.getYearlyReport(
      user.workspaceId,
      year,
      currency,
      urlUserId
    );
  }
}

const userReportForPartials = userReportData
  ? {
      totalIncome: userReportData.totalIncome,
      totalExpenses: userReportData.totalExpenses,
      netSavings: userReportData.netSavings,
      budgetHealth: userReportData.budgetHealth,
      expenseCategories: userReportData.expenseCategories,
      expenseByCategory: userReportData.expenseByCategory.map((category) => ({
        name: category.name,
        value: safeParseDecimal(category.value),
      })),
      trendData: userReportData.trendData.map((trend) => ({
        name: trend.name,
        income: safeParseDecimal(trend.income),
        expenses: safeParseDecimal(trend.expenses),
      })),
      categoryIntelligence: userReportData.categoryIntelligence.map((category) => ({
        id: category.id,
        name: category.name,
        spent: safeParseDecimal(category.spent),
        budgetLimit: category.budgetLimit ? safeParseDecimal(category.budgetLimit) : null,
        icon: category.icon,
        color: category.color,
      })),
    }
  : null;

const overviewUrl = `/reports/members?range=${range}&period=${defaultPeriod}&currency=${currency}`;

// Header subtitle: member name for detail, period for overview
const subtitleText = urlUserId
  ? `${selectedMemberName} · ${selectedPeriodLabel}`
  : selectedPeriodLabel;

// Avatar helpers for member table
const avatarColors = [
  'bg-success/15 text-success',
  'bg-info/15 text-info',
  'bg-warning/15 text-warning',
  'bg-accent/15 text-accent',
  'bg-error/15 text-error',
];
const getInitials = (name: string) =>
  name
    .split(' ')
    .map((w) => w[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
const getMemberColor = (name: string) => avatarColors[name.charCodeAt(0) % avatarColors.length];

// Currency badge classes (matches reports page pattern)
const badge =
  'inline-flex items-center px-1.5 py-0.5 rounded text-xs font-bold uppercase tracking-wider shrink-0';
const currencyBadge =
  currency === 'USD' ? `${badge} bg-info/10 text-info` : `${badge} bg-success/10 text-success`;

const totalNet = totals.income - totals.expenses;
---

<ProtectedLayout title="Member Spending" currentPath={currentPath} subtitle={subtitleText}>
  <div slot="header">
    <ReportSelector
      selectedRange={range}
      selectedPeriod={defaultPeriod}
      monthlyPeriods={monthlyPeriods}
      yearlyPeriods={yearlyPeriods}
    />
  </div>

  {
    urlUserId && userReportForPartials ? (
      <div
        class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 md:space-y-8 pb-10"
        data-reports-members-page
        data-current-range={range}
        data-current-period={defaultPeriod}
        data-current-currency={currency}
        data-current-user-id={urlUserId}
      >
        <Breadcrumb
          items={[
            { label: 'Reports', href: '/reports' },
            { label: 'Member Spending', href: overviewUrl },
            { label: selectedMemberName },
          ]}
        />

        <ReportSummaryCardsPartial
          totalIncome={userReportForPartials.totalIncome}
          totalExpenses={userReportForPartials.totalExpenses}
          netSavings={userReportForPartials.netSavings}
          budgetHealth={userReportForPartials.budgetHealth}
          expenseCategories={userReportForPartials.expenseCategories}
          currency={currency}
        />

        <ReportChartsPartial
          expenseByCategory={userReportForPartials.expenseByCategory}
          trendData={userReportForPartials.trendData}
          resourceAllocationSubtitle={range === 'monthly' ? 'EXPENSE MIX' : 'YEARLY EXPENSE MIX'}
          financialVelocitySubtitle={range === 'monthly' ? 'TRAILING 3 MONTHS' : 'YEARLY FLOW'}
        />

        <CategoryTablePartial
          categories={userReportForPartials.categoryIntelligence}
          subtitle="SORTED BY FUNCTIONAL VOLUME"
          range={range}
        />

        <CategoryDrillDownModal id="member-category-drilldown-modal" />
      </div>
    ) : (
      <div
        class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 md:space-y-8 pb-10"
        data-reports-members-page
        data-current-range={range}
        data-current-period={defaultPeriod}
        data-current-currency={currency}
        data-current-user-id=""
      >
        <Breadcrumb
          items={[{ label: 'Reports', href: '/reports' }, { label: 'Member Spending' }]}
        />

        {/* Summary Stat Cards */}
        <div class="@container">
          <div class="grid grid-cols-1 @2xl:grid-cols-3 gap-4 @2xl:gap-6">
            <StatCard title="TOTAL INCOME">
              <Fragment slot="details">
                <div class="flex items-center gap-2">
                  <span class={currencyBadge}>{currency}</span>
                  <p class="text-lg font-bold text-success tracking-tight leading-none truncate">
                    {formatCurrency(totals.income, currency)}
                  </p>
                </div>
              </Fragment>
            </StatCard>

            <StatCard title="TOTAL EXPENSES">
              <Fragment slot="details">
                <div class="space-y-1.5">
                  <div class="flex items-center gap-2">
                    <span class={currencyBadge}>{currency}</span>
                    <p class="text-lg font-bold text-error tracking-tight leading-none truncate">
                      {formatCurrency(totals.expenses, currency)}
                    </p>
                  </div>
                  <p class="text-xs font-bold uppercase text-base-content/40">
                    {totals.count} TRANSACTIONS
                  </p>
                </div>
              </Fragment>
            </StatCard>

            <StatCard title="NET SAVINGS">
              <Fragment slot="details">
                <div class="flex items-center gap-2">
                  <span class={currencyBadge}>{currency}</span>
                  <p
                    class={`text-lg font-bold tracking-tight leading-none truncate ${totalNet >= 0 ? 'text-success' : 'text-error'}`}
                  >
                    {formatCurrency(totalNet, currency)}
                  </p>
                </div>
              </Fragment>
            </StatCard>
          </div>
        </div>

        {/* Member Spending Table */}
        <div class="bg-base-100 rounded-2xl md:rounded-3xl border border-base-300 shadow-sm overflow-hidden">
          <div class="px-5 md:px-6 pt-5 md:pt-6 pb-3">
            <h2 class="text-lg font-bold">Spending by Member</h2>
            <p class="text-xs font-bold uppercase text-base-content/40 tracking-widest mt-1">
              {memberSummary.length} MEMBERS
            </p>
          </div>

          <div class="overflow-x-auto">
            <table class="table">
              <thead>
                <tr>
                  <th>Member</th>
                  <th class="text-right">Income</th>
                  <th class="text-right">Expenses</th>
                  <th class="text-right hidden sm:table-cell">Share</th>
                  <th class="text-right">Net</th>
                  <th class="text-right hidden sm:table-cell">Txns</th>
                  <th />
                </tr>
              </thead>
              <tbody>
                {memberSummary.length === 0 ? (
                  <tr>
                    <td colspan="7" class="text-center py-12 text-base-content/50">
                      <div class="flex flex-col items-center gap-2">
                        <div class="w-12 h-12 rounded-full bg-base-200 flex items-center justify-center">
                          <Users class="w-6 h-6 opacity-40" />
                        </div>
                        <p class="font-medium">No transactions found</p>
                        <p class="text-sm">Try selecting a different period</p>
                      </div>
                    </td>
                  </tr>
                ) : (
                  memberSummary.map((row) => {
                    const income = safeParseDecimal(row.totalIncome) || 0;
                    const expenses = safeParseDecimal(row.totalExpenses) || 0;
                    const net = safeParseDecimal(row.netSavings) || 0;
                    const expenseShare =
                      totals.expenses > 0 ? (expenses / totals.expenses) * 100 : 0;
                    const drillUrl = `/reports/members?user_id=${row.userId}&range=${range}&period=${defaultPeriod}&currency=${currency}`;

                    return (
                      <tr
                        class="hover:bg-base-200/50 transition-colors cursor-pointer"
                        data-href={drillUrl}
                      >
                        <td>
                          <a href={drillUrl} class="flex items-center gap-3 no-underline">
                            <div
                              class={`w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold shrink-0 ${getMemberColor(row.userName)}`}
                            >
                              {getInitials(row.userName)}
                            </div>
                            <span class="font-semibold link-hover">{row.userName}</span>
                          </a>
                        </td>
                        <td class="text-right text-success font-medium">
                          {formatCurrency(income, currency)}
                        </td>
                        <td class="text-right text-error font-medium">
                          {formatCurrency(expenses, currency)}
                        </td>
                        <td class="text-right hidden sm:table-cell">
                          <div class="flex items-center justify-end gap-2">
                            <div class="w-16 h-1.5 rounded-full bg-base-200 overflow-hidden">
                              <div
                                class="h-full bg-error/60 rounded-full"
                                style={`width: ${expenseShare}%`}
                              />
                            </div>
                            <span class="text-xs font-medium text-base-content/60 w-10 text-right tabular-nums">
                              {expenseShare.toFixed(0)}%
                            </span>
                          </div>
                        </td>
                        <td
                          class={`text-right font-semibold ${net >= 0 ? 'text-success' : 'text-error'}`}
                        >
                          {formatCurrency(net, currency)}
                        </td>
                        <td class="text-right hidden sm:table-cell">
                          <span class="text-base-content/60 tabular-nums">
                            {row.transactionCount}
                          </span>
                        </td>
                        <td class="text-right w-8">
                          <a
                            href={drillUrl}
                            class="btn btn-ghost btn-xs"
                            aria-label={`View ${row.userName} report`}
                          >
                            <ChevronRight class="w-4 h-4 text-base-content/30 group-hover:text-base-content/60 transition-colors" />
                          </a>
                        </td>
                      </tr>
                    );
                  })
                )}
              </tbody>
              {memberSummary.length > 0 && (
                <tfoot>
                  <tr class="border-t-2 border-base-300">
                    <td class="font-bold">
                      <div class="flex items-center gap-3">
                        <div class="w-9 h-9 rounded-full bg-base-200 flex items-center justify-center text-xs font-bold text-base-content/40 shrink-0">
                          ALL
                        </div>
                        <span>Total</span>
                      </div>
                    </td>
                    <td class="text-right text-success font-bold">
                      {formatCurrency(totals.income, currency)}
                    </td>
                    <td class="text-right text-error font-bold">
                      {formatCurrency(totals.expenses, currency)}
                    </td>
                    <td class="text-right hidden sm:table-cell">
                      <span class="text-xs font-medium text-base-content/40">100%</span>
                    </td>
                    <td
                      class={`text-right font-bold ${totalNet >= 0 ? 'text-success' : 'text-error'}`}
                    >
                      {formatCurrency(totalNet, currency)}
                    </td>
                    <td class="text-right hidden sm:table-cell font-bold tabular-nums">
                      {totals.count}
                    </td>
                    <td />
                  </tr>
                </tfoot>
              )}
            </table>
          </div>
        </div>
      </div>
    )
  }
</ProtectedLayout>

<script>
  function initMembersPage() {
    const container = document.querySelector('[data-reports-members-page]') as HTMLElement | null;
    if (!container) return;

    let currentRange = (container.dataset.currentRange as 'monthly' | 'yearly') || 'monthly';
    let currentPeriod = container.dataset.currentPeriod || '';
    const currency = container.dataset.currentCurrency || 'IDR';
    const userId = container.dataset.currentUserId || '';

    const navigate = () => {
      const nextUrl = new URL(window.location.href);
      nextUrl.searchParams.set('range', currentRange);
      nextUrl.searchParams.set('period', currentPeriod);
      nextUrl.searchParams.set('currency', currency);
      if (userId) {
        nextUrl.searchParams.set('user_id', userId);
      } else {
        nextUrl.searchParams.delete('user_id');
      }
      window.location.href = nextUrl.toString();
    };

    window.addEventListener('reportRangeChange', (event: Event) => {
      const customEvent = event as CustomEvent<{ range: 'monthly' | 'yearly' }>;
      currentRange = customEvent.detail.range;

      if (currentRange === 'yearly') {
        currentPeriod = currentPeriod.split('-')[0];
      } else if (/^\d{4}$/.test(currentPeriod)) {
        currentPeriod = `${currentPeriod}-01`;
      }

      navigate();
    });

    window.addEventListener('reportPeriodChange', (event: Event) => {
      const customEvent = event as CustomEvent<{ period: string }>;
      currentPeriod = customEvent.detail.period;
      navigate();
    });

    // Clickable rows — navigate on click unless clicking an interactive element
    document.querySelectorAll<HTMLTableRowElement>('tr[data-href]').forEach((row) => {
      row.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a, button')) return;
        const href = row.dataset.href;
        if (href) window.location.href = href;
      });
    });
  }

  initMembersPage();
  document.addEventListener('astro:page-load', initMembersPage);
</script>
