---
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';

const currentPath = '/reports/yearly';
---

<ProtectedLayout title="Yearly Reports - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    <h2 class="text-2xl font-bold">Yearly Reports</h2>

    <div class="tabs">
      <a class="tab" href="/reports">Monthly</a>
      <a class="tab tab-active" href="/reports/yearly">Yearly</a>
      <a class="tab" href="/reports/custom">Custom</a>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <p class="text-neutral-500">No yearly reports available yet.</p>
      </div>
    </div>
  </div>
</ProtectedLayout>
