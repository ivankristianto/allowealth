---
/**
 * Forgot Password Page
 *
 * Password reset request page for users who have forgotten their password.
 */

import AuthLayout from '../layouts/AuthLayout.astro';
import ForgotPasswordForm from '../components/molecules/ForgotPasswordForm.astro';

// Get success/error message from query params (if any)
const url = new URL(Astro.request.url);
const success = url.searchParams.get('success');
const error = url.searchParams.get('error');

const successMessages: Record<string, string> = {
  email_sent: 'If an account exists with this email, we have sent a password reset link.',
};

const errorMessages: Record<string, string> = {
  invalid_email: 'Please enter a valid email address.',
  rate_limit: 'Too many requests. Please wait before trying again.',
};

// Only use whitelisted message codes to prevent XSS
const successMessage = success && successMessages[success] ? successMessages[success] : '';
const errorMessage = error && errorMessages[error] ? errorMessages[error] : '';
---

<AuthLayout title="Finance Manager - Forgot Password">
  <ForgotPasswordForm errorMessage={errorMessage} successMessage={successMessage} />
</AuthLayout>
