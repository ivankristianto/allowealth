---
/**
 * Forecast Page
 *
 * Displays the forecast reality-check page with saved assumptions,
 * a legacy chart bridge, and detailed ledger projections.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import ForecastAssumptions from '@/components/organisms/ForecastAssumptions.astro';
import WealthTrajectory from '@/components/organisms/WealthTrajectory.astro';
import LedgerProjections from '@/components/organisms/LedgerProjections.astro';
import type { ForecastDataPoint, ForecastRealityCheckResult, ForecastResult } from '@/lib/forecast';
import { workspaceMetaService } from '@/services';

const currentPath = '/forecast';
const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}

const FORECAST_YEARS = 2;
const settings = await workspaceMetaService.getSettings(user.workspaceId);
const primaryCurrency = settings.currency;

interface ForecastPageData extends ForecastRealityCheckResult {
  assumptions: {
    monthlyTopup: number;
    annualRate: number;
  };
}

function toLegacyForecastData(data: ForecastPageData): ForecastResult {
  const dataPoints: ForecastDataPoint[] = data.timeline.map((point) => ({
    key: point.key,
    dateLabel: point.dateLabel,
    forecastBalance: point.plannedBalance ?? point.actualBalance ?? 0,
    forecastInterest: point.forecastInterest ?? 0,
    realBalance: point.actualBalance,
    realInterest: null,
  }));

  const growthMultiple =
    data.summary.latestActualBalance > 0
      ? Math.round((data.summary.plannedEndingBalance / data.summary.latestActualBalance) * 100) /
        100
      : 0;

  return {
    dataPoints,
    summary: {
      year10Target: data.summary.plannedEndingBalance,
      totalInterest: data.summary.totalForecastInterest,
      growthMultiple,
      currentTotal: data.summary.latestActualBalance,
    },
    input: {
      monthlyTopup: data.assumptions.monthlyTopup,
      annualRate: data.assumptions.annualRate,
      years: FORECAST_YEARS,
    },
  };
}

// Fetch initial forecast data from API
let forecastData: ForecastPageData | null = null;
let error: string | null = null;

try {
  const response = await fetch(`${Astro.url.origin}/api/forecast`, {
    headers: {
      cookie: Astro.request.headers.get('cookie') || '',
    },
  });

  if (!response.ok) {
    throw new Error(`Failed to fetch forecast data: ${response.statusText}`);
  }

  const result = await response.json();

  if (!result.success || !result.data) {
    throw new Error('Invalid API response format');
  }

  forecastData = result.data;
} catch (err) {
  console.error('Error fetching forecast data:', err);
  error = err instanceof Error ? err.message : 'Failed to load forecast data';
}

const assumptions = forecastData?.assumptions ?? {
  monthlyTopup: settings.forecastMonthlyTopup,
  annualRate: settings.forecastAnnualRate,
};
const legacyForecastData = forecastData ? toLegacyForecastData(forecastData) : null;
const emptyForecastData: ForecastResult = {
  dataPoints: [],
  summary: { year10Target: 0, totalInterest: 0, growthMultiple: 0, currentTotal: 0 },
  input: {
    monthlyTopup: assumptions.monthlyTopup,
    annualRate: assumptions.annualRate,
    years: FORECAST_YEARS,
  },
};
---

<ProtectedLayout title="Forecast" currentPath={currentPath} subtitle="Spending forecast">
  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8">
    <ForecastAssumptions
      monthlyTopup={assumptions.monthlyTopup}
      annualRate={assumptions.annualRate}
      currency={primaryCurrency}
    />

    {/* Wealth Trajectory Section */}
    {
      legacyForecastData ? (
        <WealthTrajectory
          data={legacyForecastData.dataPoints}
          summary={legacyForecastData.summary}
          input={legacyForecastData.input}
          currency={primaryCurrency}
        />
      ) : (
        <WealthTrajectory
          data={emptyForecastData.dataPoints}
          summary={emptyForecastData.summary}
          input={emptyForecastData.input}
          currency={primaryCurrency}
          error={error || 'Failed to load forecast data'}
        />
      )
    }

    {/* Ledger Projections Section */}
    {
      legacyForecastData ? (
        <LedgerProjections data={legacyForecastData.dataPoints} currency={primaryCurrency} />
      ) : (
        <LedgerProjections
          data={[]}
          currency={primaryCurrency}
          error={error || 'Failed to load projection data'}
        />
      )
    }
  </div>
</ProtectedLayout>

<script>
  import '@/components/organisms/ForecastAssumptions.client';
</script>
