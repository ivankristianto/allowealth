---
/**
 * Forecast Page
 *
 * Displays the forecast reality-check page with saved assumptions,
 * balance comparison charts, and a yearly ledger breakdown.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import ForecastAssumptions from '@/components/organisms/ForecastAssumptions.astro';
import ForecastMonthlyGains from '@/components/organisms/ForecastMonthlyGains.astro';
import WealthTrajectory from '@/components/organisms/WealthTrajectory.astro';
import LedgerProjections from '@/components/organisms/LedgerProjections.astro';
import type { ForecastRealityCheckResult, ForecastRealityCheckSummary } from '@/lib/forecast';
import { workspaceMetaService } from '@/services';

const currentPath = '/forecast';
const user = Astro.locals.user;
if (!user?.id) {
  return Astro.redirect('/login');
}

const settings = await workspaceMetaService.getSettings(user.workspaceId);
const primaryCurrency = settings.currency;

interface ForecastPageData extends ForecastRealityCheckResult {
  assumptions: {
    monthlyTopup: number;
    annualRate: number;
  };
}

// Fetch initial forecast data from API
let forecastData: ForecastPageData | null = null;
let error: string | null = null;

try {
  const response = await fetch(`${Astro.url.origin}/api/forecast`, {
    headers: {
      cookie: Astro.request.headers.get('cookie') || '',
    },
  });

  if (!response.ok) {
    throw new Error(`Failed to fetch forecast data: ${response.statusText}`);
  }

  const result = await response.json();

  if (!result.success || !result.data) {
    throw new Error('Invalid API response format');
  }

  forecastData = result.data;
} catch (err) {
  console.error('Error fetching forecast data:', err);
  error = err instanceof Error ? err.message : 'Failed to load forecast data';
}

const assumptions = forecastData?.assumptions ?? {
  monthlyTopup: settings.forecastMonthlyTopup,
  annualRate: settings.forecastAnnualRate,
};
const emptySummary: ForecastRealityCheckSummary = {
  latestActualKey: null,
  latestActualBalance: 0,
  plannedEndingBalance: 0,
  currentTrajectoryEndingBalance: 0,
  totalForecastInterest: 0,
  trailingAverageNetSavings: 0,
};
---

<ProtectedLayout title="Forecast" currentPath={currentPath} subtitle="Spending forecast">
  <div class="max-w-7xl mx-auto sm:px-2 lg:px-6 space-y-6 sm:space-y-8">
    <ForecastAssumptions
      monthlyTopup={assumptions.monthlyTopup}
      annualRate={assumptions.annualRate}
      currency={primaryCurrency}
    />

    {/* Wealth Trajectory Section */}
    {
      forecastData ? (
        <WealthTrajectory
          timeline={forecastData.timeline}
          chartWindow={forecastData.chartWindow}
          summary={forecastData.summary}
          currency={primaryCurrency}
        />
      ) : (
        <WealthTrajectory
          timeline={[]}
          summary={emptySummary}
          currency={primaryCurrency}
          error={error || 'Failed to load forecast data'}
        />
      )
    }

    {/* Monthly Gains Section */}
    {
      forecastData ? (
        <ForecastMonthlyGains
          timeline={forecastData.timeline}
          chartWindow={forecastData.chartWindow}
          currency={primaryCurrency}
        />
      ) : (
        <ForecastMonthlyGains
          timeline={[]}
          currency={primaryCurrency}
          error={error || 'Failed to load monthly gains data'}
        />
      )
    }

    {/* Ledger Projections Section */}
    {
      forecastData ? (
        <LedgerProjections data={forecastData.yearlyBreakdown} currency={primaryCurrency} />
      ) : (
        <LedgerProjections
          data={[]}
          currency={primaryCurrency}
          error={error || 'Failed to load projection data'}
        />
      )
    }
  </div>
</ProtectedLayout>

<script>
  import '@/components/organisms/ForecastAssumptions.client';
</script>
