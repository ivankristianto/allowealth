---
import ProtectedLayout from '@/layouts/ProtectedLayout.astro';

const currentPath = '/forecast/comparison';
---

<ProtectedLayout title="Forecast Comparison - Finance Manager" currentPath={currentPath}>
  <div class="space-y-6">
    <h2 class="text-2xl font-bold">Forecast Comparison</h2>

    <div class="tabs">
      <a class="tab" href="/forecast">Calculator</a>
      <a class="tab tab-active" href="/forecast/comparison">Comparison</a>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <p class="text-neutral-500">Compare different financial scenarios.</p>
      </div>
    </div>
  </div>
</ProtectedLayout>
