---
/**
 * Login Page
 *
 * User authentication page for signing in to the Finance Manager application.
 */

import AuthLayout from '../layouts/AuthLayout.astro';
import LoginForm from '../components/molecules/LoginForm.astro';
import { sanitizePostAuthRedirect } from '@/lib/auth/redirect';
import { getGoogleAuthErrorMessage } from '@/services/auth.service';

// Get error message and redirect from query params (if any)
const url = new URL(Astro.request.url);
const error = url.searchParams.get('error');
const redirect = sanitizePostAuthRedirect(url.searchParams.get('redirect'));
const registered = url.searchParams.get('registered');
const verified = url.searchParams.get('verified');
const passwordReset = url.searchParams.get('password-reset');
const passwordChanged = url.searchParams.get('password-changed');
const emailChanged = url.searchParams.get('email-changed');
const installed = url.searchParams.get('installed');
const oauthErrorCodes = new Set(['oauth_error', 'link_expired', 'link_failed', 'rate_limited']);
const oauthError =
  Astro.url.searchParams.get('oauth_error') || (error && oauthErrorCodes.has(error) ? error : '');
const oauthErrorMessage = getGoogleAuthErrorMessage(oauthError);

const errorMessages: Record<string, string> = {
  invalid_credentials: 'Invalid email or password. Please try again.',
  session_expired: 'Your session has expired. Please sign in again.',
  unauthorized: 'You must be logged in to access this page.',
  invalid_token: 'Invalid verification link. Please request a new one.',
  expired_token: 'Verification link has expired.',
  verification_failed: 'Email verification failed. Please try again.',
  email_taken: 'Email change failed - the email is now used by another account.',
};

// Only use whitelisted error codes to prevent XSS
// expired_token uses banner (with resend button), not inline error
const errorMessage = oauthErrorMessage
  ? oauthErrorMessage
  : error && !oauthErrorCodes.has(error) && error !== 'expired_token' && errorMessages[error]
    ? errorMessages[error]
    : '';

// Determine banner for verification status
let bannerMessage = '';
let bannerType: 'info' | 'success' | 'error' = 'info';

if (registered === 'true') {
  bannerMessage = 'Check your email to verify your account before logging in.';
  bannerType = 'info';
} else if (verified === 'true') {
  bannerMessage = 'Email verified! You can now sign in.';
  bannerType = 'success';
} else if (passwordReset === 'true') {
  bannerMessage = 'Password updated. You can now sign in.';
  bannerType = 'success';
} else if (passwordChanged === 'true') {
  bannerMessage = 'Password changed successfully. Please sign in again.';
  bannerType = 'success';
} else if (error === 'expired_token') {
  bannerMessage =
    'This verification link has expired. Sign in with your current email and request a new change from Profile.';
  bannerType = 'error';
} else if (emailChanged === 'true') {
  bannerMessage = 'Email changed successfully! Please sign in with your new email.';
  bannerType = 'success';
} else if (installed === 'true') {
  bannerMessage = 'Setup complete! Sign in with your admin account.';
  bannerType = 'success';
}
---

<AuthLayout title="allowealth - Sign In">
  <LoginForm
    errorMessage={errorMessage}
    redirectTo={redirect}
    bannerMessage={bannerMessage}
    bannerType={bannerType}
    oauthError={oauthErrorMessage ? '' : oauthError}
  />
</AuthLayout>
