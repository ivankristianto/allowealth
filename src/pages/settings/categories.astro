---
/**
 * Categories Management Page
 *
 * Full CRUD interface for managing expense/income categories.
 * Features: expense/income filtering, search, create, edit, and delete actions.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { categoryService } from '@/services';
import { Plus, Search, Pencil, Trash2 } from '@lucide/astro';
import CategoryIcon from '@/components/atoms/CategoryIcon.astro';
import TabToggle from '@/components/atoms/TabToggle.astro';

const user = Astro.locals.user!;
const currentPath = '/settings/categories';

// Fetch active categories only
const allCategories = await categoryService.findAll(user.id, { is_active: true });

// Get filters from query params
const url = new URL(Astro.url);
const typeFilter = (url.searchParams.get('type') as 'expense' | 'income') || 'expense';
const searchQuery = url.searchParams.get('search') || '';

// Filter by type
let filteredCategories = allCategories.filter((c) => c.type === typeFilter);

// Apply search filter
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredCategories = filteredCategories.filter((c) => c.name.toLowerCase().includes(query));
}

// Get type label for badge
const getTypeLabel = (type: string) => {
  return type.toUpperCase();
};

// Get type badge color
const getTypeBadgeClass = (type: string) => {
  return type === 'expense'
    ? 'bg-red-50 text-red-500 dark:bg-red-900/20'
    : 'bg-emerald-50 text-emerald-500 dark:bg-emerald-900/20';
};
---

<ProtectedLayout title="Manage Categories - Settings" currentPath={currentPath}>
  <div class="space-y-10 animate-in fade-in duration-300">
    <!-- View Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
      <div>
        <h2 class="text-2xl font-bold dark:text-white tracking-tight leading-none">
          Manage Categories
        </h2>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-2 font-medium">
          Organizing {allCategories.length} custom labels for your family ledger
        </p>
      </div>
      <button
        onclick="categoryModal.showModal()"
        class="bg-primary/10 hover:bg-primary/20 text-primary px-6 py-2.5 rounded-2xl font-bold text-sm transition-all border border-primary/10 flex items-center gap-2"
        data-type={typeFilter}
      >
        <Plus size={18} class="stroke-current" aria-hidden="true" />
        Create Category
      </button>
    </div>

    <!-- Search and Filters -->
    <div class="flex flex-col md:flex-row justify-between items-center gap-6">
      <!-- Type Filter Toggle -->
      <TabToggle
        activeTab={typeFilter}
        option1Value="expense"
        option1Label="Expense"
        option2Value="income"
        option2Label="Income"
        name="type"
      />

      <!-- Search Bar -->
      <form id="search-form" class="relative flex-1 w-full max-w-md">
        <span
          class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 dark:text-slate-500"
          aria-hidden="true"
        >
          <Search size={20} />
        </span>
        <input
          type="search"
          name="search"
          placeholder="Search categories..."
          value={searchQuery}
          class="w-full pl-12 pr-6 py-3.5 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 focus:border-primary focus:ring-0 rounded-2xl text-base font-medium dark:text-white shadow-sm"
        />
        <input type="hidden" name="type" value={typeFilter} />
      </form>
    </div>

    <!-- Categories Table -->
    <div
      class="bg-white dark:bg-slate-900 rounded-3xl border border-slate-200 dark:border-slate-800 shadow-sm overflow-hidden"
    >
      <div class="overflow-x-auto">
        {
          filteredCategories.length > 0 ? (
            <table class="w-full text-left border-collapse" role="table">
              <caption class="sr-only">
                Categories list with {filteredCategories.length} {typeFilter} categories
              </caption>
              <thead>
                <tr class="border-b border-slate-100 dark:border-slate-800 bg-slate-50/50 dark:bg-slate-800/30">
                  <th
                    scope="col"
                    class="px-8 py-5 text-[10px] font-bold text-slate-400 uppercase tracking-widest"
                  >
                    Icon
                  </th>
                  <th
                    scope="col"
                    class="px-8 py-5 text-[10px] font-bold text-slate-400 uppercase tracking-widest"
                  >
                    Category Name
                  </th>
                  <th
                    scope="col"
                    class="px-8 py-5 text-[10px] font-bold text-slate-400 uppercase tracking-widest text-center"
                  >
                    Type
                  </th>
                  <th
                    scope="col"
                    class="px-8 py-5 text-[10px] font-bold text-slate-400 uppercase tracking-widest text-right"
                  >
                    Actions
                  </th>
                </tr>
              </thead>
              <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                {filteredCategories.map((category) => (
                  <tr class="group hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                    <td class="px-8 py-5">
                      <CategoryIcon
                        icon={category.icon}
                        color={category.color}
                        size="md"
                        className="group-hover:scale-110"
                      />
                    </td>
                    <td class="px-8 py-5">
                      <span class="text-base font-bold dark:text-white tracking-tight leading-none">
                        {category.name}
                      </span>
                    </td>
                    <td class="px-8 py-5 text-center">
                      <span
                        class={`inline-block px-3 py-1 rounded-lg text-[10px] font-bold uppercase tracking-widest ${getTypeBadgeClass(category.type)}`}
                      >
                        {getTypeLabel(category.type)}
                      </span>
                    </td>
                    <td class="px-8 py-5 text-right">
                      <div class="flex items-center justify-end gap-2">
                        <button
                          class="p-2 text-slate-300 hover:text-primary hover:bg-indigo-50 dark:hover:bg-indigo-900/20 rounded-xl transition-all"
                          data-action="edit"
                          data-category-id={category.id}
                          aria-label={`Edit ${category.name} category`}
                        >
                          <Pencil size={18} class="stroke-current" aria-hidden="true" />
                        </button>
                        <button
                          class="p-2 text-slate-300 hover:text-red-500 hover:bg-red-50 dark:hover:bg-red-900/20 rounded-xl transition-all"
                          data-action="delete"
                          data-category-id={category.id}
                          aria-label={`Delete ${category.name} category`}
                        >
                          <Trash2 size={18} class="stroke-current" aria-hidden="true" />
                        </button>
                      </div>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          ) : (
            <div class="py-24 text-center">
              <div class="w-20 h-20 bg-slate-50 dark:bg-slate-800/50 mx-auto rounded-3xl flex items-center justify-center text-slate-300 mb-6 shadow-inner">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="40"
                  height="40"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <title>No categories</title>
                  <path d="M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z" />
                  <path d="M7 7h.01" />
                </svg>
              </div>
              <h4 class="text-lg font-bold text-slate-900 dark:text-white mb-2">
                No categories found
              </h4>
              <p class="text-slate-400 font-medium">Try adjusting your search terms.</p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</ProtectedLayout>

<!-- Add/Edit Category Modal -->
<dialog id="category-modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 id="modal-title" class="font-bold text-lg">Add Category</h3>
    <form id="category-form" class="py-4 space-y-4">
      <input type="hidden" name="id" value="" />

      <div class="form-control">
        <label class="label" for="name">
          <span class="label-text">Name</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <input
          type="text"
          name="name"
          id="name"
          class="input input-bordered"
          required
          placeholder="e.g., Food & Groceries"
        />
      </div>

      <div class="form-control">
        <label class="label" for="type">
          <span class="label-text">Type</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <select name="type" id="type" class="select select-bordered" required>
          <option value="expense">Expense</option>
          <option value="income">Income</option>
        </select>
      </div>

      <div class="form-control">
        <label class="label" for="icon">
          <span class="label-text">Icon</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <input
          type="text"
          name="icon"
          id="icon"
          class="input input-bordered"
          required
          placeholder="e.g., home, shopping-basket, car"
        />
        <label class="label">
          <span class="label-text-alt">Lucide icon name (kebab-case)</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label" for="color">
          <span class="label-text">Color</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <select name="color" id="color" class="select select-bordered" required>
          <option value="bg-primary">Primary</option>
          <option value="bg-secondary">Secondary</option>
          <option value="bg-accent">Accent</option>
          <option value="bg-neutral">Neutral</option>
          <option value="bg-success">Success</option>
          <option value="bg-warning">Warning</option>
          <option value="bg-error">Error</option>
          <option value="bg-info">Info</option>
        </select>
      </div>

      <div class="form-control">
        <label class="label" for="currency">
          <span class="label-text">Currency</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <select name="currency" id="currency" class="select select-bordered" required>
          <option value="IDR">IDR</option>
          <option value="USD">USD</option>
        </select>
      </div>

      <div class="form-control">
        <label class="label" for="percentage">
          <span class="label-text">Budget Allocation %</span>
        </label>
        <input
          type="number"
          name="percentage"
          id="percentage"
          class="input input-bordered"
          min="0"
          max="100"
          step="0.1"
          value="0"
          placeholder="e.g., 15"
        />
      </div>

      <div class="form-control">
        <label class="label" for="budget_amount">
          <span class="label-text">Monthly Budget Amount</span>
        </label>
        <input
          type="number"
          name="budget_amount"
          id="budget_amount"
          class="input input-bordered"
          min="0"
          step="0.01"
          value="0"
          placeholder="e.g., 1000000"
        />
      </div>

      <div id="form-error" class="hidden alert alert-error text-sm" role="alert"></div>

      <div class="modal-action">
        <button type="button" onclick="categoryModal.close()" class="btn btn-ghost">
          Cancel
        </button>
        <button type="submit" class="btn btn-primary"> Save Category </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<!-- Delete Confirmation Dialog -->
<dialog id="delete-dialog" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Delete Category</h3>
    <p class="py-4">
      Are you sure you want to delete this category? This action cannot be undone. Existing
      transactions with this category will remain unchanged.
    </p>
    <div id="delete-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-ghost">Cancel</button>
      </form>
      <button id="confirm-delete-btn" class="btn btn-error"> Delete </button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script src="./categories-client.ts"></script>
