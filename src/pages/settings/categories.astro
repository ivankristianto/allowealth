---
/**
 * Categories Management Page
 *
 * Full CRUD interface for managing expense/income categories.
 * Supports create, edit, deactivate (soft delete), and list with filtering.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { categoryService } from '@/services';
import { Plus, Search, X, Pencil, Ban, RefreshCw, Tag } from '@lucide/astro';
import Badge from '@components/atoms/Badge.astro';
import { formatCurrency } from '@/lib/tokens';

const user = Astro.locals.user!;
const currentPath = '/settings/categories';

// Fetch all categories (both active and inactive)
const activeCategories = await categoryService.findAll(user.id, { is_active: true });
const inactiveCategories = await categoryService.findAll(user.id, { is_active: false });

// Combine with status indicator
const allCategories = [
  ...activeCategories.map((c) => ({ ...c, status: 'active' })),
  ...inactiveCategories.map((c) => ({ ...c, status: 'inactive' })),
];

// Get filter from query params
const url = new URL(Astro.url);
const showInactive = url.searchParams.get('show') === 'inactive';
const searchQuery = url.searchParams.get('search') || '';

let filteredCategories = showInactive
  ? allCategories.filter((c) => c.status === 'inactive')
  : allCategories.filter((c) => c.status === 'active');

// Apply search filter
if (searchQuery) {
  const query = searchQuery.toLowerCase();
  filteredCategories = filteredCategories.filter((c) => c.name.toLowerCase().includes(query));
}

// Calculate total budget for expense categories
const totalBudget = filteredCategories
  .filter((c) => c.type === 'expense')
  .reduce((sum, c) => sum + parseFloat(c.budget_amount || '0'), 0);

// Get currency from first expense category
const currency = filteredCategories.find((c) => c.type === 'expense')?.currency || 'IDR';

// Type badges
const getTypeBadgeVariant = (type: string): 'error' | 'success' => {
  return type === 'expense' ? 'error' : 'success';
};

const getTypeLabel = (type: string) => {
  return type.charAt(0).toUpperCase() + type.slice(1);
};
---

<ProtectedLayout title="Categories - Settings" currentPath={currentPath}>
  <div class="space-y-6" data-categories-container data-categories={JSON.stringify(allCategories)}>
    <div class="flex justify-between items-center">
      <div>
        <h2 class="text-2xl font-bold">Categories</h2>
        <p class="text-base-content/60">
          Manage your expense and income categories for budget tracking
        </p>
      </div>
      <button onclick="categoryModal.showModal()" class="btn btn-primary gap-2" data-type="expense">
        <Plus size={16} class="stroke-current" aria-hidden="true" />
        Add Category
      </button>
    </div>

    <div class="tabs">
      <a class="tab" href="/settings">Profile</a>
      <a class="tab tab-active" href="/settings/categories">Categories</a>
      <a class="tab" href="/settings/payment-methods">Payment Methods</a>
    </div>

    <!-- Status Filter Tabs and Search -->
    <div class="flex flex-col sm:flex-row gap-4 justify-between items-start sm:items-center">
      <div class="tabs tabs-boxed bg-base-200 p-1">
        <a href="/settings/categories" class={'tab '.concat(!showInactive ? 'tab-active' : '')}>
          Active ({activeCategories.length})
        </a>
        <a
          href={'/settings/categories?show=inactive' +
            (searchQuery ? '&search=' + encodeURIComponent(searchQuery) : '')}
          class={'tab '.concat(showInactive ? 'tab-active' : '')}
        >
          Inactive ({inactiveCategories.length})
        </a>
      </div>
      <form id="search-form" class="join">
        <input
          type="search"
          name="search"
          placeholder="Search categories..."
          class="input input-bordered join-item"
          value={searchQuery}
        />
        <button type="submit" class="btn btn-neutral join-item" aria-label="Search categories">
          <Search size={16} class="stroke-current" aria-hidden="true" />
        </button>
        {
          searchQuery && (
            <a
              href="/settings/categories"
              class="btn btn-ghost join-item"
              aria-label="Clear search"
            >
              <X size={16} class="stroke-current" aria-hidden="true" />
            </a>
          )
        }
      </form>
    </div>

    <!-- Summary for active categories -->
    {
      !showInactive && (
        <div class="stats stats-horizontal shadow bg-base-100">
          <div class="stat">
            <div class="stat-title">Total Budget</div>
            <div class="stat-value text-primary">
              {formatCurrency(totalBudget, currency as 'IDR' | 'USD')}
            </div>
            <div class="stat-desc">
              Across {activeCategories.filter((c) => c.type === 'expense').length} expense
              categories
            </div>
          </div>
          <div class="stat">
            <div class="stat-title">Categories</div>
            <div class="stat-value">{activeCategories.length}</div>
            <div class="stat-desc">
              {activeCategories.filter((c) => c.type === 'expense').length} expense,{' '}
              {activeCategories.filter((c) => c.type === 'income').length} income
            </div>
          </div>
        </div>
      )
    }

    <!-- Categories List -->
    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body p-0">
        {
          filteredCategories.length > 0 ? (
            <div class="overflow-x-auto">
              <table class="table table-zebra">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Currency</th>
                    <th>Allocation</th>
                    <th>Budget</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {filteredCategories.map((category) => (
                    <tr>
                      <td>
                        <div class="font-medium">{category.name}</div>
                      </td>
                      <td>
                        <Badge variant={getTypeBadgeVariant(category.type)} size="sm">
                          {getTypeLabel(category.type)}
                        </Badge>
                      </td>
                      <td>{category.currency}</td>
                      <td>{category.percentage}%</td>
                      <td>
                        {category.type === 'expense'
                          ? formatCurrency(
                              category.budget_amount || '0',
                              category.currency as 'IDR' | 'USD'
                            )
                          : '-'}
                      </td>
                      <td>
                        <div class="flex gap-1">
                          {category.status === 'active' ? (
                            <>
                              <button
                                class="btn btn-ghost btn-sm"
                                onclick={'editCategory("' + category.id + '")'}
                                aria-label="Edit category"
                              >
                                <Pencil size={16} class="stroke-current" aria-hidden="true" />
                              </button>
                              <button
                                class="btn btn-ghost btn-sm text-warning"
                                onclick={'deactivateCategory("' + category.id + '")'}
                                aria-label="Deactivate category"
                              >
                                <Ban size={16} class="stroke-current" aria-hidden="true" />
                              </button>
                            </>
                          ) : (
                            <button
                              class="btn btn-ghost btn-sm text-success"
                              onclick={'activateCategory("' + category.id + '")'}
                              aria-label="Reactivate category"
                            >
                              <RefreshCw size={16} class="stroke-current" aria-hidden="true" />
                              Reactivate
                            </button>
                          )}
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="py-12 text-center text-neutral-500">
              <Tag size={24} class="mx-auto mb-2 opacity-50" aria-hidden="true" />
              <p>
                {showInactive
                  ? 'No inactive categories'
                  : 'No categories found. Create your first category to get started.'}
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</ProtectedLayout>

<!-- Add/Edit Category Modal -->
<dialog id="category-modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 id="modal-title" class="font-bold text-lg">Add Category</h3>
    <form id="category-form" class="py-4 space-y-4">
      <input type="hidden" name="id" value="" />

      <div class="form-control">
        <label class="label" for="name">
          <span class="label-text">Name</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <input
          type="text"
          name="name"
          id="name"
          class="input input-bordered"
          required
          placeholder="e.g., Food & Groceries"
        />
      </div>

      <div class="form-control">
        <label class="label" for="type">
          <span class="label-text">Type</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <select name="type" id="type" class="select select-bordered" required>
          <option value="expense">Expense</option>
          <option value="income">Income</option>
        </select>
      </div>

      <div class="form-control">
        <label class="label" for="currency">
          <span class="label-text">Currency</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <select name="currency" id="currency" class="select select-bordered" required>
          <option value="IDR">IDR</option>
          <option value="USD">USD</option>
        </select>
      </div>

      <div class="form-control">
        <label class="label" for="percentage">
          <span class="label-text">Budget Allocation %</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <input
          type="number"
          name="percentage"
          id="percentage"
          class="input input-bordered"
          required
          min="0"
          max="100"
          step="0.1"
          placeholder="e.g., 15"
        />
        <label class="label">
          <span class="label-text-alt">Percentage of total budget allocation</span>
        </label>
      </div>

      <div class="form-control">
        <label class="label" for="budget_amount">
          <span class="label-text">Monthly Budget Amount</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <input
          type="number"
          name="budget_amount"
          id="budget_amount"
          class="input input-bordered"
          required
          min="0"
          step="0.01"
          placeholder="e.g., 1000000"
        />
        <label class="label">
          <span class="label-text-alt">For expense categories only</span>
        </label>
      </div>

      <div id="form-error" class="hidden alert alert-error text-sm" role="alert"></div>

      <div class="modal-action">
        <button type="button" onclick="categoryModal.close()" class="btn btn-ghost">
          Cancel
        </button>
        <button type="submit" class="btn btn-primary"> Save Category </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<!-- Deactivate Confirmation Dialog -->
<dialog id="deactivate-dialog" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Deactivate Category</h3>
    <p class="py-4">
      Are you sure you want to deactivate this category? It will no longer appear in transaction
      forms, but existing transactions will remain unchanged.
    </p>
    <div id="deactivate-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-ghost">Cancel</button>
      </form>
      <button id="confirm-deactivate-btn" class="btn btn-warning"> Deactivate </button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<!-- Reactivate Confirmation Dialog -->
<dialog id="activate-dialog" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Reactivate Category</h3>
    <p class="py-4">
      Are you sure you want to reactivate this category? It will become available for use in
      transaction forms again.
    </p>
    <div id="activate-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-ghost">Cancel</button>
      </form>
      <button id="confirm-activate-btn" class="btn btn-success"> Reactivate </button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script src="./categories-client.ts"></script>
