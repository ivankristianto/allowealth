---
import MainLayout from '../../layouts/MainLayout.astro';

const currentPath = '/settings/payment-methods';
---

<MainLayout title="Payment Methods - Settings" currentPath={currentPath}>
  <div class="space-y-6">
    <div class="flex justify-between items-center">
      <h2 class="text-2xl font-bold">Payment Methods</h2>
      <button class="btn btn-primary">Add Method</button>
    </div>

    <div class="tabs">
      <a class="tab" href="/settings">Profile</a>
      <a class="tab" href="/settings/categories">Categories</a>
      <a class="tab tab-active" href="/settings/payment-methods">Payment Methods</a>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <p class="text-neutral-500">Manage your payment methods (cash, cards, bank accounts).</p>
      </div>
    </div>
  </div>
</MainLayout>
