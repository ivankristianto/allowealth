---
/**
 * Payment Methods Management Page
 *
 * Full CRUD interface for managing payment methods.
 * Supports create, edit, deactivate (soft delete), and list with filtering.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import { paymentMethodService } from '@/services';
import {
  Plus,
  Pencil,
  Ban,
  RefreshCw,
  DollarSign,
  CreditCard,
  ArrowLeft,
  Wallet,
} from '@lucide/astro';
import Badge from '@components/atoms/Badge.astro';
import PaymentMethodFormModal from '@components/organisms/PaymentMethodFormModal.astro';
import PaymentMethodConfirmModal from '@components/organisms/PaymentMethodConfirmModal.astro';

const user = Astro.locals.user!;
const currentPath = '/settings/payment-methods';

// Fetch all payment methods (both active and inactive)
const activeMethods = await paymentMethodService.findAll(user.id, { is_active: true });
const inactiveMethods = await paymentMethodService.findAll(user.id, { is_active: false });

// Combine with status indicator
const allMethods = [
  ...activeMethods.map((m) => ({ ...m, status: 'active' })),
  ...inactiveMethods.map((m) => ({ ...m, status: 'inactive' })),
];

// Get filter from query params
const url = new URL(Astro.url);
const showInactive = url.searchParams.get('show') === 'inactive';
const filteredMethods = showInactive
  ? allMethods.filter((m) => m.status === 'inactive')
  : allMethods.filter((m) => m.status === 'active');

// Type labels
const getTypeLabel = (type: string) => {
  const labels: Record<string, string> = {
    cash: 'Cash',
    credit_card: 'Credit Card',
    debit_card: 'Debit Card',
    bank_transfer: 'Bank Transfer',
    e_wallet: 'E-Wallet',
  };
  return labels[type] || type;
};
---

<ProtectedLayout title="Payment Methods - Settings" currentPath={currentPath}>
  <div class="space-y-6" data-methods-container data-methods={JSON.stringify(allMethods)}>
    <div class="flex justify-between items-center">
      <div>
        <h2 class="text-2xl font-bold">Payment Methods</h2>
        <p class="text-neutral-500">
          Manage your payment methods (cash, cards, bank accounts, e-wallets)
        </p>
      </div>
      <button data-action="add-method" class="btn btn-accent gap-2">
        <Plus size={16} class="stroke-current" aria-hidden="true" />
        Add Method
      </button>
    </div>

    <div class="tabs">
      <a class="tab" href="/profile">Manage Account</a>
      <a class="tab" href="/security">Security</a>
      <a class="tab" href="/categories">Categories</a>
      <a class="tab tab-active" href="/settings/payment-methods">Payment Methods</a>
    </div>

    <!-- Status Filter Tabs -->
    <div class="tabs tabs-boxed bg-base-200 p-1">
      <a href="/settings/payment-methods" class={'tab '.concat(!showInactive ? 'tab-active' : '')}>
        Active ({activeMethods.length})
      </a>
      <a
        href="/settings/payment-methods?show=inactive"
        class={'tab '.concat(showInactive ? 'tab-active' : '')}
      >
        Inactive ({inactiveMethods.length})
      </a>
    </div>

    <!-- Summary for active methods -->
    {
      !showInactive && activeMethods.length > 0 && (
        <div class="stats stats-horizontal shadow bg-base-100">
          <div class="stat">
            <div class="stat-title">Payment Methods</div>
            <div class="stat-value">{activeMethods.length}</div>
            <div class="stat-desc">Configured for transactions</div>
          </div>
        </div>
      )
    }

    <!-- Payment Methods List -->
    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body p-0">
        {
          filteredMethods.length > 0 ? (
            <div class="overflow-x-auto">
              <table class="table table-zebra">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {filteredMethods.map((method) => (
                    <tr>
                      <td>
                        <div class="flex items-center gap-2">
                          {method.type === 'cash' ? (
                            <DollarSign
                              size={16}
                              class="opacity-50 stroke-current"
                              aria-hidden="true"
                            />
                          ) : method.type === 'credit_card' || method.type === 'debit_card' ? (
                            <CreditCard
                              size={16}
                              class="opacity-50 stroke-current"
                              aria-hidden="true"
                            />
                          ) : method.type === 'bank_transfer' ? (
                            <>
                              {/* TODO: P2 - Replace ArrowLeft with Building2 or Landmark icon for better semantic meaning */}
                              <ArrowLeft
                                size={16}
                                class="opacity-50 stroke-current"
                                aria-hidden="true"
                              />
                            </>
                          ) : method.type === 'e_wallet' ? (
                            <Wallet
                              size={16}
                              class="opacity-50 stroke-current"
                              aria-hidden="true"
                            />
                          ) : (
                            <CreditCard
                              size={16}
                              class="opacity-50 stroke-current"
                              aria-hidden="true"
                            />
                          )}
                          <span class="font-medium">{method.name}</span>
                        </div>
                      </td>
                      <td>
                        <Badge variant="neutral" size="sm">
                          {getTypeLabel(method.type)}
                        </Badge>
                      </td>
                      <td>
                        <div class="flex gap-1">
                          {method.status === 'active' ? (
                            <>
                              <button
                                class="btn btn-ghost btn-sm"
                                data-action="edit"
                                data-method-id={method.id}
                                data-method-name={method.name}
                                data-method-type={method.type}
                                aria-label="Edit payment method"
                              >
                                <Pencil size={16} class="stroke-current" aria-hidden="true" />
                              </button>
                              <button
                                class="btn btn-ghost btn-sm text-warning"
                                data-action="deactivate"
                                data-method-id={method.id}
                                aria-label="Deactivate payment method"
                              >
                                <Ban size={16} class="stroke-current" aria-hidden="true" />
                              </button>
                            </>
                          ) : (
                            <button
                              class="btn btn-ghost btn-sm text-success"
                              data-action="activate"
                              data-method-id={method.id}
                              aria-label="Reactivate payment method"
                            >
                              <RefreshCw size={16} class="stroke-current" aria-hidden="true" />
                              Reactivate
                            </button>
                          )}
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="py-12 text-center text-neutral-500">
              <CreditCard size={24} class="mx-auto mb-2 opacity-50" aria-hidden="true" />
              <p>
                {showInactive
                  ? 'No inactive payment methods'
                  : 'No payment methods found. Add your first payment method to get started.'}
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</ProtectedLayout>

<!-- Modals using Modal.astro component pattern -->
<PaymentMethodFormModal id="payment-method-form-modal" />
<PaymentMethodConfirmModal id="deactivate-modal" action="deactivate" />
<PaymentMethodConfirmModal id="activate-modal" action="activate" />

<script>
  // Initialize page event handlers
  function initPaymentMethodsPage() {
    const container = document.querySelector('[data-methods-container]');
    if (!container) return;

    // Prevent duplicate initialization
    if ((container as HTMLElement).dataset.initialized === 'true') return;
    (container as HTMLElement).dataset.initialized = 'true';

    // Handle Add button
    const addBtn = container.querySelector('[data-action="add-method"]');
    addBtn?.addEventListener('click', () => {
      if (typeof (window as any).openPaymentMethodModal === 'function') {
        (window as any).openPaymentMethodModal();
      }
    });

    // Handle Edit buttons
    // TODO: P2 - Add defensive checks for missing data attributes and log errors
    container.querySelectorAll('[data-action="edit"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const methodData = {
          id: el.dataset.methodId || '',
          name: el.dataset.methodName || '',
          type: el.dataset.methodType || '',
        };
        if (typeof (window as any).openPaymentMethodModal === 'function') {
          (window as any).openPaymentMethodModal(methodData);
        }
      });
    });

    // Handle Deactivate buttons
    container.querySelectorAll('[data-action="deactivate"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const methodId = el.dataset.methodId;
        if (methodId && typeof (window as any).openDeactivateModal === 'function') {
          (window as any).openDeactivateModal(methodId);
        }
      });
    });

    // Handle Activate buttons
    container.querySelectorAll('[data-action="activate"]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        const methodId = el.dataset.methodId;
        if (methodId && typeof (window as any).openActivateModal === 'function') {
          (window as any).openActivateModal(methodId);
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPaymentMethodsPage);
  } else {
    initPaymentMethodsPage();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initPaymentMethodsPage);
</script>
