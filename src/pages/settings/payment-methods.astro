---
/**
 * Payment Methods Management Page
 *
 * Full CRUD interface for managing payment methods.
 * Supports create, edit, deactivate (soft delete), and list with filtering.
 */

import MainLayout from '@layouts/MainLayout.astro';
import { requireAuth } from '@/lib/auth/requireAuth';
import { paymentMethodService } from '@/services';
import Icon from '@components/atoms/Icon.astro';
import Badge from '@components/atoms/Badge.astro';

// Check authentication
const redirectResponse = requireAuth(Astro);
if (redirectResponse) {
  return redirectResponse;
}

const user = Astro.locals.user;
const currentPath = '/settings/payment-methods';

// Fetch all payment methods (both active and inactive)
const activeMethods = await paymentMethodService.findAll(user.id, { is_active: true });
const inactiveMethods = await paymentMethodService.findAll(user.id, { is_active: false });

// Combine with status indicator
const allMethods = [
  ...activeMethods.map((m) => ({ ...m, status: 'active' })),
  ...inactiveMethods.map((m) => ({ ...m, status: 'inactive' })),
];

// Get filter from query params
const url = new URL(Astro.url);
const showInactive = url.searchParams.get('show') === 'inactive';
const filteredMethods = showInactive
  ? allMethods.filter((m) => m.status === 'inactive')
  : allMethods.filter((m) => m.status === 'active');

// Type icons and labels
const getTypeLabel = (type: string) => {
  const labels: Record<string, string> = {
    cash: 'Cash',
    credit_card: 'Credit Card',
    debit_card: 'Debit Card',
    bank_transfer: 'Bank Transfer',
    e_wallet: 'E-Wallet',
  };
  return labels[type] || type;
};

const getTypeIcon = (type: string) => {
  const icons: Record<string, string> = {
    cash: 'currency-dollar',
    credit_card: 'credit-card',
    debit_card: 'credit-card',
    bank_transfer: 'arrow-left',
    e_wallet: 'calendar',
  };
  return icons[type] || 'tag';
};
---

<MainLayout title="Payment Methods - Settings" currentPath={currentPath} user={user}>
  <div class="space-y-6" data-methods-container data-methods={JSON.stringify(allMethods)}>
    <div class="flex justify-between items-center">
      <div>
        <h2 class="text-2xl font-bold">Payment Methods</h2>
        <p class="text-neutral-500">
          Manage your payment methods (cash, cards, bank accounts, e-wallets)
        </p>
      </div>
      <button onclick="methodModal.showModal()" class="btn btn-primary gap-2">
        <Icon name="plus" size="sm" />
        Add Method
      </button>
    </div>

    <div class="tabs">
      <a class="tab" href="/settings">Profile</a>
      <a class="tab" href="/settings/categories">Categories</a>
      <a class="tab tab-active" href="/settings/payment-methods">Payment Methods</a>
    </div>

    <!-- Status Filter Tabs -->
    <div class="tabs tabs-boxed bg-base-200 p-1">
      <a href="/settings/payment-methods" class={'tab '.concat(!showInactive ? 'tab-active' : '')}>
        Active ({activeMethods.length})
      </a>
      <a
        href="/settings/payment-methods?show=inactive"
        class={'tab '.concat(showInactive ? 'tab-active' : '')}
      >
        Inactive ({inactiveMethods.length})
      </a>
    </div>

    <!-- Summary for active methods -->
    {
      !showInactive && activeMethods.length > 0 && (
        <div class="stats stats-horizontal shadow bg-base-100">
          <div class="stat">
            <div class="stat-title">Payment Methods</div>
            <div class="stat-value">{activeMethods.length}</div>
            <div class="stat-desc">Configured for transactions</div>
          </div>
        </div>
      )
    }

    <!-- Payment Methods List -->
    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body p-0">
        {
          filteredMethods.length > 0 ? (
            <div class="overflow-x-auto">
              <table class="table table-zebra">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Actions</th>
                  </tr>
                </thead>
                <tbody>
                  {filteredMethods.map((method) => (
                    <tr>
                      <td>
                        <div class="flex items-center gap-2">
                          <Icon name={getTypeIcon(method.type)} size="sm" className="opacity-50" />
                          <span class="font-medium">{method.name}</span>
                        </div>
                      </td>
                      <td>
                        <Badge variant="neutral" size="sm">
                          {getTypeLabel(method.type)}
                        </Badge>
                      </td>
                      <td>
                        <div class="flex gap-1">
                          {method.status === 'active' ? (
                            <>
                              <button
                                class="btn btn-ghost btn-sm"
                                onclick={'editMethod("' + method.id + '")'}
                                aria-label="Edit payment method"
                              >
                                <Icon name="pencil" size="sm" />
                              </button>
                              <button
                                class="btn btn-ghost btn-sm text-warning"
                                onclick={'deactivateMethod("' + method.id + '")'}
                                aria-label="Deactivate payment method"
                              >
                                <Icon name="ban" size="sm" />
                              </button>
                            </>
                          ) : (
                            <button
                              class="btn btn-ghost btn-sm text-success"
                              onclick={'activateMethod("' + method.id + '")'}
                              aria-label="Reactivate payment method"
                            >
                              <Icon name="refresh" size="sm" />
                              Reactivate
                            </button>
                          )}
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          ) : (
            <div class="py-12 text-center text-neutral-500">
              <Icon name="credit-card" size="lg" className="mx-auto mb-2 opacity-50" />
              <p>
                {showInactive
                  ? 'No inactive payment methods'
                  : 'No payment methods found. Add your first payment method to get started.'}
              </p>
            </div>
          )
        }
      </div>
    </div>
  </div>
</MainLayout>

<!-- Add/Edit Payment Method Modal -->
<dialog id="method-modal" class="modal">
  <div class="modal-box max-w-md">
    <h3 id="modal-title" class="font-bold text-lg">Add Payment Method</h3>
    <form id="method-form" class="py-4 space-y-4">
      <input type="hidden" name="id" value="" />

      <div class="form-control">
        <label class="label" for="name">
          <span class="label-text">Name</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <input
          type="text"
          name="name"
          id="name"
          class="input input-bordered"
          required
          placeholder="e.g., BCA Account, GoPay, Cash Wallet"
        />
      </div>

      <div class="form-control">
        <label class="label" for="type">
          <span class="label-text">Type</span>
          <span class="label-text-alt text-error">*</span>
        </label>
        <select name="type" id="type" class="select select-bordered" required>
          <option value="">Select type...</option>
          <option value="cash">Cash</option>
          <option value="credit_card">Credit Card</option>
          <option value="debit_card">Debit Card</option>
          <option value="bank_transfer">Bank Transfer</option>
          <option value="e_wallet">E-Wallet</option>
        </select>
      </div>

      <div id="form-error" class="hidden alert alert-error text-sm" role="alert"></div>

      <div class="modal-action">
        <button type="button" onclick="methodModal.close()" class="btn btn-ghost"> Cancel </button>
        <button type="submit" class="btn btn-primary"> Save Payment Method </button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<!-- Deactivate Confirmation Dialog -->
<dialog id="deactivate-dialog" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Deactivate Payment Method</h3>
    <p class="py-4">
      Are you sure you want to deactivate this payment method? It will no longer appear in
      transaction forms, but existing transactions will remain unchanged.
    </p>
    <div id="deactivate-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-ghost">Cancel</button>
      </form>
      <button id="confirm-deactivate-btn" class="btn btn-warning"> Deactivate </button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<!-- Reactivate Confirmation Dialog -->
<dialog id="activate-dialog" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg">Reactivate Payment Method</h3>
    <p class="py-4">
      Are you sure you want to reactivate this payment method? It will become available for use in
      transaction forms again.
    </p>
    <div id="activate-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
    <div class="modal-action">
      <form method="dialog">
        <button class="btn btn-ghost">Cancel</button>
      </form>
      <button id="confirm-activate-btn" class="btn btn-success"> Reactivate </button>
    </div>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>

<script src="./payment-methods-client.ts"></script>
