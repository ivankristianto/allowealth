---
/**
 * System Settings Page
 *
 * Workspace settings page with general configuration and member management.
 * Admin users can manage workspace settings and invite/remove members.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import Label from '@/components/atoms/Label.astro';
import Card from '@/components/atoms/Card.astro';
import MemberList from '@/components/organisms/MemberList.astro';
import InviteMemberModal from '@/components/organisms/InviteMemberModal.astro';
import {
  Bell,
  Building2,
  Clock,
  Database,
  Mail,
  RotateCcw,
  Save,
  Settings,
  Trash2,
  UserPlus,
  Users,
  X,
} from '@lucide/astro';
import { workspaceService, workspaceMetaService, workspaceInvitationService } from '@/services';

const currentPath = '/settings';

// Get user from locals
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login?error=unauthorized');
}

const isAdmin = user.role === 'admin';
const workspaceId = user.workspaceId;

// Initialize workspace data with defaults
let workspaceData = {
  id: '',
  name: 'My Workspace',
  createdAt: new Date().toISOString(),
  settings: {
    currency: 'IDR',
    weekStart: 'monday',
    compactNumbers: true,
  },
};

let members: Array<{
  id: string;
  name: string;
  email: string;
  role: 'admin' | 'member';
  createdAt: string;
}> = [];

let invitations: Array<{
  id: string;
  email: string;
  role: 'admin' | 'member';
  expiresAt: string;
  createdAt: string;
}> = [];

try {
  // Fetch workspace settings directly from services
  const workspace = await workspaceService.findById(workspaceId);
  if (workspace) {
    const settings = await workspaceMetaService.getSettings(workspaceId);
    workspaceData = {
      id: workspace.id,
      name: workspace.name,
      createdAt:
        workspace.created_at instanceof Date
          ? workspace.created_at.toISOString()
          : String(workspace.created_at),
      settings: {
        currency: settings.currency,
        weekStart: settings.weekStart,
        compactNumbers: settings.compactNumbers,
      },
    };
  }

  // Fetch workspace members
  const workspaceMembers = await workspaceService.getMembers(workspaceId);
  members = workspaceMembers.map((member) => ({
    id: member.id,
    name: member.name,
    email: member.email,
    role: member.role,
    createdAt:
      member.created_at instanceof Date
        ? member.created_at.toISOString()
        : String(member.created_at),
  }));

  // Fetch pending invitations (admin only)
  if (isAdmin) {
    const pendingInvitations = await workspaceInvitationService.findPendingByWorkspace(workspaceId);
    invitations = pendingInvitations.map((inv) => ({
      id: inv.id,
      email: inv.email,
      role: inv.role,
      expiresAt:
        inv.expires_at instanceof Date ? inv.expires_at.toISOString() : String(inv.expires_at),
      createdAt:
        inv.created_at instanceof Date ? inv.created_at.toISOString() : String(inv.created_at),
    }));
  }
} catch (error) {
  console.error('Failed to fetch workspace data:', error);
}

const navItems = [
  { id: 'general', label: 'General', icon: Settings },
  { id: 'members', label: 'Members', icon: Users },
  { id: 'notifications', label: 'Notifications', icon: Bell },
  { id: 'data', label: 'Data', icon: Database },
] as const;

const activeSection = 'general';

const currencyOptions = [
  { value: 'IDR', label: 'Indonesian Rupiah (IDR)' },
  { value: 'USD', label: 'US Dollar (USD)' },
];

const weekStartOptions = [
  { value: 'monday', label: 'Monday' },
  { value: 'sunday', label: 'Sunday' },
];

const notificationSettings = [
  {
    id: 'budget-alerts',
    label: 'Budget Threshold Alerts',
    description: 'Notify when categories hit 80% usage.',
    enabled: true,
  },
  {
    id: 'large-expense',
    label: 'Large Expense Monitoring',
    description: 'Alert for any transaction over defined threshold.',
    enabled: true,
  },
  {
    id: 'bill-reminders',
    label: 'Bill Due Reminders',
    description: 'Get notified 48 hours before scheduled bills.',
    enabled: true,
  },
  {
    id: 'daily-digest',
    label: 'Daily Financial Summary',
    description: "Evening summary of today's total spending.",
    enabled: false,
  },
];

const dataActions = [
  {
    id: 'clear-history',
    title: 'Clear Transaction History',
    description: 'Archive all transactions',
    icon: Trash2,
  },
  {
    id: 'factory-reset',
    title: 'Factory Reset App',
    description: 'Delete all assets, members and settings',
    icon: RotateCcw,
  },
];
---

<ProtectedLayout title="Settings" currentPath={currentPath} subtitle="Manage your preferences">
  <main
    class="mx-auto max-w-5xl space-y-8 px-4 sm:px-6 lg:px-8"
    data-settings-page
    data-active-tab={activeSection}
    data-is-admin={isAdmin ? 'true' : 'false'}
    data-user-id={user.id}
  >
    <header class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
      <div class="space-y-1">
        <h1 class="text-2xl font-semibold text-base-content">System Settings</h1>
        <p class="text-sm text-base-content/60">Configure workspace settings and manage access.</p>
      </div>
      <button
        type="button"
        class="btn btn-accent h-14 rounded-2xl gap-2 font-bold shadow-sm"
        id="save-settings-btn"
      >
        <Save size={18} class="stroke-current" aria-hidden="true" />
        Save Changes
      </button>
    </header>

    <section class="flex flex-col gap-6 lg:flex-row">
      <nav class="w-full lg:w-64" aria-label="Settings sections">
        <ul class="flex flex-col gap-2" role="tablist" aria-orientation="vertical">
          {
            navItems.map((item) => (
              <li>
                <button
                  type="button"
                  id={`settings-tab-${item.id}`}
                  class={[
                    'relative',
                    'flex',
                    'items-center',
                    'gap-4',
                    'py-4',
                    'px-5',
                    'w-full',
                    'text-base',
                    'rounded-xl',
                    'transition-all',
                    'duration-200',
                    'border',
                    item.id === activeSection
                      ? 'bg-accent/10 text-accent font-bold border-accent'
                      : 'text-base-content/60 hover:text-base-content font-medium border-transparent',
                  ]
                    .filter(Boolean)
                    .join(' ')}
                  data-settings-tab
                  data-tab={item.id}
                  role="tab"
                  aria-controls={`settings-panel-${item.id}`}
                  aria-selected={item.id === activeSection ? 'true' : 'false'}
                >
                  <item.icon size={20} class="stroke-current" aria-hidden="true" />
                  <span>{item.label}</span>
                  <span
                    class={[
                      'ml-auto',
                      'w-2',
                      'h-2',
                      'bg-accent',
                      'rounded-full',
                      item.id === activeSection ? '' : 'hidden',
                    ]
                      .filter(Boolean)
                      .join(' ')}
                    data-active-dot
                    aria-hidden="true"
                  />
                </button>
              </li>
            ))
          }
        </ul>
      </nav>

      <article class="flex-1">
        <Card padding="lg" rounded="card-lg" className="w-full">
          <div class="flex flex-col gap-8">
            {/* General Settings Panel */}
            <section
              id="settings-panel-general"
              data-settings-panel
              data-tab="general"
              role="tabpanel"
              aria-labelledby="settings-tab-general"
            >
              <div class="flex flex-col gap-6">
                <header class="space-y-1">
                  <h2 class="text-xl font-semibold text-base-content">Workspace Settings</h2>
                  <p class="text-sm text-base-content/60">
                    Manage your workspace name and preferences.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <form id="workspace-settings-form" class="flex flex-col gap-5">
                  {/* Workspace Name (Admin only) */}
                  {
                    isAdmin && (
                      <div class="form-control">
                        <Label htmlFor="workspace-name">Workspace Name</Label>
                        <div class="flex gap-2">
                          <input
                            type="text"
                            id="workspace-name"
                            name="workspaceName"
                            value={workspaceData.name}
                            class="input input-bordered flex-1 h-14 rounded-lg border border-base-300 bg-base-200 py-4 px-6 text-base font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                            placeholder="My Workspace"
                          />
                        </div>
                        <p class="text-xs text-base-content/50 mt-2 ml-4">
                          This name is visible to all workspace members.
                        </p>
                      </div>
                    )
                  }

                  {/* Non-admin workspace name display */}
                  {
                    !isAdmin && (
                      <div class="form-control">
                        <Label>Workspace Name</Label>
                        <div class="flex items-center gap-3 h-14 rounded-lg border border-base-300 bg-base-200 py-4 px-6">
                          <Building2
                            size={20}
                            class="stroke-current text-base-content/50"
                            aria-hidden="true"
                          />
                          <span class="text-base font-bold">{workspaceData.name}</span>
                        </div>
                        <p class="text-xs text-base-content/50 mt-2 ml-4">
                          Only admins can change the workspace name.
                        </p>
                      </div>
                    )
                  }

                  <div class="grid gap-4 md:grid-cols-2">
                    <div class="form-control">
                      <Label htmlFor="primary-currency">Primary Currency</Label>
                      <select
                        id="primary-currency"
                        name="currency"
                        class="select select-bordered w-full h-14 rounded-lg border border-base-300 bg-base-200 py-4 pl-6 pr-10 text-base font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                      >
                        {
                          currencyOptions.map((currency) => (
                            <option
                              value={currency.value}
                              selected={workspaceData.settings.currency === currency.value}
                            >
                              {currency.label}
                            </option>
                          ))
                        }
                      </select>
                    </div>

                    <div class="form-control">
                      <Label htmlFor="week-starts">Week Starts On</Label>
                      <select
                        id="week-starts"
                        name="weekStart"
                        class="select select-bordered w-full h-14 rounded-lg border border-base-300 bg-base-200 py-4 pl-6 pr-10 text-base font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                      >
                        {
                          weekStartOptions.map((option) => (
                            <option
                              value={option.value}
                              selected={workspaceData.settings.weekStart === option.value}
                            >
                              {option.label}
                            </option>
                          ))
                        }
                      </select>
                    </div>
                  </div>

                  <div
                    class="flex flex-col gap-4 rounded-box border border-base-300 bg-base-200 p-6 sm:flex-row sm:items-center sm:justify-between"
                  >
                    <div class="space-y-1">
                      <h3 class="font-semibold text-base-content">Compact Number Display</h3>
                      <p class="text-sm text-base-content/60">
                        Show amounts as Rp 1.5M instead of Rp 1.500.000
                      </p>
                    </div>
                    <input
                      type="checkbox"
                      class="toggle toggle-accent"
                      name="compactNumbers"
                      id="compact-numbers"
                      aria-label="Compact number display"
                      checked={workspaceData.settings.compactNumbers}
                    />
                  </div>
                </form>
              </div>
            </section>

            {/* Members Panel */}
            <section
              id="settings-panel-members"
              data-settings-panel
              data-tab="members"
              role="tabpanel"
              aria-labelledby="settings-tab-members"
              class="hidden"
            >
              <div class="flex flex-col gap-6">
                <header class="space-y-1">
                  <h2 class="text-xl font-semibold text-base-content">Workspace Members</h2>
                  <p class="text-sm text-base-content/60">
                    Manage who has access to this workspace.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                  <p class="text-xs font-semibold uppercase tracking-wide text-base-content/50">
                    {members.length} Active Member{members.length !== 1 ? 's' : ''}
                  </p>
                  {
                    isAdmin && (
                      <button
                        type="button"
                        class="btn btn-ghost btn-sm gap-2"
                        onclick="openInviteMemberModal()"
                      >
                        <UserPlus size={16} class="stroke-current" aria-hidden="true" />
                        Invite Member
                      </button>
                    )
                  }
                </div>

                <MemberList members={members} currentUserId={user.id} isAdmin={isAdmin} />

                {/* Pending Invitations (Admin only) */}
                {
                  isAdmin && invitations.length > 0 && (
                    <div class="mt-6">
                      <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between mb-4">
                        <p class="text-xs font-semibold uppercase tracking-wide text-base-content/50">
                          Pending Invitations ({invitations.length})
                        </p>
                      </div>

                      <ul
                        class="divide-y divide-base-200 rounded-box border border-base-300 bg-base-100"
                        data-invitations-list
                      >
                        {invitations.map((invitation) => (
                          <li
                            class="flex flex-col gap-4 p-4 sm:flex-row sm:items-center sm:justify-between"
                            data-invitation-item
                            data-invitation-id={invitation.id}
                          >
                            <div class="flex items-center gap-4">
                              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-warning/10 text-warning">
                                <Mail size={20} class="stroke-current" aria-hidden="true" />
                              </div>
                              <div>
                                <p class="font-semibold text-base-content">{invitation.email}</p>
                                <div class="flex items-center gap-2 text-xs text-base-content/60">
                                  <Clock size={12} aria-hidden="true" />
                                  <span>
                                    Expires{' '}
                                    {new Date(invitation.expiresAt).toLocaleDateString('en-US', {
                                      month: 'short',
                                      day: 'numeric',
                                    })}
                                  </span>
                                </div>
                              </div>
                            </div>
                            <div class="flex items-center gap-3">
                              <span class="badge badge-warning badge-outline">
                                {invitation.role}
                              </span>
                              <button
                                type="button"
                                class="btn btn-ghost btn-sm btn-square text-error hover:bg-error/10"
                                aria-label={`Cancel invitation to ${invitation.email}`}
                                data-cancel-invitation
                                data-invitation-id={invitation.id}
                                data-invitation-email={invitation.email}
                              >
                                <X size={16} class="stroke-current" aria-hidden="true" />
                              </button>
                            </div>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )
                }

                {
                  isAdmin && invitations.length === 0 && (
                    <p class="text-sm text-base-content/60 text-center py-4">
                      No pending invitations. Use the "Invite Member" button to add new members.
                    </p>
                  )
                }
              </div>
            </section>

            {/* Notifications Panel */}
            <section
              id="settings-panel-notifications"
              data-settings-panel
              data-tab="notifications"
              role="tabpanel"
              aria-labelledby="settings-tab-notifications"
              class="hidden"
            >
              <div class="flex flex-col gap-6">
                <header class="space-y-1">
                  <h2 class="text-xl font-semibold text-base-content">
                    Notifications Configuration
                  </h2>
                  <p class="text-sm text-base-content/60">
                    Choose how and when we should notify you.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <div class="flex flex-col gap-4">
                  {
                    notificationSettings.map((item) => (
                      <div class="flex flex-col gap-4 rounded-box border border-base-300 bg-base-200 p-6 sm:flex-row sm:items-center sm:justify-between">
                        <div class="space-y-1">
                          <p class="font-semibold text-base-content">{item.label}</p>
                          <p class="text-sm text-base-content/60">{item.description}</p>
                        </div>
                        <input
                          type="checkbox"
                          class="toggle toggle-accent"
                          name={`notification-${item.id}`}
                          aria-label={item.label}
                          checked={item.enabled}
                          disabled
                        />
                      </div>
                    ))
                  }
                </div>
                <p class="text-xs text-base-content/50 text-center">
                  Notification settings are coming soon.
                </p>
              </div>
            </section>

            {/* Data Panel */}
            <section
              id="settings-panel-data"
              data-settings-panel
              data-tab="data"
              role="tabpanel"
              aria-labelledby="settings-tab-data"
              class="hidden"
            >
              <div class="flex flex-col gap-6">
                <header class="space-y-1">
                  <h2 class="text-xl font-semibold text-base-content">Data Configuration</h2>
                  <p class="text-sm text-base-content/60">
                    Review critical maintenance actions for your ledger.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <div class="flex flex-col gap-4 rounded-box border border-base-300 bg-base-200 p-6">
                  <div class="space-y-1">
                    <h3 class="text-base font-semibold text-error">Ledger Maintenance</h3>
                    <p class="text-sm text-base-content/60">
                      These actions are permanent and cannot be undone.
                    </p>
                  </div>
                  <div class="flex flex-col gap-3">
                    {
                      dataActions.map((action) => (
                        <button
                          type="button"
                          class="flex w-full items-center justify-between rounded-box border border-base-300 bg-base-100 p-4 text-left hover:bg-base-200 opacity-50 cursor-not-allowed"
                          disabled
                        >
                          <div class="space-y-1">
                            <p class="font-semibold text-base-content">{action.title}</p>
                            <p class="text-xs font-semibold uppercase tracking-wide text-base-content/50">
                              {action.description}
                            </p>
                          </div>
                          <action.icon
                            size={18}
                            class="stroke-current text-error"
                            aria-hidden="true"
                          />
                        </button>
                      ))
                    }
                  </div>
                  <p class="text-xs text-base-content/50 text-center">
                    Data management actions are coming soon.
                  </p>
                </div>
              </div>
            </section>
          </div>
        </Card>
      </article>
    </section>
  </main>

  {/* Invite Member Modal */}
  <InviteMemberModal id="invite-member-modal" />

  {/* Cancel Invitation Confirmation Modal */}
  <dialog id="cancel-invitation-modal" class="modal" data-cancel-invitation-modal>
    <div class="modal-box max-w-md rounded-card shadow-premium">
      <h3 class="font-bold text-lg text-warning">Cancel Invitation</h3>
      <p class="py-4 text-base-content/70">
        Are you sure you want to cancel the invitation to <span
          class="font-semibold"
          data-invitation-email-display></span>? They will no longer be able to join this workspace
        using the invitation link.
      </p>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn btn-ghost rounded-2xl">Keep Invitation</button>
        </form>
        <button
          type="button"
          class="btn btn-warning rounded-2xl"
          data-confirm-cancel-invitation
          data-canceling-invitation-id=""
        >
          Cancel Invitation
        </button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  <script src="./settings-client.ts"></script>
</ProtectedLayout>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { setButtonLoading } from '@/lib/client-utils';
  import { getCsrfHeaders } from '@/lib/csrf-client';

  const container = document.querySelector('[data-settings-page]') as HTMLElement | null;
  if (!container) throw new Error('Settings page container not found');

  const isAdmin = container.dataset.isAdmin === 'true';

  // ==================== WORKSPACE SETTINGS FORM ====================
  const saveBtn = document.getElementById('save-settings-btn') as HTMLButtonElement | null;
  const settingsForm = document.getElementById('workspace-settings-form') as HTMLFormElement | null;

  if (saveBtn && settingsForm) {
    saveBtn.addEventListener('click', async () => {
      setButtonLoading(saveBtn, true);

      try {
        const formData = new FormData(settingsForm);

        const payload: Record<string, unknown> = {
          currency: formData.get('currency'),
          weekStart: formData.get('weekStart'),
          compactNumbers: formData.get('compactNumbers') === 'on',
        };

        // Include workspace name only if admin
        if (isAdmin) {
          const workspaceName = formData.get('workspaceName');
          if (workspaceName) {
            payload.name = workspaceName;
          }
        }

        const response = await fetch('/api/workspace/settings', {
          method: 'PUT',
          headers: getCsrfHeaders({
            'Content-Type': 'application/json',
          }),
          credentials: 'include',
          body: JSON.stringify(payload),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          addToast('Settings saved successfully!', 'success');
        } else {
          const errorMessage =
            result.error?.message || 'Failed to save settings. Please try again.';
          addToast(errorMessage, 'error');
        }
      } catch (error) {
        console.error('Settings update error:', error);
        addToast('An error occurred. Please check your connection and try again.', 'error');
      } finally {
        setButtonLoading(saveBtn, false);
      }
    });
  }

  // ==================== CANCEL INVITATION ====================
  const cancelInvitationModal = document.getElementById(
    'cancel-invitation-modal'
  ) as HTMLDialogElement | null;
  const invitationEmailDisplay = cancelInvitationModal?.querySelector(
    '[data-invitation-email-display]'
  );
  const confirmCancelBtn = cancelInvitationModal?.querySelector(
    '[data-confirm-cancel-invitation]'
  ) as HTMLButtonElement | null;

  // Handle cancel invitation button clicks - open modal
  document.querySelectorAll('[data-cancel-invitation]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const invitationId = btn.getAttribute('data-invitation-id');
      const invitationEmail = btn.getAttribute('data-invitation-email');

      if (
        invitationId &&
        invitationEmail &&
        invitationEmailDisplay &&
        confirmCancelBtn &&
        cancelInvitationModal
      ) {
        invitationEmailDisplay.textContent = invitationEmail;
        confirmCancelBtn.setAttribute('data-canceling-invitation-id', invitationId);
        cancelInvitationModal.showModal();
      }
    });
  });

  // Handle confirm cancel in modal
  if (confirmCancelBtn && cancelInvitationModal) {
    confirmCancelBtn.addEventListener('click', async () => {
      const invitationId = confirmCancelBtn.getAttribute('data-canceling-invitation-id');
      if (!invitationId) return;

      setButtonLoading(confirmCancelBtn, true);

      try {
        const response = await fetch(`/api/workspace/invitations?invitationId=${invitationId}`, {
          method: 'DELETE',
          credentials: 'include',
          headers: getCsrfHeaders(),
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.error?.message || 'Failed to cancel invitation');
        }

        addToast('Invitation cancelled', 'success');
        cancelInvitationModal.close();

        // Remove the invitation row from the list
        const invitationRow = document.querySelector(
          `[data-invitation-item][data-invitation-id="${invitationId}"]`
        );
        if (invitationRow) {
          invitationRow.remove();
        }

        // Check if there are no more invitations
        const remainingInvitations = document.querySelectorAll('[data-invitation-item]');
        if (remainingInvitations.length === 0) {
          const invitationsList = document.querySelector('[data-invitations-list]');
          if (invitationsList) {
            invitationsList.parentElement?.remove();
          }
        }
      } catch (err) {
        const message = err instanceof Error ? err.message : 'Failed to cancel invitation';
        addToast(message, 'error');
      } finally {
        setButtonLoading(confirmCancelBtn, false);
      }
    });
  }

  // Listen for new invitations to refresh the page
  document.addEventListener('invitation:created', () => {
    // Reload the page to show the new invitation
    window.location.reload();
  });
</script>
