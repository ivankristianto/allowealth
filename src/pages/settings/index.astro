---
/**
 * System Settings Page
 *
 * Workspace settings page with general configuration and member management.
 * Admin users can manage workspace settings and invite/remove members.
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import Label from '@/components/atoms/Label.astro';
import Card from '@/components/atoms/Card.astro';
import Button from '@/components/atoms/Button.astro';
import Modal from '@/components/molecules/Modal.astro';
import DiagnosticsDisplay from '@/components/organisms/DiagnosticsDisplay.astro';
import MemberList from '@/components/organisms/MemberList.astro';
import InviteMemberModal from '@/components/organisms/InviteMemberModal.astro';
import { db } from '@/db';
import { isDemoMode } from '@/lib/demo-mode';
import { accentGhostBtn } from '@/lib/ui/action-button-classes';
import {
  Bell,
  Building2,
  CircleAlert,
  Clock,
  Database,
  Info,
  Mail,
  RotateCcw,
  Save,
  Server,
  Settings,
  Trash2,
  UserPlus,
  Users,
  X,
} from '@lucide/astro';
import { DiagnosticsService } from '@/services/diagnostics.service';
import type { DiagnosticsData } from '@/types/diagnostics';
import { workspaceService, workspaceMetaService, workspaceInvitationService } from '@/services';
import { CURRENCY_META, CURRENCY_OPTIONS } from '@/lib/constants/currency';

const currentPath = '/settings';

// Get user from locals
const user = Astro.locals.user;
if (!user) {
  return Astro.redirect('/login?error=unauthorized');
}

const isAdmin = user.role === 'admin';
const workspaceId = user.workspaceId;

// Settings page requires a workspace context (super_admin has no workspace)
if (!workspaceId) {
  return Astro.redirect('/admin');
}

// Initialize workspace data with defaults
let workspaceData = {
  id: '',
  name: 'My Workspace',
  createdAt: new Date().toISOString(),
  settings: {
    currency: 'IDR',
    secondaryCurrency: '',
    weekStart: 'monday',
  },
};
let canChangeCurrency = true;

let members: Array<{
  id: string;
  name: string;
  email: string;
  role: 'admin' | 'member' | 'super_admin';
  createdAt: string;
  mfaEnabled: boolean;
}> = [];

let invitations: Array<{
  id: string;
  email: string;
  role: 'admin' | 'member';
  expiresAt: string;
  createdAt: string;
}> = [];

try {
  // Fetch workspace settings directly from services
  const workspace = await workspaceService.findById(workspaceId);
  if (workspace) {
    const settings = await workspaceMetaService.getSettings(workspaceId);
    workspaceData = {
      id: workspace.id,
      name: workspace.name,
      createdAt:
        workspace.created_at instanceof Date
          ? workspace.created_at.toISOString()
          : String(workspace.created_at),
      settings: {
        currency: settings.currency,
        secondaryCurrency: settings.secondaryCurrency,
        weekStart: settings.weekStart,
      },
    };

    canChangeCurrency = await workspaceMetaService.canChangeCurrencySettings(workspaceId);
  }

  // Fetch workspace members
  const workspaceMembers = await workspaceService.getMembers(workspaceId);
  members = workspaceMembers.map((member) => ({
    id: member.id,
    name: member.name,
    email: member.email,
    role: member.role,
    createdAt:
      member.created_at instanceof Date
        ? member.created_at.toISOString()
        : String(member.created_at),
    mfaEnabled: member.mfaEnabled,
  }));

  // Fetch pending invitations (admin only)
  if (isAdmin) {
    const pendingInvitations = await workspaceInvitationService.findPendingByWorkspace(workspaceId);
    invitations = pendingInvitations.map((inv) => ({
      id: inv.id,
      email: inv.email,
      role: inv.role,
      expiresAt:
        inv.expires_at instanceof Date ? inv.expires_at.toISOString() : String(inv.expires_at),
      createdAt:
        inv.created_at instanceof Date ? inv.created_at.toISOString() : String(inv.created_at),
    }));
  }
} catch (error) {
  console.error('Failed to fetch workspace data:', error);
}

let diagnosticsData: DiagnosticsData | null = null;
let diagnosticsError: string | null = null;

if (isAdmin) {
  try {
    const diagnosticsService = new DiagnosticsService(db);
    diagnosticsData = await diagnosticsService.getDiagnostics();
  } catch (err) {
    console.error('Failed to fetch diagnostics:', err);
    diagnosticsError = err instanceof Error ? err.message : 'Unknown error';
  }
}

const navItems: Array<{ id: string; label: string; icon: typeof Settings }> = [
  { id: 'general', label: 'General', icon: Settings },
  { id: 'members', label: 'Members', icon: Users },
  { id: 'notifications', label: 'Notifications', icon: Bell },
  { id: 'data', label: 'Data', icon: Database },
];

if (isAdmin) {
  navItems.push({ id: 'server-stats', label: 'Server Stats', icon: Server });
}

const activeSection = 'general';
const demoMode = isDemoMode();

const currencyOptions = CURRENCY_OPTIONS.map((opt) => ({
  value: opt.value,
  label: `${CURRENCY_META[opt.value].flagEmoji} ${opt.value} — ${CURRENCY_META[opt.value].name}`,
}));

const weekStartOptions = [
  { value: 'monday', label: 'Monday' },
  { value: 'sunday', label: 'Sunday' },
];

const notificationSettings = [
  {
    id: 'budget-alerts',
    label: 'Budget Threshold Alerts',
    description: 'Notify when categories hit 80% usage.',
    enabled: true,
  },
  {
    id: 'large-expense',
    label: 'Large Expense Monitoring',
    description: 'Alert for any transaction over defined threshold.',
    enabled: true,
  },
  {
    id: 'bill-reminders',
    label: 'Bill Due Reminders',
    description: 'Get notified 48 hours before scheduled bills.',
    enabled: true,
  },
  {
    id: 'daily-digest',
    label: 'Daily Financial Summary',
    description: "Evening summary of today's total spending.",
    enabled: false,
  },
];

const groupedSectionClass = 'rounded-3xl border border-base-300 bg-base-200/40 p-5 sm:p-6';
const sectionEyebrowClass =
  'text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45';
const sectionTitleClass = 'text-lg font-semibold text-base-content';
const inviteMemberButtonClassName = accentGhostBtn
  .split(' ')
  .filter((className) => !['btn', 'btn-ghost', 'btn-sm', 'md:btn-md'].includes(className))
  .concat('border-0')
  .join(' ');
---

<ProtectedLayout title="Settings" currentPath={currentPath} subtitle="Manage your preferences">
  <main
    class="mx-auto max-w-6xl space-y-8 px-4 sm:px-6 lg:px-8"
    data-settings-page
    data-active-tab={activeSection}
    data-is-admin={isAdmin ? 'true' : 'false'}
    data-user-id={user.id}
  >
    <section class="flex flex-col gap-6 lg:flex-row lg:items-start">
      <nav class="w-full lg:sticky lg:top-24 lg:w-72 lg:self-start" aria-label="Settings sections">
        <div class="rounded-3xl border border-base-300 bg-base-100/80 p-2 shadow-sm">
          <div class="px-3 pb-2 pt-3">
            <p class={sectionEyebrowClass}>Workspace Settings</p>
            <p class="mt-1 text-sm text-base-content/60">
              Switch between workspace preferences, members, and diagnostics.
            </p>
          </div>
          <ul class="flex flex-col gap-1.5" role="tablist" aria-orientation="vertical">
            {
              navItems.map((item) => (
                <li>
                  <button
                    type="button"
                    id={`settings-tab-${item.id}`}
                    class:list={[
                      'group flex min-h-11 w-full items-center gap-3 rounded-2xl px-4 py-3 text-left text-sm transition-colors duration-200',
                      item.id === activeSection
                        ? 'bg-accent/10 font-semibold text-accent shadow-sm'
                        : 'text-base-content/65 hover:bg-base-200 hover:text-base-content',
                    ]}
                    data-settings-tab
                    data-tab={item.id}
                    role="tab"
                    aria-controls={`settings-panel-${item.id}`}
                    aria-selected={item.id === activeSection ? 'true' : 'false'}
                  >
                    <span
                      class:list={[
                        'flex h-9 w-9 shrink-0 items-center justify-center rounded-xl transition-colors',
                        item.id === activeSection
                          ? 'bg-accent/15 text-accent'
                          : 'bg-base-200 text-base-content/50 group-hover:bg-base-300 group-hover:text-base-content/70',
                      ]}
                    >
                      <item.icon size={18} class="stroke-current" aria-hidden="true" />
                    </span>
                    <span class="min-w-0 flex-1">{item.label}</span>
                    <span
                      class:list={[
                        'rounded-full px-2 py-0.5 text-xs font-semibold uppercase tracking-[0.18em]',
                        item.id === activeSection
                          ? 'bg-accent/15 text-accent'
                          : 'bg-base-200 text-base-content/40',
                      ]}
                      data-active-dot
                      aria-hidden="true"
                    >
                      {item.id === activeSection ? 'Live' : 'Tab'}
                    </span>
                  </button>
                </li>
              ))
            }
          </ul>
        </div>
      </nav>

      <article class="flex-1">
        <Card padding="lg" rounded="card-lg" className="w-full">
          <div class="flex flex-col gap-8">
            {/* General Settings Panel */}
            <section
              id="settings-panel-general"
              data-settings-panel
              data-tab="general"
              role="tabpanel"
              aria-labelledby="settings-tab-general"
            >
              <div class="flex flex-col gap-6">
                <header class="space-y-2">
                  <p class={sectionEyebrowClass}>General</p>
                  <h2 class="text-xl font-semibold text-base-content">Workspace Settings</h2>
                  <p class="text-sm text-base-content/60">
                    Manage your workspace name and preferences.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <form id="workspace-settings-form" class="flex flex-col gap-5">
                  <div class="grid gap-5 xl:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)]">
                    <section
                      class={groupedSectionClass}
                      aria-labelledby="settings-general-identity"
                    >
                      <div class="mb-5 space-y-1">
                        <p class={sectionEyebrowClass}>Workspace Identity</p>
                        <h3 id="settings-general-identity" class={sectionTitleClass}>
                          How your workspace appears
                        </h3>
                        <p class="text-sm text-base-content/60">
                          Name the space your members see in navigation, onboarding, and shared
                          settings.
                        </p>
                      </div>

                      {
                        isAdmin && (
                          <div class="form-control">
                            <Label htmlFor="workspace-name">Workspace Name</Label>
                            <div class="flex gap-2">
                              <input
                                type="text"
                                id="workspace-name"
                                name="workspaceName"
                                value={workspaceData.name}
                                class="input input-bordered flex-1 h-14 rounded-lg border border-base-300 bg-base-100 py-4 px-6 text-base font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                                placeholder="My Workspace"
                              />
                            </div>
                            <p class="mt-2 ml-4 text-xs text-base-content/50">
                              This name is visible to all workspace members.
                            </p>
                          </div>
                        )
                      }

                      {
                        !isAdmin && (
                          <div class="form-control">
                            <Label>Workspace Name</Label>
                            <div class="flex h-14 items-center gap-3 rounded-lg border border-base-300 bg-base-100 py-4 px-6">
                              <Building2
                                size={20}
                                class="stroke-current text-base-content/50"
                                aria-hidden="true"
                              />
                              <span class="text-base font-bold">{workspaceData.name}</span>
                            </div>
                            <p class="mt-2 ml-4 text-xs text-base-content/50">
                              Only admins can change the workspace name.
                            </p>
                          </div>
                        )
                      }
                    </section>

                    <section
                      class={groupedSectionClass}
                      aria-labelledby="settings-general-preferences"
                    >
                      <div class="mb-5 space-y-1">
                        <p class={sectionEyebrowClass}>Preferences</p>
                        <h3 id="settings-general-preferences" class={sectionTitleClass}>
                          Regional and reporting defaults
                        </h3>
                        <p class="text-sm text-base-content/60">
                          Set the currencies and calendar rules used across your workspace.
                        </p>
                      </div>

                      <div class="grid gap-4 md:grid-cols-2">
                        <div class="form-control">
                          <Label htmlFor="primary-currency">Primary Currency</Label>
                          <select
                            id="primary-currency"
                            name="currency"
                            class:list={[
                              'select select-bordered h-14 w-full rounded-lg border border-base-300 bg-base-100 py-4 pl-6 pr-10 text-base font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
                              !canChangeCurrency &&
                                'appearance-none cursor-not-allowed bg-none pr-6 opacity-70',
                            ]}
                            disabled={!canChangeCurrency}
                          >
                            {
                              currencyOptions.map((currency) => (
                                <option
                                  value={currency.value}
                                  selected={workspaceData.settings.currency === currency.value}
                                >
                                  {currency.label}
                                </option>
                              ))
                            }
                          </select>
                        </div>

                        <div class="form-control">
                          <Label htmlFor="secondary-currency">Secondary Currency</Label>
                          <select
                            id="secondary-currency"
                            name="secondaryCurrency"
                            class:list={[
                              'select select-bordered h-14 w-full rounded-lg border border-base-300 bg-base-100 py-4 pl-6 pr-10 text-base font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
                              !canChangeCurrency &&
                                'appearance-none cursor-not-allowed bg-none pr-6 opacity-70',
                            ]}
                            disabled={!canChangeCurrency}
                          >
                            <option value="" selected={!workspaceData.settings.secondaryCurrency}>
                              None
                            </option>
                            {
                              currencyOptions
                                .filter(
                                  (currency) => currency.value !== workspaceData.settings.currency
                                )
                                .map((currency) => (
                                  <option
                                    value={currency.value}
                                    selected={
                                      workspaceData.settings.secondaryCurrency === currency.value
                                    }
                                  >
                                    {currency.label}
                                  </option>
                                ))
                            }
                          </select>
                        </div>
                      </div>

                      <div class="mt-4">
                        {
                          !canChangeCurrency && (
                            <div class="alert alert-info text-sm">
                              <Info class="size-5 shrink-0" />
                              <span>
                                Currency settings are locked after creating accounts, budgets, or
                                transactions.
                              </span>
                            </div>
                          )
                        }
                        {
                          canChangeCurrency && (
                            <div class="alert alert-warning text-sm">
                              <Info class="size-5 shrink-0" />
                              <span>
                                Choose carefully. Currency settings cannot be changed after you add
                                accounts or transactions.
                              </span>
                            </div>
                          )
                        }
                      </div>

                      <div class="mt-4 form-control">
                        <Label htmlFor="week-starts">Week Starts On</Label>
                        <select
                          id="week-starts"
                          name="weekStart"
                          class="select select-bordered h-14 w-full rounded-lg border border-base-300 bg-base-100 py-4 pl-6 pr-10 text-base font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
                        >
                          {
                            weekStartOptions.map((option) => (
                              <option
                                value={option.value}
                                selected={workspaceData.settings.weekStart === option.value}
                              >
                                {option.label}
                              </option>
                            ))
                          }
                        </select>
                      </div>
                    </section>
                  </div>
                </form>

                <div class="rounded-3xl border border-base-300 bg-base-100 px-5 py-4 sm:px-6">
                  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <div class="space-y-1">
                      <p class={sectionEyebrowClass}>Save</p>
                      <p class="text-sm text-base-content/60">
                        Review your changes, then save them explicitly for this tab.
                      </p>
                    </div>
                    <Button
                      type="button"
                      variant="primary"
                      size="lg"
                      className="w-full gap-2 font-bold shadow-sm sm:w-auto"
                      id="save-settings-btn"
                    >
                      <Save size={18} class="stroke-current" aria-hidden="true" />
                      Save Changes
                    </Button>
                  </div>
                </div>
              </div>
            </section>

            {/* Members Panel */}
            <section
              id="settings-panel-members"
              data-settings-panel
              data-tab="members"
              role="tabpanel"
              aria-labelledby="settings-tab-members"
              class="hidden"
            >
              <div class="flex flex-col gap-6">
                <header class="space-y-2">
                  <p class={sectionEyebrowClass}>Members</p>
                  <h2 class="text-xl font-semibold text-base-content">Workspace Members</h2>
                  <p class="text-sm text-base-content/60">
                    Manage who has access to this workspace.
                  </p>
                  <p class="text-xs text-base-content/50">
                    Linked sign-in methods and two-factor setup are managed from
                    <a href="/security" class="link link-hover ml-1">Security</a>.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <div class={groupedSectionClass}>
                  <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <div class="space-y-1">
                      <p class={sectionEyebrowClass}>Team Access</p>
                      <h3 class={sectionTitleClass}>Active members and invitations</h3>
                      <p class="text-sm text-base-content/60">
                        Keep your workspace roster current and invite collaborators when you are
                        ready.
                      </p>
                    </div>
                    {
                      isAdmin && !demoMode && (
                        <Button
                          type="button"
                          variant="ghost"
                          size="sm"
                          className={`${inviteMemberButtonClassName} w-full sm:w-auto`}
                          onclick="document.getElementById('invite-member-modal')?.showModal()"
                        >
                          <UserPlus size={16} class="stroke-current" aria-hidden="true" />
                          Invite Member
                        </Button>
                      )
                    }
                  </div>
                </div>

                <section class={groupedSectionClass} aria-labelledby="settings-members-active">
                  <div
                    class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
                  >
                    <div class="space-y-1">
                      <p class={sectionEyebrowClass}>Active Members</p>
                      <h3 id="settings-members-active" class={sectionTitleClass}>
                        Current workspace roster
                      </h3>
                    </div>
                    <span class="badge badge-neutral badge-lg">
                      {members.length} Active Member{members.length !== 1 ? 's' : ''}
                    </span>
                  </div>

                  <MemberList members={members} currentUserId={user.id} isAdmin={isAdmin} />
                </section>

                {/* Pending Invitations (Admin only) */}
                {
                  !demoMode && isAdmin && invitations.length > 0 && (
                    <section class={groupedSectionClass} aria-labelledby="settings-members-pending">
                      <div class="mb-4 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div class="space-y-1">
                          <p class={sectionEyebrowClass}>Pending Invitations</p>
                          <h3 id="settings-members-pending" class={sectionTitleClass}>
                            Waiting for a response
                          </h3>
                        </div>
                        <span class="badge badge-warning badge-lg">
                          {invitations.length} Pending
                        </span>
                      </div>

                      <ul
                        class="divide-y divide-base-200 rounded-box border border-base-300 bg-base-100"
                        data-invitations-list
                      >
                        {invitations.map((invitation) => (
                          <li
                            class="flex flex-col gap-4 p-4 sm:flex-row sm:items-center sm:justify-between"
                            data-invitation-item
                            data-invitation-id={invitation.id}
                          >
                            <div class="flex items-center gap-4">
                              <div class="flex h-10 w-10 items-center justify-center rounded-full bg-warning/10 text-warning">
                                <Mail size={20} class="stroke-current" aria-hidden="true" />
                              </div>
                              <div>
                                <p class="font-semibold text-base-content">{invitation.email}</p>
                                <div class="flex items-center gap-2 text-xs text-base-content/60">
                                  <Clock size={12} aria-hidden="true" />
                                  <span>
                                    Expires{' '}
                                    {new Date(invitation.expiresAt).toLocaleDateString('en-US', {
                                      month: 'short',
                                      day: 'numeric',
                                    })}
                                  </span>
                                </div>
                              </div>
                            </div>
                            <div class="flex items-center gap-3">
                              <span class="badge badge-warning badge-outline">
                                {invitation.role}
                              </span>
                              <Button
                                type="button"
                                variant="ghost"
                                size="sm"
                                shape="square"
                                className="rounded-xl border-0 text-error hover:bg-error/10 hover:text-error"
                                aria-label={`Cancel invitation to ${invitation.email}`}
                                data-cancel-invitation
                                data-invitation-id={invitation.id}
                                data-invitation-email={invitation.email}
                              >
                                <X size={16} class="stroke-current" aria-hidden="true" />
                              </Button>
                            </div>
                          </li>
                        ))}
                      </ul>
                    </section>
                  )
                }

                {
                  !demoMode && isAdmin && invitations.length === 0 && (
                    <section class={groupedSectionClass}>
                      <p class={sectionEyebrowClass}>Pending Invitations</p>
                      <p class="mt-2 text-sm text-base-content/60">
                        No pending invitations. Use the "Invite Member" button to add new members.
                      </p>
                    </section>
                  )
                }

                {
                  isAdmin && demoMode && (
                    <section class={groupedSectionClass}>
                      <p class={sectionEyebrowClass}>Demo Mode</p>
                      <p class="mt-2 text-sm text-base-content/60">
                        Member invitations are disabled in demo mode.
                      </p>
                    </section>
                  )
                }
              </div>
            </section>

            {/* Notifications Panel */}
            <section
              id="settings-panel-notifications"
              data-settings-panel
              data-tab="notifications"
              role="tabpanel"
              aria-labelledby="settings-tab-notifications"
              class="hidden"
            >
              <div class="flex flex-col gap-6">
                <header class="space-y-2">
                  <p class={sectionEyebrowClass}>Notifications</p>
                  <h2 class="text-xl font-semibold text-base-content">
                    Notifications Configuration
                  </h2>
                  <p class="text-sm text-base-content/60">
                    Choose how and when we should notify you.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <div class={groupedSectionClass}>
                  <p class={sectionEyebrowClass}>Roadmap</p>
                  <h3 class={`mt-2 ${sectionTitleClass}`}>Delivery preferences are planned</h3>
                  <p class="mt-2 text-sm text-base-content/60">
                    These controls show the notification categories that will become configurable as
                    email, digest, and alert delivery ships.
                  </p>
                  <div class="mt-4 alert alert-info text-sm">
                    <Info class="size-5 shrink-0" />
                    <span
                      >Preview only for now. The toggles stay disabled until delivery is live.</span
                    >
                  </div>
                </div>

                <div class="flex flex-col gap-4">
                  {
                    notificationSettings.map((item) => (
                      <div class="flex flex-col gap-4 rounded-3xl border border-base-300 bg-base-200/40 p-6 sm:flex-row sm:items-center sm:justify-between">
                        <div class="space-y-1">
                          <p class="font-semibold text-base-content">{item.label}</p>
                          <p class="text-sm text-base-content/60">{item.description}</p>
                        </div>
                        <input
                          type="checkbox"
                          class="toggle toggle-accent"
                          name={`notification-${item.id}`}
                          aria-label={item.label}
                          checked={item.enabled}
                          disabled
                        />
                      </div>
                    ))
                  }
                </div>
                <p class="text-center text-xs text-base-content/50">
                  Notification settings are coming soon.
                </p>
              </div>
            </section>

            {/* Data Panel */}
            <section
              id="settings-panel-data"
              data-settings-panel
              data-tab="data"
              role="tabpanel"
              aria-labelledby="settings-tab-data"
              class="hidden"
            >
              <div class="flex flex-col gap-8">
                <header class="space-y-2">
                  <p class={sectionEyebrowClass}>Data</p>
                  <h2 class="text-xl font-semibold text-base-content">Data Management</h2>
                  <p class="text-sm text-base-content/60">
                    Manage workspace data. Destructive actions require admin access.
                  </p>
                </header>
                <div class="divider my-0"></div>

                <section class={groupedSectionClass} aria-labelledby="settings-data-danger">
                  <div class="mb-5 space-y-1">
                    <p class={sectionEyebrowClass}>Danger Zone</p>
                    <h3 id="settings-data-danger" class={sectionTitleClass}>
                      High-risk workspace actions
                    </h3>
                    <p class="text-sm text-base-content/60">
                      These actions affect permanent workspace data and stay restricted to admins.
                    </p>
                  </div>

                  <div class="grid gap-4 xl:grid-cols-2">
                    <div
                      class="flex flex-col gap-4 rounded-3xl border border-warning/30 bg-base-100 p-6"
                    >
                      <div class="space-y-1">
                        <p class="font-semibold text-base-content">Clear Transaction History</p>
                        <p class="text-sm text-base-content/60">
                          Permanently deletes all transactions. Accounts, budgets, and categories
                          are kept.
                        </p>
                      </div>
                      <div
                        class="alert border border-accent/20 bg-accent/10 py-3 text-sm text-base-content"
                      >
                        <Info size={16} class="shrink-0 text-accent" aria-hidden="true" />
                        <span>This cannot be undone.</span>
                      </div>
                      <div
                        class={!isAdmin ? 'tooltip tooltip-top w-fit' : ''}
                        data-tip={!isAdmin ? 'Admin access required' : undefined}
                      >
                        <Button
                          type="button"
                          variant="danger"
                          size="sm"
                          disabled={!isAdmin}
                          data-open-modal="clear-history-modal"
                        >
                          <Trash2 size={14} class="stroke-current" aria-hidden="true" />
                          Clear History
                        </Button>
                      </div>
                    </div>

                    <div
                      class="flex flex-col gap-4 rounded-3xl border border-error/30 bg-base-100 p-6"
                    >
                      <div class="space-y-1">
                        <p class="font-semibold text-base-content">Factory Reset</p>
                        <p class="text-sm text-base-content/60">
                          Deletes everything — transactions, accounts, budgets, categories, and
                          workspace settings. Members are kept.
                        </p>
                      </div>
                      <div class="alert alert-error py-3 text-sm">
                        <Info size={16} class="shrink-0" aria-hidden="true" />
                        <span>This is irreversible.</span>
                      </div>
                      <div
                        class={!isAdmin ? 'tooltip tooltip-top w-fit' : ''}
                        data-tip={!isAdmin ? 'Admin access required' : undefined}
                      >
                        <Button
                          type="button"
                          variant="danger"
                          size="sm"
                          disabled={!isAdmin}
                          data-open-modal="factory-reset-modal"
                        >
                          <RotateCcw size={14} class="stroke-current" aria-hidden="true" />
                          Factory Reset
                        </Button>
                      </div>
                    </div>
                  </div>
                </section>

                <section class={groupedSectionClass} aria-labelledby="settings-data-backup">
                  <div
                    class="mb-5 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between"
                  >
                    <div class="space-y-1">
                      <p class={sectionEyebrowClass}>Backup & Restore</p>
                      <h3 id="settings-data-backup" class={sectionTitleClass}>
                        Recovery tools on the roadmap
                      </h3>
                    </div>
                    <span class="badge badge-neutral badge-lg">Coming soon</span>
                  </div>
                  <div
                    class="flex flex-col gap-3 rounded-3xl border border-base-300 bg-base-100/60 p-6 opacity-60"
                  >
                    <p class="text-sm text-base-content/60">
                      Backup and restore stay intentionally inactive until export and restore flows
                      are implemented end to end.
                    </p>
                    <div class="flex flex-col gap-3 sm:flex-row">
                      <Button type="button" variant="outline" size="sm" disabled className="flex-1">
                        <Database size={14} class="stroke-current" aria-hidden="true" />
                        Download Backup
                      </Button>
                      <Button type="button" variant="outline" size="sm" disabled className="flex-1">
                        <RotateCcw size={14} class="stroke-current" aria-hidden="true" />
                        Restore from Backup
                      </Button>
                    </div>
                    <p class="text-xs text-base-content/50">
                      Backup & restore is tracked in
                      <a
                        href="https://github.com/ivankristianto/allowealth/issues/351"
                        class="link link-hover"
                        target="_blank"
                        rel="noopener noreferrer"
                      >
                        issue #351
                      </a>.
                    </p>
                  </div>
                </section>
              </div>
            </section>

            {
              isAdmin && (
                <section
                  id="settings-panel-server-stats"
                  data-settings-panel
                  data-tab="server-stats"
                  role="tabpanel"
                  aria-labelledby="settings-tab-server-stats"
                  class="hidden"
                >
                  <div class="flex flex-col gap-6">
                    <header class="space-y-1">
                      <h2 class="text-xl font-semibold text-base-content">Server Stats</h2>
                      <p class="text-sm text-base-content/60">
                        Runtime configuration, database, and cache health.
                      </p>
                    </header>
                    <div class="divider my-0" />

                    {diagnosticsError && (
                      <div class="alert alert-error rounded-xl" role="alert">
                        <CircleAlert size={20} class="shrink-0" aria-hidden="true" />
                        <div>
                          <h3 class="font-bold">Error Loading Stats</h3>
                          <p class="text-sm">{diagnosticsError}</p>
                        </div>
                      </div>
                    )}

                    {diagnosticsData && <DiagnosticsDisplay data={diagnosticsData} />}
                  </div>
                </section>
              )
            }
          </div>
        </Card>
      </article>
    </section>
  </main>

  {/* Invite Member Modal */}
  <InviteMemberModal id="invite-member-modal" />

  {/* Cancel Invitation Confirmation Modal */}
  <Modal
    id="cancel-invitation-modal"
    size="sm"
    closable={true}
    backdropClose={true}
    ariaLabel="Cancel invitation"
  >
    <div data-cancel-invitation-modal>
      <h3 class="font-bold text-lg text-warning mb-2">Cancel Invitation</h3>
      <p class="text-base-content/70">
        Are you sure you want to cancel the invitation to <span
          class="font-semibold"
          data-invitation-email-display></span>? They will no longer be able to join this workspace
        using the invitation link.
      </p>
    </div>
    <div slot="actions" class="modal-action">
      <form method="dialog">
        <Button type="submit" variant="ghost" className="rounded-2xl">Keep Invitation</Button>
      </form>
      <Button
        type="button"
        variant="warning"
        data-confirm-cancel-invitation
        data-canceling-invitation-id=""
      >
        Cancel Invitation
      </Button>
    </div>
  </Modal>

  <Modal
    id="clear-history-modal"
    size="sm"
    closable={true}
    backdropClose={true}
    ariaLabel="Clear transaction history"
  >
    <div>
      <h3 class="font-bold text-lg text-warning mb-2">Clear Transaction History</h3>
      <p class="text-base-content/70">
        Are you sure? All transactions will be permanently deleted. Accounts, budgets, and
        categories are kept. This cannot be undone.
      </p>
    </div>
    <div slot="actions" class="modal-action">
      <form method="dialog">
        <Button type="submit" variant="ghost" className="rounded-2xl">Cancel</Button>
      </form>
      <Button type="button" variant="danger" data-confirm-clear-history>Clear History</Button>
    </div>
  </Modal>

  <Modal
    id="factory-reset-modal"
    size="sm"
    closable={true}
    backdropClose={false}
    ariaLabel="Factory reset"
  >
    <div>
      <h3 class="font-bold text-lg text-error mb-2">Factory Reset</h3>
      <p class="text-base-content/70 mb-4">
        This will delete all transactions, accounts, budgets, categories, and workspace settings.
        Members are kept. This is irreversible.
      </p>
      <label for="factory-reset-confirm-input" class="text-sm font-semibold mb-2 block">
        Type <code class="bg-base-300 px-1 rounded">RESET</code> to confirm:
      </label>
      <input
        type="text"
        id="factory-reset-confirm-input"
        class="input input-bordered w-full"
        placeholder="RESET"
        autocomplete="off"
        aria-label="Type RESET to confirm factory reset"
        data-reset-confirm-input
      />
    </div>
    <div slot="actions" class="modal-action">
      <form method="dialog">
        <Button type="submit" variant="ghost" className="rounded-2xl">Cancel</Button>
      </form>
      <Button type="button" variant="danger" disabled data-confirm-factory-reset>
        Factory Reset
      </Button>
    </div>
  </Modal>

  <script src="./settings-client.ts"></script>
</ProtectedLayout>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { setButtonLoading } from '@/lib/client-utils';
  import { getCsrfHeaders } from '@/lib/csrf-client';

  const container = document.querySelector('[data-settings-page]') as HTMLElement | null;
  if (!container) throw new Error('Settings page container not found');

  const isAdmin = container.dataset.isAdmin === 'true';

  // ==================== WORKSPACE SETTINGS FORM ====================
  const saveBtnBottom = document.getElementById('save-settings-btn') as HTMLButtonElement | null;
  const settingsForm = document.getElementById('workspace-settings-form') as HTMLFormElement | null;
  const primaryCurrencySelect = document.getElementById(
    'primary-currency'
  ) as HTMLSelectElement | null;
  const secondaryCurrencySelect = document.getElementById(
    'secondary-currency'
  ) as HTMLSelectElement | null;

  async function handleSave() {
    const allSaveBtns = [saveBtnBottom].filter(Boolean) as HTMLButtonElement[];
    allSaveBtns.forEach((btn) => setButtonLoading(btn, true));

    try {
      const formData = new FormData(settingsForm!);
      const canEditCurrencySettings =
        !primaryCurrencySelect?.disabled && !secondaryCurrencySelect?.disabled;

      const payload: Record<string, unknown> = {
        weekStart: formData.get('weekStart'),
      };
      if (canEditCurrencySettings) {
        payload.currency = primaryCurrencySelect?.value ?? formData.get('currency');
        payload.secondaryCurrency = secondaryCurrencySelect?.value ?? '';
      }

      // Include workspace name only if admin
      if (isAdmin) {
        const workspaceName = formData.get('workspaceName');
        if (workspaceName) {
          payload.name = workspaceName;
        }
      }

      const response = await fetch('/api/workspace/settings', {
        method: 'PUT',
        headers: getCsrfHeaders({
          'Content-Type': 'application/json',
        }),
        credentials: 'include',
        body: JSON.stringify(payload),
      });

      const result = await response.json();

      if (response.ok && result.success) {
        addToast('Settings saved successfully!', 'success');
      } else {
        const errorMessage = result.error?.message || 'Failed to save settings. Please try again.';
        addToast(errorMessage, 'error');
      }
    } catch (error) {
      console.error('Settings update error:', error);
      addToast('An error occurred. Please check your connection and try again.', 'error');
    } finally {
      allSaveBtns.forEach((btn) => setButtonLoading(btn, false));
    }
  }

  if (saveBtnBottom && settingsForm) {
    saveBtnBottom.addEventListener('click', handleSave);
  }

  if (primaryCurrencySelect && secondaryCurrencySelect) {
    const syncSecondaryCurrencyOptions = () => {
      const selectedPrimary = primaryCurrencySelect.value;
      for (const option of Array.from(secondaryCurrencySelect.options)) {
        if (option.value === '') continue;
        option.hidden = option.value === selectedPrimary;
      }
      if (secondaryCurrencySelect.value === selectedPrimary) {
        secondaryCurrencySelect.value = '';
      }
    };

    primaryCurrencySelect.addEventListener('change', syncSecondaryCurrencyOptions);
    syncSecondaryCurrencyOptions();
  }

  // ==================== CANCEL INVITATION ====================
  const cancelInvitationModal = document.getElementById(
    'cancel-invitation-modal'
  ) as HTMLDialogElement | null;
  const invitationEmailDisplay = cancelInvitationModal?.querySelector(
    '[data-invitation-email-display]'
  );
  const confirmCancelBtn = cancelInvitationModal?.querySelector(
    '[data-confirm-cancel-invitation]'
  ) as HTMLButtonElement | null;

  // Handle cancel invitation button clicks - open modal
  document.querySelectorAll('[data-cancel-invitation]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const invitationId = btn.getAttribute('data-invitation-id');
      const invitationEmail = btn.getAttribute('data-invitation-email');

      if (
        invitationId &&
        invitationEmail &&
        invitationEmailDisplay &&
        confirmCancelBtn &&
        cancelInvitationModal
      ) {
        invitationEmailDisplay.textContent = invitationEmail;
        confirmCancelBtn.setAttribute('data-canceling-invitation-id', invitationId);
        cancelInvitationModal.showModal();
      }
    });
  });

  // Handle confirm cancel in modal
  if (confirmCancelBtn && cancelInvitationModal) {
    confirmCancelBtn.addEventListener('click', async () => {
      const invitationId = confirmCancelBtn.getAttribute('data-canceling-invitation-id');
      if (!invitationId) return;

      setButtonLoading(confirmCancelBtn, true);

      try {
        const response = await fetch(`/api/workspace/invitations?invitationId=${invitationId}`, {
          method: 'DELETE',
          credentials: 'include',
          headers: getCsrfHeaders(),
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          throw new Error(result.error?.message || 'Failed to cancel invitation');
        }

        addToast('Invitation cancelled', 'success');
        cancelInvitationModal.close();

        // Remove the invitation row from the list
        const invitationRow = document.querySelector(
          `[data-invitation-item][data-invitation-id="${invitationId}"]`
        );
        if (invitationRow) {
          invitationRow.remove();
        }

        // Check if there are no more invitations
        const remainingInvitations = document.querySelectorAll('[data-invitation-item]');
        if (remainingInvitations.length === 0) {
          const invitationsList = document.querySelector('[data-invitations-list]');
          if (invitationsList) {
            invitationsList.parentElement?.remove();
          }
        }
      } catch (err) {
        const message = err instanceof Error ? err.message : 'Failed to cancel invitation';
        addToast(message, 'error');
      } finally {
        setButtonLoading(confirmCancelBtn, false);
      }
    });
  }

  // ==================== DATA PANEL ====================
  document.querySelectorAll<HTMLButtonElement>('[data-open-modal]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const modalId = btn.dataset.openModal;
      if (!modalId) return;
      const modal = document.getElementById(modalId) as HTMLDialogElement | null;
      modal?.showModal();
    });
  });

  const confirmClearHistoryBtn = document.querySelector(
    '[data-confirm-clear-history]'
  ) as HTMLButtonElement | null;

  if (confirmClearHistoryBtn) {
    confirmClearHistoryBtn.addEventListener('click', () => {
      addToast('Clear History is not yet implemented.', 'info');
      (document.getElementById('clear-history-modal') as HTMLDialogElement | null)?.close();
    });
  }

  const resetInput = document.getElementById(
    'factory-reset-confirm-input'
  ) as HTMLInputElement | null;
  const confirmResetBtn = document.querySelector(
    '[data-confirm-factory-reset]'
  ) as HTMLButtonElement | null;
  const factoryResetModal = document.getElementById(
    'factory-reset-modal'
  ) as HTMLDialogElement | null;

  if (resetInput && confirmResetBtn) {
    resetInput.addEventListener('input', () => {
      confirmResetBtn.disabled = resetInput.value !== 'RESET';
    });
  }

  factoryResetModal?.addEventListener('close', () => {
    if (resetInput) resetInput.value = '';
    if (confirmResetBtn) confirmResetBtn.disabled = true;
  });

  if (confirmResetBtn) {
    confirmResetBtn.addEventListener('click', () => {
      addToast('Factory Reset is not yet implemented.', 'info');
      factoryResetModal?.close();
    });
  }

  // Listen for new invitations to refresh the page
  document.addEventListener('invitation:created', () => {
    // Reload the page to show the new invitation
    window.location.reload();
  });
</script>
