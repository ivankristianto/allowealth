---
/**
 * Admin Diagnostics Page
 *
 * System diagnostics page for administrators.
 * Displays runtime, database, cache, environment, and configuration information.
 *
 * Protected by requireAdmin() - only accessible to admin users.
 * Fetches diagnostics server-side via diagnosticsService.getDiagnostics().
 *
 * Features:
 * - Server-side data fetching
 * - Refresh button with client-side script
 * - Toast notifications on error
 * - ProtectedLayout wrapper
 */

import ProtectedLayout from '@/layouts/ProtectedLayout.astro';
import DiagnosticsDisplay from '@/components/organisms/DiagnosticsDisplay.astro';
import { requireAdmin } from '@/lib/auth/requireAuth';
import { DiagnosticsService } from '@/services/diagnostics.service';
import { db } from '@/db';
import { Activity } from '@lucide/astro';

// Authorization check - must be admin
const authResponse = requireAdmin(Astro);
if (authResponse) {
  return authResponse;
}

// Initialize diagnostics service
const service = new DiagnosticsService(db);

// Fetch diagnostics server-side
let diagnosticsData = null;
let error = null;

try {
  diagnosticsData = await service.getDiagnostics();
} catch (err) {
  console.error('Error fetching diagnostics:', err);
  error = err instanceof Error ? err.message : 'Unknown error occurred';
}

// Page metadata
const title = 'System Diagnostics';
const currentPath = '/admin/diagnostics';
---

<ProtectedLayout title={title} currentPath={currentPath}>
  <!-- Page Header -->
  <div slot="header" class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
    <div class="flex items-center gap-3">
      <Activity class="h-6 w-6" />
      <div>
        <h1 class="text-2xl font-bold">{title}</h1>
        <p class="text-sm text-base-content/70">
          System runtime, database, cache, and configuration information
        </p>
      </div>
    </div>
    <button id="refresh-diagnostics" class="btn btn-primary btn-sm" type="button">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="h-4 w-4"
      >
        <path d="M21 12a9 9 0 0 0-9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path>
        <path d="M3 3v5h5"></path>
        <path d="M3 12a9 9 0 0 0 9 9 9.75 9.75 0 0 0 6.74-2.74L21 16"></path>
        <path d="M16 16h5v5"></path>
      </svg>
      Refresh
    </button>
  </div>

  <!-- Error State -->
  {
    error && (
      <div class="alert alert-error mb-6" role="alert">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="h-5 w-5"
        >
          <circle cx="12" cy="12" r="10" />
          <line x1="12" y1="8" x2="12" y2="12" />
          <line x1="12" y1="16" x2="12.01" y2="16" />
        </svg>
        <div>
          <h3 class="font-bold">Error Loading Diagnostics</h3>
          <p class="text-sm">{error}</p>
        </div>
      </div>
    )
  }

  <!-- Diagnostics Display -->
  {diagnosticsData && <DiagnosticsDisplay data={diagnosticsData} />}
</ProtectedLayout>

<!-- Client Script for Refresh Functionality -->
<script src="./diagnostics.client.ts"></script>
