---
/**
 * User List Page
 *
 * Lists all users across workspaces with search, role/status/workspace filtering, and pagination.
 * Super admin only.
 */
import AdminLayout from '@/layouts/AdminLayout.astro';
import Card from '@/components/atoms/Card.astro';
import AdminUserTable from '@/components/organisms/AdminUserTable.astro';
import { superAdminService } from '@/services';
import { Search, SlidersHorizontal, X } from '@lucide/astro';

// Parse query params for server-side filtering
const url = Astro.url;
const search = url.searchParams.get('search') || '';
const role = (url.searchParams.get('role') as 'admin' | 'member' | 'super_admin') || undefined;
const status = (url.searchParams.get('status') as 'active' | 'deactivated') || undefined;
const workspaceId = url.searchParams.get('workspaceId') || undefined;
const sortBy =
  (url.searchParams.get('sortBy') as 'name' | 'email' | 'created_at' | 'role') || 'created_at';
const sortOrder = (url.searchParams.get('sortOrder') as 'asc' | 'desc') || 'desc';
const rawPage = Number.parseInt(url.searchParams.get('page') || '1', 10);
let page = Number.isFinite(rawPage) && rawPage > 0 ? rawPage : 1;
const limit = 20;
let offset = (page - 1) * limit;

// Fetch users and workspaces for filter dropdown in parallel
let [result, workspaceResult] = await Promise.all([
  superAdminService.listAllUsers({
    search: search || undefined,
    role,
    status,
    workspaceId,
    sortBy,
    sortOrder,
    limit,
    offset,
  }),
  superAdminService.listAllWorkspaces({ limit: 200 }),
]);

const totalPages = Math.max(1, Math.ceil(result.total / limit));
if (page > totalPages) {
  page = totalPages;
  offset = (page - 1) * limit;
  result = await superAdminService.listAllUsers({
    search: search || undefined,
    role,
    status,
    workspaceId,
    sortBy,
    sortOrder,
    limit,
    offset,
  });
}

const hasActiveFilters = Boolean(search || role || status || workspaceId);
const isFirstPage = page <= 1;
const isLastPage = page >= totalPages;
const visibleStart = Math.max(1, page - 4);
const visibleEnd = Math.min(totalPages, visibleStart + 8);
const pageNumbers = Array.from(
  { length: Math.max(0, visibleEnd - visibleStart + 1) },
  (_, index) => visibleStart + index
);

// Build query string for pagination links
function buildQueryString(pageNum: number): string {
  const params = new URLSearchParams();
  params.set('page', String(pageNum));
  if (search) params.set('search', search);
  if (role) params.set('role', role);
  if (status) params.set('status', status);
  if (workspaceId) params.set('workspaceId', workspaceId);
  params.set('sortBy', sortBy);
  params.set('sortOrder', sortOrder);
  return `/admin/users?${params.toString()}`;
}
---

<AdminLayout title="Users" currentPath="/admin/users" subtitle="All Users">
  <div class="max-w-7xl mx-auto space-y-6" data-testid="admin-users">
    <section aria-label="Users summary">
      <Card padding="sm">
        <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
          <div>
            <p class="text-xs font-bold uppercase tracking-wider text-accent">Directory</p>
            <h2 class="text-lg sm:text-xl font-semibold text-base-content">Workspace Users</h2>
          </div>
          <span class="badge badge-outline">{result.total} total</span>
        </div>
      </Card>
    </section>

    <!-- Search and filters -->
    <section aria-label="Search and filters">
      <Card compact padding="sm">
        <form method="GET" class="space-y-4">
          <div
            class="flex items-center gap-2 text-xs font-bold uppercase tracking-wider text-base-content/60"
          >
            <SlidersHorizontal size={14} aria-hidden="true" />
            Filters
          </div>
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-3">
            <label class="input input-bordered lg:col-span-4 rounded-xl flex items-center gap-2">
              <Search size={16} class="stroke-current opacity-50" aria-hidden="true" />
              <input
                type="text"
                name="search"
                value={search}
                placeholder="Search by name or email..."
                class="grow"
                aria-label="Search by name or email"
              />
            </label>
            <select
              name="role"
              class="select select-bordered rounded-xl lg:col-span-2"
              aria-label="Filter by role"
            >
              <option value="">All Roles</option>
              <option value="admin" selected={role === 'admin'}>Admin</option>
              <option value="member" selected={role === 'member'}>Member</option>
              <option value="super_admin" selected={role === 'super_admin'}>Super Admin</option>
            </select>
            <select
              name="status"
              class="select select-bordered rounded-xl lg:col-span-2"
              aria-label="Filter by status"
            >
              <option value="">All Status</option>
              <option value="active" selected={status === 'active'}>Active</option>
              <option value="deactivated" selected={status === 'deactivated'}>Deactivated</option>
            </select>
            <select
              name="workspaceId"
              class="select select-bordered rounded-xl lg:col-span-3"
              aria-label="Filter by workspace"
            >
              <option value="">All Workspaces</option>
              {
                workspaceResult.workspaces.map((ws) => (
                  <option value={ws.id} selected={workspaceId === ws.id}>
                    {ws.name}
                  </option>
                ))
              }
            </select>
            <button type="submit" class="btn btn-accent rounded-lg sm:rounded-xl lg:col-span-1">
              Search
            </button>
          </div>
          <div class="flex flex-wrap items-center gap-2">
            {
              hasActiveFilters && (
                <a href="/admin/users" class="btn btn-ghost rounded-lg min-h-11">
                  <X size={14} aria-hidden="true" />
                  Clear filters
                </a>
              )
            }
          </div>
        </form>
      </Card>
    </section>

    <!-- Results count -->
    <p class="text-sm text-base-content/60">
      Showing {(page - 1) * limit + (result.users.length > 0 ? 1 : 0)}-
      {(page - 1) * limit + result.users.length} of {result.total} users
    </p>

    <!-- Table -->
    <section aria-label="User list">
      <AdminUserTable users={result.users} />
    </section>

    <!-- Pagination -->
    {
      totalPages > 1 && (
        <nav aria-label="Pagination">
          <div class="flex flex-wrap sm:flex-nowrap items-center justify-center gap-2">
            {isFirstPage ? (
              <button class="btn rounded-lg sm:rounded-xl min-h-11" type="button" disabled>
                Previous
              </button>
            ) : (
              <a
                href={buildQueryString(Math.max(1, page - 1))}
                class="btn rounded-lg sm:rounded-xl min-h-11"
              >
                Previous
              </a>
            )}
            <div class="hidden sm:flex items-center gap-2">
              <div class="join">
                {pageNumbers.map((p) => (
                  <a
                    href={buildQueryString(p)}
                    class:list={['join-item btn rounded-lg min-h-11', { 'btn-active': p === page }]}
                    aria-current={p === page ? 'page' : undefined}
                  >
                    {p}
                  </a>
                ))}
              </div>
            </div>
            <div class="sm:hidden text-sm text-base-content/70 px-2">
              Page {page} of {totalPages}
            </div>
            {isLastPage ? (
              <button class="btn rounded-lg sm:rounded-xl min-h-11" type="button" disabled>
                Next
              </button>
            ) : (
              <a
                href={buildQueryString(Math.min(totalPages, page + 1))}
                class="btn rounded-lg sm:rounded-xl min-h-11"
              >
                Next
              </a>
            )}
          </div>
        </nav>
      )
    }
  </div>
</AdminLayout>
