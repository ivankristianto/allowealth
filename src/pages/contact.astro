---
/**
 * Contact Page
 *
 * Contact form with placeholder submission (shows toast, no backend).
 * SECURITY NOTE: When implementing backend, add CSRF protection via Astro actions
 * and rate limiting.
 */

import PublicLayout from '@/layouts/PublicLayout.astro';
import Input from '@/components/atoms/Input.astro';
import Label from '@/components/atoms/Label.astro';
import { brandContent } from '@/lib/landing-content';
import { Mail, Send } from '@lucide/astro';
---

<PublicLayout title={`Contact Us - ${brandContent.name}`} showBackground={false}>
  <article class="pt-32 pb-16 px-6">
    <div class="max-w-2xl mx-auto">
      <!-- Header -->
      <header class="mb-12 text-center">
        <div
          class="w-16 h-16 bg-accent/10 text-accent rounded-2xl flex items-center justify-center mx-auto mb-6"
        >
          <Mail size={32} class="stroke-current" aria-hidden="true" />
        </div>
        <h1 class="text-4xl md:text-5xl font-bold text-base-content tracking-tight mb-4">
          Contact Us
        </h1>
        <p class="text-neutral text-lg font-medium max-w-md mx-auto">
          Have questions or feedback? We'd love to hear from you.
        </p>
      </header>

      <!-- Contact Form -->
      <form
        id="contact-form"
        class="bg-base-100 border border-base-300 rounded-card p-8 md:p-12 shadow-xl"
        novalidate
      >
        <!-- Name Field -->
        <div class="form-control mb-6">
          <Label htmlFor="contact-name" required>Your Name</Label>
          <Input
            id="contact-name"
            name="name"
            type="text"
            placeholder="John Doe"
            required
            describedBy="contact-name-error"
            data-testid="contact-name"
          />
          <p id="contact-name-error" class="text-error text-xs mt-2 hidden" role="alert">
            Please enter your name
          </p>
        </div>

        <!-- Email Field -->
        <div class="form-control mb-6">
          <Label htmlFor="contact-email" required>Email Address</Label>
          <Input
            id="contact-email"
            name="email"
            type="email"
            placeholder="john@example.com"
            required
            describedBy="contact-email-error"
            data-testid="contact-email"
          />
          <p id="contact-email-error" class="text-error text-xs mt-2 hidden" role="alert">
            Please enter a valid email address
          </p>
        </div>

        <!-- Message Field -->
        <div class="form-control mb-8">
          <Label htmlFor="contact-message" required>Message</Label>
          <textarea
            id="contact-message"
            name="message"
            placeholder="Tell us how we can help..."
            required
            rows="6"
            class="textarea textarea-bordered w-full bg-base-100 text-base-content border-base-300 focus:border-accent focus:ring-2 focus:ring-accent/20 focus:outline-none rounded-2xl resize-none placeholder:text-neutral/50"
            aria-describedby="contact-message-error"
            data-testid="contact-message"></textarea>
          <p id="contact-message-error" class="text-error text-xs mt-2 hidden" role="alert">
            Please enter your message
          </p>
        </div>

        <!-- Submit Button -->
        <button
          type="submit"
          class="btn btn-accent w-full py-4 rounded-2xl font-bold text-base shadow-xl shadow-accent/20 flex items-center justify-center gap-2"
        >
          <Send size={20} class="stroke-current" aria-hidden="true" />
          Send Message
        </button>

        <!-- Form note -->
        <p class="text-neutral text-xs text-center mt-6">
          We typically respond within 24-48 hours.
        </p>
      </form>
    </div>
  </article>
</PublicLayout>

<script>
  import { addToast } from '@/lib/stores/toastStore';

  const form = document.getElementById('contact-form') as HTMLFormElement | null;

  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      // Get form elements
      const nameInput = form.querySelector<HTMLInputElement>('[name="name"]');
      const emailInput = form.querySelector<HTMLInputElement>('[name="email"]');
      const messageInput = form.querySelector<HTMLTextAreaElement>('[name="message"]');
      const nameError = document.getElementById('contact-name-error');
      const emailError = document.getElementById('contact-email-error');
      const messageError = document.getElementById('contact-message-error');

      // Reset error states
      nameInput?.classList.remove('input-error');
      nameInput?.removeAttribute('aria-invalid');
      nameError?.classList.add('hidden');
      emailInput?.classList.remove('input-error');
      emailInput?.removeAttribute('aria-invalid');
      emailError?.classList.add('hidden');
      messageInput?.classList.remove('textarea-error');
      messageInput?.removeAttribute('aria-invalid');
      messageError?.classList.add('hidden');

      // Validate
      let isValid = true;

      if (!nameInput?.value.trim()) {
        nameInput?.classList.add('input-error');
        nameInput?.setAttribute('aria-invalid', 'true');
        nameError?.classList.remove('hidden');
        isValid = false;
      }

      if (!emailInput?.value.trim() || !emailInput.validity.valid) {
        emailInput?.classList.add('input-error');
        emailInput?.setAttribute('aria-invalid', 'true');
        emailError?.classList.remove('hidden');
        isValid = false;
      }

      if (!messageInput?.value.trim()) {
        messageInput?.classList.add('textarea-error');
        messageInput?.setAttribute('aria-invalid', 'true');
        messageError?.classList.remove('hidden');
        isValid = false;
      }

      if (!isValid) {
        addToast('Please fill in all required fields', 'error');
        return;
      }

      // Show coming soon toast (placeholder - no backend implementation)
      // TODO: P2 - Implement backend form submission with CSRF protection and rate limiting
      addToast('Coming soon - contact feature in development', 'info');

      // Reset form
      form.reset();
    });
  }
</script>
