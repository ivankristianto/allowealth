---
/**
 * CategoryIcon Component
 *
 * Circular icon container for category display with colored background.
 * Used in category lists, forms, and cards.
 *
 * Aligned with Oasis Finance v1.0.0 design system specifications.
 *
 * @param {string} icon - Lucide icon name
 * @param {string} color - Semantic background class (e.g., 'bg-error', 'bg-accent', 'bg-base-300')
 * @param {string} size - Icon size: sm, md, lg
 * @param {string} className - Additional CSS classes
 */

import * as LucideIcons from '@lucide/astro';

export interface Props {
  icon: string;
  color?: string;
  size?: 'sm' | 'md' | 'lg';
  className?: string;
}

const { icon, color = 'bg-base-300', size = 'md', className = '' } = Astro.props;

// Convert kebab-case icon names to PascalCase for Lucide component lookup
const iconName = icon
  .split('-')
  .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
  .join('');

// Get the Lucide icon component dynamically
const IconComponent = (LucideIcons as Record<string, any>)[iconName];

// Size classes for container
const containerSizeClasses: Record<string, string> = {
  sm: 'w-8 h-8', // 32px
  md: 'w-10 h-10', // 40px
  lg: 'w-12 h-12', // 48px
};

// Icon size in pixels
const iconSizeMap: Record<string, number> = {
  sm: 16,
  md: 20,
  lg: 24,
};

const iconSize = iconSizeMap[size];

const semanticContentClassByBackground: Record<string, string> = {
  'bg-primary': 'text-primary-content',
  'bg-secondary': 'text-secondary-content',
  'bg-accent': 'text-accent-content',
  'bg-neutral': 'text-neutral-content',
  'bg-info': 'text-info-content',
  'bg-success': 'text-success-content',
  'bg-warning': 'text-warning-content',
  'bg-error': 'text-error-content',
};

function getForegroundClass(backgroundClass: string): string {
  const normalizedBgClass = backgroundClass
    .split(/\s+/)
    .find((className) => className.startsWith('bg-'))
    ?.split('/')[0];

  if (!normalizedBgClass) {
    return 'text-white';
  }

  if (normalizedBgClass.startsWith('bg-base-')) {
    return 'text-base-content';
  }

  return semanticContentClassByBackground[normalizedBgClass] || 'text-white';
}

const containerClasses = [
  // Size
  containerSizeClasses[size],
  // Shape
  'rounded-xl',
  // Background color
  color,
  // Layout
  'flex items-center justify-center',
  // Foreground color from semantic bg token
  getForegroundClass(color),
  // Shadow for depth
  'shadow-lg',
  // Transition for hover effects
  'transition-transform',
  // Additional classes
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={containerClasses}>
  {
    IconComponent ? (
      <IconComponent size={iconSize} class="stroke-current" aria-hidden="true" />
    ) : (
      <LucideIcons.Tag size={iconSize} class="stroke-current" aria-hidden="true" />
    )
  }
</div>
