---
/**
 * Currency Display Component
 *
 * Formatted currency display with optional color coding.
 *
 * @param {number} amount - The amount to display
 * @param {string} currency - Currency code: IDR, USD
 * @param {boolean} compact - Use compact notation (e.g., 2.5M)
 * @param {boolean} showSign - Show +/- sign for positive/negative
 * @param {string} size - Text size: sm, md, lg, xl
 * @param {string} variant - Color variant: default, positive, negative, neutral
 * @param {string} className - Additional CSS classes
 */

import { formatCurrency, formatCurrencyCompact } from '@/lib/formatting/currency';

export interface Props {
  amount: number;
  currency?: Currency;
  compact?: boolean;
  showSign?: boolean;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  variant?: 'default' | 'positive' | 'negative' | 'neutral';
  className?: string;
}

const {
  amount,
  currency = 'IDR',
  compact = false,
  showSign = false,
  size = 'md',
  variant = 'default',
  className = '',
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
  xl: 'text-xl',
};

const variantClasses: Record<string, string> = {
  default: currency === 'IDR' ? 'text-success' : currency === 'USD' ? 'text-info' : '',
  positive: 'text-success',
  negative: 'text-error',
  neutral: 'text-neutral',
};

let formattedAmount = compact
  ? formatCurrencyCompact(amount, currency)
  : formatCurrency(amount, currency);

// Add sign if requested and amount is not zero
if (showSign && amount !== 0) {
  const sign = amount > 0 ? '+' : '';
  formattedAmount = sign + formattedAmount;
}

const currencyClass = [
  'font-mono font-medium',
  sizeClasses[size],
  variantClasses[variant],
  className,
]
  .filter(Boolean)
  .join(' ');
---

<span class={currencyClass}>{formattedAmount}</span>
