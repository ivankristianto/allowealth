---
import Label from './Label.astro';

/**
 * Category Select Component
 *
 * Searchable category dropdown for transaction forms.
 *
 * @param {Array} categories - Array of category objects {id, name, type}
 * @param {string} label - Label text for the select (renders a <label> element)
 * @param {string} helpText - Optional help text displayed below the label
 * @param {string} name - Input name
 * @param {string} value - Selected category ID
 * @param {string} type - Filter by transaction type (expense/income)
 * @param {boolean} required - Whether the field is required
 * @param {boolean} error - Show error state
 * @param {string} errorMessage - Error message to display
 * @param {string} className - Additional CSS classes
 * @param {string} id - Element ID. If not provided, auto-generates as '{name}-select'
 * @param {boolean} disabled - Whether the select is disabled
 * @param {string} describedBy - Additional IDs for aria-describedby (combined with inline error message ID)
 */

export interface Props {
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  /** Label text for the select (renders a <label> element) */
  label?: string;
  /** Optional help text displayed below the label */
  helpText?: string;
  name?: string;
  value?: string;
  type?: 'expense' | 'income';
  required?: boolean;
  error?: boolean;
  errorMessage?: string;
  className?: string;
  id?: string;
  disabled?: boolean;
  /**
   * Additional IDs for aria-describedby (combined with inline error message ID if error exists)
   * Used to associate select with external description elements like form-level error containers
   */
  describedBy?: string;
}

const {
  categories = [],
  label = '',
  helpText = '',
  name = 'category_id',
  value = '',
  type = undefined,
  required = false,
  error = false,
  errorMessage = '',
  className = '',
  id = '',
  disabled = false,
  describedBy = '',
} = Astro.props;

const inputId = id || `${name}-select`;

// Filter categories by type if specified
const filteredCategories = type ? categories.filter((cat) => cat.type === type) : categories;

// Build aria-describedby value: combine inline error ID with external describedBy IDs
const ariaDescribeIds = [error && errorMessage && inputId ? `${inputId}-error` : null, describedBy]
  .filter(Boolean)
  .join(' ')
  .trim();
---

<div class="form-control">
  {
    label && (
      <Label htmlFor={inputId} required={required} helpText={helpText}>
        {label}
      </Label>
    )
  }
  <select
    id={inputId}
    name={name}
    value={value}
    required={required}
    disabled={disabled}
    class:list={[
      // Base select classes aligned with Oasis Finance v1.0.0 input spec
      'select select-bordered w-full',
      'h-10', // Height: 2.5rem (40px)
      'pt-2 pb-2 pl-3 pr-10', // Padding: 0.5rem 2.5rem 0.5rem 0.75rem
      'text-xs', // Font size: 0.75rem (12px)
      'bg-base-200', // Theme-aware background
      'focus:ring-2 focus:ring-accent focus:ring-opacity-20 focus:outline-none focus:ring-offset-2', // 2px accent focus ring with 2px offset
      error && 'select-error border-error', // Error state with border-error
      disabled && 'opacity-50 cursor-not-allowed',
      className,
    ]}
    aria-invalid={error}
    aria-describedby={ariaDescribeIds || undefined}
    aria-required={required ? 'true' : undefined}
  >
    <option value="">Select category...</option>
    {
      filteredCategories.map((category) => (
        <option value={category.id} selected={category.id === value}>
          {category.name}
          {category.currency ? ` (${category.currency})` : ''}
        </option>
      ))
    }
  </select>

  {
    error && errorMessage && (
      <span id={`${inputId}-error`} class="text-error text-sm mt-1" role="alert">
        {errorMessage}
      </span>
    )
  }
</div>
