---
/**
 * Category Select Component
 *
 * Searchable category dropdown for transaction forms.
 *
 * @param {Array} categories - Array of category objects {id, name, type}
 * @param {string} name - Input name
 * @param {string} value - Selected category ID
 * @param {string} type - Filter by transaction type (expense/income)
 * @param {boolean} required - Whether the field is required
 * @param {boolean} error - Show error state
 * @param {string} errorMessage - Error message to display
 * @param {string} className - Additional CSS classes
 * @param {string} id - Element ID
 * @param {boolean} disabled - Whether the select is disabled
 */

export interface Props {
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  name?: string;
  value?: string;
  type?: 'expense' | 'income';
  required?: boolean;
  error?: boolean;
  errorMessage?: string;
  className?: string;
  id?: string;
  disabled?: boolean;
}

const {
  categories = [],
  name = 'category_id',
  value = '',
  type = undefined,
  required = false,
  error = false,
  errorMessage = '',
  className = '',
  id = '',
  disabled = false,
} = Astro.props;

const inputId = id || `${name}-select`;
const errorId = `${name}-error`;

// Filter categories by type if specified
const filteredCategories = type ? categories.filter((cat) => cat.type === type) : categories;
---

<div class="form-control">
  <select
    id={inputId}
    name={name}
    value={value}
    required={required}
    disabled={disabled}
    class:list={[
      'select select-bordered w-full',
      error && 'select-error',
      disabled && 'opacity-50 cursor-not-allowed',
      className,
    ]}
    aria-invalid={error}
    aria-describedby={error ? errorId : undefined}
    aria-required={required}
  >
    <option value="">Select category...</option>
    {
      filteredCategories.map((category) => (
        <option value={category.id} selected={category.id === value}>
          {category.name}
          {category.currency ? ` (${category.currency})` : ''}
        </option>
      ))
    }
  </select>

  {
    error && errorMessage && (
      <span id={errorId} class="text-error text-sm mt-1" role="alert">
        {errorMessage}
      </span>
    )
  }
</div>
