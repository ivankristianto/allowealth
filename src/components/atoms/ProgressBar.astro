---
/**
 * ProgressBar Component
 *
 * Horizontal progress bar for displaying completion percentage.
 * Follows Oasis Finance v1.0.0 design system specifications.
 *
 * @param {number} value - Progress percentage (0-100)
 * @param {string} status - Color status: ok, warning, danger
 * @param {string} size - Bar height: sm, md, lg
 * @param {boolean} showLabel - Show percentage label on the right
 * @param {boolean} animate - Enable animation on initial render
 * @param {string} ariaLabel - Optional accessible label for context (e.g., "Budget progress for January")
 * @param {string} className - Additional CSS classes
 */

import { getProgressBarStatusColors, type ProgressBarStatus } from '@/lib/tokens';

export interface Props {
  value: number;
  status?: ProgressBarStatus;
  size?: 'sm' | 'md' | 'lg';
  showLabel?: boolean;
  animate?: boolean;
  ariaLabel?: string;
  className?: string;
}

const {
  value = 0,
  status = 'ok',
  size = 'md',
  showLabel = false,
  animate = true,
  ariaLabel,
  className = '',
} = Astro.props;

// Clamp value between 0 and 100
const clampedValue = Math.max(0, Math.min(100, value));

// Size classes: sm (h-2), md (h-3), lg (h-4)
const sizeClasses: Record<string, string> = {
  sm: 'h-2',
  md: 'h-3',
  lg: 'h-4',
};

// Status color classes using DaisyUI semantic colors
const statusClasses: Record<ProgressBarStatus, string> = {
  ok: 'bg-success',
  warning: 'bg-warning',
  danger: 'bg-error',
};

const barContainerClasses = [
  'w-full bg-base-300 rounded-full overflow-hidden shadow-inner',
  sizeClasses[size],
  className,
]
  .filter(Boolean)
  .join(' ');

const barFillClasses = ['h-full rounded-full shadow-md progress-bar-fill', statusClasses[status]]
  .filter(Boolean)
  .join(' ');

// Generate unique ID for this progress bar instance
const progressBarId = `progress-bar-${Math.random().toString(36).slice(2, 11)}`;
---

<div class="flex items-center gap-3">
  <div
    class={barContainerClasses}
    role="progressbar"
    aria-valuenow={clampedValue}
    aria-valuemin="0"
    aria-valuemax="100"
    aria-valuetext={`${clampedValue} percent`}
    aria-label={ariaLabel}
  >
    <div
      id={progressBarId}
      class={barFillClasses}
      style={animate ? 'width: 0%' : `width: ${clampedValue}%`}
      data-target-width={clampedValue}
      data-animate={animate.toString()}
    >
    </div>
  </div>
  {
    showLabel && (
      <span
        class={`text-xs font-bold tracking-wider uppercase ${getProgressBarStatusColors(status)} px-2 py-1 rounded-full shrink-0`}
      >
        {clampedValue}% used
      </span>
    )
  }
</div>

<style>
  /* CSS transition for progress bar animation
   * Per design system guidelines, CSS transitions are appropriate for simple,
   * single-property animations. Motion library is reserved for complex animations.
   *
   * Uses design system animation tokens from tokens.css:
   * - --anim-duration-slower (1s) for smooth progress fill
   * - --anim-easing-default (ease-out curve) for natural deceleration
   */
  .progress-bar-fill {
    transition: width var(--anim-duration-slower, 1s)
      var(--anim-easing-default, cubic-bezier(0.4, 0, 0.2, 1));
  }

  /* Respect user's reduced motion preference - instant transition */
  @media (prefers-reduced-motion: reduce) {
    .progress-bar-fill {
      transition: none;
    }
  }
</style>

<script>
  function initProgressBar() {
    const progressBars = document.querySelectorAll<HTMLElement>('[data-target-width]');

    progressBars.forEach((bar) => {
      const shouldAnimate = bar.dataset.animate === 'true';
      const targetWidth = Number(bar.dataset.targetWidth);

      // Skip if already animated or animation disabled
      if (!shouldAnimate || bar.dataset.animated === 'true') {
        bar.style.width = `${targetWidth}%`;
        return;
      }

      // Use requestAnimationFrame to ensure the initial width (0%) is rendered
      // before transitioning to the target width
      requestAnimationFrame(() => {
        requestAnimationFrame(() => {
          bar.style.width = `${targetWidth}%`;
        });
      });

      // Mark as animated to prevent re-animation
      bar.dataset.animated = 'true';
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initProgressBar);
  } else {
    initProgressBar();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:after-swap', initProgressBar);
</script>
