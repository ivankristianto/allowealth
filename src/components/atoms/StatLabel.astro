---
/**
 * StatLabel Component
 *
 * Uppercase label for displaying statistics and metrics.
 * Follows Oasis Finance v1.0.0 design system specifications.
 *
 * @param {string} size - Label size: sm, md, lg
 * @param {string} color - Text color: neutral, primary, accent, success, warning, error
 * @param {string} className - Additional CSS classes
 */

export interface Props {
  size?: 'sm' | 'md' | 'lg';
  color?: 'neutral' | 'primary' | 'accent' | 'success' | 'warning' | 'error';
  className?: string;
}

const { size = 'md', color = 'neutral', className = '' } = Astro.props;

// Size classes: small (0.625rem/10px), medium (0.75rem/12px), large (0.875rem/14px)
// Note: 10px is below WCAG AA minimum for body text, use only for decorative labels
const sizeClasses: Record<string, string> = {
  sm: 'text-[10px]', // Use sparingly, only for decorative elements
  md: 'text-xs', // 0.75rem (12px) - minimum accessible size
  lg: 'text-sm', // 0.875rem (14px)
};

// Color classes using DaisyUI semantic colors for theme compatibility
const colorClasses: Record<string, string> = {
  neutral: 'text-base-content/60',
  primary: 'text-primary',
  accent: 'text-accent',
  success: 'text-success',
  warning: 'text-warning',
  error: 'text-error',
};

const labelClasses = [
  // Uppercase with wide letter spacing for premium look
  'label-premium uppercase tracking-widest font-semibold',
  // Size
  sizeClasses[size],
  // Color
  colorClasses[color],
  // Additional classes
  className,
]
  .filter(Boolean)
  .join(' ');
---

<span class={labelClasses}>
  <slot />
</span>
