---
/**
 * Card Component
 *
 * Container component for grouping related content.
 * Follows Oasis Finance v1.0.0 design system specifications.
 *
 * @param {boolean} bordered - Show border around card
 * @param {boolean} compact - Use compact padding
 * @param {string} padding - Padding size: sm (1rem), md (1.75rem), lg (2rem/premium)
 * @param {string} rounded - Border radius: none, sm, md, lg, xl, 2xl, 3xl
 * @param {boolean} hoverable - Add hover effect (y: -4, enhanced shadow)
 * @param {string} className - Additional CSS classes
 */

export interface Props {
  bordered?: boolean;
  compact?: boolean;
  padding?: 'sm' | 'md' | 'lg';
  rounded?: 'none' | 'sm' | 'md' | 'lg' | 'xl' | '2xl' | '3xl';
  hoverable?: boolean;
  className?: string;
  role?: string;
  'aria-labelledby'?: string;
}

const {
  bordered = true,
  compact = false,
  padding = 'md',
  rounded = 'md',
  hoverable = false,
  className = '',
  role,
  'aria-labelledby': ariaLabelledby,
} = Astro.props;

// Padding classes: sm (1rem), md (1.75rem), lg (2rem/premium card padding)
const paddingClasses: Record<string, string> = {
  sm: 'p-4',
  md: 'p-7',
  lg: 'p-8',
};

// Border radius classes using design tokens
const roundedClasses: Record<string, string> = {
  none: 'rounded-none',
  sm: 'rounded-sm',
  md: 'rounded-md',
  lg: 'rounded-lg',
  xl: 'rounded-xl',
  '2xl': 'rounded-2xl',
  '3xl': 'rounded-3xl',
};

const cardClasses = [
  // Base card styles with theme-aware background
  'card bg-base-100',
  // Border using DaisyUI semantic color for theme compatibility
  bordered && 'card-bordered border-base-300',
  // Rounded corners
  roundedClasses[rounded],
  // Padding: compact uses small, otherwise use padding prop
  compact ? 'card-compact p-4' : paddingClasses[padding],
  // Hoverable cards get premium shadow and hover animation
  hoverable && 'shadow-premium hover:-translate-y-1 hover:shadow-lg transition-all duration-200',
  // Default premium shadow for non-hoverable cards
  !hoverable && 'shadow-premium',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={cardClasses} role={role as any} aria-labelledby={ariaLabelledby}>
  <slot />
</div>
