---
/**
 * Button Component
 *
 * A versatile button component with multiple variants, sizes, and states.
 * Follows Oasis Finance v1.0.0 design system with slate-primary/indigo-accent color model.
 *
 * @param {string} variant - Button style variant: primary (accent/indigo CTAs), secondary, outline, ghost, danger, warning, success
 * @param {string} size - Button size: sm (2rem), md (2.5rem), lg (3rem)
 * @param {boolean} disabled - Whether the button is disabled
 * @param {boolean} loading - Show loading spinner
 * @param {string} type - Button type: button, submit, reset
 * @param {string} className - Additional CSS classes
 * @param {string} id - Element ID
 */

export interface Props {
  variant?: 'primary' | 'secondary' | 'outline' | 'ghost' | 'danger' | 'warning' | 'success';
  size?: 'sm' | 'md' | 'lg';
  disabled?: boolean;
  loading?: boolean;
  type?: 'button' | 'submit' | 'reset';
  className?: string;
  id?: string;
  href?: string;
}

const {
  variant = 'primary',
  size = 'md',
  disabled = false,
  loading = false,
  type = 'button',
  className = '',
  id = '',
  href = '',
} = Astro.props;

const isDisabled = disabled || loading;
const Tag = href ? 'a' : 'button';

// Base classes - focus ring uses accent color for theme-aware consistency
const baseClasses =
  'btn inline-flex items-center justify-center gap-2 font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent';

// Variant classes - primary uses btn-accent (indigo) for CTAs per Oasis Finance v1.0.0
const variantClasses: Record<string, string> = {
  primary: 'btn-accent shadow-accent-glow',
  secondary: 'btn-secondary',
  outline: 'btn-outline border-accent text-accent hover:bg-accent/5',
  ghost: 'btn-ghost text-accent hover:bg-accent/5',
  danger: 'btn-error',
  warning: 'btn-warning',
  success: 'btn-success',
};

// Size classes - match styles.json specifications exactly
// sm: h-8 (2rem), padding 0.375rem 0.75rem, text-xs (0.75rem)
// md: h-10 (2.5rem), padding 0.625rem 1.25rem, text-sm (0.875rem)
// lg: h-12 (3rem), padding 0.75rem 1.5rem, text-sm (0.875rem)
const sizeClasses: Record<string, string> = {
  sm: 'h-8 px-3 py-1.5 text-xs',
  md: 'h-10 px-5 py-2.5 text-sm',
  lg: 'h-12 px-6 py-3 text-sm',
};

// Combined classes
const buttonClasses = [
  baseClasses,
  variantClasses[variant] || variantClasses.primary,
  sizeClasses[size] || sizeClasses.md,
  isDisabled ? 'opacity-50 cursor-not-allowed focus:ring-0 focus:ring-offset-0' : 'cursor-pointer',
  className,
]
  .filter(Boolean)
  .join(' ');

const typeAttr = Tag === 'button' ? type : undefined;
const hrefAttr = Tag === 'a' ? href : undefined;
---

<Tag
  class={buttonClasses}
  id={id}
  disabled={isDisabled}
  type={typeAttr}
  href={hrefAttr}
  aria-disabled={isDisabled}
  aria-busy={loading}
>
  {loading && <span class="loading loading-spinner loading-sm" aria-hidden="true" />}
  <slot />
</Tag>
