---
import { getCurrencyMeta } from '@/lib/constants/currency';

export interface Props {
  tabs: Array<{ currency: Currency; href: string }>;
  selected: Currency;
}

const { tabs = [], selected } = Astro.props;
const showTabs = tabs.length > 1;
---

{
  showTabs && (
    <div class="tabs tabs-boxed tabs-sm bg-base-200 w-fit p-1 rounded-xl" role="tablist">
      {tabs.map((tab) => (
        <a
          href={tab.href}
          class:list={[
            'tab font-semibold transition-colors',
            selected === tab.currency
              ? 'tab-active !bg-accent !text-accent-content shadow-sm'
              : 'text-base-content/70 hover:text-base-content',
          ]}
          data-currency-tab={tab.currency}
          aria-current={selected === tab.currency ? 'page' : undefined}
        >
          {getCurrencyMeta(tab.currency).flagEmoji} {tab.currency}
        </a>
      ))}
    </div>
  )
}
