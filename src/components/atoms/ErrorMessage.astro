---
/**
 * Error Message Component
 *
 * Display error messages with optional title and actions.
 *
 * @param {string} title - Error title
 * @param {string} message - Error message
 * @param {string} variant - Style variant: alert, banner, inline
 * @param {boolean} dismissible - Show dismiss button
 * @param {string} className - Additional CSS classes
 */

import { CircleX, X } from '@lucide/astro';

export interface Props {
  title?: string;
  message: string;
  variant?: 'alert' | 'banner' | 'inline';
  dismissible?: boolean;
  className?: string;
}

const { title = '', message, variant = 'alert', dismissible = false, className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
  alert: 'alert alert-error',
  banner: 'alert alert-error shadow-lg',
  inline: 'text-error text-sm',
};

const hasTitle = title && variant !== 'inline';
---

{
  variant === 'inline' ? (
    <span class={variantClasses[variant] + ' ' + className} role="alert">
      {message}
    </span>
  ) : (
    <div class={variantClasses[variant] + ' ' + className} role="alert">
      <CircleX size={24} class="shrink-0" aria-hidden="true" />
      <div>
        {hasTitle && <h3 class="font-bold">{title}</h3>}
        <div class="text-xs">{message}</div>
      </div>
      {dismissible && (
        <button class="btn btn-sm btn-ghost" type="button" aria-label="Dismiss">
          <X size={16} class="stroke-current" aria-hidden="true" />
        </button>
      )}
    </div>
  )
}
