---
/**
 * AdminDiagnosticsIcon Component
 *
 * Admin-only icon button linking to system diagnostics page.
 * Displays Activity icon with active state styling when on diagnostics page.
 *
 * @accessibility WCAG 2.1 AA compliant - minimum touch target 44x44px
 * @admin-only Renders only for users with admin role
 *
 * @param currentPath - Current URL path for active state styling
 */

import { Activity } from '@lucide/astro';

interface Props {
  /** Current URL path for active state styling */
  currentPath: string;
}

const { currentPath } = Astro.props;

// Check if currently on diagnostics page for active state styling
const isActive = currentPath === '/admin/diagnostics';

// Icon color class based on active state
const iconColorClass = isActive ? 'text-primary' : 'text-base-content/70';
---

<a
  href="/admin/diagnostics"
  class="btn btn-ghost btn-circle btn-sm"
  data-admin-only="true"
  aria-label="Open System Diagnostics"
  title="System Diagnostics"
>
  <Activity size={20} class:list={['stroke-current', iconColorClass]} aria-hidden="true" />
</a>
