---
/**
 * Badge Component
 *
 * Small status indicator badge for alerts and categories.
 *
 * Aligned with Oasis Finance v1.0.0 design system specifications.
 *
 * @see design-system/styles.json - Badge component specifications
 *
 * @param {string} variant - Badge style: neutral, primary, accent, secondary, success, warning, error, info, optimal, review, exceeded
 * @param {string} size - Badge size: sm, md, lg
 * @param {boolean} outline - Show outline style
 * @param {string} className - Additional CSS classes
 */

export interface Props {
  variant?:
    | 'neutral'
    | 'primary'
    | 'accent'
    | 'secondary'
    | 'success'
    | 'warning'
    | 'error'
    | 'info'
    | 'optimal'
    | 'review'
    | 'exceeded';
  size?: 'sm' | 'md' | 'lg';
  outline?: boolean;
  className?: string;
}

const { variant = 'neutral', size = 'md', outline = false, className = '' } = Astro.props;

const variantClasses: Record<string, string> = {
  neutral: outline ? 'badge-outline' : 'badge-neutral',
  primary: outline ? 'badge-outline' : 'badge-primary',
  accent: outline ? 'badge-outline' : 'badge-accent',
  secondary: outline ? 'badge-outline' : 'badge-secondary',
  success: outline ? 'badge-outline' : 'badge-success',
  warning: outline ? 'badge-outline' : 'badge-warning',
  error: outline ? 'badge-outline' : 'badge-error',
  info: outline ? 'badge-outline' : 'badge-info',
  // Budget status variants - using DaisyUI semantic colors
  optimal: outline ? 'badge-outline' : 'badge-success', // On track (<80%)
  review: outline ? 'badge-outline' : 'badge-warning', // Review needed (80-99%)
  exceeded: outline ? 'badge-outline' : 'badge-error', // Over budget (≥100%)
};

const sizeClasses: Record<string, string> = {
  sm: 'badge-sm',
  md: '',
  lg: 'badge-lg',
};

// Base classes include tokenized padding (px-2.5 py-1), font size (text-badge), and font weight (font-bold)
// Border radius is inherited from DaisyUI badge class using --radius-selector (1rem) from theme configuration
const baseClasses = 'px-2.5 py-1 text-badge font-bold';

const badgeClasses = [baseClasses, 'badge', variantClasses[variant], sizeClasses[size], className]
  .filter(Boolean)
  .join(' ');
---

<span class={badgeClasses}>
  <slot />
</span>
