---
/**
 * Empty State Component
 *
 * Display a message when there's no content to show.
 *
 * @param {string} title - Heading text
 * @param {string} message - Descriptive message
 * @param {string} iconName - Lucide icon name (search, folder, inbox, calendar, etc.)
 * @param {string} actionLabel - Button label
 * @param {string} actionHref - Link destination (if using link)
 * @param {string} variant - Visual style: default, compact, centered
 * @param {string} className - Additional CSS classes
 */

import {
  Search,
  Folder,
  Inbox,
  Calendar,
  FileText,
  Wallet,
  TrendingUp,
  Receipt,
  TriangleAlert,
  Info,
  Check,
  Plus,
} from '@lucide/astro';
import Button from '@/components/atoms/Button.astro';

export interface Props {
  title: string;
  message: string;
  iconName?: keyof typeof iconMap;
  actionLabel?: string;
  actionHref?: string;
  actionAttributes?: Record<string, string | boolean>;
  actionClassName?: string;
  variant?: 'default' | 'compact' | 'centered';
  className?: string;
}

// Map icon names to Lucide icon components
const iconMap = {
  search: Search,
  folder: Folder,
  inbox: Inbox,
  calendar: Calendar,
  file: FileText,
  wallet: Wallet,
  trending: TrendingUp,
  receipt: Receipt,
  alert: TriangleAlert,
  info: Info,
  check: Check,
  plus: Plus,
} as const;

const {
  title,
  message,
  iconName,
  actionLabel = '',
  actionHref = '',
  actionAttributes = {},
  actionClassName = '',
  variant = 'default',
  className = '',
} = Astro.props;

const containerClasses = [
  'flex flex-col items-center justify-center',
  variant === 'centered' ? 'text-center py-12' : 'text-left py-8',
  className,
]
  .filter(Boolean)
  .join(' ');

// Get the Lucide icon component
const IconComponent = iconName ? iconMap[iconName] : null;
---

<div class={containerClasses}>
  {
    IconComponent && (
      <div class="mb-4" aria-hidden="true">
        <IconComponent size={32} class="text-base-content/40" />
      </div>
    )
  }
  <h3 class="text-lg font-semibold mb-2 text-base-content">{title}</h3>
  <p class="text-base-content/60 mb-4 max-w-md">{message}</p>
  {
    actionLabel && (
      <div>
        {actionHref ? (
          <a
            href={actionHref}
            class={['btn btn-accent btn-sm rounded-xl', actionClassName].filter(Boolean).join(' ')}
            {...actionAttributes}
          >
            {actionLabel}
          </a>
        ) : (
          <Button variant="primary" size="sm" className={actionClassName} {...actionAttributes}>
            {actionLabel}
          </Button>
        )}
      </div>
    )
  }
</div>
