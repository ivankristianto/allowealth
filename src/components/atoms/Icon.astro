  },
};

const icon = icons[name] || (icons['information'] as { viewBox: string; path: string });
---

<svg
  class={iconClass}
  xmlns="http://www.w3.org/2000/svg"
  viewBox={icon.viewBox}
  fill="currentColor"
  aria-hidden="true"
>
  <path fill-rule="evenodd" d={icon.path} clip-rule="evenodd"></path>
</svg>
