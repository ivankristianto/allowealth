---
/**
 * Icon Component
 *
 * SVG icon wrapper using Heroicons or custom SVG paths.
 *
 * @param {string} name - Icon name/identifier
 * @param {string} size - Icon size: xs, sm, md, lg, xl
 * @param {string} className - Additional CSS classes
 */

export interface Props {
  name: string;
  size?: 'xs' | 'sm' | 'md' | 'lg' | 'xl';
  className?: string;
}

const { name, size = 'md', className = '' } = Astro.props;

// Size classes map
const sizeClasses: Record<string, string> = {
  xs: 'w-3 h-3',
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
  xl: 'w-8 h-8',
};

const iconClass = [sizeClasses[size], className].filter(Boolean).join(' ');

// SVG paths for common icons (Heroicons style)
const icons: Record<string, { viewBox: string; path: string }> = {
