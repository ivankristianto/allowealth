---
/**
 * PasswordField Component
 *
 * Password input field with show/hide toggle button.
 *
 * @param {string} placeholder - Placeholder text
 * @param {string} value - Input value
 * @param {boolean} disabled - Whether the input is disabled
 * @param {boolean} error - Show error state
 * @param {string} errorMessage - Error message to display
 * @param {string} className - Additional CSS classes
 * @param {string} id - Element ID
 * @param {string} name - Input name
 * @param {boolean} required - Whether the field is required
 */

export interface Props {
  placeholder?: string;
  value?: string;
  disabled?: boolean;
  error?: boolean;
  errorMessage?: string;
  className?: string;
  id?: string;
  name?: string;
  required?: boolean;
}

const {
  placeholder = 'Enter password',
  value = '',
  disabled = false,
  error = false,
  errorMessage = '',
  className = '',
  id = 'password',
  name = 'password',
  required = false,
} = Astro.props;

const inputId = id || name;
const uniqueId = `password-field-${inputId}-${Math.random().toString(36).substring(2, 9)}`;
---

<div class={['relative w-full', className].filter(Boolean).join(' ')}>
  <input
    id={uniqueId}
    name={name}
    type="password"
    placeholder={placeholder}
    value={value}
    disabled={disabled}
    required={required}
    class:list={[
      'input input-bordered w-full pr-12',
      error && 'input-error',
      disabled && 'opacity-50 cursor-not-allowed',
    ]}
    aria-invalid={error}
    aria-describedby={error ? `${uniqueId}-error` : undefined}
    data-password-input
  />
  <button
    type="button"
    class="absolute right-3 top-1/2 -translate-y-1/2 text-base-content/50 hover:text-base-content transition-colors"
    aria-label="Toggle password visibility"
    data-password-toggle
    data-target={uniqueId}
    disabled={disabled}
  >
    <!-- Eye icon (show) -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-5 h-5"
      data-eye-icon
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.638 0-8.573-3.007-9.963-7.178z"
      ></path>
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"
      ></path>
    </svg>
    <!-- Eye slash icon (hide) -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      fill="none"
      viewBox="0 0 24 24"
      stroke-width="1.5"
      stroke="currentColor"
      class="w-5 h-5 hidden"
      data-eye-slash-icon
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        d="M3.98 8.223A10.477 10.477 0 001.934 12C3.226 16.338 7.244 19.5 12 19.5c.993 0 1.953-.138 2.863-.395M6.228 6.228A10.45 10.45 0 0112 4.5c4.756 0 8.773 3.162 10.065 7.498a10.523 10.523 0 01-4.293 5.774M6.228 6.228L3 3m3.228 3.228l3.65 3.65m7.894 7.894L21 21m-3.228-3.228l-3.65-3.65m0 0a3 3 0 10-4.243-4.243m4.242 4.242L9.88 9.88"
      ></path>
    </svg>
  </button>
  {
    error && errorMessage && (
      <span id={`${uniqueId}-error`} class="text-error text-sm mt-1 block" role="alert">
        {errorMessage}
      </span>
    )
  }
</div>

<script>
  // Toggle password visibility
  document.addEventListener('DOMContentLoaded', () => {
    const toggleButtons = document.querySelectorAll('[data-password-toggle]');

    toggleButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-target');
        if (!targetId) return;

        const input = document.getElementById(targetId) as HTMLInputElement;
        const eyeIcon = button.querySelector('[data-eye-icon]') as HTMLElement;
        const eyeSlashIcon = button.querySelector('[data-eye-slash-icon]') as HTMLElement;

        if (!input || !eyeIcon || !eyeSlashIcon) return;

        if (input.type === 'password') {
          input.type = 'text';
          eyeIcon.classList.add('hidden');
          eyeSlashIcon.classList.remove('hidden');
          button.setAttribute('aria-label', 'Hide password');
        } else {
          input.type = 'password';
          eyeIcon.classList.remove('hidden');
          eyeSlashIcon.classList.add('hidden');
          button.setAttribute('aria-label', 'Show password');
        }
      });
    });
  });
</script>
