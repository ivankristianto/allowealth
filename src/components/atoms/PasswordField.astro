---
/**
 * PasswordField Component (Atom)
 *
 * Password input with toggle visibility, strength meter, and requirements checklist
 * Provides real-time validation feedback
 *
 * Requirements (matching server-side validation):
 * - At least 12 characters
 * - At least one letter (uppercase or lowercase)
 * - At least one number or special character
 */

import Input from './Input.astro';
import Label from './Label.astro';
import { PASSWORD_MIN_LENGTH, PASSWORD_REGEX_SOURCES } from '@/lib/validation';

interface Props {
  id?: string;
  name?: string;
  label?: string;
  placeholder?: string;
  required?: boolean;
  disabled?: boolean;
  error?: string;
  showStrength?: boolean;
  showRequirements?: boolean;
  class?: string;
}

const {
  id = 'password',
  name = 'password',
  label = 'Password',
  placeholder = 'Enter your password',
  required = false,
  disabled = false,
  error = '',
  showStrength = false,
  showRequirements = false,
  class: className = '',
} = Astro.props;

const uniqueId = `password-${Math.random().toString(36).substring(2, 9)}`;
const inputId = id || uniqueId;
const requirementsId = `requirements-${inputId}`;
const strengthMeterId = `strength-${inputId}`;

// Get CSP nonce from middleware
const cspNonce = Astro.locals?.cspNonce || '';

// Password validation regex source strings (from centralized constants)
// These MUST match the server-side validation in src/lib/validation/password.ts
const HAS_LETTER_REGEX = PASSWORD_REGEX_SOURCES.hasLetter;
const HAS_NUMBER_OR_SPECIAL_REGEX = PASSWORD_REGEX_SOURCES.hasNumberOrSpecial;
---

<div class={['form-control w-full', className].filter(Boolean).join(' ')}>
  <Label htmlFor={inputId} required={required}>
    {label}
  </Label>

  <div class="relative">
    <Input
      type="password"
      id={inputId}
      name={name}
      placeholder={placeholder}
      required={required}
      disabled={disabled}
      error={error ? true : false}
      errorMessage={error}
      className="pr-12"
      data-password-input
      data-show-strength={showStrength ? 'true' : 'false'}
      data-requirements-id={requirementsId}
      data-strength-meter-id={strengthMeterId}
    />

    <button
      type="button"
      class="absolute right-3 top-1/2 -translate-y-1/2 btn btn-ghost btn-circle btn-sm"
      aria-label="Toggle password visibility"
      data-toggle-password={inputId}
      tabindex="-1"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        data-eye-icon
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
        ></path>
      </svg>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 hidden"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        data-eye-off-icon
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="2"
          d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"
        ></path>
      </svg>
    </button>
  </div>

  {
    showStrength && (
      <div class="mt-2 space-y-2" id={strengthMeterId}>
        <div class="flex gap-1">
          <div
            class="h-1 flex-1 rounded-full bg-base-300 transition-all duration-300"
            data-strength-bar="1"
          />
          <div
            class="h-1 flex-1 rounded-full bg-base-300 transition-all duration-300"
            data-strength-bar="2"
          />
          <div
            class="h-1 flex-1 rounded-full bg-base-300 transition-all duration-300"
            data-strength-bar="3"
          />
          <div
            class="h-1 flex-1 rounded-full bg-base-300 transition-all duration-300"
            data-strength-bar="4"
          />
        </div>
        <p class="text-xs" data-strength-text aria-live="polite">
          Password strength: <span data-strength-label>Not entered</span>
        </p>
      </div>
    )
  }

  {
    showRequirements && (
      <ul class="mt-2 space-y-1 text-xs" id={requirementsId} aria-label="Password requirements">
        <li class="flex items-center gap-2 text-base-content/60" data-requirement="length">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            data-check-icon
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 13l4 4L19 7"
            />
          </svg>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            data-x-icon
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
          <span>At least 12 characters</span>
        </li>
        <li class="flex items-center gap-2 text-base-content/60" data-requirement="letter">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            data-check-icon
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 13l4 4L19 7"
            />
          </svg>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            data-x-icon
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
          <span>At least one letter (A-Z or a-z)</span>
        </li>
        <li class="flex items-center gap-2 text-base-content/60" data-requirement="numberOrSpecial">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            data-check-icon
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M5 13l4 4L19 7"
            />
          </svg>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            data-x-icon
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"
            />
          </svg>
          <span>At least one number or special character</span>
        </li>
      </ul>
    )
  }
</div>

<script
  is:inline
  define:vars={{
    showStrength,
    showRequirements,
    // Inject server-side validation constants to ensure client/server consistency
    PASSWORD_MIN_LENGTH,
    HAS_LETTER_REGEX,
    HAS_NUMBER_OR_SPECIAL_REGEX,
  }}
  nonce={cspNonce}
>
  document.addEventListener('DOMContentLoaded', () => {
    // Password toggle visibility
    document.querySelectorAll('[data-toggle-password]').forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-toggle-password');
        const input = document.getElementById(targetId);
        const eyeIcon = button.querySelector('[data-eye-icon]');
        const eyeOffIcon = button.querySelector('[data-eye-off-icon]');

        if (input && eyeIcon && eyeOffIcon) {
          const isPassword = input.type === 'password';
          input.type = isPassword ? 'text' : 'password';
          eyeIcon.classList.toggle('hidden', !isPassword);
          eyeOffIcon.classList.toggle('hidden', isPassword);
          button.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
        }
      });
    });

    if (showStrength || showRequirements) {
      // Build regex patterns from server-side constants
      // These variables are injected via Astro's define:vars from server-side validation
      // @ts-ignore - HAS_LETTER_REGEX is injected at runtime via define:vars
      const hasLetterRegex = new RegExp(HAS_LETTER_REGEX);
      // @ts-ignore - HAS_NUMBER_OR_SPECIAL_REGEX is injected at runtime via define:vars
      const hasNumberOrSpecialRegex = new RegExp(HAS_NUMBER_OR_SPECIAL_REGEX);

      document.querySelectorAll('[data-password-input]').forEach((input) => {
        const requirementsId = input.getAttribute('data-requirements-id');
        const strengthMeterId = input.getAttribute('data-strength-meter-id');
        const requirementsList = requirementsId ? document.getElementById(requirementsId) : null;
        const strengthMeter = strengthMeterId ? document.getElementById(strengthMeterId) : null;

        if (!requirementsList && !strengthMeter) return;

        input.addEventListener('input', () => {
          try {
            const password = input.value;

            // Check requirements (matching server-side validation)
            const checks = {
              length: password.length >= PASSWORD_MIN_LENGTH,
              letter: hasLetterRegex.test(password),
              numberOrSpecial: hasNumberOrSpecialRegex.test(password),
            };

            // Update requirements list
            if (requirementsList) {
              Object.entries(checks).forEach(([key, passed]) => {
                const item = requirementsList.querySelector(`[data-requirement="${key}"]`);
                if (item) {
                  const checkIcon = item.querySelector('[data-check-icon]');
                  const xIcon = item.querySelector('[data-x-icon]');

                  if (passed) {
                    item.classList.remove('text-base-content/60');
                    item.classList.add('text-success');
                    checkIcon?.classList.remove('hidden');
                    xIcon?.classList.add('hidden');
                  } else {
                    item.classList.remove('text-success');
                    item.classList.add('text-base-content/60');
                    checkIcon?.classList.add('hidden');
                    xIcon?.classList.remove('hidden');
                  }
                }
              });
            }

            // Calculate and update strength (3 requirements total)
            if (strengthMeter) {
              const passedCount = Object.values(checks).filter(Boolean).length;
              const strengthLabel = strengthMeter.querySelector('[data-strength-label]');
              const bars = strengthMeter.querySelectorAll('[data-strength-bar]');

              // Check if bars exist before manipulating
              if (!bars || bars.length === 0) return;

              let strength = 'weak';
              let colorClass = 'bg-error';

              // Handle empty password first
              if (password.length === 0) {
                strength = 'Not entered';
                colorClass = 'bg-base-300';
              } else if (passedCount === 1) {
                strength = 'Weak';
                colorClass = 'bg-error';
              } else if (passedCount === 2) {
                strength = 'Medium';
                colorClass = 'bg-warning';
              } else {
                strength = 'Strong';
                colorClass = 'bg-success';
              }

              if (strengthLabel) {
                strengthLabel.textContent = strength;
              }

              // Update strength bars (scale 3 requirements to 4 bars)
              // 1 requirement = 1 bar, 2 requirements = 3 bars, 3 requirements = 4 bars
              bars.forEach((bar, index) => {
                bar.classList.remove(
                  'bg-error',
                  'bg-warning',
                  'bg-success',
                  'bg-base-300',
                  'opacity-30'
                );

                if (password.length === 0) {
                  bar.classList.add('bg-base-300');
                } else {
                  // Scale 3 requirements to 4 visual bars
                  const barsToFill = passedCount === 1 ? 1 : passedCount === 2 ? 3 : 4;

                  if (index < barsToFill) {
                    bar.classList.add(colorClass);
                  } else {
                    bar.classList.add('bg-base-300');
                  }
                }
              });
            }
          } catch (error) {
            console.error('Password strength calculation error:', error);
          }
        });
      });
    }
  });
</script>
