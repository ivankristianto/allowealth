---
/**
 * TabToggle Component
 *
 * Pill-style toggle button group for filtering between two options (e.g., Expense/Income).
 * Features rounded container with active state highlighting.
 *
 * Aligned with Allowealth v1.0.0 design system specifications.
 *
 * @param {string} activeTab - Currently active tab value
 * @param {string} option1Value - Value for first option
 * @param {string} option1Label - Label for first option
 * @param {string} option2Value - Value for second option
 * @param {string} option2Label - Label for second option
 * @param {string} name - Name attribute for form input
 * @param {string} className - Additional CSS classes
 */

export interface Props {
  activeTab: string;
  option1Value: string;
  option1Label: string;
  option2Value: string;
  option2Label: string;
  name?: string;
  className?: string;
  /** When true, skip navigate() and dispatch 'tab-toggle-change' event for client-side filtering */
  clientFilter?: boolean;
  /** ID of the panel controlled by option 1's tab button (for aria-controls) */
  option1Controls?: string;
  /** ID of the panel controlled by option 2's tab button (for aria-controls) */
  option2Controls?: string;
}

const {
  activeTab,
  option1Value,
  option1Label,
  option2Value,
  option2Label,
  name = 'tab-toggle',
  className = '',
  clientFilter = false,
  option1Controls,
  option2Controls,
} = Astro.props;
---

<div
  class={`flex bg-base-200 p-1.5 rounded-2xl w-full md:w-auto ${className}`}
  role="tablist"
  data-tab-toggle
  data-name={name}
  {...clientFilter ? { 'data-client-filter': '' } : {}}
>
  <button
    type="button"
    class={`flex-1 md:w-40 py-2.5 text-sm font-bold rounded-xl transition-all ${
      activeTab === option1Value
        ? 'bg-base-100 shadow-md text-primary'
        : 'text-base-content/60 hover:text-base-content/80'
    }`}
    data-tab-value={option1Value}
    role="tab"
    aria-selected={activeTab === option1Value ? 'true' : 'false'}
    tabindex={activeTab === option1Value ? 0 : -1}
    {...option1Controls ? { 'aria-controls': option1Controls } : {}}
    data-active={activeTab === option1Value}
    data-testid={`type-filter-${option1Value}`}
  >
    {option1Label}
  </button>
  <button
    type="button"
    class={`flex-1 md:w-40 py-2.5 text-sm font-bold rounded-xl transition-all ${
      activeTab === option2Value
        ? 'bg-base-100 shadow-md text-primary'
        : 'text-base-content/60 hover:text-base-content/80'
    }`}
    data-tab-value={option2Value}
    role="tab"
    aria-selected={activeTab === option2Value ? 'true' : 'false'}
    tabindex={activeTab === option2Value ? 0 : -1}
    {...option2Controls ? { 'aria-controls': option2Controls } : {}}
    data-active={activeTab === option2Value}
    data-testid={`type-filter-${option2Value}`}
  >
    {option2Label}
  </button>
</div>

<script>
  import { navigate } from 'astro:transitions/client';

  const ACTIVE_CLASS = 'bg-base-100 shadow-md text-primary';
  const INACTIVE_CLASS = 'text-base-content/60 hover:text-base-content/80';
  const ACTIVE_CLASSES = ACTIVE_CLASS.split(' ');
  const INACTIVE_CLASSES = INACTIVE_CLASS.split(' ');

  // Event delegation on document — survives Astro View Transition DOM swaps
  // without needing astro:page-load re-initialization.
  document.addEventListener('click', (e: Event) => {
    const target = e.target as Element | null;
    if (!target) return;

    const button = target.closest('[data-tab-toggle] button[data-tab-value]');
    if (!button) return;

    const container = button.closest('[data-tab-toggle]');
    if (!container) return;

    const value = button.getAttribute('data-tab-value');
    const name = container.getAttribute('data-name');
    if (!value || !name) return;

    // Client-filter mode: update visual state + dispatch event, no server round-trip
    if (container.hasAttribute('data-client-filter')) {
      // Update active tab visual state and roving tabindex
      container.querySelectorAll('button[data-tab-value]').forEach((btn) => {
        const isActive = btn.getAttribute('data-tab-value') === value;
        btn.setAttribute('data-active', String(isActive));
        btn.setAttribute('aria-selected', String(isActive));
        btn.setAttribute('tabindex', isActive ? '0' : '-1');
        // Swap active/inactive classes
        ACTIVE_CLASSES.forEach((c) => btn.classList.toggle(c, isActive));
        INACTIVE_CLASSES.forEach((c) => btn.classList.toggle(c, !isActive));
      });

      // Update URL without navigation
      const url = new URL(window.location.href);
      url.searchParams.set(name, value);
      window.history.replaceState({}, '', url.toString());

      // Dispatch event for page-specific filtering
      document.dispatchEvent(new CustomEvent('tab-toggle-change', { detail: { name, value } }));
      return;
    }

    // Default: navigate (full page reload via view transitions)
    const url = new URL(window.location.href);
    url.searchParams.set(name, value);
    navigate(url.toString());
  });

  // Roving tabindex: arrow key navigation for all tab-toggle containers
  document.addEventListener('keydown', (e: KeyboardEvent) => {
    const target = e.target as Element | null;
    if (!target) return;

    const button = target.closest<HTMLElement>('[data-tab-toggle] button[data-tab-value]');
    if (!button) return;

    const container = button.closest('[data-tab-toggle]');
    if (!container) return;

    if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(e.key)) return;

    const buttons = Array.from(container.querySelectorAll<HTMLElement>('button[data-tab-value]'));
    const currentIndex = buttons.indexOf(button);
    if (currentIndex === -1) return;

    let nextIndex: number;
    if (e.key === 'ArrowRight') {
      nextIndex = (currentIndex + 1) % buttons.length;
    } else if (e.key === 'ArrowLeft') {
      nextIndex = (currentIndex - 1 + buttons.length) % buttons.length;
    } else if (e.key === 'Home') {
      nextIndex = 0;
    } else {
      // End
      nextIndex = buttons.length - 1;
    }

    const nextButton = buttons[nextIndex];
    if (!nextButton) return;

    e.preventDefault();
    nextButton.focus();

    // In client-filter mode, auto-activate the focused tab
    if (container.hasAttribute('data-client-filter')) {
      const value = nextButton.getAttribute('data-tab-value');
      const name = container.getAttribute('data-name');
      if (!value || !name) return;

      container.querySelectorAll('button[data-tab-value]').forEach((btn) => {
        const isActive = btn === nextButton;
        btn.setAttribute('data-active', String(isActive));
        btn.setAttribute('aria-selected', String(isActive));
        btn.setAttribute('tabindex', isActive ? '0' : '-1');
        ACTIVE_CLASSES.forEach((c) => btn.classList.toggle(c, isActive));
        INACTIVE_CLASSES.forEach((c) => btn.classList.toggle(c, !isActive));
      });

      const url = new URL(window.location.href);
      url.searchParams.set(name, value);
      window.history.replaceState({}, '', url.toString());
      document.dispatchEvent(new CustomEvent('tab-toggle-change', { detail: { name, value } }));
    } else {
      // For non-client-filter mode (navigate-on-click), just update tabindex without navigating
      const activeValue = nextButton.getAttribute('data-tab-value') ?? '';
      container.querySelectorAll<HTMLElement>('button[data-tab-value]').forEach((btn) => {
        const isActive = btn.getAttribute('data-tab-value') === activeValue;
        btn.setAttribute('tabindex', isActive ? '0' : '-1');
      });
    }
  });
</script>
