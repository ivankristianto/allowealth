---
/**
 * Input Component
 *
 * Form input component with support for text, number, date, select, and search types.
 * Aligned with Oasis Finance v1.0.0 design system.
 *
 * @param {string} type - Input type: text, number, email, date, select, search, password
 * @param {string} placeholder - Placeholder text
 * @param {string} value - Input value
 * @param {boolean} disabled - Whether the input is disabled
 * @param {boolean} error - Show error state
 * @param {string} errorMessage - Error message to display
 * @param {Array} options - Options for select type
 * @param {string} className - Additional CSS classes
 * @param {string} id - Element ID
 * @param {string} name - Input name
 */

export interface Props {
  type?: 'text' | 'number' | 'email' | 'date' | 'select' | 'search' | 'password';
  placeholder?: string;
  value?: string | number;
  disabled?: boolean;
  error?: boolean;
  errorMessage?: string;
  options?: Array<{ value: string; label: string }>;
  className?: string;
  id?: string;
  name?: string;
  min?: string | number;
  max?: string | number;
  step?: string | number;
  required?: boolean;
  pattern?: string;
  title?: string;
  /**
   * Additional IDs for aria-describedby (combined with inline error message ID if error exists)
   * Used to associate input with external description elements like form-level error containers
   */
  describedBy?: string;
  /**
   * Icon slot name for rendering an icon inside the input (e.g., search icon)
   * Use with <slot name="icon"> in the component usage
   */
  icon?: boolean;
  /**
   * Test ID for E2E testing
   */
  'data-testid'?: string;
  /**
   * Optional current email marker used by profile form change-detection logic.
   */
  'data-current-email'?: string;
}

const {
  type = 'text',
  placeholder = '',
  value = '',
  disabled = false,
  error = false,
  errorMessage = '',
  options = [],
  className = '',
  id = '',
  name = '',
  min = '',
  max = '',
  step = '',
  pattern = '',
  title = '',
  describedBy = '',
  required = false,
  icon = false,
  'data-testid': dataTestId = '',
  'data-current-email': dataCurrentEmail = '',
} = Astro.props;

// Check if input has an icon slot
const hasIcon = icon || Astro.slots.has('icon');

// Base input styles aligned with Oasis Finance v1.0.0 design system
// Height: 2.5rem (40px), Font size: 0.75rem (12px), Border radius: var(--radius-field)
const inputClasses = [
  'input input-bordered w-full h-10 rounded-lg border border-base-300',
  // Adjust padding based on icon presence
  hasIcon ? 'pt-2 pb-2 pl-10 pr-3' : 'pt-2 pb-2 pl-3 pr-10',
  'text-xs', // Font size: 0.75rem (12px)
  'bg-base-200', // Theme-aware background
  'focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
  error && 'input-error border-error', // Error state with border-error
  disabled && 'opacity-50 cursor-not-allowed',
  className,
]
  .filter(Boolean)
  .join(' ');

// Build aria-describedby value: combine inline error ID with external describedBy IDs
const ariaDescribeIds = [error && errorMessage && id ? `${id}-error` : null, describedBy]
  .filter(Boolean)
  .join(' ')
  .trim();

const selectOptions = type === 'select' ? options : [];
---

<!-- Input wrapper for icon positioning -->
<div class="relative">
  {
    hasIcon && (
      <div
        class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none text-muted-foreground"
        aria-hidden="true"
      >
        <slot name="icon" />
      </div>
    )
  }
  {
    type === 'select' ? (
      <select
        id={id}
        name={name}
        class={inputClasses}
        disabled={disabled}
        required={required}
        aria-invalid={error}
        aria-describedby={ariaDescribeIds || undefined}
        aria-required={required}
        data-testid={dataTestId || undefined}
      >
        <option value="">{placeholder || 'Select...'}</option>
        {selectOptions.map((opt) => (
          <option value={opt.value}>{opt.label}</option>
        ))}
      </select>
    ) : (
      <input
        id={id}
        name={name}
        type={type}
        placeholder={placeholder}
        value={value}
        disabled={disabled}
        required={required}
        class={inputClasses}
        min={type === 'number' ? min : undefined}
        max={type === 'number' ? max : undefined}
        step={type === 'number' ? step : undefined}
        pattern={pattern || undefined}
        title={title || undefined}
        aria-invalid={error}
        aria-describedby={ariaDescribeIds || undefined}
        aria-required={required}
        data-testid={dataTestId || undefined}
        data-current-email={dataCurrentEmail || undefined}
      />
    )
  }
</div>
{
  error && errorMessage && (
    <span id={`${id}-error`} class="text-error text-sm mt-1" role="alert">
      {errorMessage}
    </span>
  )
}
