---
/**
 * Input Component
 *
 * Form input component with support for text, number, date, and select types.
 * Aligned with Oasis Finance v1.0.0 design system.
 *
 * @param {string} type - Input type: text, number, email, date, select
 * @param {string} placeholder - Placeholder text
 * @param {string} value - Input value
 * @param {boolean} disabled - Whether the input is disabled
 * @param {boolean} error - Show error state
 * @param {string} errorMessage - Error message to display
 * @param {Array} options - Options for select type
 * @param {string} className - Additional CSS classes
 * @param {string} id - Element ID
 * @param {string} name - Input name
 */

export interface Props {
  type?: 'text' | 'number' | 'email' | 'date' | 'select' | 'password';
  placeholder?: string;
  value?: string | number;
  disabled?: boolean;
  error?: boolean;
  errorMessage?: string;
  options?: Array<{ value: string; label: string }>;
  className?: string;
  id?: string;
  name?: string;
  min?: string | number;
  max?: string | number;
  step?: string | number;
  required?: boolean;
  pattern?: string;
  title?: string;
  /**
   * Additional IDs for aria-describedby (combined with inline error message ID if error exists)
   * Used to associate input with external description elements like form-level error containers
   */
  describedBy?: string;
}

const {
  type = 'text',
  placeholder = '',
  value = '',
  disabled = false,
  error = false,
  errorMessage = '',
  options = [],
  className = '',
  id = '',
  name = '',
  min = '',
  max = '',
  step = '',
  pattern = '',
  title = '',
  describedBy = '',
  required = false,
} = Astro.props;

// Base input styles aligned with Oasis Finance v1.0.0 design system
// Height: 2.5rem (40px), Font size: 0.75rem (12px), Border radius: var(--radius-field)
const inputClasses = [
  'input input-bordered w-full h-10',
  'pt-2 pb-2 pl-3 pr-10', // Padding: 0.5rem 2.5rem 0.5rem 0.75rem
  'text-xs', // Font size: 0.75rem (12px)
  'bg-base-200', // Theme-aware background
  'focus:ring-2 focus:ring-accent focus:ring-opacity-20 focus:outline-none focus:ring-offset-2', // 2px accent focus ring with 2px offset
  error && 'input-error border-error', // Error state with border-error
  disabled && 'opacity-50 cursor-not-allowed',
  className,
]
  .filter(Boolean)
  .join(' ');

// Build aria-describedby value: combine inline error ID with external describedBy IDs
const ariaDescribeIds = [error && errorMessage && id ? `${id}-error` : null, describedBy]
  .filter(Boolean)
  .join(' ')
  .trim();

const selectOptions = type === 'select' ? options : [];
---

{
  type === 'select' ? (
    <select
      id={id}
      name={name}
      class={inputClasses}
      disabled={disabled}
      required={required}
      aria-invalid={error}
      aria-describedby={ariaDescribeIds || undefined}
      aria-required={required}
    >
      <option value="">{placeholder || 'Select...'}</option>
      {selectOptions.map((opt) => (
        <option value={opt.value}>{opt.label}</option>
      ))}
    </select>
  ) : (
    <input
      id={id}
      name={name}
      type={type}
      placeholder={placeholder}
      value={value}
      disabled={disabled}
      required={required}
      class={inputClasses}
      min={type === 'number' ? min : undefined}
      max={type === 'number' ? max : undefined}
      step={type === 'number' ? step : undefined}
      pattern={pattern || undefined}
      title={title || undefined}
      aria-invalid={error}
      aria-describedby={ariaDescribeIds || undefined}
      aria-required={required}
    />
  )
}
{
  error && errorMessage && (
    <span id={`${id}-error`} class="text-error text-sm mt-1" role="alert">
      {errorMessage}
    </span>
  )
}
