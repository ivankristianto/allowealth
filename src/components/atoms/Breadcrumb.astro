---
/**
 * Breadcrumb Component (Atom)
 *
 * Reusable breadcrumb navigation using DaisyUI's `breadcrumbs` class.
 * Items without href render as the current page with active styling.
 * Items with href render as navigable links.
 *
 * @example
 * <Breadcrumb items={[
 *   { label: "Reports" },
 *   { label: "Member Spending", href: "/reports/members" }
 * ]} />
 */

export interface BreadcrumbItem {
  label: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;

// Find the last non-link item index for aria-current="page"
const lastNonLinkIndex = items.reduce((acc, item, i) => (!item.href ? i : acc), -1);
---

<nav aria-label="Breadcrumb">
  <div class="breadcrumbs text-sm">
    <ul>
      {
        items.map((item, index) => (
          <li>
            {item.href ? (
              <a href={item.href}>{item.label}</a>
            ) : (
              <span
                class="font-semibold text-base-content"
                aria-current={index === lastNonLinkIndex ? 'page' : undefined}
              >
                {item.label}
              </span>
            )}
          </li>
        ))
      }
    </ul>
  </div>
</nav>
