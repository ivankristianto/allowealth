---
/**
 * Currency Input Component
 *
 * Amount input field with currency selector.
 *
 * @param {string} name - Input name
 * @param {string} value - Initial amount value
 * @param {string} currency - Initial currency (IDR or USD)
 * @param {boolean} required - Whether the field is required
 * @param {boolean} error - Show error state
 * @param {string} errorMessage - Error message to display
 * @param {string} className - Additional CSS classes
 * @param {string} id - Element ID
 * @param {string} amountName - Name attribute for amount input
 * @param {string} currencyName - Name attribute for currency select
 */

import { AVAILABLE_CURRENCIES } from '@/lib/constants/currency';
import AmountInput from './AmountInput.astro';

export interface Props {
  name?: string;
  value?: string;
  currency?: 'IDR' | 'USD';
  required?: boolean;
  error?: boolean;
  errorMessage?: string;
  className?: string;
  id?: string;
  amountName?: string;
  currencyName?: string;
  disabled?: boolean;
  'data-testid'?: string;
}

const {
  name = 'amount',
  value = '',
  currency = 'IDR',
  required = false,
  error = false,
  errorMessage = '',
  className = '',
  id = '',
  amountName = 'amount',
  currencyName = 'currency',
  disabled = false,
  'data-testid': dataTestId,
} = Astro.props;

const inputId = id || `${name}-input`;
const currencyId = `${name}-currency`;
const errorId = `${name}-error`;
---

<div class="join w-full rounded-lg">
  <!-- Currency Selector -->
  <select
    id={currencyId}
    name={currencyName}
    class="select select-bordered join-item h-14 w-20 min-w-20 rounded-l-lg border border-base-300 bg-base-200 text-sm font-bold focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
    disabled={disabled}
    aria-label="Currency"
  >
    {
      AVAILABLE_CURRENCIES.map((code) => (
        <option value={code} selected={code === currency}>
          {code}
        </option>
      ))
    }
  </select>

  <!-- Amount Input -->
  <AmountInput
    id={inputId}
    name={amountName}
    value={value}
    currency={currency}
    required={required}
    disabled={disabled}
    placeholder="0.00"
    className={[
      'input input-bordered join-item w-full h-14 rounded-r-lg border border-base-300 bg-base-200 text-base font-bold',
      'focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
      error && 'input-error',
      disabled && 'opacity-50 cursor-not-allowed',
      className,
    ]
      .filter(Boolean)
      .join(' ')}
    ariaInvalid={error}
    ariaDescribedBy={error ? errorId : ''}
    ariaRequired={required}
    data-testid={dataTestId}
  />
</div>

{
  error && errorMessage && (
    <span id={errorId} class="text-error text-sm mt-1" role="alert">
      {errorMessage}
    </span>
  )
}
