---
import StatCard from '@/components/atoms/StatCard.astro';
import { formatCurrency, formatPercentage } from '@/lib/formatting';
import type { Currency } from '@/lib/constants/currency';
import { TrendingDown, TrendingUp } from '@lucide/astro';

export interface Props {
  totalIncome: string;
  totalExpenses: string;
  netSavings: string;
  savingsRate: string;
  currency: Currency;
}

const { totalIncome, totalExpenses, netSavings, savingsRate, currency } = Astro.props;

const rateNum = parseFloat(savingsRate) || 0;
const netSavingsNum = parseFloat(netSavings) || 0;
const isNetPositive = netSavingsNum >= 0;
const savingsRateSummary =
  rateNum < 0
    ? 'Spending is above income for this period'
    : rateNum >= 20
      ? 'A healthy share of income is being kept'
      : rateNum > 0
        ? 'Income is ahead, but with a smaller buffer'
        : 'No savings were recorded for this period';
---

<div class="@container" data-summary-cards>
  <div class="grid grid-cols-1 @2xl:grid-cols-2 @5xl:grid-cols-4 gap-4 @2xl:gap-6">
    <StatCard
      title="Total income"
      value={formatCurrency(totalIncome, currency)}
      valueColor="text-success"
      subtitle="Money received during this period"
      iconVariant="success"
      data-testid="reports-overview-income-card"
    >
      <TrendingUp slot="icon" size={48} class="stroke-current" aria-hidden="true" />
    </StatCard>

    <StatCard
      title="Total expenses"
      value={formatCurrency(totalExpenses, currency)}
      valueColor="text-error"
      subtitle="Money spent during this period"
      iconVariant="error"
      data-testid="reports-overview-expense-card"
    >
      <TrendingDown slot="icon" size={48} class="stroke-current" aria-hidden="true" />
    </StatCard>

    <StatCard
      title="Net savings"
      value={formatCurrency(netSavings, currency)}
      valueColor={isNetPositive ? 'text-accent' : 'text-error'}
      subtitle={isNetPositive ? 'Income is covering expenses' : 'Expenses are higher than income'}
      iconVariant={isNetPositive ? 'accent' : 'error'}
      data-testid="reports-overview-savings-card"
    >
      {
        (
          <Fragment slot="icon">
            {isNetPositive ? (
              <TrendingUp size={48} class="stroke-current" aria-hidden="true" />
            ) : (
              <TrendingDown size={48} class="stroke-current" aria-hidden="true" />
            )}
          </Fragment>
        )
      }
    </StatCard>

    <StatCard
      title="Savings rate"
      value={formatPercentage(rateNum, 1)}
      valueColor={rateNum >= 0 ? 'text-success' : 'text-error'}
      subtitle={savingsRateSummary}
      progress={Math.min(Math.abs(rateNum), 100)}
      progressColor={rateNum >= 0 ? 'bg-success' : 'bg-error'}
      data-testid="reports-overview-savings-rate-card"
    />
  </div>
</div>
