---
/**
 * Pagination Partial
 *
 * Renders pagination controls as an HTML fragment.
 * Used for server-rendered HTML responses (HTMX-style).
 */

import { tokenClasses } from '@/lib/tokens';

export interface Props {
  total: number;
  limit: number;
  offset: number;
  page: number;
  totalPages: number;
  hideSummary?: boolean;
}

const { total, limit, page, totalPages, hideSummary = false } = Astro.props;

const start = (page - 1) * limit + 1;
const end = Math.min(page * limit, total);
const showPagination = total > limit;
const paginationCurrentClass = `inline-flex items-center justify-center min-h-[44px] rounded-2xl border border-base-300 bg-base-200 px-3 font-medium text-base-content ${tokenClasses.textSm}`;
import Button from '@/components/atoms/Button.astro';
---

<div
  id="pagination-container"
  class={`flex flex-col sm:flex-row items-center justify-between gap-3 px-4 sm:px-6 py-4 border-t border-base-200 ${!showPagination ? 'hidden' : ''}`}
  data-pagination
  data-total={total}
  data-page-size={limit}
  data-current-page={page}
>
  {
    !hideSummary && (
      <div
        class:list={['hidden sm:block text-base-content/60', tokenClasses.textSm]}
        data-pagination-info
      >
        Showing {start} to {end} of {total} transactions
      </div>
    )
  }
  <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-end">
    <Button
      variant="ghost"
      size="sm"
      className="min-h-[44px] min-w-[44px] rounded-2xl bg-base-100 text-base-content hover:border-accent sm:min-w-0"
      disabled={page <= 1}
      data-pagination-prev
      aria-label="Previous page"
    >
      Previous
    </Button>

    <span class={paginationCurrentClass} data-pagination-current>
      {page} / {totalPages}
    </span>

    <Button
      variant="ghost"
      size="sm"
      className="min-h-[44px] min-w-[44px] rounded-2xl bg-base-100 text-base-content hover:border-accent sm:min-w-0"
      disabled={page >= totalPages}
      data-pagination-next
      aria-label="Next page"
    >
      Next
    </Button>
  </div>
</div>
