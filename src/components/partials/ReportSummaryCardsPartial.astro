---
/**
 * Report Summary Cards Partial
 *
 * Server-rendered partial for report summary stat cards.
 * Used for both SSR and HTML fragment responses (?_render=html).
 *
 * @param {number} totalIncome - Total income for period
 * @param {number} totalExpenses - Total expenses for period
 * @param {number} netSavings - Net savings for period
 * @param {number} budgetHealth - Budget health percentage
 * @param {number} expenseCategories - Number of expense categories
 */

import StatCard from '@/components/atoms/StatCard.astro';

export interface Props {
  totalIncome: number;
  totalExpenses: number;
  netSavings: number;
  budgetHealth: number;
  expenseCategories: number;
}

const { totalIncome, totalExpenses, netSavings, budgetHealth, expenseCategories } = Astro.props;

// Format currency helper for display
function formatNumber(amount: number): string {
  return new Intl.NumberFormat('id-ID', {
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  }).format(amount);
}
---

<!-- Summary Metric Cards -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6" data-summary-cards>
  <StatCard
    title="TOTAL INCOME"
    value={`Rp ${formatNumber(totalIncome)}`}
    subtitle="PERIOD TOTAL"
    subtitleIcon="trending-up"
    valueColor="text-success"
    subtitleColor="text-success/60"
  />

  <StatCard
    title="TOTAL EXPENSES"
    value={`Rp ${formatNumber(totalExpenses)}`}
    subtitle={`${expenseCategories} CATEGORIES`}
    valueColor="text-error"
    subtitleColor="text-error/60"
  />

  <StatCard
    title="NET SAVINGS"
    value={`Rp ${formatNumber(netSavings)}`}
    subtitle="RETAINED CAPITAL"
    valueColor="text-accent"
    subtitleColor="text-base-content/60"
  />

  <StatCard
    title="BUDGET HEALTH"
    value={`${budgetHealth}%`}
    valueColor={budgetHealth > 100 ? 'text-error' : 'text-success'}
    progress={budgetHealth}
    progressColor={budgetHealth > 100 ? 'bg-error' : 'bg-success'}
  />
</div>
