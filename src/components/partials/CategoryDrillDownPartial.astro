---
/**
 * CategoryDrillDownPartial Component
 *
 * Server-rendered partial for category drill-down modal content.
 * Returns complete modal content including header with CategoryIcon and transaction list.
 *
 * This follows the Interactive Pages Architecture pattern (002-interactive-pages.md)
 */

import CategoryIcon from '../atoms/CategoryIcon.astro';
import Badge from '../atoms/Badge.astro';
import EmptyState from '../atoms/EmptyState.astro';
import ProgressBar from '../atoms/ProgressBar.astro';
import TransactionDateGroups from '../molecules/TransactionDateGroups.astro';
import { TrendingUp, TrendingDown, TriangleAlert } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import { getBudgetStatus } from '@/lib/utils/budget';
import { groupTransactionsByDate } from '@/lib/utils/transaction-grouping';

import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  categoryId: string;
  categoryName: string;
  categoryIcon: string;
  categoryColor: string;
  spent: number;
  budgetLimit?: number | null;
  period: string;
  transactions: TransactionOutput[];
}

const { categoryName, categoryIcon, categoryColor, spent, budgetLimit, period, transactions } =
  Astro.props;

const dateGroups = groupTransactionsByDate(transactions);

// Budget calculations
const hasBudget = typeof budgetLimit === 'number' && budgetLimit > 0;
const resolvedBudgetLimit = hasBudget ? budgetLimit : 0;
const percentage = hasBudget ? (spent / resolvedBudgetLimit) * 100 : 0;
const remaining = hasBudget ? resolvedBudgetLimit - spent : 0;
const budgetStatus = hasBudget ? getBudgetStatus(percentage) : null;

// Badge styling
let badgeVariant: 'neutral' | 'optimal' | 'review' | 'exceeded' = 'neutral';
let badgeClassName = 'inline-flex items-center gap-1.5 text-xs font-bold uppercase tracking-widest';
let badgeText = '';
let showAlertIcon = false;
let showTrendingUpIcon = false;
let showTrendingDownIcon = false;

if (!hasBudget) {
  badgeVariant = 'neutral';
  badgeClassName = `${badgeClassName} bg-base-300 text-base-content/60`;
  badgeText = 'NOT SET';
} else if (budgetStatus) {
  badgeVariant = budgetStatus.badgeVariant;
  if (budgetStatus.status === 'danger') {
    badgeText = `OVER BY ${percentage.toFixed(1)}%`;
    showAlertIcon = true;
  } else {
    badgeText = `${percentage.toFixed(1)}% USED`;
    showTrendingUpIcon = budgetStatus.status === 'warning';
    showTrendingDownIcon = budgetStatus.status === 'ok';
  }
}

// Progress bar
const progressStatus: 'ok' | 'warning' | 'danger' = budgetStatus?.status ?? 'ok';
---

<div data-category-drilldown-content>
  {/* Header with category info */}
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
    <div class="flex items-center gap-4">
      <CategoryIcon icon={categoryIcon} color={categoryColor} size="lg" />
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-primary leading-none">
          {categoryName}
        </h2>
        <p class="text-neutral text-sm mt-2 font-medium uppercase tracking-widest">
          {period.toUpperCase()}
        </p>
      </div>
    </div>

    <div class="flex flex-col items-start md:items-end">
      <p class="text-2xl md:text-3xl font-bold text-base-content tracking-tight">
        {formatCurrency(spent, 'IDR')}
      </p>
      <div class="mt-2">
        <Badge variant={badgeVariant} size="sm" className={badgeClassName}>
          {showAlertIcon && <TriangleAlert size={12} class="stroke-current" aria-hidden="true" />}
          {showTrendingUpIcon && <TrendingUp size={12} class="stroke-current" aria-hidden="true" />}
          {
            showTrendingDownIcon && (
              <TrendingDown size={12} class="stroke-current" aria-hidden="true" />
            )
          }
          <span>{badgeText}</span>
        </Badge>
      </div>
    </div>
  </div>

  {/* Budget Progress Section */}
  <div class="bg-base-200/50 rounded-card p-6 border border-base-300/50">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-sm font-bold text-base-content/60 uppercase tracking-widest">
        Budget Overview
      </h3>
    </div>

    <div class="space-y-3">
      <div class="flex justify-between items-center text-sm">
        <span class="text-base-content/60">Spent</span>
        <span class="font-bold">{formatCurrency(spent, 'IDR')}</span>
      </div>
      <div class="flex justify-between items-center text-sm">
        <span class="text-base-content/60">Budget Limit</span>
        <span class="font-bold">
          {hasBudget ? formatCurrency(resolvedBudgetLimit, 'IDR') : 'Not Set'}
        </span>
      </div>
      <div class="flex justify-between items-center text-sm">
        <span class="text-base-content/60">Remaining</span>
        <span
          class={`font-bold ${hasBudget ? (remaining >= 0 ? 'text-success' : 'text-error') : 'text-base-content/60'}`}
        >
          {hasBudget ? formatCurrency(Math.abs(remaining), 'IDR') : '-'}
        </span>
      </div>

      {/* Progress Bar */}
      <ProgressBar
        value={percentage}
        status={progressStatus}
        size="sm"
        ariaLabel={`Budget progress for ${categoryName}`}
      />
    </div>
  </div>

  {/* Transactions Section */}
  <div class="bg-base-200/50 rounded-card border border-base-300/50 overflow-hidden">
    <div class="flex justify-between items-center px-6 pt-6 pb-4">
      <h3 class="text-sm font-bold text-base-content/60 uppercase tracking-widest">
        Transactions (<span>{transactions.length}</span>)
      </h3>
    </div>

    {
      transactions.length === 0 ? (
        <div role="status" aria-live="polite" class="px-6 pb-6">
          <EmptyState
            title="No transactions"
            message="No transactions in this period."
            iconName="info"
            variant="centered"
            className="py-0"
          />
        </div>
      ) : (
        <TransactionDateGroups groups={dateGroups} showActions={false} variant="compact" />
      )
    }
  </div>

  {/* Close button */}
  <div class="flex justify-end pt-2">
    <form method="dialog">
      <button
        type="submit"
        class="btn btn-outline btn-accent px-8 h-14 rounded-2xl font-bold text-base-content hover:bg-base-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent"
        data-close-drilldown
      >
        Close
      </button>
    </form>
  </div>
</div>
