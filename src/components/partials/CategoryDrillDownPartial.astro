---
/**
 * CategoryDrillDownPartial Component
 *
 * Server-rendered partial for category drill-down modal content.
 * Returns complete modal content including header with CategoryIcon and transaction list.
 *
 * This follows the Interactive Pages Architecture pattern (002-interactive-pages.md)
 */

import CategoryIcon from '../atoms/CategoryIcon.astro';
import ProgressBar from '../atoms/ProgressBar.astro';
import TransactionCard from '../molecules/TransactionCard.astro';
import { TrendingUp, TrendingDown, TriangleAlert } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';

import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  categoryId: string;
  categoryName: string;
  categoryIcon: string;
  categoryColor: string;
  spent: number;
  budgetLimit?: number | null;
  period: string;
  transactions: TransactionOutput[];
}

const { categoryName, categoryIcon, categoryColor, spent, budgetLimit, period, transactions } =
  Astro.props;

// Budget calculations
const hasBudget = budgetLimit !== null && budgetLimit !== undefined;
const percentage = hasBudget ? (spent / budgetLimit) * 100 : 0;
const remaining = hasBudget ? budgetLimit - spent : 0;
const isOverBudget = percentage > 100;

// Badge styling
let badgeClasses = '';
let badgeText = '';
let showAlertIcon = false;
let showTrendingUpIcon = false;
let showTrendingDownIcon = false;

if (!hasBudget) {
  badgeClasses =
    'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-base-300 text-base-content/60';
  badgeText = 'NOT SET';
} else if (isOverBudget) {
  badgeClasses =
    'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-error/10 text-error';
  badgeText = `OVER BY ${percentage.toFixed(1)}%`;
  showAlertIcon = true;
} else if (percentage >= 80) {
  badgeClasses =
    'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-warning/10 text-warning';
  badgeText = `${percentage.toFixed(1)}% USED`;
  showTrendingUpIcon = true;
} else {
  badgeClasses =
    'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-success/10 text-success';
  badgeText = `${percentage.toFixed(1)}% USED`;
  showTrendingDownIcon = true;
}

// Progress bar
const progressStatus: 'ok' | 'warning' | 'danger' = isOverBudget
  ? 'danger'
  : percentage >= 80
    ? 'warning'
    : 'ok';
---

<div data-category-drilldown-content>
  {/* Header with category info */}
  <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
    <div class="flex items-center gap-4">
      <CategoryIcon icon={categoryIcon} color={categoryColor} size="lg" />
      <div>
        <h2 class="text-2xl font-bold tracking-tight text-primary leading-none">
          {categoryName}
        </h2>
        <p class="text-neutral text-sm mt-2 font-medium uppercase tracking-widest">
          {period.toUpperCase()}
        </p>
      </div>
    </div>

    <div class="flex flex-col items-start md:items-end">
      <p class="text-2xl md:text-3xl font-bold text-base-content tracking-tight">
        {formatCurrency(spent, 'IDR')}
      </p>
      <div class={badgeClasses}>
        {showAlertIcon && <TriangleAlert size={12} class="stroke-current" aria-hidden="true" />}
        {showTrendingUpIcon && <TrendingUp size={12} class="stroke-current" aria-hidden="true" />}
        {
          showTrendingDownIcon && (
            <TrendingDown size={12} class="stroke-current" aria-hidden="true" />
          )
        }
        <span>{badgeText}</span>
      </div>
    </div>
  </div>

  {/* Budget Progress Section */}
  <div class="bg-base-200/50 rounded-card p-6 border border-base-300/50">
    <div class="flex justify-between items-center mb-4">
      <h3 class="text-sm font-bold text-base-content/60 uppercase tracking-widest">
        Budget Overview
      </h3>
    </div>

    <div class="space-y-3">
      <div class="flex justify-between items-center text-sm">
        <span class="text-base-content/60">Spent</span>
        <span class="font-bold">{formatCurrency(spent, 'IDR')}</span>
      </div>
      <div class="flex justify-between items-center text-sm">
        <span class="text-base-content/60">Budget Limit</span>
        <span class="font-bold">{hasBudget ? formatCurrency(budgetLimit, 'IDR') : 'Not Set'}</span>
      </div>
      <div class="flex justify-between items-center text-sm">
        <span class="text-base-content/60">Remaining</span>
        <span
          class={`font-bold ${hasBudget ? (remaining >= 0 ? 'text-success' : 'text-error') : 'text-base-content/60'}`}
        >
          {hasBudget ? formatCurrency(Math.abs(remaining), 'IDR') : '-'}
        </span>
      </div>

      {/* Progress Bar */}
      <ProgressBar
        value={percentage}
        status={progressStatus}
        size="sm"
        ariaLabel={`Budget progress for ${categoryName}`}
      />
    </div>
  </div>

  {/* Transactions Section */}
  <div class="bg-base-200/50 rounded-card p-6 border border-base-300/50">
    <div class="flex justify-between items-center mb-6">
      <h3 class="text-sm font-bold text-base-content/60 uppercase tracking-widest">
        Transactions (<span>{transactions.length}</span>)
      </h3>
    </div>

    {
      transactions.length === 0 ? (
        <div
          class="flex flex-col items-center justify-center py-8"
          role="status"
          aria-live="polite"
        >
          <p class="text-base-content/50 text-sm">No transactions in this period</p>
        </div>
      ) : (
        <div class="space-y-3">
          {transactions.map((transaction) => (
            <div data-transaction-card>
              <TransactionCard transaction={transaction} showActions={false} />
            </div>
          ))}
        </div>
      )
    }
  </div>

  {/* Close button */}
  <div class="flex justify-end pt-2">
    <form method="dialog">
      <button
        type="submit"
        class="btn btn-outline btn-accent px-8 h-14 rounded-full font-bold text-base-content hover:bg-base-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent"
        data-close-drilldown
      >
        Close
      </button>
    </form>
  </div>
</div>
