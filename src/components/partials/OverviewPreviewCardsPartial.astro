---
import { formatCurrency } from '@/lib/formatting';
import type { Currency } from '@/lib/constants/currency';
import {
  buildReportUrl,
  REPORT_SECTION_PATHS,
  type ReportState,
} from '@/lib/reporting/report-state';
import { TrendingUp, TrendingDown, ArrowRight } from '@lucide/astro';

interface PreviewCategory {
  name: string;
  value: string;
}

export interface Props {
  incomePreview: { topCategories: PreviewCategory[]; total: string };
  expensePreview: { topCategories: PreviewCategory[]; total: string };
  currency: Currency;
  state: ReportState;
}

const { incomePreview, expensePreview, currency, state } = Astro.props;

const incomeHref = buildReportUrl(REPORT_SECTION_PATHS.income, state);
const expensesHref = buildReportUrl(REPORT_SECTION_PATHS.expenses, state);
---

<div class="@container" data-overview-previews>
  <div class="grid grid-cols-1 @3xl:grid-cols-2 gap-6">
    {/* Income Preview Card */}
    <div class="card bg-base-100 shadow-sm border border-base-200">
      <div class="card-body p-4 sm:p-6">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <TrendingUp size={18} class="text-success" />
            <h3 class="font-semibold text-sm uppercase tracking-wider text-base-content/70">
              Top Income Sources
            </h3>
          </div>
          <p class="text-sm font-bold text-success">
            {formatCurrency(incomePreview.total, currency)}
          </p>
        </div>
        {
          incomePreview.topCategories.length > 0 ? (
            <ul class="space-y-2 mb-4">
              {incomePreview.topCategories.map((cat) => (
                <li class="flex items-center justify-between text-sm">
                  <span class="text-base-content/80 truncate">{cat.name}</span>
                  <span class="font-medium text-base-content tabular-nums">
                    {formatCurrency(cat.value, currency)}
                  </span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-base-content/50 mb-4">No income recorded</p>
          )
        }
        <a
          href={incomeHref}
          class="btn btn-ghost btn-sm gap-1 self-end text-success hover:text-success"
        >
          View Income Report <ArrowRight size={14} />
        </a>
      </div>
    </div>

    {/* Expense Preview Card */}
    <div class="card bg-base-100 shadow-sm border border-base-200">
      <div class="card-body p-4 sm:p-6">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <TrendingDown size={18} class="text-error" />
            <h3 class="font-semibold text-sm uppercase tracking-wider text-base-content/70">
              Top Expense Categories
            </h3>
          </div>
          <p class="text-sm font-bold text-error">
            {formatCurrency(expensePreview.total, currency)}
          </p>
        </div>
        {
          expensePreview.topCategories.length > 0 ? (
            <ul class="space-y-2 mb-4">
              {expensePreview.topCategories.map((cat) => (
                <li class="flex items-center justify-between text-sm">
                  <span class="text-base-content/80 truncate">{cat.name}</span>
                  <span class="font-medium text-base-content tabular-nums">
                    {formatCurrency(cat.value, currency)}
                  </span>
                </li>
              ))}
            </ul>
          ) : (
            <p class="text-sm text-base-content/50 mb-4">No expenses recorded</p>
          )
        }
        <a
          href={expensesHref}
          class="btn btn-ghost btn-sm gap-1 self-end text-error hover:text-error"
        >
          View Expense Report <ArrowRight size={14} />
        </a>
      </div>
    </div>
  </div>
</div>
