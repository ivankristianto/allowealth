---
/**
 * Report Charts Partial
 *
 * Server-rendered partial for report charts (Expense Breakdown + Income vs. Expenses).
 * Used for both SSR and HTML fragment responses (?_render=html).
 *
 * @param {Array} expenseByCategory - Expense breakdown by category
 * @param {Array} trendData - Income vs expenses trend data
 * @param {string} chartSubtitle - Subtitle for charts (e.g., "EXPENSE MIX", "2023 FLOW")
 */

import ResourceAllocationChart from '@/components/organisms/ResourceAllocationChart.astro';
import FinancialVelocityChart from '@/components/organisms/FinancialVelocityChart.astro';
import RecurringVsOneTimeChart from '@/components/organisms/RecurringVsOneTimeChart.astro';
import type { Currency } from '@/lib/constants/currency';

export interface ExpenseCategory {
  name: string;
  value: number;
}

export interface TrendData {
  name: string;
  income: number;
  expenses: number;
}

export interface Props {
  expenseByCategory: ExpenseCategory[];
  trendData: TrendData[];
  currency: Currency;
  resourceAllocationSubtitle?: string;
  financialVelocitySubtitle?: string;
  recurringBreakdown?: {
    recurringTotal: number;
    oneTimeTotal: number;
  };
}

const {
  expenseByCategory,
  trendData,
  currency,
  resourceAllocationSubtitle = 'EXPENSE MIX',
  financialVelocitySubtitle = 'TRAILING 3 MONTHS',
  recurringBreakdown,
} = Astro.props;
---

<!-- Charts Grid -->
<div class="@container" data-report-charts>
  <div class="grid grid-cols-1 @3xl:grid-cols-2 gap-6 @2xl:gap-8">
    <!-- Expense Breakdown Chart -->
    <ResourceAllocationChart data={expenseByCategory} subtitle={resourceAllocationSubtitle} />

    <!-- Income vs. Expenses Chart -->
    <FinancialVelocityChart
      data={trendData}
      currency={currency}
      subtitle={financialVelocitySubtitle}
    />

    {
      recurringBreakdown && (
        <RecurringVsOneTimeChart
          recurringTotal={recurringBreakdown.recurringTotal}
          oneTimeTotal={recurringBreakdown.oneTimeTotal}
          currency={currency}
          subtitle="RECURRING SPLIT"
          className="@3xl:col-span-2"
        />
      )
    }
  </div>
</div>
