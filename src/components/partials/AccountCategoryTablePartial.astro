---
/**
 * Account Category Table Partial
 *
 * Server-rendered partial for the account categories table body.
 * Used for both SSR and HTML fragment responses (?_render=html).
 *
 * @param {Array} categories - Array of category objects with account counts
 * @param {string} typeFilter - 'account' | 'liability' for current tab filter
 */

import { Pencil, Trash2, Folder } from '@lucide/astro';

export interface AccountCategoryWithCount {
  id: string;
  name: string;
  description: string | null;
  isLiability: boolean;
  isSystem: boolean;
  sortOrder: number;
  accountCount: number;
}

export interface Props {
  categories: AccountCategoryWithCount[];
  typeFilter: 'account' | 'liability';
}

const { categories, typeFilter } = Astro.props;
// Show table only when at least one category is visible in the current tab.
// categories may contain all types (search-only filtered), so check by type.
const hasVisibleCategories = categories.some(
  (c) => (c.isLiability ? 'liability' : 'account') === typeFilter
);
---

{
  hasVisibleCategories ? (
    <tbody class="divide-y divide-base-200" data-category-table-body>
      {categories.map((category) => {
        const categoryType = category.isLiability ? 'liability' : 'account';
        const isVisible = categoryType === typeFilter;
        return (
          <tr
            class={`group hover:bg-base-200/50 transition-colors ${!isVisible ? 'hidden' : ''}`}
            data-category-row={category.id}
            data-category-type={categoryType}
          >
            <td class="px-8 py-5">
              <div class="flex items-center gap-3">
                <span class="text-base font-bold text-base-content tracking-tight leading-none">
                  {category.name}
                </span>
                {category.isSystem && <span class="badge badge-ghost text-xs">System</span>}
              </div>
            </td>
            <td class="px-8 py-5 hidden md:table-cell">
              <span class="text-sm text-base-content/60 font-medium">
                {category.description || '—'}
              </span>
            </td>
            <td class="px-8 py-5">
              <span class="text-sm font-semibold text-base-content">
                {category.isLiability ? 'Liability' : 'Account'}
              </span>
            </td>
            <td class="px-8 py-5">
              <span class="text-sm font-semibold text-base-content">{category.accountCount}</span>
            </td>
            <td class="px-8 py-5 text-right">
              {category.isSystem ? (
                <span class="text-xs text-base-content/30 font-medium">System</span>
              ) : (
                <div class="flex items-center justify-end gap-2">
                  <button
                    type="button"
                    class="p-2 text-base-content/30 hover:text-primary hover:bg-primary/10 rounded-xl transition-all"
                    data-action="edit-account-category"
                    data-category-id={category.id}
                    data-category-name={category.name}
                    data-category-description={category.description || ''}
                    data-category-type={category.isLiability ? 'liability' : 'account'}
                    aria-label={`Edit ${category.name} category`}
                  >
                    <Pencil size={18} class="stroke-current" aria-hidden="true" />
                  </button>
                  <button
                    type="button"
                    class="p-2 text-base-content/30 hover:text-error hover:bg-error/10 rounded-xl transition-all"
                    data-action="delete-account-category"
                    data-category-id={category.id}
                    data-category-name={category.name}
                    data-category-meta={`${category.accountCount} account${category.accountCount !== 1 ? 's' : ''}`}
                    aria-label={`Delete ${category.name} category`}
                  >
                    <Trash2 size={18} class="stroke-current" aria-hidden="true" />
                  </button>
                </div>
              )}
            </td>
          </tr>
        );
      })}
    </tbody>
  ) : (
    <tbody data-category-table-body>
      <tr>
        <td colspan={5} class="py-24 text-center">
          <div class="w-20 h-20 bg-base-200 mx-auto rounded-3xl flex items-center justify-center text-base-content/30 mb-6 shadow-inner">
            <Folder size={40} class="stroke-current" aria-hidden="true" />
          </div>
          <h4 class="text-lg font-bold text-base-content mb-2">No categories found</h4>
          <p class="text-base-content/60 font-medium max-w-xs mx-auto">
            Try adjusting your search terms or switch to the other tab.
          </p>
        </td>
      </tr>
    </tbody>
  )
}
