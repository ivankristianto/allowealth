---
/**
 * Income Member Table Partial
 *
 * Member income summary table. Each row shows member name,
 * total income, transaction count, and share of total.
 */

import { formatCurrency } from '@/lib/formatting';
import { safeParseDecimal } from '@/lib/utils/decimal';
import type { Currency } from '@/lib/constants/currency';
import { Users } from '@lucide/astro';

export interface IncomeMember {
  userId: string;
  userName: string;
  totalIncome: string;
  transactionCount: number;
}

export interface Props {
  members: IncomeMember[];
  currency: Currency;
  totalIncome: string;
}

const { members, currency, totalIncome } = Astro.props;

const totalIncomeNum = safeParseDecimal(totalIncome) || 0;
const totalTxns = members.reduce((acc, m) => acc + m.transactionCount, 0);

const avatarColors = [
  'bg-success/15 text-success',
  'bg-info/15 text-info',
  'bg-warning/15 text-warning',
  'bg-accent/15 text-accent',
  'bg-error/15 text-error',
];

const getInitials = (name: string) => {
  if (!name) return '??';
  return name
    .split(' ')
    .map((w) => w[0])
    .join('')
    .toUpperCase()
    .slice(0, 2);
};

const getMemberColor = (name: string) => {
  if (!name) return avatarColors[0];
  return avatarColors[name.charCodeAt(0) % avatarColors.length];
};
---

<div
  data-income-member-table
  class="bg-base-100 rounded-2xl md:rounded-3xl border border-base-300 shadow-sm overflow-hidden"
>
  <div class="px-5 md:px-6 pt-5 md:pt-6 pb-3">
    <h2 class="text-lg font-bold">Income by Member</h2>
    <p class="text-xs font-bold uppercase text-base-content/40 tracking-widest mt-1">
      {members.length} MEMBERS
    </p>
  </div>

  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Member</th>
          <th class="text-right">Total Income</th>
          <th class="text-right hidden sm:table-cell">Share</th>
          <th class="text-right">Txns</th>
        </tr>
      </thead>
      <tbody>
        {
          members.length === 0 ? (
            <tr>
              <td colspan="4" class="text-center py-12 text-base-content/50">
                <div class="flex flex-col items-center gap-2">
                  <div class="w-12 h-12 rounded-full bg-base-200 flex items-center justify-center">
                    <Users class="w-6 h-6 opacity-40" />
                  </div>
                  <p class="font-medium">No income data found</p>
                  <p class="text-sm">Try selecting a different period</p>
                </div>
              </td>
            </tr>
          ) : (
            members.map((member) => {
              const income = safeParseDecimal(member.totalIncome) || 0;
              const share = totalIncomeNum > 0 ? (income / totalIncomeNum) * 100 : 0;

              return (
                <tr class="hover:bg-base-200/50 transition-colors">
                  <td>
                    <div class="flex items-center gap-3">
                      <div
                        class={`w-9 h-9 rounded-full flex items-center justify-center text-xs font-bold shrink-0 ${getMemberColor(member.userName)}`}
                      >
                        {getInitials(member.userName)}
                      </div>
                      <span class="font-semibold">{member.userName}</span>
                    </div>
                  </td>
                  <td class="text-right text-success font-medium tabular-nums">
                    {formatCurrency(income, currency)}
                  </td>
                  <td class="text-right hidden sm:table-cell">
                    <div class="flex items-center justify-end gap-2">
                      <div class="w-16 h-1.5 rounded-full bg-base-200 overflow-hidden">
                        <div class="h-full bg-success/60 rounded-full" style={`width: ${share}%`} />
                      </div>
                      <span class="text-xs font-medium text-base-content/60 w-10 text-right tabular-nums">
                        {share.toFixed(0)}%
                      </span>
                    </div>
                  </td>
                  <td class="text-right">
                    <span class="text-base-content/60 tabular-nums">{member.transactionCount}</span>
                  </td>
                </tr>
              );
            })
          )
        }
      </tbody>
      {
        members.length > 0 && (
          <tfoot>
            <tr class="border-t-2 border-base-300">
              <td class="font-bold">
                <div class="flex items-center gap-3">
                  <div class="w-9 h-9 rounded-full bg-base-200 flex items-center justify-center text-xs font-bold text-base-content/40 shrink-0">
                    ALL
                  </div>
                  <span>Total</span>
                </div>
              </td>
              <td class="text-right text-success font-bold tabular-nums">
                {formatCurrency(totalIncomeNum, currency)}
              </td>
              <td class="text-right hidden sm:table-cell">
                <span class="text-xs font-medium text-base-content/40">100%</span>
              </td>
              <td class="text-right font-bold tabular-nums">{totalTxns}</td>
            </tr>
          </tfoot>
        )
      }
    </table>
  </div>
</div>
