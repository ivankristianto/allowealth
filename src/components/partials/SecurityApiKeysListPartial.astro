---
/**
 * API Keys List Partial
 *
 * Server-rendered partial for the API keys list.
 * Follows the same row layout as SecurityPasskeysCard.
 * Used for both SSR and HTML fragment responses (?_render=html).
 */

import { KeyRound, Trash2 } from '@lucide/astro';

export interface ApiKeyItem {
  id: string;
  name: string;
  key_prefix: string;
  last_used_at: Date | null;
  created_at: Date;
  expires_at: Date | null;
}

export interface Props {
  keys: ApiKeyItem[];
}

const { keys } = Astro.props;

function formatRelativeDate(date: Date | null): string {
  if (!date) return 'Never';
  const d = date instanceof Date ? date : new Date(date);
  const now = new Date();
  const diffMs = now.getTime() - d.getTime();
  const diffMins = Math.floor(diffMs / 60000);
  if (diffMins < 1) return 'Just now';
  if (diffMins < 60) return `${diffMins}m ago`;
  const diffHours = Math.floor(diffMins / 60);
  if (diffHours < 24) return `${diffHours}h ago`;
  const diffDays = Math.floor(diffHours / 24);
  if (diffDays < 30) return `${diffDays}d ago`;
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function formatDate(date: Date): string {
  const d = date instanceof Date ? date : new Date(date);
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

function isExpired(date: Date | null): boolean {
  if (!date) return false;
  const d = date instanceof Date ? date : new Date(date);
  return d < new Date();
}
---

{
  keys.length === 0 ? (
    <div class="text-center py-8 text-base-content/50">
      <p class="text-sm">No API keys yet. Generate one to connect AI assistants.</p>
    </div>
  ) : (
    <div class="border border-base-300 rounded-2xl overflow-hidden divide-y divide-base-300 bg-base-100">
      {keys.map((key) => (
        <div
          class="flex items-center justify-between gap-4 p-4"
          data-api-key-item
          data-key-id={key.id}
        >
          <div class="flex items-center gap-4 min-w-0">
            <div class="rounded-xl bg-base-200 p-2 text-base-content/60 shrink-0">
              <KeyRound size={18} class="stroke-current" aria-hidden="true" />
            </div>
            <div class="min-w-0">
              <div class="flex items-center gap-2">
                <p class="text-sm font-semibold truncate">{key.name}</p>
                {isExpired(key.expires_at) && (
                  <span class="badge badge-error badge-xs shrink-0">Expired</span>
                )}
              </div>
              <div class="flex flex-wrap gap-x-3 gap-y-0.5 text-xs text-base-content/60">
                <span class="font-mono">{key.key_prefix}...</span>
                <span>Created {formatDate(key.created_at)}</span>
                <span>Used: {formatRelativeDate(key.last_used_at)}</span>
                {key.expires_at && !isExpired(key.expires_at) && (
                  <span>Expires {formatDate(key.expires_at)}</span>
                )}
              </div>
            </div>
          </div>
          <button
            type="button"
            class="btn btn-ghost btn-sm text-error"
            data-revoke-key
            data-key-id={key.id}
            data-key-name={key.name}
            aria-label={`Revoke ${key.name}`}
          >
            <Trash2 size={16} class="stroke-current" aria-hidden="true" />
          </button>
        </div>
      ))}
    </div>
  )
}
