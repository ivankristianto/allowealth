---
/**
 * AccountHistoryPartial
 *
 * Server-rendered partial for account inline history table.
 * Used by both initial page render and API HTML responses.
 *
 * Part of the Interactive Page Architecture pattern.
 * See: docs/architecture/002-interactive-pages.md
 *
 * @param {HistoryEntry[]} entries - Array of history entries
 * @param {string} accountId - Account ID for the "View all history" link
 */

export interface HistoryEntry {
  id: string;
  balance: string;
  notes: string | null;
  recorded_at: string;
}

export interface Props {
  entries: HistoryEntry[];
  accountId: string;
}

const { entries, accountId } = Astro.props;

// Helper to format date
function formatDate(dateString: string): string {
  const date = new Date(dateString);
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
}

// Helper to calculate change and determine styling
function calculateChange(balance: number, prevBalance: number, isLastEntry: boolean) {
  if (isLastEntry) {
    return {
      change: 0,
      display: '—',
      className: 'text-base-content/50',
    };
  }

  const change = balance - prevBalance;
  const changeClass =
    change > 0 ? 'text-success' : change < 0 ? 'text-error' : 'text-base-content/50';
  const changePrefix = change > 0 ? '+' : '';

  return {
    change,
    display: changePrefix + change.toLocaleString(),
    className: changeClass,
  };
}
---

{
  entries.length === 0 ? (
    <p class="text-sm text-base-content/60 text-center py-2">No history entries yet.</p>
  ) : (
    <>
      <table class="w-full text-left border-collapse">
        <thead>
          <tr class="bg-base-200/50 border-b border-base-300">
            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-bold text-base-content/40 uppercase tracking-widest w-1/5">
              Date
            </th>
            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right w-1/4">
              Balance
            </th>
            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right w-1/4">
              Change
            </th>
            <th class="px-4 md:px-6 py-3 md:py-4 text-xs font-bold text-base-content/40 uppercase tracking-widest">
              Notes
            </th>
          </tr>
        </thead>
        <tbody class="divide-y divide-base-300">
          {entries.map((entry, i) => {
            const balance = parseFloat(entry.balance);
            const prevBalance =
              i < entries.length - 1 ? parseFloat(entries[i + 1].balance) : balance;
            const isLastEntry = i === entries.length - 1;
            const changeData = calculateChange(balance, prevBalance, isLastEntry);
            const date = formatDate(entry.recorded_at);

            return (
              <tr class="group hover:bg-base-200/30 transition-colors">
                <td class="px-4 md:px-6 py-3 md:py-4 text-sm text-base-content">{date}</td>
                <td class="px-4 md:px-6 py-3 md:py-4 text-sm text-right font-bold text-base-content">
                  {balance.toLocaleString()}
                </td>
                <td
                  class={`px-4 md:px-6 py-3 md:py-4 text-sm text-right font-bold ${changeData.className}`}
                >
                  {changeData.display}
                </td>
                <td class="px-4 md:px-6 py-3 md:py-4 text-sm text-base-content/60">
                  {entry.notes || '—'}
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
      <div class="text-center mt-2">
        <a href={`/accounts/history/${accountId}`} class="link link-accent text-sm">
          View all history
        </a>
      </div>
    </>
  )
}
