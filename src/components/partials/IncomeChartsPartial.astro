---
/**
 * Income Charts Partial
 *
 * Server-rendered partial for income charts (Source Mix donut + Source Group Trend).
 * Used for both SSR and HTML fragment responses (?_render=html).
 */

import ResourceAllocationChart from '@/components/organisms/ResourceAllocationChart.astro';
import IncomeSourceTrendChart from '@/components/organisms/IncomeSourceTrendChart.astro';
import type { Currency } from '@/lib/constants/currency';

export interface SourceMixItem {
  name: string;
  value: number;
}

export interface SourceTrendItem {
  name: string;
  active: number;
  passive: number;
  other: number;
}

export interface Props {
  sourceMix: SourceMixItem[];
  sourceGroupTrend: SourceTrendItem[];
  currency: Currency;
  sourceMixSubtitle?: string;
  trendSubtitle?: string;
}

const {
  sourceMix,
  sourceGroupTrend,
  currency,
  sourceMixSubtitle = 'INCOME SOURCE MIX',
  trendSubtitle = 'SOURCE GROUP TREND',
} = Astro.props;
---

<!-- Charts Grid -->
<div class="@container" data-report-charts>
  <div class="grid grid-cols-1 @3xl:grid-cols-2 gap-6 @2xl:gap-8">
    <!-- Income Source Mix Chart -->
    <ResourceAllocationChart
      data={sourceMix}
      subtitle={sourceMixSubtitle}
      title="Income Source Mix"
      emptyText="No income source data available."
      ariaLabel="Income breakdown by source category"
    />

    <!-- Income Source Group Trend Chart -->
    <IncomeSourceTrendChart data={sourceGroupTrend} currency={currency} subtitle={trendSubtitle} />
  </div>
</div>
