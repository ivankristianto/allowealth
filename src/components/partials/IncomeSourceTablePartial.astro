---
/**
 * Income Source Table Partial
 *
 * Shows income categories with source-type badges and amounts.
 * Similar pattern to CategoryTablePartial for expenses.
 */

import { formatCurrency } from '@/lib/formatting';
import type { Currency } from '@/lib/constants/currency';
import { Tag } from '@lucide/astro';

export interface IncomeCategory {
  name: string;
  value: string;
  sourceType: string;
}

export interface Props {
  categories: IncomeCategory[];
  currency: Currency;
  subtitle?: string;
}

const { categories, currency, subtitle = 'SORTED BY AMOUNT' } = Astro.props;

const sourceTypeBadge = (type: string) => {
  const base =
    'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-bold uppercase tracking-wider';
  switch (type) {
    case 'active':
      return `${base} bg-success/10 text-success`;
    case 'passive':
      return `${base} bg-info/10 text-info`;
    case 'other':
      return `${base} bg-warning/10 text-warning`;
    default:
      return `${base} bg-base-200 text-base-content/60`;
  }
};
---

<div
  data-source-table
  class="bg-base-100 rounded-2xl md:rounded-3xl border border-base-300 shadow-sm overflow-hidden"
>
  <div class="px-5 md:px-6 pt-5 md:pt-6 pb-3">
    <h2 class="text-lg font-bold">Income Sources</h2>
    <p class="text-xs font-bold uppercase text-base-content/40 tracking-widest mt-1">
      {subtitle}
    </p>
  </div>

  <div class="overflow-x-auto">
    <table class="table">
      <thead>
        <tr>
          <th>Category</th>
          <th class="text-right">Amount</th>
          <th class="text-right">Source Type</th>
        </tr>
      </thead>
      <tbody>
        {
          categories.length === 0 ? (
            <tr>
              <td colspan="3" class="text-center py-12 text-base-content/50">
                <div class="flex flex-col items-center gap-2">
                  <div class="w-12 h-12 rounded-full bg-base-200 flex items-center justify-center">
                    <Tag class="w-6 h-6 opacity-40" />
                  </div>
                  <p class="font-medium">No income sources found</p>
                  <p class="text-sm">Try selecting a different period</p>
                </div>
              </td>
            </tr>
          ) : (
            categories.map((cat) => (
              <tr class="hover:bg-base-200/50 transition-colors">
                <td>
                  <span class="font-semibold">{cat.name}</span>
                </td>
                <td class="text-right font-medium text-success">
                  {formatCurrency(cat.value, currency)}
                </td>
                <td class="text-right">
                  <span class={sourceTypeBadge(cat.sourceType)}>{cat.sourceType}</span>
                </td>
              </tr>
            ))
          )
        }
      </tbody>
    </table>
  </div>
</div>
