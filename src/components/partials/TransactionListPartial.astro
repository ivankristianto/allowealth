---
/**
 * Transaction List Partial
 *
 * Renders a list of transaction cards as an HTML fragment.
 * Used for server-rendered HTML responses (HTMX-style).
 *
 * This partial outputs ONLY the transaction items - no wrapper container.
 * The client injects this directly into #transaction-list.
 */

import EmptyState from '../atoms/EmptyState.astro';
import TransactionCard from '../molecules/TransactionCard.astro';
import { RotateCcw } from '@lucide/astro';
import { groupTransactionsByDate } from '@/lib/utils/transaction-grouping';
import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  transactions: TransactionOutput[];
  showActions?: boolean;
  currentMonth?: string;
}

const { transactions, showActions = true, currentMonth = '' } = Astro.props;
const dateGroups = groupTransactionsByDate(transactions);
---

{
  transactions.length > 0 ? (
    dateGroups.map((group) => (
      <div role="group" aria-label={`Transactions from ${group.label}`}>
        <div class="text-xs font-semibold text-base-content/50 uppercase tracking-wide py-2 px-4 bg-base-200/30 border-b border-base-200">
          {group.label}
        </div>
        <div class="divide-y divide-base-200">
          {group.transactions.map((transaction) => (
            <TransactionCard transaction={transaction} showActions={showActions} />
          ))}
        </div>
      </div>
    ))
  ) : (
    <div id="empty-state" class="py-24 text-center">
      <EmptyState
        title="No matching transactions"
        message="Try adjusting your filters or search terms to find what you're looking for."
        iconName="receipt"
        variant="centered"
        className="py-0"
      />
      <a
        href="/transactions"
        class="btn btn-outline btn-sm gap-2 mt-6"
        data-reset-filters
        data-current-month={currentMonth}
      >
        <RotateCcw size={16} class="stroke-current" aria-hidden="true" />
        Reset filters
      </a>
    </div>
  )
}
