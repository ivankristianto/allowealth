---
import { TrendingUp, TrendingDown, Wallet } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import type { RecurringMonthlySummary } from '@/lib/utils/recurring-summary';

export interface Props {
  summary: RecurringMonthlySummary;
}

const { summary } = Astro.props;

const upcomingIncomeLabel =
  summary.incomeByCurrency.length > 0
    ? summary.incomeByCurrency
        .map((entry) => formatCurrency(entry.amount, entry.currency))
        .join(' + ')
    : '0';

const upcomingExpenseLabel =
  summary.expenseByCurrency.length > 0
    ? summary.expenseByCurrency
        .map((entry) => formatCurrency(entry.amount, entry.currency))
        .join(' + ')
    : '0';

const netLabel =
  summary.netByCurrency.length > 0
    ? summary.netByCurrency.map((entry) => formatCurrency(entry.net, entry.currency)).join(' + ')
    : '0';

const incomeBreakdown =
  summary.netByCurrency.length > 0
    ? summary.netByCurrency.map((entry) => formatCurrency(entry.income, entry.currency)).join(' + ')
    : '0';

const expenseBreakdown =
  summary.netByCurrency.length > 0
    ? summary.netByCurrency
        .map((entry) => formatCurrency(entry.expenses, entry.currency))
        .join(' + ')
    : '0';

const isNetNegative = summary.netByCurrency.some((entry) => Number.parseFloat(entry.net) < 0);
const netSavingsClass = isNetNegative ? 'text-error' : 'text-success';
---

<section
  class="rounded-2xl border border-base-300 bg-base-100 p-3 sm:rounded-3xl sm:p-4"
  aria-label="Recurring monthly summary"
>
  <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 sm:gap-0" data-testid="recurring-stats-row">
    <article
      class="rounded-xl border border-base-200 bg-base-100 p-3 sm:rounded-none sm:border-0 sm:px-4 sm:py-3 sm:border-r sm:border-base-200"
      role="region"
      aria-label="Upcoming income summary"
    >
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-wide text-base-content/70"
      >
        <TrendingUp size={14} class="stroke-current text-success" aria-hidden="true" />
        Upcoming Income
      </div>
      <p class="mt-2 text-lg font-bold tabular-nums text-success">{upcomingIncomeLabel}</p>
      <p class="mt-1 text-xs text-base-content/70">{summary.upcomingIncomeCount} items due</p>
    </article>

    <article
      class="rounded-xl border border-base-200 bg-base-100 p-3 sm:rounded-none sm:border-0 sm:px-4 sm:py-3 sm:border-r sm:border-base-200"
      role="region"
      aria-label="Upcoming expense summary"
    >
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-wide text-base-content/70"
      >
        <TrendingDown size={14} class="stroke-current text-error" aria-hidden="true" />
        Upcoming Expense
      </div>
      <p class="mt-2 text-lg font-bold tabular-nums text-error">{upcomingExpenseLabel}</p>
      <p class="mt-1 text-xs text-base-content/70">{summary.upcomingExpenseCount} items due</p>
    </article>

    <article
      class="rounded-xl border border-base-200 bg-base-100 p-3 sm:rounded-none sm:border-0 sm:px-4 sm:py-3"
      role="region"
      aria-label="Net cashflow summary"
    >
      <div
        class="flex items-center gap-2 text-xs font-bold uppercase tracking-wide text-base-content/70"
      >
        <Wallet size={14} class={`stroke-current ${netSavingsClass}`} aria-hidden="true" />
        Net Cashflow
      </div>
      <p class={`mt-2 text-lg font-bold tabular-nums ${netSavingsClass}`}>{netLabel}</p>
      <p class="mt-1 text-xs text-base-content/70">
        Income {incomeBreakdown} · Expense {expenseBreakdown}
      </p>
    </article>
  </div>
</section>
