---
/**
 * Bulk Action Bar
 *
 * Sticky bottom bar shown when transactions are selected.
 * Includes actions for category change, account change, and delete.
 */

import Button from '@/components/atoms/Button.astro';
import { X, FolderPen, CreditCard, Trash2 } from '@lucide/astro';

export interface Props {
  categories: Array<{ id: string; name: string; type: string }>;
  accounts: Array<{ id: string; name: string }>;
}

const { categories, accounts } = Astro.props;

const expenseCategories = categories.filter((category) => category.type === 'expense');
const incomeCategories = categories.filter((category) => category.type === 'income');
---

<div
  id="bulk-action-bar"
  class="fixed bottom-0 inset-x-0 z-40 hidden"
  role="toolbar"
  aria-label="Bulk transaction actions"
>
  <div class="bg-base-100 border-t border-base-300 shadow-[0_-4px_20px_rgba(0,0,0,0.1)]">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 py-3 flex items-center gap-3 flex-wrap">
      <Button
        type="button"
        variant="ghost"
        size="sm"
        shape="square"
        className="rounded-xl border-0"
        data-bulk-clear
        aria-label="Clear selection"
      >
        <X size={18} class="stroke-current" aria-hidden="true" />
      </Button>

      <span class="text-sm font-bold text-base-content" data-bulk-selected-count>0 selected</span>

      <div class="flex-1"></div>

      <div class="dropdown dropdown-top dropdown-end">
        <Button
          type="button"
          variant="outline"
          size="sm"
          tabindex={0}
          className="gap-2 rounded-lg sm:rounded-xl"
          aria-haspopup="listbox"
          aria-label="Change category for selected transactions"
        >
          <FolderPen size={16} class="stroke-current" aria-hidden="true" />
          <span class="hidden sm:inline">Category</span>
        </Button>
        <div
          tabindex={0}
          class="dropdown-content z-50 p-3 shadow-lg bg-base-100 rounded-2xl w-72 border border-base-300 mb-2"
          role="listbox"
          data-bulk-category-list
        >
          <div class="space-y-2 max-h-72 overflow-y-auto">
            {
              expenseCategories.length > 0 && (
                <div class="space-y-1">
                  <div class="px-3 py-1.5 text-xs font-semibold text-base-content/40 uppercase tracking-wider">
                    Expense
                  </div>
                  {expenseCategories.map((category) => (
                    <button
                      type="button"
                      role="option"
                      class="w-full text-left text-sm px-3 py-2 rounded-xl hover:bg-base-200 transition-colors"
                      data-bulk-action="update_category"
                      data-bulk-value={category.id}
                    >
                      {category.name}
                    </button>
                  ))}
                </div>
              )
            }
            {
              incomeCategories.length > 0 && (
                <div class="space-y-1">
                  <div class="px-3 py-1.5 text-xs font-semibold text-base-content/40 uppercase tracking-wider">
                    Income
                  </div>
                  {incomeCategories.map((category) => (
                    <button
                      type="button"
                      role="option"
                      class="w-full text-left text-sm px-3 py-2 rounded-xl hover:bg-base-200 transition-colors"
                      data-bulk-action="update_category"
                      data-bulk-value={category.id}
                    >
                      {category.name}
                    </button>
                  ))}
                </div>
              )
            }
          </div>
        </div>
      </div>

      <div class="dropdown dropdown-top dropdown-end">
        <Button
          type="button"
          variant="outline"
          size="sm"
          tabindex={0}
          className="gap-2 rounded-lg sm:rounded-xl"
          aria-haspopup="listbox"
          aria-label="Change account for selected transactions"
        >
          <CreditCard size={16} class="stroke-current" aria-hidden="true" />
          <span class="hidden sm:inline">Account</span>
        </Button>
        <div
          tabindex={0}
          class="dropdown-content z-50 p-3 shadow-lg bg-base-100 rounded-2xl w-72 border border-base-300 mb-2"
          role="listbox"
          data-bulk-account-list
        >
          <div class="space-y-1 max-h-72 overflow-y-auto">
            {
              accounts.map((account) => (
                <button
                  type="button"
                  role="option"
                  class="w-full text-left text-sm px-3 py-2 rounded-xl hover:bg-base-200 transition-colors"
                  data-bulk-action="update_account"
                  data-bulk-value={account.id}
                >
                  {account.name}
                </button>
              ))
            }
          </div>
        </div>
      </div>

      <Button
        type="button"
        variant="danger"
        size="sm"
        className="btn-outline gap-2 rounded-lg sm:rounded-xl"
        data-bulk-action="delete"
        aria-label="Delete selected transactions"
      >
        <Trash2 size={16} class="stroke-current" aria-hidden="true" />
        <span class="hidden sm:inline">Delete</span>
      </Button>
    </div>
  </div>
</div>
