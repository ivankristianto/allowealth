---
/**
 * Budget Overview Table Component (Organism)
 *
 * Displays monthly budget table with:
 * - Category name, percentage, budget amount, expenses, balance
 * - Totals row with summary
 * - Color-coded status indicators
 * - Click category to view transactions
 *
 * @param {Array} categories - Array of budget category data
 * @param {Object} summary - Budget summary totals
 * @param {string} currency - Currency code (IDR or USD)
 * @param {string} className - Additional CSS classes
 */

import { formatCurrency, formatPercentage } from '@/lib/tokens';
import Badge from '../atoms/Badge.astro';
import Icon from '../atoms/Icon.astro';
import EmptyState from '../atoms/EmptyState.astro';

export interface BudgetCategory {
  category_id: string;
  category_name: string;
  category_type: 'expense' | 'income';
  percentage: string;
  budget_amount: string;
  spent_amount: string;
  balance: string;
  status: 'ok' | 'warning' | 'exceeded';
  percentage_used: number;
}

export interface BudgetSummary {
  total_budget: string;
  total_spent: string;
  total_balance: string;
  categories_warning: number;
  categories_exceeded: number;
  categories: BudgetCategory[];
}

export interface Props {
  summary: BudgetSummary;
  currency?: 'IDR' | 'USD';
  className?: string;
  sortBy?: 'category' | 'percentage' | 'budget' | 'spent' | 'balance' | 'status';
  sortOrder?: 'asc' | 'desc';
  baseUrl?: string;
}

const {
  summary,
  currency = 'IDR',
  className = '',
  sortBy = 'category',
  sortOrder = 'asc',
  baseUrl = '',
} = Astro.props;

const {
  categories,
  total_budget,
  total_spent,
  total_balance,
  categories_warning,
  categories_exceeded,
} = summary;

// Sort categories based on sortBy and sortOrder
const sortedCategories = [...categories].sort((a, b) => {
  let comparison = 0;

  switch (sortBy) {
    case 'category':
      comparison = a.category_name.localeCompare(b.category_name);
      break;
    case 'percentage':
      comparison = a.percentage_used - b.percentage_used;
      break;
    case 'budget':
      comparison = parseFloat(a.budget_amount) - parseFloat(b.budget_amount);
      break;
    case 'spent':
      comparison = parseFloat(a.spent_amount) - parseFloat(b.spent_amount);
      break;
    case 'balance':
      comparison = parseFloat(a.balance) - parseFloat(b.balance);
      break;
    case 'status':
      const statusOrder = { exceeded: 0, warning: 1, ok: 2 };
      comparison = statusOrder[a.status] - statusOrder[b.status];
      break;
    default:
      comparison = 0;
  }

  return sortOrder === 'asc' ? comparison : -comparison;
});

// Calculate total percentage (may exceed 100%)
const totalPercentage = categories.reduce((sum, cat) => sum + parseFloat(cat.percentage || '0'), 0);

// Status helpers
const getStatusColor = (status: string): string => {
  switch (status) {
    case 'ok':
      return 'text-success';
    case 'warning':
      return 'text-warning';
    case 'exceeded':
      return 'text-error';
    default:
      return 'text-neutral';
  }
};

const getStatusBadge = (status: string): 'success' | 'warning' | 'error' | 'neutral' => {
  switch (status) {
    case 'ok':
      return 'success';
    case 'warning':
      return 'warning';
    case 'exceeded':
      return 'error';
    default:
      return 'neutral';
  }
};

const getRowBackgroundClass = (status: string): string => {
  switch (status) {
    case 'exceeded':
      return 'bg-error/5';
    case 'warning':
      return 'bg-warning/5';
    default:
      return '';
  }
};

const getProgressClass = (percentage: number): string => {
  if (percentage >= 100) return 'progress-error';
  if (percentage >= 80) return 'progress-warning';
  return 'progress-success';
};

// Helper to build sort URL
const buildSortUrl = (
  column: string,
  currentSort: string,
  currentOrder: string,
  baseUrl: string
): string => {
  const params = new URLSearchParams();

  // If clicking the same column, toggle order
  if (column === currentSort) {
    params.set('sort', column);
    params.set('order', currentOrder === 'asc' ? 'desc' : 'asc');
  } else {
    params.set('sort', column);
    params.set('order', 'asc');
  }

  return `${baseUrl}?${params.toString()}`;
};

// Get sort icon
const getSortIcon = (column: string, currentSort: string, currentOrder: string): string => {
  if (column !== currentSort) {
    return `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4" /></svg>`;
  }
  if (currentOrder === 'asc') {
    return `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h6m4 4l4-4m0 0l4 4m-4-4l-4 4" /></svg>`;
  }
  return `<svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4h13M3 8h9m-9 4h9m4-4l4 4m0 0l-4-4m-4 4l4 4" /></svg>`;
};

// Helper to build export URL from baseUrl
const buildExportUrl = (): string => {
  if (!baseUrl) return '';

  // baseUrl is like "/budget?year=2025&month=1&currency=IDR"
  // We need to extract the params and build export URL
  const urlParts = baseUrl.split('?');
  if (urlParts.length < 2) return '/api/budget/export';

  const params = urlParts[1];
  return `/api/budget/export?${params}`;
};
---

<div class={`space-y-6 ${className}`} data-budget-overview-table>
  {/* Budget Overview Header */}
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h2 class="text-2xl font-bold">Budget Overview</h2>
      <p class="text-neutral-600">Monthly budget breakdown and spending status</p>
    </div>

    <div class="flex items-center gap-2">
      {/* Export Button */}
      {
        baseUrl && (
          <a href={buildExportUrl()} class="btn btn-outline btn-sm gap-2" download>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"
              />
            </svg>
            Export CSV
          </a>
        )
      }

      {/* Budget Alert Summary */}
      {
        (categories_warning > 0 || categories_exceeded > 0) && (
          <div class="flex items-center gap-2">
            {categories_exceeded > 0 && (
              <Badge variant="error" size="lg" className="gap-1">
                <Icon name="warning" size="sm" />
                {categories_exceeded} exceeded
              </Badge>
            )}
            {categories_warning > 0 && (
              <Badge variant="warning" size="lg" className="gap-1">
                <Icon name="alert" size="sm" />
                {categories_warning} warning
              </Badge>
            )}
          </div>
        )
      }
    </div>
  </div>

  {/* Budget Table - Desktop View */}
  {
    categories.length > 0 ? (
      <div class="card bg-base-100 shadow border border-base-300 overflow-hidden">
        <div class="card-body p-0">
          {/* Table Header */}
          <div class="hidden lg:grid grid-cols-12 gap-4 px-6 py-4 bg-base-200 text-sm font-semibold text-neutral-600">
            <div class="col-span-1 text-center">#</div>
            <div class="col-span-3">
              <a
                href={buildSortUrl('category', sortBy, sortOrder, baseUrl)}
                class="flex items-center gap-1 hover:text-primary transition-colors cursor-pointer"
              >
                Category
                <span set:html={getSortIcon('category', sortBy, sortOrder)} />
              </a>
            </div>
            <div class="col-span-1 text-center">
              <a
                href={buildSortUrl('percentage', sortBy, sortOrder, baseUrl)}
                class="flex items-center justify-center gap-1 hover:text-primary transition-colors cursor-pointer"
              >
                %
                <span set:html={getSortIcon('percentage', sortBy, sortOrder)} />
              </a>
            </div>
            <div class="col-span-2 text-right">
              <a
                href={buildSortUrl('budget', sortBy, sortOrder, baseUrl)}
                class="flex items-center justify-end gap-1 hover:text-primary transition-colors cursor-pointer"
              >
                Budget
                <span set:html={getSortIcon('budget', sortBy, sortOrder)} />
              </a>
            </div>
            <div class="col-span-2 text-right">
              <a
                href={buildSortUrl('spent', sortBy, sortOrder, baseUrl)}
                class="flex items-center justify-end gap-1 hover:text-primary transition-colors cursor-pointer"
              >
                Expense
                <span set:html={getSortIcon('spent', sortBy, sortOrder)} />
              </a>
            </div>
            <div class="col-span-2 text-right">
              <a
                href={buildSortUrl('balance', sortBy, sortOrder, baseUrl)}
                class="flex items-center justify-end gap-1 hover:text-primary transition-colors cursor-pointer"
              >
                Balance
                <span set:html={getSortIcon('balance', sortBy, sortOrder)} />
              </a>
            </div>
            <div class="col-span-1" />
          </div>

          {/* Table Body */}
          <div class="divide-y divide-base-200">
            {sortedCategories.map((category, index) => {
              const budgetAmount = parseFloat(category.budget_amount);
              const spentAmount = parseFloat(category.spent_amount);
              const balance = parseFloat(category.balance);
              const percentageUsed = category.percentage_used;

              return (
                <div
                  class={`grid grid-cols-1 lg:grid-cols-12 gap-2 lg:gap-4 px-4 lg:px-6 py-4 hover:bg-base-100/50 transition-colors ${getRowBackgroundClass(
                    category.status
                  )}`}
                >
                  {/* Mobile View - Card Layout */}
                  <div class="lg:hidden col-span-full space-y-2">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-2">
                        <span class="text-sm font-medium text-neutral-500">{index + 1}.</span>
                        <span class="font-semibold">{category.category_name}</span>
                      </div>
                      <Badge variant={getStatusBadge(category.status)} size="sm">
                        {formatPercentage(percentageUsed)}
                      </Badge>
                    </div>

                    <div class="flex items-center justify-between text-sm">
                      <span class="text-neutral-500">Budget:</span>
                      <span class="font-medium">{formatCurrency(budgetAmount, currency)}</span>
                    </div>

                    <div class="flex items-center justify-between text-sm">
                      <span class="text-neutral-500">Spent:</span>
                      <span class="font-medium">{formatCurrency(spentAmount, currency)}</span>
                    </div>

                    <div class="flex items-center justify-between text-sm">
                      <span class="text-neutral-500">Balance:</span>
                      <span class={`font-medium ${getStatusColor(category.status)}`}>
                        {balance >= 0 ? '+' : '-'}
                        {formatCurrency(Math.abs(balance), currency)}
                      </span>
                    </div>

                    {/* Progress Bar - Mobile */}
                    <div class="pt-2">
                      <div class="w-full bg-base-300 rounded-full h-2 overflow-hidden">
                        <div
                          class={`h-full ${getProgressClass(percentageUsed)} transition-all duration-300`}
                          style={`width: ${Math.min(percentageUsed, 100)}%`}
                          role="progressbar"
                          aria-valuenow={percentageUsed}
                          aria-valuemin={0}
                          aria-valuemax={100}
                          aria-label={`${category.category_name}: ${formatPercentage(percentageUsed)} used`}
                        />
                      </div>
                    </div>
                  </div>

                  {/* Desktop View - Table Row */}
                  <div class="hidden lg:block col-span-1 text-center text-neutral-500">
                    {index + 1}
                  </div>
                  <div class="hidden lg:block col-span-3">
                    <div class="flex items-center gap-2">
                      <span class="font-medium">{category.category_name}</span>
                      {category.status !== 'ok' && (
                        <Badge variant={getStatusBadge(category.status)} size="sm">
                          {formatPercentage(percentageUsed)}
                        </Badge>
                      )}
                    </div>
                  </div>
                  <div class="hidden lg:block col-span-1 text-center">
                    {formatPercentage(parseFloat(category.percentage || '0'))}
                  </div>
                  <div class="hidden lg:block col-span-2 text-right font-medium">
                    {formatCurrency(budgetAmount, currency)}
                  </div>
                  <div class="hidden lg:block col-span-2 text-right">
                    {formatCurrency(spentAmount, currency)}
                  </div>
                  <div class="hidden lg:block col-span-2 text-right">
                    <span class={`font-semibold ${getStatusColor(category.status)}`}>
                      {balance >= 0 ? '+' : '-'}
                      {formatCurrency(Math.abs(balance), currency)}
                    </span>
                  </div>
                  <div class="hidden lg:block col-span-1">
                    <a
                      href={`/transactions?category_id=${category.category_id}`}
                      class="btn btn-ghost btn-xs btn-circle"
                      title={`View ${category.category_name} transactions`}
                    >
                      <Icon name="chevron-up" size="sm" className="rotate-90" />
                    </a>
                  </div>
                </div>
              );
            })}
          </div>

          {/* Totals Row */}
          <div class="mt-4 px-4 lg:px-6 py-4 bg-base-200 border-t-2 border-base-300">
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-2 lg:gap-4 items-center">
              {/* Mobile Totals */}
              <div class="lg:hidden space-y-2">
                <div class="flex items-center justify-between">
                  <span class="font-bold">Total Allocation</span>
                  <span
                    class={`font-bold ${totalPercentage > 100 ? 'text-error' : 'text-success'}`}
                  >
                    {formatPercentage(totalPercentage)}
                  </span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-neutral-600">Total Budget:</span>
                  <span class="font-semibold">
                    {formatCurrency(parseFloat(total_budget), currency)}
                  </span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-neutral-600">Total Spent:</span>
                  <span class="font-semibold">
                    {formatCurrency(parseFloat(total_spent), currency)}
                  </span>
                </div>
                <div class="flex items-center justify-between">
                  <span class="text-neutral-600">Total Balance:</span>
                  <span
                    class={`font-semibold ${parseFloat(total_balance) >= 0 ? 'text-success' : 'text-error'}`}
                  >
                    {parseFloat(total_balance) >= 0 ? '+' : '-'}
                    {formatCurrency(Math.abs(parseFloat(total_balance)), currency)}
                  </span>
                </div>
              </div>

              {/* Desktop Totals */}
              <div class="hidden lg:block col-span-1 text-center font-bold">Total</div>
              <div class="hidden lg:block col-span-3">
                <span class={`font-bold ${totalPercentage > 100 ? 'text-error' : 'text-success'}`}>
                  {totalPercentage > 100 && (
                    <Icon name="warning" size="sm" className="text-error inline mr-1" />
                  )}
                  {formatPercentage(totalPercentage)}
                </span>
                {totalPercentage > 100 && (
                  <span class="text-xs text-error block">Over-allocated budget</span>
                )}
              </div>
              <div class="hidden lg:block col-span-1 text-center font-bold">100%</div>
              <div class="hidden lg:block col-span-2 text-right font-bold">
                {formatCurrency(parseFloat(total_budget), currency)}
              </div>
              <div class="hidden lg:block col-span-2 text-right font-bold">
                {formatCurrency(parseFloat(total_spent), currency)}
              </div>
              <div
                class={`hidden lg:block col-span-2 text-right font-bold ${parseFloat(total_balance) >= 0 ? 'text-success' : 'text-error'}`}
              >
                {parseFloat(total_balance) >= 0 ? '+' : '-'}
                {formatCurrency(Math.abs(parseFloat(total_balance)), currency)}
              </div>
              <div class="hidden lg:block col-span-1" />
            </div>
          </div>
        </div>
      </div>
    ) : (
      // Empty state
      <div class="card bg-base-100 shadow border border-base-300">
        <div class="card-body">
          <EmptyState
            title="No budget categories found"
            message="Create categories and set budget amounts to track your spending."
            actionLabel="Manage Categories"
            actionHref="/settings/categories"
          />
        </div>
      </div>
    )
  }
</div>
