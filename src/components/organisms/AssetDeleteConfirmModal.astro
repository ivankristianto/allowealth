---
/**
 * AssetDeleteConfirmModal Component
 *
 * Modal for confirming asset deletion.
 * Based on the ConfirmationModal pattern.
 *
 * @param {string} id - Modal ID
 */

import ConfirmationModal from '../molecules/ConfirmationModal.astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div data-asset-delete-modal-container data-id={id} data-testid="asset-delete-modal">
  <ConfirmationModal
    id={id}
    title="Delete Asset"
    description="Are you sure you want to delete this asset?"
    confirmLabel="Delete Asset"
    confirmVariant="error"
    confirmLoadingLabel="Deleting..."
    iconVariant="error"
    confirmTestId="confirm-delete-btn"
  >
    <div slot="details" class="bg-base-200 rounded-2xl p-4" data-asset-details>
      <div class="flex items-center justify-between">
        <div>
          <p class="font-bold text-base-content" data-asset-name>Asset Name</p>
          <p class="text-xs text-base-content/50 mt-1" data-asset-type>Type</p>
        </div>
        <div class="text-right">
          <p class="font-bold" data-asset-balance>Balance</p>
          <span
            class="inline-block px-2 py-0.5 rounded-md text-[10px] font-bold tracking-wider uppercase bg-base-300 text-base-content/60"
            data-asset-currency
          >
            Currency
          </span>
        </div>
      </div>
    </div>

    <div slot="details" class="text-sm text-error/80 bg-error/5 p-3 rounded-xl">
      This action cannot be undone. All balance history for this asset will also be deleted.
    </div>
  </ConfirmationModal>
</div>

<script>
  import { addToast } from '@lib/stores/toastStore';
  import { formatCurrency } from '@/lib/formatting/currency-client';
  import { getCsrfHeaders } from '@/lib/csrf-client';
  import {
    clearConfirmError,
    closeConfirmationModal,
    getConfirmationModalElements,
    resetConfirmationModal,
    setConfirmLoading,
    showConfirmError,
  } from '@/components/molecules/ConfirmationModal.client';

  // Track initialized modals to avoid duplicate handlers
  const initializedModals = new WeakSet<Element>();

  interface AssetDeleteData {
    id: string;
    name: string;
    type: string;
    balance: number;
    currency: 'IDR' | 'USD';
  }

  function initAssetDeleteModal() {
    document.querySelectorAll('[data-asset-delete-modal-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedModals.has(container)) return;
      initializedModals.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const { modal, confirmButton, cancelButton, errorElement } = getConfirmationModalElements(
        container,
        id
      );

      // Detail elements
      const nameEl = container.querySelector('[data-asset-name]');
      const typeEl = container.querySelector('[data-asset-type]');
      const balanceEl = container.querySelector('[data-asset-balance]');
      const currencyEl = container.querySelector('[data-asset-currency]');

      if (!modal || !confirmButton) return;

      // Store current asset ID for deletion
      let currentAssetId: string | null = null;

      // Function to populate modal with asset data
      // SECURITY: Use textContent (not innerHTML) to prevent XSS from user data
      const populateModal = (data: AssetDeleteData) => {
        currentAssetId = data.id;
        if (nameEl) nameEl.textContent = data.name;
        if (typeEl) typeEl.textContent = data.type;
        if (balanceEl) {
          balanceEl.textContent = formatCurrency(data.balance, data.currency);
          // Apply currency color
          balanceEl.classList.remove('text-success', 'text-info');
          balanceEl.classList.add(data.currency === 'IDR' ? 'text-success' : 'text-info');
        }
        if (currencyEl) {
          currencyEl.textContent = data.currency;
          currencyEl.classList.remove('bg-success/10', 'text-success', 'bg-info/10', 'text-info');
          currencyEl.classList.add(
            data.currency === 'IDR' ? 'bg-success/10' : 'bg-info/10',
            data.currency === 'IDR' ? 'text-success' : 'text-info'
          );
        }
      };

      // Function to reset modal
      const resetModal = () => {
        currentAssetId = null;
        resetConfirmationModal(confirmButton, errorElement);
      };

      // Listen for open-asset-delete event
      const handleOpenDelete = ((e: CustomEvent<AssetDeleteData>) => {
        populateModal(e.detail);
        modal.showModal();
      }) as EventListener;

      document.addEventListener('open-asset-delete', handleOpenDelete);

      // Clean up event listener on Astro page transitions to prevent memory leaks
      document.addEventListener(
        'astro:before-swap',
        () => {
          document.removeEventListener('open-asset-delete', handleOpenDelete);
        },
        { once: true }
      );

      // Reset modal when closed (form method="dialog" triggers this)
      modal.addEventListener('close', resetModal);

      cancelButton?.addEventListener('click', () => {
        resetModal();
        closeConfirmationModal(modal);
      });

      // Handle confirm delete
      confirmButton.addEventListener('click', async () => {
        if (!currentAssetId) return;

        // Validate asset ID format (nanoid)
        const nanoidPattern = /^[A-Za-z0-9_-]{21}$/;
        if (!nanoidPattern.test(currentAssetId)) {
          showConfirmError(errorElement, 'Invalid asset ID format.');
          return;
        }

        // Clear previous errors
        clearConfirmError(errorElement);

        // Show loading state
        setConfirmLoading(confirmButton, true);

        try {
          const response = await fetch(`/api/assets/${currentAssetId}`, {
            method: 'DELETE',
            headers: getCsrfHeaders(),
          });

          if (!response.ok) {
            const errorData = await response.json();
            throw new Error(errorData.message || 'Failed to delete asset');
          }

          // Success
          addToast('Asset deleted successfully', 'success');
          closeConfirmationModal(modal);

          // Dispatch event for page update
          document.dispatchEvent(
            new CustomEvent('asset-deleted', {
              detail: { assetId: currentAssetId },
            })
          );

          // Reload page to show updated data
          setTimeout(() => window.location.reload(), 500);
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Failed to delete asset';
          showConfirmError(errorElement, message);
          addToast(message, 'error');
        } finally {
          setConfirmLoading(confirmButton, false);
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAssetDeleteModal);
  } else {
    initAssetDeleteModal();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAssetDeleteModal);
</script>
