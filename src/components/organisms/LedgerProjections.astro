---
/**
 * LedgerProjections Component
 *
 * Displays a detailed 120-month breakdown table showing forecast and real data
 * for wealth trajectory projections. Includes columns for period, forecast interest,
 * forecast balance, real interest, and real balance.
 *
 * @param {ForecastDataPoint[]} data - Array of monthly forecast data points
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import Card from '@/components/atoms/Card.astro';
import StatLabel from '@/components/atoms/StatLabel.astro';
import Skeleton from '@/components/atoms/Skeleton.astro';
import { formatCurrency } from '@/lib/formatting';
import type { Currency } from '@/lib/constants/currency';
import type { ForecastDataPoint } from '@/lib/forecast';

export interface Props {
  data: ForecastDataPoint[];
  currency?: Currency;
  loading?: boolean;
  error?: string;
  className?: string;
}

const { data = [], currency = 'IDR', loading = false, error, className = '' } = Astro.props;
---

<Card
  padding="sm"
  rounded="card-lg"
  className={`!p-0 ${className}`}
  role="region"
  aria-label="Ledger projections table"
>
  {/* Header */}
  <div class="p-6 md:p-8 border-b border-base-300">
    <h3 class="text-lg md:text-xl font-bold text-base-content tracking-tight leading-none">
      Ledger Projections
    </h3>
    <StatLabel size="sm" color="neutral" className="mt-1"> 120 MONTH DETAILED BREAKDOWN </StatLabel>
  </div>

  {/* Loading State */}
  {
    loading ? (
      <div class="p-6 md:p-8 space-y-3">
        {Array.from({ length: 10 }).map(() => (
          <div class="flex items-center justify-between gap-4 p-4 bg-base-200/30 rounded-xl">
            <Skeleton variant="text" width="80px" height="16px" />
            <Skeleton variant="text" width="100px" height="16px" />
            <Skeleton variant="text" width="100px" height="16px" />
            <Skeleton variant="text" width="80px" height="16px" />
            <Skeleton variant="text" width="80px" height="16px" />
          </div>
        ))}
      </div>
    ) : error ? (
      /* Error State */
      <div class="p-12 text-center">
        <p class="text-error font-medium" role="alert">
          {error}
        </p>
      </div>
    ) : data.length === 0 ? (
      /* Empty State */
      <div class="p-12 text-center">
        <p class="text-base-content/60 font-medium">No projection data available.</p>
      </div>
    ) : (
      /* Table with horizontal scroll on mobile */
      <div class="table-scroll-hint">
        <div class="overflow-x-auto">
          <table class="table w-full">
            <thead class="sticky top-0 bg-base-200/50 backdrop-blur-sm z-10">
              <tr class="border-b border-base-300">
                <th class="px-6 md:px-8 py-4 md:py-5 text-left">
                  <StatLabel size="sm" color="neutral">
                    {' '}
                    PERIOD{' '}
                  </StatLabel>
                </th>
                <th class="px-6 md:px-8 py-4 md:py-5 text-right">
                  <StatLabel size="sm" color="accent">
                    {' '}
                    FORECAST INTEREST{' '}
                  </StatLabel>
                </th>
                <th class="px-6 md:px-8 py-4 md:py-5 text-right">
                  <StatLabel size="sm" color="accent">
                    {' '}
                    FORECAST BALANCE{' '}
                  </StatLabel>
                </th>
                <th class="px-6 md:px-8 py-4 md:py-5 text-right">
                  <StatLabel size="sm" color="success">
                    {' '}
                    REAL INTEREST{' '}
                  </StatLabel>
                </th>
                <th class="px-6 md:px-8 py-4 md:py-5 text-right">
                  <StatLabel size="sm" color="success">
                    {' '}
                    REAL BALANCE{' '}
                  </StatLabel>
                </th>
              </tr>
            </thead>
            <tbody class="divide-y divide-base-300">
              {data.map((row) => (
                <tr class="group hover:bg-base-200/50 transition-colors">
                  {/* Period */}
                  <td class="px-6 md:px-8 py-3 md:py-4">
                    <span class="text-sm font-bold text-base-content">{row.dateLabel}</span>
                  </td>

                  {/* Forecast Interest */}
                  <td class="px-6 md:px-8 py-3 md:py-4 text-right">
                    <span class="text-sm font-medium text-base-content/60">
                      +{formatCurrency(row.forecastInterest, currency)}
                    </span>
                  </td>

                  {/* Forecast Balance */}
                  <td class="px-6 md:px-8 py-3 md:py-4 text-right">
                    <span class="text-sm font-bold text-accent">
                      {formatCurrency(row.forecastBalance, currency)}
                    </span>
                  </td>

                  {/* Real Interest */}
                  <td class="px-6 md:px-8 py-3 md:py-4 text-right">
                    <span class="text-sm font-medium text-base-content/40">
                      {row.realInterest !== null
                        ? `+${formatCurrency(row.realInterest, currency)}`
                        : '—'}
                    </span>
                  </td>

                  {/* Real Balance */}
                  <td class="px-6 md:px-8 py-3 md:py-4 text-right">
                    <span class="text-sm font-bold text-success">
                      {row.realBalance !== null ? formatCurrency(row.realBalance, currency) : '—'}
                    </span>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )
  }
</Card>

<style>
  /* Ensure sticky header works properly */
  thead {
    position: sticky;
    top: 0;
  }

  /* Improve table scrolling on mobile */
  .overflow-x-auto {
    -webkit-overflow-scrolling: touch;
  }

  /* Optional: Add subtle shadow to sticky header */
  thead::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    bottom: -1px;
    height: 1px;
    background: hsl(var(--bc) / 0.1);
  }
</style>
