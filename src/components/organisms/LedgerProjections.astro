---
/**
 * LedgerProjections Component
 *
 * Displays a yearly forecast ledger with expandable monthly child rows.
 *
 * @param {ForecastYearBreakdownRow[]} data - Array of yearly breakdown rows
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import Card from '@/components/atoms/Card.astro';
import StatLabel from '@/components/atoms/StatLabel.astro';
import Skeleton from '@/components/atoms/Skeleton.astro';
import { formatCurrency } from '@/lib/formatting';
import type { Currency } from '@/lib/constants/currency';
import type { ForecastYearBreakdownRow } from '@/lib/forecast';

export interface Props {
  data: ForecastYearBreakdownRow[];
  currency?: Currency;
  loading?: boolean;
  error?: string;
  className?: string;
}

const { data = [], currency = 'IDR', loading = false, error, className = '' } = Astro.props;

function formatValue(value: number | null, valueCurrency: Currency): string {
  return value === null ? '—' : formatCurrency(value, valueCurrency);
}

function formatSignedValue(value: number | null, valueCurrency: Currency): string {
  if (value === null) {
    return '—';
  }

  const prefix = value > 0 ? '+' : '';
  return `${prefix}${formatCurrency(value, valueCurrency)}`;
}
---

<Card
  padding="sm"
  rounded="card-lg"
  className={`!p-0 ${className}`}
  role="region"
  aria-label="Ledger projections table"
>
  <div class="p-6 md:p-8 border-b border-base-300">
    <h3 class="text-lg md:text-xl font-bold text-base-content tracking-tight leading-none">
      Ledger Projections
    </h3>
    <StatLabel size="sm" color="neutral" className="mt-1">YEARLY BREAKDOWN</StatLabel>
  </div>

  {
    loading ? (
      <div class="p-6 md:p-8 space-y-3">
        {Array.from({ length: 6 }).map(() => (
          <div class="flex items-center justify-between gap-4 p-4 bg-base-200/30 rounded-xl">
            <Skeleton variant="text" width="80px" height="16px" />
            <Skeleton variant="text" width="100px" height="16px" />
            <Skeleton variant="text" width="100px" height="16px" />
            <Skeleton variant="text" width="80px" height="16px" />
            <Skeleton variant="text" width="80px" height="16px" />
          </div>
        ))}
      </div>
    ) : error ? (
      <div class="p-12 text-center">
        <p class="text-error font-medium" role="alert">
          {error}
        </p>
      </div>
    ) : data.length === 0 ? (
      <div class="p-12 text-center">
        <p class="text-base-content/60 font-medium">
          Add account balance history to see your plan versus reality.
        </p>
      </div>
    ) : (
      <>
        <div class="table-scroll-hint">
          <div class="overflow-x-auto">
            <div class="min-w-[880px]">
              <div class="grid grid-cols-[1.5fr_repeat(4,minmax(0,1fr))] gap-4 px-6 md:px-8 py-4 md:py-5 border-b border-base-300 bg-base-200/50">
                <StatLabel size="sm" color="neutral">
                  PERIOD
                </StatLabel>
                <StatLabel size="sm" color="accent" className="text-right">
                  PLANNED ENDING BALANCE
                </StatLabel>
                <StatLabel size="sm" color="success" className="text-right">
                  ACTUAL ENDING BALANCE
                </StatLabel>
                <StatLabel size="sm" color="accent" className="text-right">
                  FORECAST INTEREST
                </StatLabel>
                <StatLabel size="sm" color="success" className="text-right">
                  ACTUAL NET SAVINGS
                </StatLabel>
              </div>

              <div class="divide-y divide-base-300">
                {data.map((row) => (
                  <details class="group" data-ledger-year-row>
                    <summary class="grid grid-cols-[1.5fr_repeat(4,minmax(0,1fr))] gap-4 px-6 md:px-8 py-4 md:py-5 cursor-pointer list-none hover:bg-base-200/40 transition-colors [&::-webkit-details-marker]:hidden">
                      <div class="flex items-center gap-3">
                        <span class="text-base-content/40 text-xs font-bold transition-transform group-open:rotate-90">
                          ▶
                        </span>
                        <div class="flex flex-col">
                          <span class="text-sm font-bold text-base-content">{row.yearLabel}</span>
                          <span class="text-xs text-base-content/50 uppercase tracking-widest">
                            {row.months.length} months
                          </span>
                        </div>
                      </div>
                      <div class="text-right text-sm font-bold text-accent">
                        {formatValue(row.plannedEndingBalance, currency)}
                      </div>
                      <div class="text-right text-sm font-bold text-success">
                        {formatValue(row.actualEndingBalance, currency)}
                      </div>
                      <div class="text-right text-sm font-medium text-accent">
                        {formatSignedValue(row.forecastInterestTotal, currency)}
                      </div>
                      <div class="text-right text-sm font-medium text-success">
                        {formatSignedValue(row.actualNetSavingsTotal, currency)}
                      </div>
                    </summary>

                    <div class="bg-base-200/20 border-t border-base-300/60">
                      {row.months.map((month) => (
                        <div
                          class="grid grid-cols-[1.5fr_repeat(4,minmax(0,1fr))] gap-4 px-6 md:px-8 py-3 md:py-4 text-sm"
                          data-ledger-month-row
                        >
                          <div class="font-medium text-base-content/70">{month.dateLabel}</div>
                          <div class="text-right font-medium text-base-content">
                            {formatValue(month.plannedBalance, currency)}
                          </div>
                          <div class="text-right font-medium text-base-content">
                            {formatValue(month.actualBalance, currency)}
                          </div>
                          <div class="text-right font-medium text-base-content/70">
                            {formatSignedValue(month.forecastInterest ?? 0, currency)}
                          </div>
                          <div class="text-right font-medium text-base-content/70">
                            {month.actualNetSavings === null
                              ? '—'
                              : formatSignedValue(month.actualNetSavings, currency)}
                          </div>
                        </div>
                      ))}
                    </div>
                  </details>
                ))}
              </div>
            </div>
          </div>
        </div>

        <table class="sr-only" aria-label="Ledger projections data table">
          <thead>
            <tr>
              <th>Period</th>
              <th>Planned Ending Balance</th>
              <th>Actual Ending Balance</th>
              <th>Forecast Interest</th>
              <th>Actual Net Savings</th>
            </tr>
          </thead>
          <tbody>
            {data.map((row) => (
              <>
                <tr>
                  <th scope="row">{`${row.yearLabel} summary`}</th>
                  <td>{formatValue(row.plannedEndingBalance, currency)}</td>
                  <td>{formatValue(row.actualEndingBalance, currency)}</td>
                  <td>{formatSignedValue(row.forecastInterestTotal, currency)}</td>
                  <td>{formatSignedValue(row.actualNetSavingsTotal, currency)}</td>
                </tr>
                {row.months.map((month) => (
                  <tr>
                    <th scope="row">{`${row.yearLabel} ${month.dateLabel}`}</th>
                    <td>{formatValue(month.plannedBalance, currency)}</td>
                    <td>{formatValue(month.actualBalance, currency)}</td>
                    <td>{formatSignedValue(month.forecastInterest ?? 0, currency)}</td>
                    <td>
                      {month.actualNetSavings === null
                        ? '—'
                        : formatSignedValue(month.actualNetSavings, currency)}
                    </td>
                  </tr>
                ))}
              </>
            ))}
          </tbody>
        </table>
      </>
    )
  }
</Card>
