---
/**
 * Transaction Drawer Component
 *
 * Provides a bulk entry interface for transactions using a side drawer.
 * Features tabs for toggling between expense and income, and a live list of added items.
 */

import Drawer from '../molecules/Drawer.astro';
import TransactionEntryForm from '../molecules/TransactionEntryForm.astro';
import { CircleMinus, CirclePlus, Inbox } from '@lucide/astro';
import type { Currency } from '@/lib/constants/currency';

export interface Props {
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  accounts: Array<{ id: string; name: string; type: string; account_class: string }>;
  categoryUsageCounts?: Array<{ category_id: string; count: number }>;
  activeCurrency?: Currency;
}

const { categories, accounts, categoryUsageCounts = [], activeCurrency } = Astro.props;
---

<Drawer id="transaction-drawer" title="Add Transaction" width="w-full sm:max-w-md">
  <!-- Tabs -->
  <div
    class="grid grid-cols-2 gap-1 p-1 bg-base-200 rounded-lg mb-5"
    role="tablist"
    aria-label="Transaction type"
  >
    <button
      id="drawer-tab-expense"
      type="button"
      class="btn btn-sm h-9 rounded-md border-none bg-white shadow-sm text-primary font-bold transition-all hover:bg-white flex gap-1.5 text-xs"
      data-tab="expense"
      role="tab"
      aria-selected="true"
      aria-controls="drawer-expense-form"
      tabindex="0"
    >
      <CircleMinus size={15} class="text-error" />
      <span>Expense</span>
    </button>
    <button
      id="drawer-tab-income"
      type="button"
      class="btn btn-sm h-9 rounded-md border-none bg-transparent text-base-content/60 font-medium hover:bg-base-300 transition-all flex gap-1.5 text-xs"
      data-tab="income"
      role="tab"
      aria-selected="false"
      aria-controls="drawer-income-form"
      tabindex="-1"
    >
      <CirclePlus size={15} class="text-success" />
      <span>Income</span>
    </button>
  </div>

  <!-- Forms -->
  <!-- Expense Form -->
  <div
    id="drawer-expense-form"
    class="block"
    role="tabpanel"
    aria-labelledby="drawer-tab-expense"
    aria-hidden="false"
  >
    <TransactionEntryForm
      type="expense"
      mode="create"
      action="/api/transactions"
      categories={categories}
      accounts={accounts}
      categoryUsageCounts={categoryUsageCounts}
      activeCurrency={activeCurrency}
      bulk={true}
      formId="drawer-form-expense"
    />
  </div>

  <!-- Income Form -->
  <div
    id="drawer-income-form"
    class="hidden"
    role="tabpanel"
    aria-labelledby="drawer-tab-income"
    aria-hidden="true"
  >
    <TransactionEntryForm
      type="income"
      mode="create"
      action="/api/transactions"
      categories={categories}
      accounts={accounts}
      categoryUsageCounts={categoryUsageCounts}
      activeCurrency={activeCurrency}
      bulk={true}
      formId="drawer-form-income"
    />
  </div>

  <!-- Recently Added Section -->
  <div class="mt-5 pt-4 border-t border-base-200" data-recent-section>
    <div class="flex items-center justify-between mb-2">
      <h3 class="font-semibold text-xs uppercase tracking-wider text-neutral">Just Added</h3>
      <span class="text-xs text-base-content/40 font-medium" id="session-summary">
        <span id="session-count">0</span> items
      </span>
    </div>

    <div
      id="empty-state-message"
      class="flex flex-col items-center justify-center py-4 text-base-content/30 gap-1.5 border border-dashed border-base-300/60 rounded-lg"
    >
      <Inbox size={22} class="stroke-current" />
      <span class="text-xs font-medium">No items yet</span>
    </div>

    <ul id="drawer-recent-list" class="space-y-1.5 hidden">
      <!-- Items will be injected here -->
    </ul>
  </div>
</Drawer>

<!-- Templates for dynamic list items -->
<template id="icon-expense">
  <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-error/10 text-error shrink-0">
    <CircleMinus size={16} class="stroke-current" aria-hidden="true" />
  </div>
</template>

<template id="icon-income">
  <div
    class="w-8 h-8 rounded-lg flex items-center justify-center bg-success/10 text-success shrink-0"
  >
    <CirclePlus size={16} class="stroke-current" aria-hidden="true" />
  </div>
</template>

<script>
  import './TransactionDrawer.client';
</script>
