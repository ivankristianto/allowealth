---
/**
 * Transaction Drawer Component
 *
 * Provides a bulk entry interface for transactions using a side drawer.
 * Features tabs for toggling between expense and income, and a live list of added items.
 */

import Drawer from '../molecules/Drawer.astro';
import TransactionEntryForm from '../molecules/TransactionEntryForm.astro';
import { CircleMinus, CirclePlus, Inbox } from '@lucide/astro';

export interface Props {
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  assets: Array<{ id: string; name: string; type: string }>;
}

const { categories, assets } = Astro.props;
---

<Drawer id="transaction-drawer" title="Bulk Transaction Entry" width="w-full sm:max-w-md">
  <!-- Tabs -->
  <div class="grid grid-cols-2 gap-2 p-1 bg-base-200 rounded-xl mb-6">
    <button
      type="button"
      class="btn btn-sm h-10 rounded-lg border-none bg-white shadow-sm text-primary font-bold transition-all hover:bg-white flex gap-2"
      data-tab="expense"
    >
      <CircleMinus size={18} class="text-error" />
      <span>Expense</span>
    </button>
    <button
      type="button"
      class="btn btn-sm h-10 rounded-lg border-none bg-transparent text-neutral font-medium hover:bg-base-300 transition-all flex gap-2"
      data-tab="income"
    >
      <CirclePlus size={18} class="text-success" />
      <span>Income</span>
    </button>
  </div>

  <!-- Forms -->
  <!-- Expense Form -->
  <div id="drawer-expense-form" class="block animate-in fade-in slide-in-from-right-4 duration-300">
    <TransactionEntryForm
      type="expense"
      mode="create"
      action="/api/transactions"
      categories={categories}
      assets={assets}
      bulk={true}
      formId="drawer-form-expense"
    />
  </div>

  <!-- Income Form -->
  <div id="drawer-income-form" class="hidden animate-in fade-in slide-in-from-right-4 duration-300">
    <TransactionEntryForm
      type="income"
      mode="create"
      action="/api/transactions"
      categories={categories}
      assets={assets}
      bulk={true}
      formId="drawer-form-income"
    />
  </div>

  <!-- Recently Added Section -->
  <div class="mt-8 pt-6 border-t border-base-200">
    <div class="flex items-center justify-between mb-4">
      <h3 class="font-bold text-xs uppercase tracking-wider text-neutral/70">
        Just Added in Session
      </h3>
      <span class="badge badge-sm badge-ghost font-mono" id="session-count">0</span>
    </div>

    <div
      id="empty-state-message"
      class="flex flex-col items-center justify-center py-8 text-neutral/40 gap-3 border-2 border-dashed border-base-200 rounded-xl"
    >
      <Inbox size={32} class="stroke-current opacity-50" />
      <span class="text-sm font-medium">No items added yet</span>
    </div>

    <ul id="drawer-recent-list" class="space-y-3 hidden">
      <!-- Items will be injected here -->
    </ul>
  </div>
</Drawer>

<!-- Templates for dynamic list items -->
<template id="icon-expense">
  <div
    class="w-10 h-10 rounded-xl flex items-center justify-center bg-error/10 text-error shrink-0"
  >
    <CircleMinus size={20} class="stroke-current" aria-hidden="true" />
  </div>
</template>

<template id="icon-income">
  <div
    class="w-10 h-10 rounded-xl flex items-center justify-center bg-success/10 text-success shrink-0"
  >
    <CirclePlus size={20} class="stroke-current" aria-hidden="true" />
  </div>
</template>

<script>
  import './TransactionDrawer.client';
</script>
