---
/**
 * CategoryDrillDownModal Component
 *
 * Modal for viewing detailed transactions and spending analysis for a category.
 * Shows transaction list, spending vs budget, and category insights.
 *
 * @param {string} id - Modal ID
 */

import Modal from '../molecules/Modal.astro';
import { TrendingUp, TrendingDown, TriangleAlert } from '@lucide/astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div data-category-drilldown-modal-container data-id={id}>
  <Modal id={id} size="xl" closable={false} backdropClose={true}>
    <div slot="default" class="flex flex-col gap-6">
      {/* Header with category info */}
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 rounded-2xl flex items-center justify-center" data-category-icon-bg>
            <span class="text-lg font-bold" data-category-icon>U</span>
          </div>
          <div>
            <h2
              class="text-2xl font-bold tracking-tight text-primary leading-none"
              data-category-name
            >
              Category Name
            </h2>
            <p
              class="text-neutral text-sm mt-2 font-medium uppercase tracking-widest"
              data-category-period
            >
              FEBRUARY 2024
            </p>
          </div>
        </div>

        <div class="flex flex-col items-start md:items-end">
          <p
            class="text-2xl md:text-3xl font-bold text-base-content tracking-tight"
            data-category-spent
          >
            Rp 0
          </p>
          <div
            class="flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest"
            data-budget-badge
          >
            <span class="hidden" data-alert-icon>
              <TriangleAlert size={12} class="stroke-current" aria-hidden="true" />
            </span>
            <span class="hidden" data-trending-up-icon>
              <TrendingUp size={12} class="stroke-current" aria-hidden="true" />
            </span>
            <span class="hidden" data-trending-down-icon>
              <TrendingDown size={12} class="stroke-current" aria-hidden="true" />
            </span>
            <span data-budget-text>NOT SET</span>
          </div>
        </div>
      </div>

      {/* Budget Progress Section */}
      <div class="bg-base-200/50 rounded-3xl p-6 border border-base-300/50">
        <div class="flex justify-between items-center mb-4">
          <h3 class="text-sm font-bold text-base-content/60 uppercase tracking-widest">
            Budget Overview
          </h3>
        </div>

        <div class="space-y-3">
          <div class="flex justify-between items-center text-sm">
            <span class="text-base-content/60">Spent</span>
            <span class="font-bold" data-spent-amount>Rp 0</span>
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="text-base-content/60">Budget Limit</span>
            <span class="font-bold" data-budget-limit>Not Set</span>
          </div>
          <div class="flex justify-between items-center text-sm">
            <span class="text-base-content/60">Remaining</span>
            <span class="font-bold" data-remaining-amount>-</span>
          </div>

          {/* Progress Bar */}
          <div class="w-full bg-base-300 rounded-full h-2 overflow-hidden" data-progress-container>
            <div
              class="h-full bg-accent transition-all duration-300"
              style="width: 0%"
              role="progressbar"
              aria-valuenow="0"
              aria-valuemin="0"
              aria-valuemax="100"
              data-progress-bar
            >
            </div>
          </div>
        </div>
      </div>

      {/* Transactions Section */}
      <div class="bg-base-200/50 rounded-3xl p-6 border border-base-300/50">
        <div class="flex justify-between items-center mb-6">
          <h3 class="text-sm font-bold text-base-content/60 uppercase tracking-widest">
            Transactions (<span data-transaction-count>0</span>)
          </h3>
        </div>

        {/* Loading state */}
        <div class="flex items-center justify-center py-8 hidden" data-transactions-loading>
          <div class="loading loading-spinner loading-lg text-accent"></div>
        </div>

        {/* Empty state */}
        <div
          class="flex flex-col items-center justify-center py-8 hidden"
          data-transactions-empty
          role="status"
          aria-live="polite"
        >
          <p class="text-base-content/50 text-sm">No transactions in this period</p>
        </div>

        {/* Transaction List */}
        <div class="space-y-3 hidden" data-transactions-list></div>
      </div>

      {/* Close button */}
      <div class="flex justify-end pt-2">
        <form method="dialog">
          <button
            type="submit"
            class="btn btn-outline btn-accent px-8 h-14 rounded-full font-bold text-base-content hover:bg-base-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent"
            data-close-drilldown
          >
            Close
          </button>
        </form>
      </div>
    </div>
  </Modal>
</div>

<script>
  import { formatCurrency } from '@/lib/tokens';

  // Track initialized modals to avoid duplicate handlers
  const initializedModals = new WeakSet<Element>();

  interface CategoryDrillDownData {
    categoryId: string;
    categoryName: string;
    categoryIcon?: string;
    categoryColor?: string;
    spent: number;
    budgetLimit?: number | null;
    period: string;
  }

  function initCategoryDrillDownModal() {
    document.querySelectorAll('[data-category-drilldown-modal-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedModals.has(container)) return;
      initializedModals.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const modal = document.getElementById(id) as HTMLDialogElement | null;
      if (!modal) return;

      // Header elements
      const categoryIconBg = container.querySelector('[data-category-icon-bg]') as HTMLElement;
      const categoryIcon = container.querySelector('[data-category-icon]');
      const categoryName = container.querySelector('[data-category-name]');
      const categoryPeriod = container.querySelector('[data-category-period]');
      const categorySpent = container.querySelector('[data-category-spent]');

      // Badge elements
      const budgetBadge = container.querySelector('[data-budget-badge]') as HTMLElement;
      const budgetText = container.querySelector('[data-budget-text]');
      const alertIcon = container.querySelector('[data-alert-icon]');
      const trendingUpIcon = container.querySelector('[data-trending-up-icon]');
      const trendingDownIcon = container.querySelector('[data-trending-down-icon]');

      // Budget overview elements
      const spentAmount = container.querySelector('[data-spent-amount]');
      const budgetLimit = container.querySelector('[data-budget-limit]');
      const remainingAmount = container.querySelector('[data-remaining-amount]');
      const progressBar = container.querySelector('[data-progress-bar]') as HTMLElement;

      // Transaction list elements
      const transactionsLoading = container.querySelector('[data-transactions-loading]');
      const transactionsEmpty = container.querySelector('[data-transactions-empty]');
      const transactionsList = container.querySelector('[data-transactions-list]');
      const transactionCount = container.querySelector('[data-transaction-count]');

      let currentData: CategoryDrillDownData | null = null;

      /**
       * Fetch category transactions HTML from backend API
       * @param categoryId - Category ID
       * @param period - Period string (YYYY-MM for monthly, YYYY for yearly)
       * @param range - Range type (monthly or yearly)
       * @returns Promise with HTML string and transaction count
       */
      async function fetchCategoryTransactionsHTML(
        categoryId: string,
        period: string,
        range: 'monthly' | 'yearly'
      ): Promise<{ html: string; count: number }> {
        const params = new URLSearchParams({ categoryId, period, range, _render: 'html' });
        const response = await fetch(`/api/reports/category-transactions?${params.toString()}`);

        if (!response.ok) {
          throw new Error(`Failed to fetch transactions: ${response.statusText}`);
        }

        const html = await response.text();

        // Parse HTML to count transactions
        // Create a temporary element to parse the HTML
        const temp = document.createElement('div');
        temp.innerHTML = html;
        const transactionCards = temp.querySelectorAll('[data-transaction-card]');
        const count = transactionCards.length;

        return {
          html,
          count,
        };
      }

      // Inject server-rendered transaction HTML into the modal
      const injectTransactionHTML = (html: string) => {
        if (!transactionsList) return;
        transactionsList.innerHTML = html;
      };

      // Update display with data
      // SECURITY: Use textContent (not innerHTML) to prevent XSS from user data in header
      // Transaction list HTML is server-rendered and already sanitized
      const updateDisplay = (data: CategoryDrillDownData, transactionHTML?: string) => {
        // Header
        if (categoryIcon) {
          categoryIcon.textContent = data.categoryIcon || data.categoryName.charAt(0).toUpperCase();
        }
        if (categoryIconBg) {
          categoryIconBg.className = `w-12 h-12 rounded-2xl flex items-center justify-center ${data.categoryColor || 'bg-primary/10'}`;
        }
        if (categoryName) categoryName.textContent = data.categoryName;
        if (categoryPeriod) categoryPeriod.textContent = data.period.toUpperCase();
        if (categorySpent) categorySpent.textContent = formatCurrency(data.spent, 'IDR');

        // Budget calculations
        const hasBudget = data.budgetLimit !== null && data.budgetLimit !== undefined;
        const percentage = hasBudget ? (data.spent / data.budgetLimit!) * 100 : 0;
        const remaining = hasBudget ? data.budgetLimit! - data.spent : 0;
        const isOverBudget = percentage > 100;

        // Budget badge
        if (budgetBadge && budgetText && alertIcon && trendingUpIcon && trendingDownIcon) {
          if (!hasBudget) {
            budgetBadge.className =
              'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-base-300 text-base-content/60';
            budgetText.textContent = 'NOT SET';
            alertIcon.classList.add('hidden');
            trendingUpIcon.classList.add('hidden');
            trendingDownIcon.classList.add('hidden');
          } else if (isOverBudget) {
            budgetBadge.className =
              'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-error/10 text-error';
            budgetText.textContent = `OVER BY ${percentage.toFixed(1)}%`;
            alertIcon.classList.remove('hidden');
            trendingUpIcon.classList.add('hidden');
            trendingDownIcon.classList.add('hidden');
          } else if (percentage >= 80) {
            budgetBadge.className =
              'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-warning/10 text-warning';
            budgetText.textContent = `${percentage.toFixed(1)}% USED`;
            alertIcon.classList.add('hidden');
            trendingUpIcon.classList.remove('hidden');
            trendingDownIcon.classList.add('hidden');
          } else {
            budgetBadge.className =
              'flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-[10px] font-bold uppercase tracking-widest bg-success/10 text-success';
            budgetText.textContent = `${percentage.toFixed(1)}% USED`;
            alertIcon.classList.add('hidden');
            trendingUpIcon.classList.add('hidden');
            trendingDownIcon.classList.remove('hidden');
          }
        }

        // Budget overview
        if (spentAmount) spentAmount.textContent = formatCurrency(data.spent, 'IDR');
        if (budgetLimit) {
          budgetLimit.textContent = hasBudget
            ? formatCurrency(data.budgetLimit!, 'IDR')
            : 'Not Set';
        }
        if (remainingAmount) {
          if (!hasBudget) {
            remainingAmount.textContent = '-';
            remainingAmount.className = 'font-bold text-base-content/60';
          } else {
            remainingAmount.textContent = formatCurrency(Math.abs(remaining), 'IDR');
            remainingAmount.className = `font-bold ${remaining >= 0 ? 'text-success' : 'text-error'}`;
          }
        }

        // Progress bar
        if (progressBar) {
          const progressPercent = Math.min(percentage, 100);
          progressBar.style.width = `${progressPercent}%`;
          progressBar.setAttribute('aria-valuenow', percentage.toFixed(1));
          progressBar.className = `h-full transition-all duration-300 ${
            isOverBudget ? 'bg-error' : percentage >= 80 ? 'bg-warning' : 'bg-success'
          }`;
        }

        // Transactions - inject server-rendered HTML
        if (transactionHTML) {
          if (transactionHTML.trim() === '' || transactionHTML.includes('No transactions')) {
            transactionsList?.classList.add('hidden');
            transactionsEmpty?.classList.remove('hidden');
            if (transactionCount) transactionCount.textContent = '0';
          } else {
            transactionsList?.classList.remove('hidden');
            transactionsEmpty?.classList.add('hidden');
            injectTransactionHTML(transactionHTML);

            // Count transactions from HTML
            const temp = document.createElement('div');
            temp.innerHTML = transactionHTML;
            const count = temp.querySelectorAll('[data-transaction-card]').length;
            if (transactionCount) transactionCount.textContent = String(count);
          }
        }

        transactionsLoading?.classList.add('hidden');
      };

      // Listen for open-category-drilldown event
      const handleOpenDrillDown = (async (e: CustomEvent<CategoryDrillDownData>) => {
        currentData = e.detail;

        // Show loading
        transactionsLoading?.classList.remove('hidden');
        transactionsList?.classList.add('hidden');
        transactionsEmpty?.classList.add('hidden');

        modal.showModal();

        // Fetch transaction HTML from backend
        let transactionHTML = '';
        try {
          // Determine range from period format (YYYY-MM = monthly, YYYY = yearly)
          const range = currentData.period.includes('-') ? 'monthly' : 'yearly';

          const data = await fetchCategoryTransactionsHTML(
            currentData.categoryId,
            currentData.period,
            range
          );

          transactionHTML = data.html;
        } catch (error) {
          console.error('Error fetching category transactions:', error);
          // Show error state
          transactionsLoading?.classList.add('hidden');
          transactionsEmpty?.classList.remove('hidden');
          if (transactionsList) transactionsList.innerHTML = '';
          return;
        }

        // Update display with fetched data
        if (currentData) {
          updateDisplay(currentData, transactionHTML);
        }
      }) as EventListener;

      document.addEventListener('open-category-drilldown', handleOpenDrillDown);

      // Clean up event listener on Astro page transitions to prevent memory leaks
      document.addEventListener(
        'astro:before-swap',
        () => {
          document.removeEventListener('open-category-drilldown', handleOpenDrillDown);
        },
        { once: true }
      );

      // Reset data when modal closes
      modal.addEventListener('close', () => {
        currentData = null;
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCategoryDrillDownModal);
  } else {
    initCategoryDrillDownModal();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initCategoryDrillDownModal);
</script>
