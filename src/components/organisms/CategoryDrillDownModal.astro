---
/**
 * CategoryDrillDownModal Component
 *
 * Modal for viewing detailed transactions and spending analysis for a category.
 * Fetches server-rendered HTML content from the API (following Interactive Pages Architecture).
 *
 * @param {string} id - Modal ID
 */

import Modal from '../molecules/Modal.astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div data-category-drilldown-modal-container data-id={id}>
  <Modal id={id} size="xl" closable={false} backdropClose={true}>
    <div slot="default" class="flex flex-col gap-6">
      {/* Loading state */}
      <div class="flex items-center justify-center py-8" data-modal-loading>
        <div class="loading loading-spinner loading-lg text-accent"></div>
      </div>

      {/* Content container - will be populated with server-rendered HTML */}
      <div data-drilldown-content class="hidden"></div>
    </div>
  </Modal>
</div>

<script>
  import { initTransactionHistory } from '../molecules/TransactionHistory.client';
  import { getOrderedCategories } from './BudgetCategoryNav.client';
  import { csrfFetch } from '@/lib/csrf-client';
  import { replaceWithSanitizedHtml } from '@/lib/dom/sanitize-fragment';
  initTransactionHistory();

  const initializedModals = new WeakSet<Element>();

  interface CategoryDrillDownData {
    categoryId: string;
    categoryName: string;
    categoryIcon?: string;
    categoryColor?: string;
    spent: number;
    budgetLimit?: number | null;
    period: string;
    currency: string;
  }

  function initCategoryDrillDownModal() {
    document.querySelectorAll('[data-category-drilldown-modal-container]').forEach((container) => {
      if (initializedModals.has(container)) return;
      initializedModals.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const modal = document.getElementById(id) as HTMLDialogElement | null;
      if (!modal) return;

      const loadingContainer = container.querySelector('[data-modal-loading]');
      const contentContainer = container.querySelector('[data-drilldown-content]');

      let currentData: CategoryDrillDownData | null = null;
      let activeFetchController: AbortController | null = null;
      let currentLimit = 100;
      let currentOffset = 0;
      let currentHasMore = false;

      async function fetchDrilldownHTML(
        data: CategoryDrillDownData,
        pagination: { limit: number; offset: number },
        signal?: AbortSignal
      ): Promise<string> {
        const range = data.period.includes('-') ? 'monthly' : 'yearly';
        const params = new URLSearchParams({
          categoryId: data.categoryId,
          categoryName: data.categoryName,
          categoryIcon: data.categoryIcon || 'tag',
          categoryColor: data.categoryColor || 'bg-base-300',
          spent: String(data.spent),
          period: data.period,
          range,
          currency: data.currency,
          limit: String(pagination.limit),
          offset: String(pagination.offset),
          _render: 'html',
        });
        if (data.budgetLimit !== null && data.budgetLimit !== undefined) {
          params.set('budgetLimit', String(data.budgetLimit));
        }
        const response = await csrfFetch(`/api/reports/category-drilldown?${params.toString()}`, {
          signal,
        });
        if (!response.ok) {
          throw new Error(`Failed to fetch drilldown content: ${response.statusText}`);
        }
        return await response.text();
      }

      function syncPaginationStateFromContent() {
        const root = contentContainer?.querySelector('[data-category-drilldown-content]');
        if (!root) {
          currentHasMore = false;
          return;
        }

        const offsetAttr = root.getAttribute('data-drilldown-offset');
        const limitAttr = root.getAttribute('data-drilldown-limit');
        const hasMoreAttr = root.getAttribute('data-drilldown-has-more');

        currentOffset = offsetAttr ? Number.parseInt(offsetAttr, 10) || 0 : currentOffset;
        currentLimit = limitAttr ? Number.parseInt(limitAttr, 10) || currentLimit : currentLimit;
        currentHasMore = hasMoreAttr === 'true';
      }

      /**
       * Navigate to adjacent category in the modal
       */
      function navigateToCategory(direction: 'prev' | 'next'): void {
        if (!currentData) return;
        const categories = getOrderedCategories();
        const currentIndex = categories.findIndex((c) => c.categoryId === currentData!.categoryId);
        if (currentIndex === -1) return;

        const targetIndex = direction === 'prev' ? currentIndex - 1 : currentIndex + 1;
        if (targetIndex < 0 || targetIndex >= categories.length) return;

        const target = categories[targetIndex];
        document.dispatchEvent(
          new CustomEvent('open-category-drilldown', {
            detail: {
              categoryId: target.categoryId,
              categoryName: target.categoryName,
              categoryIcon: target.categoryIcon,
              categoryColor: '', // Drilldown API defaults to bg-base-300; hex from cards is not compatible
              spent: target.spent,
              budgetLimit: target.budgetLimit ?? null,
              period: target.period,
              currency: currentData.currency,
            },
          })
        );
      }

      /**
       * Inject prev/next nav buttons into content
       */
      function injectNavButtons(): void {
        if (!contentContainer || !currentData) return;
        const categories = getOrderedCategories();
        const currentIndex = categories.findIndex((c) => c.categoryId === currentData!.categoryId);
        if (currentIndex === -1) return;

        const hasPrev = currentIndex > 0;
        const hasNext = currentIndex < categories.length - 1;

        // Only add nav if there are multiple categories
        if (categories.length <= 1) return;

        // Inject nav as direct child of modal-box for reliable sticky positioning.
        // modal-box is the scroll container; sticky bottom-0 keeps nav visible during scroll.
        const modalBox = modal.querySelector('.modal-box');
        if (!modalBox) return;

        const navHtml = `
          <div class="sticky bottom-0 z-10 -mx-6 -mb-6 px-6 pb-4 pt-3 border-t border-base-300 bg-base-100/90 backdrop-blur-sm" data-modal-nav>
            <div class="flex justify-between items-center">
              <button
                type="button"
                class="btn btn-ghost rounded-2xl font-bold gap-2 ${hasPrev ? '' : 'invisible'}"
                data-nav-prev
                aria-label="Previous category"
              >
                ← Prev
              </button>
              <span class="text-xs text-base-content/40 font-bold">
                ${currentIndex + 1} / ${categories.length}
              </span>
              <button
                type="button"
                class="btn btn-ghost rounded-2xl font-bold gap-2 ${hasNext ? '' : 'invisible'}"
                data-nav-next
                aria-label="Next category"
              >
                Next →
              </button>
            </div>
          </div>
        `;

        // Remove existing nav if any (from modal-box, not contentContainer)
        modalBox.querySelector('[data-modal-nav]')?.remove();
        modalBox.insertAdjacentHTML('beforeend', navHtml);

        // Attach click handlers
        modalBox
          .querySelector('[data-nav-prev]')
          ?.addEventListener('click', () => navigateToCategory('prev'));
        modalBox
          .querySelector('[data-nav-next]')
          ?.addEventListener('click', () => navigateToCategory('next'));
      }

      const handleOpenDrillDown = (async (e: CustomEvent<CategoryDrillDownData>) => {
        currentData = e.detail;
        currentLimit = 100;
        currentOffset = 0;
        currentHasMore = false;

        // Abort any in-flight fetch to prevent stale content from overwriting
        activeFetchController?.abort();
        const controller = new AbortController();
        activeFetchController = controller;

        loadingContainer?.classList.remove('hidden');
        contentContainer?.classList.add('hidden');
        if (!modal.open) modal.showModal();

        try {
          const html = await fetchDrilldownHTML(
            currentData,
            { limit: currentLimit, offset: currentOffset },
            controller.signal
          );
          // Guard: if aborted between fetch and render, skip DOM update
          if (controller.signal.aborted) return;
          if (contentContainer) {
            replaceWithSanitizedHtml(contentContainer, html);
          }
          loadingContainer?.classList.add('hidden');
          contentContainer?.classList.remove('hidden');
          syncPaginationStateFromContent();
          injectNavButtons();
        } catch (error) {
          // Silently ignore aborted requests — a newer navigation superseded this one
          if (error instanceof DOMException && error.name === 'AbortError') return;
          console.error('Error fetching category drilldown:', error);
          if (contentContainer) {
            contentContainer.innerHTML = `
              <div class="flex flex-col items-center justify-center py-12 text-center">
                <p class="text-error text-base font-semibold mb-2">Failed to load category details</p>
                <p class="text-base-content/60 text-sm mb-4">Please try again later</p>
                <form method="dialog">
                  <button type="submit" class="btn btn-outline btn-accent rounded-2xl">Close</button>
                </form>
              </div>
            `;
          }
          loadingContainer?.classList.add('hidden');
          contentContainer?.classList.remove('hidden');
        }
      }) as EventListener;

      const handlePageChange = (async (e: Event) => {
        const target = e.target as Element | null;
        const button = target?.closest('[data-drilldown-page]') as HTMLButtonElement | null;
        if (!button || !currentData) return;
        e.preventDefault();

        const action = button.getAttribute('data-drilldown-page');
        if (!action) return;

        if (action === 'prev' && currentOffset <= 0) return;
        if (action === 'next' && !currentHasMore) return;

        const nextOffset =
          action === 'next'
            ? currentOffset + currentLimit
            : Math.max(0, currentOffset - currentLimit);

        activeFetchController?.abort();
        const controller = new AbortController();
        activeFetchController = controller;

        loadingContainer?.classList.remove('hidden');
        contentContainer?.classList.add('hidden');

        try {
          const html = await fetchDrilldownHTML(
            currentData,
            { limit: currentLimit, offset: nextOffset },
            controller.signal
          );
          if (controller.signal.aborted) return;
          if (contentContainer) {
            replaceWithSanitizedHtml(contentContainer, html);
          }
          loadingContainer?.classList.add('hidden');
          contentContainer?.classList.remove('hidden');
          syncPaginationStateFromContent();
          injectNavButtons();
        } catch (error) {
          if (error instanceof DOMException && error.name === 'AbortError') return;
          console.error('Error paginating category drilldown:', error);
          loadingContainer?.classList.add('hidden');
          contentContainer?.classList.remove('hidden');
        }
      }) as EventListener;

      // Keyboard navigation
      function handleKeyDown(e: KeyboardEvent): void {
        if (!modal.open) return;
        // Don't hijack arrow keys when user is focused on form elements
        const tag = document.activeElement?.tagName?.toLowerCase();
        if (tag === 'input' || tag === 'textarea' || tag === 'select') return;
        if (e.key === 'ArrowLeft') {
          e.preventDefault();
          navigateToCategory('prev');
        } else if (e.key === 'ArrowRight') {
          e.preventDefault();
          navigateToCategory('next');
        }
      }

      document.addEventListener('open-category-drilldown', handleOpenDrillDown);
      document.addEventListener('keydown', handleKeyDown);
      contentContainer?.addEventListener('click', handlePageChange);

      document.addEventListener(
        'astro:before-swap',
        () => {
          document.removeEventListener('open-category-drilldown', handleOpenDrillDown);
          document.removeEventListener('keydown', handleKeyDown);
          contentContainer?.removeEventListener('click', handlePageChange);
        },
        { once: true }
      );

      modal.addEventListener('close', () => {
        currentData = null;
        activeFetchController?.abort();
        activeFetchController = null;
        if (contentContainer) {
          contentContainer.innerHTML = '';
        }
        // Clean up nav from modal-box (it's injected outside contentContainer)
        modal.querySelector('[data-modal-nav]')?.remove();
      });
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCategoryDrillDownModal);
  } else {
    initCategoryDrillDownModal();
  }
  document.addEventListener('astro:page-load', initCategoryDrillDownModal);
</script>
