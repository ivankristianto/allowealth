---
/**
 * BudgetSummary Component
 *
 * Overview section showing total budget allocation, aggregate spending,
 * surplus/deficit status, and allocation mix distribution bar.
 *
 * Part of the Budget page redesign.
 *
 * @param {number} totalAllocated - Total monthly budget pot
 * @param {number} totalSpent - Aggregate spending amount
 * @param {Array} distribution - Category distribution for allocation bar
 * @param {string} currency - Currency code (IDR or USD)
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} className - Additional CSS classes
 */

// Internal aliases - lib
import { formatCurrency } from '@/lib/formatting';
import { getBudgetStatus, sanitizeColor } from '@/lib/utils/budget';
import {
  COPY_BUDGET_TO_NEXT_MONTH_LABEL,
  getRemainingBudgetMetric,
} from '@/lib/utils/budget-summary';

// Internal aliases - components
import StatLabel from '@components/atoms/StatLabel.astro';
import Skeleton from '@components/atoms/Skeleton.astro';
import AllocationBar from '@components/molecules/AllocationBar.astro';

// P2: TODO - Consider importing AllocationDistribution type from budget utils
// and aligning with DistributionItem interface
export interface DistributionItem {
  name: string;
  weight: number;
  color: string;
}

// Maximum number of individual categories to show before grouping the rest as "Others"
const MAX_LEGEND_ITEMS = 7;
const OTHERS_COLOR = '#9ca3af'; // gray-400 for "Others" category

export interface Props {
  totalAllocated: number;
  totalSpent: number;
  distribution: DistributionItem[];
  currency?: 'IDR' | 'USD';
  showCopyButton?: boolean;
  loading?: boolean;
  className?: string;
}

const {
  totalAllocated,
  totalSpent,
  distribution,
  currency = 'IDR',
  showCopyButton = false,
  loading = false,
  className = '',
} = Astro.props;

// Calculate derived values
const overallUsage = totalAllocated > 0 ? (totalSpent / totalAllocated) * 100 : 0;
const usageStatus = getBudgetStatus(overallUsage);
const remainingMetric = getRemainingBudgetMetric(totalAllocated, totalSpent);
const spentAmountColorClass =
  remainingMetric.tone === 'error'
    ? 'text-error'
    : usageStatus.status === 'warning'
      ? 'text-warning'
      : 'text-base-content';

// Sort distribution by weight (largest first)
const sortedDistribution = [...distribution].sort((a, b) => b.weight - a.weight);

// Take top N for legend display, combine rest as "Others"
const topCategories = sortedDistribution.slice(0, MAX_LEGEND_ITEMS);
const remainingCategories = sortedDistribution.slice(MAX_LEGEND_ITEMS);
const othersWeight = remainingCategories.reduce((sum, item) => sum + item.weight, 0);

// Build display distribution with "Others" if there are remaining categories
const displayDistribution: DistributionItem[] =
  othersWeight > 0
    ? [...topCategories, { name: 'Others', weight: othersWeight, color: OTHERS_COLOR }]
    : topCategories;

// Generate accessible description for screen readers (P1: Accessibility fix)
const allocationDescription = sortedDistribution
  .map((item) => `${item.name} ${item.weight.toFixed(1)}%`)
  .join(', ');

const cardClasses = [
  // Base card styling
  'bg-base-100 rounded-card border border-base-300',
  // Premium shadow
  'shadow-sm',
  // Padding - responsive
  'p-6 @3xl:p-10',
  // Relative for overflow
  'relative overflow-hidden',
  // Additional classes
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class="@container">
  {
    loading ? (
      <section class={cardClasses} aria-busy="true" aria-label="Loading budget summary">
        <div class="grid grid-cols-1 @5xl:grid-cols-12 gap-8 @5xl:gap-10">
          {/* Left: Key Metrics Skeleton */}
          <div class="@5xl:col-span-4 flex flex-col justify-center gap-6 @5xl:gap-8">
            <div class="flex flex-col gap-6">
              <div>
                <Skeleton variant="text" width="120px" height="12px" />
                <Skeleton variant="text" width="180px" height="32px" className="mt-3" />
              </div>
              <div>
                <Skeleton variant="text" width="140px" height="12px" />
                <div class="flex items-baseline gap-2 mt-3">
                  <Skeleton variant="text" width="160px" height="32px" />
                  <Skeleton variant="text" width="50px" height="16px" />
                </div>
              </div>
            </div>
            <Skeleton variant="rectangular" width="100%" height="56px" className="rounded-2xl" />
          </div>

          {/* Right: Allocation Bar Skeleton */}
          <div class="@5xl:col-span-8 flex flex-col justify-center gap-6 @5xl:gap-8">
            <div class="flex justify-between items-end mb-2">
              <Skeleton variant="text" width="120px" height="20px" />
              <Skeleton variant="text" width="160px" height="12px" />
            </div>
            <Skeleton variant="rectangular" width="100%" height="24px" className="rounded-full" />
            {/* Legend skeleton - up to 8 items (7 categories + Others) */}
            <div class="grid grid-cols-2 @sm:grid-cols-3 @5xl:grid-cols-4 gap-3 @5xl:gap-4">
              {Array(8)
                .fill(0)
                .map(() => (
                  <div class="flex flex-col gap-1.5">
                    <div class="flex items-center gap-2">
                      <Skeleton variant="circular" width="8px" height="8px" />
                      <Skeleton variant="text" width="60px" height="10px" />
                    </div>
                    <Skeleton variant="text" width="40px" height="12px" className="ml-4" />
                  </div>
                ))}
            </div>
          </div>
        </div>
      </section>
    ) : (
      <section class={cardClasses} aria-label="Budget overview summary">
        <div class="grid grid-cols-1 @5xl:grid-cols-12 gap-8 @5xl:gap-10 relative z-10">
          {/* Left: Key Metrics */}
          <div class="@5xl:col-span-4 flex flex-col justify-center gap-6 @5xl:gap-8">
            <div class="flex flex-col gap-6">
              {/* Total Monthly Pot */}
              <div>
                <StatLabel size="sm" className="uppercase tracking-widest">
                  Allocated Budget
                </StatLabel>
                <p class="text-2xl @3xl:text-3xl font-bold mt-2 @3xl:mt-3 text-base-content tracking-tight leading-none">
                  {formatCurrency(totalAllocated, currency)}
                </p>
              </div>

              {/* Aggregate Spending */}
              <div>
                <StatLabel size="sm" color="warning" className="uppercase tracking-widest">
                  Total Budget Spent
                </StatLabel>
                <div class="flex items-baseline gap-2 mt-2 @3xl:mt-3">
                  <p
                    class:list={[
                      'text-2xl @3xl:text-3xl font-bold tracking-tight leading-none',
                      spentAmountColorClass,
                    ]}
                  >
                    {formatCurrency(totalSpent, currency)}
                  </p>
                  <span class="text-xs font-bold text-base-content/40">
                    / {overallUsage.toFixed(1)}%
                  </span>
                </div>
              </div>

              {/* Remaining / Overbudget */}
              <div>
                <StatLabel
                  size="sm"
                  color={remainingMetric.tone === 'error' ? 'error' : 'success'}
                  className="uppercase tracking-widest"
                >
                  {remainingMetric.label}
                </StatLabel>
                <p
                  class:list={[
                    'text-2xl @3xl:text-3xl font-bold mt-2 @3xl:mt-3 tracking-tight leading-none',
                    remainingMetric.tone === 'error' ? 'text-error' : 'text-success',
                  ]}
                >
                  {formatCurrency(remainingMetric.value, currency)}
                </p>
              </div>
            </div>
          </div>

          {/* Right: Budget Allocations — collapsed on mobile/tablet, open on wide desktop */}
          <details class="@5xl:col-span-8" data-budget-allocations>
            <summary class="flex justify-between items-center cursor-pointer list-none @5xl:pointer-events-none select-none mb-6 @5xl:mb-8 [&::-webkit-details-marker]:hidden">
              <h3 class="font-bold text-base-content tracking-tight text-base @5xl:text-lg leading-none">
                Budget Allocations
              </h3>
              <span class="text-base-content/40 text-xs font-bold uppercase tracking-widest @5xl:hidden">
                Tap to expand
              </span>
              <StatLabel size="sm" className="uppercase tracking-widest hidden @5xl:block">
                Total Share Distribution
              </StatLabel>
            </summary>

            <div class="flex flex-col gap-6 @5xl:gap-8">
              {/* Stacked Bar - P0: Colors sanitized, P1: Accessible description */}
              {/* Uses displayDistribution to match legend (top 7 + Others) */}
              <AllocationBar
                segments={displayDistribution.map((item) => ({
                  label: item.name,
                  percentage: item.weight,
                  color: item.color,
                }))}
                height="md"
                ariaLabel={`Budget allocation: ${allocationDescription}`}
              />

              {/* Legend - P0: Colors sanitized, shows top 7 + Others */}
              <div class="grid grid-cols-2 @sm:grid-cols-3 @5xl:grid-cols-4 gap-3 @5xl:gap-4">
                {displayDistribution.map((item) => {
                  return (
                    <div class="flex flex-col gap-1">
                      <div class="flex items-center gap-2">
                        <div
                          class="w-2 h-2 rounded-full shrink-0"
                          style={`background-color: ${sanitizeColor(item.color)};`}
                          aria-hidden="true"
                        />
                        <span class="text-xs font-bold text-base-content/60 uppercase tracking-tight truncate">
                          {item.name}
                        </span>
                      </div>
                      <p class="text-xs font-bold text-base-content leading-none ml-4">
                        {item.weight.toFixed(1)}%
                      </p>
                    </div>
                  );
                })}
              </div>
            </div>
          </details>
        </div>

        {showCopyButton && (
          <div class="mt-5 flex justify-end">
            <button
              type="button"
              class="btn btn-sm min-h-[44px] rounded-xl border border-base-300 bg-base-100 px-4 text-xs font-semibold text-base-content/70 hover:border-accent/30 hover:text-accent"
              data-budget-summary-copy-btn
              data-target-modal="copy-budget-modal"
              aria-label={COPY_BUDGET_TO_NEXT_MONTH_LABEL}
            >
              {COPY_BUDGET_TO_NEXT_MONTH_LABEL}
            </button>
          </div>
        )}
      </section>
    )
  }
</div>

<script>
  const initializedDetails = new WeakSet<Element>();
  const detailsObservers = new Map<Element, ResizeObserver>();
  const copyButtonHandlers = new WeakMap<HTMLElement, (event: Event) => void>();

  function initBudgetAllocations() {
    document
      .querySelectorAll<HTMLDetailsElement>('[data-budget-allocations]')
      .forEach((details) => {
        if (initializedDetails.has(details)) return;
        initializedDetails.add(details);

        // Observe the @container wrapper (parent of section) for its content width
        const section = details.closest('section');
        const container = section?.parentElement;
        if (!container) return;

        // Open by default when container is wide enough (@5xl = 1024px)
        const WIDE_THRESHOLD = 1024;

        const observer = new ResizeObserver((entries) => {
          for (const entry of entries) {
            details.open = entry.contentRect.width >= WIDE_THRESHOLD;
          }
        });

        observer.observe(container);
        detailsObservers.set(details, observer);
      });
  }

  function cleanupBudgetAllocations() {
    detailsObservers.forEach((observer) => observer.disconnect());
    detailsObservers.clear();
  }

  function initBudgetSummaryCopyButtons() {
    document.querySelectorAll<HTMLElement>('[data-budget-summary-copy-btn]').forEach((button) => {
      if (copyButtonHandlers.has(button)) return;

      const handler = (event: Event) => {
        event.preventDefault();
        event.stopPropagation();

        const targetId = button.getAttribute('data-target-modal');
        if (!targetId) return;

        const modal = document.getElementById(targetId) as HTMLDialogElement | null;
        if (modal) modal.showModal();
      };

      copyButtonHandlers.set(button, handler);
      button.addEventListener('click', handler);
    });
  }

  function cleanupBudgetSummaryCopyButtons() {
    document.querySelectorAll<HTMLElement>('[data-budget-summary-copy-btn]').forEach((button) => {
      const handler = copyButtonHandlers.get(button);
      if (!handler) return;
      button.removeEventListener('click', handler);
      copyButtonHandlers.delete(button);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
      initBudgetAllocations();
      initBudgetSummaryCopyButtons();
    });
  } else {
    initBudgetAllocations();
    initBudgetSummaryCopyButtons();
  }

  document.addEventListener('astro:before-swap', () => {
    cleanupBudgetAllocations();
    cleanupBudgetSummaryCopyButtons();
  });
  document.addEventListener('astro:page-load', () => {
    initBudgetAllocations();
    initBudgetSummaryCopyButtons();
  });
</script>
