---
/**
 * AccountHistoryModal Component
 *
 * Modal for viewing account performance history with an area chart.
 * Shows balance trends over 7 or 30 days with percentage change.
 *
 * Based on the Global Accounts PoC design.
 *
 * @param {string} id - Modal ID
 */

import Modal from '../molecules/Modal.astro';
import { TrendingUp, ArrowUp, ArrowDown } from '@lucide/astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div data-account-history-modal-container data-id={id}>
  <Modal id={id} size="xl" closable={false} backdropClose={true}>
    <div slot="default" class="flex flex-col gap-6">
      {/* Header with account info */}
      <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div class="flex items-center gap-4">
          <div
            class="w-12 h-12 rounded-2xl flex items-center justify-center bg-accent/10 text-accent"
          >
            <TrendingUp size={24} class="stroke-current" aria-hidden="true" />
          </div>
          <div>
            <h2
              class="text-2xl font-bold tracking-tight text-primary leading-none"
              data-account-name
            >
              Account Name
            </h2>
            <p
              class="text-base-content/60 text-sm mt-2 font-medium uppercase tracking-widest"
              data-account-meta
            >
              TYPE • CURRENCY Accounts
            </p>
          </div>
        </div>

        <div class="flex flex-col items-start md:items-end">
          <p
            class="text-2xl md:text-3xl font-bold text-base-content tracking-tight"
            data-current-balance
          >
            Rp 0
          </p>
          <div
            class="flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest"
            data-change-badge
          >
            <span class="hidden" data-arrow-up>
              <ArrowUp size={12} class="stroke-current" aria-hidden="true" />
            </span>
            <span class="hidden" data-arrow-down>
              <ArrowDown size={12} class="stroke-current" aria-hidden="true" />
            </span>
            <span data-change-text>0% (monthly)</span>
          </div>
        </div>
      </div>

      {/* Chart section */}
      <div class="bg-base-200/50 rounded-card p-6 md:p-8 border border-base-300/50">
        {/* Chart header */}
        <div class="flex justify-between items-center mb-8">
          <h3 class="text-sm font-bold text-neutral uppercase tracking-widest">
            Performance History
          </h3>
          <div class="flex bg-base-100 p-1 rounded-xl shadow-sm border border-base-300/50">
            <button
              type="button"
              class="px-4 py-2 text-xs font-bold rounded-lg uppercase tracking-widest transition-all text-base-content/50"
              data-timeframe="weekly"
            >
              7 Days
            </button>
            <button
              type="button"
              class="px-4 py-2 text-xs font-bold rounded-lg uppercase tracking-widest transition-all bg-accent text-white shadow-sm"
              data-timeframe="monthly"
            >
              30 Days
            </button>
          </div>
        </div>

        {/* Chart container */}
        <div class="relative h-[250px] md:h-[300px] w-full" data-chart-container>
          {/* Loading state */}
          <div class="absolute inset-0 flex items-center justify-center" data-chart-loading>
            <div class="loading loading-spinner loading-lg text-accent"></div>
          </div>

          {/* Empty state */}
          <div
            class="absolute inset-0 flex flex-col items-center justify-center hidden"
            data-chart-empty
            role="status"
            aria-live="polite"
          >
            <p class="text-base-content/50 text-sm">No history data available</p>
          </div>

          {/* SVG Chart */}
          {
            /* P2: TODO - Hardcoded accent color #15803d should use CSS variables for theme support */
          }
          <svg
            class="w-full h-full hidden"
            viewBox="0 0 800 300"
            preserveAspectRatio="none"
            data-chart-svg
          >
            <defs>
              <linearGradient id={`${id}-gradient`} x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#15803d" stop-opacity="0.3"></stop>
                <stop offset="100%" stop-color="#15803d" stop-opacity="0"></stop>
              </linearGradient>
            </defs>

            {/* Grid lines */}
            <g data-grid-lines class="text-base-300">
              <line
                x1="0"
                y1="60"
                x2="800"
                y2="60"
                stroke="currentColor"
                stroke-dasharray="4 4"
                opacity="0.3"></line>
              <line
                x1="0"
                y1="120"
                x2="800"
                y2="120"
                stroke="currentColor"
                stroke-dasharray="4 4"
                opacity="0.3"></line>
              <line
                x1="0"
                y1="180"
                x2="800"
                y2="180"
                stroke="currentColor"
                stroke-dasharray="4 4"
                opacity="0.3"></line>
              <line
                x1="0"
                y1="240"
                x2="800"
                y2="240"
                stroke="currentColor"
                stroke-dasharray="4 4"
                opacity="0.3"></line>
            </g>

            {/* Area fill */}
            <path data-chart-area fill={`url(#${id}-gradient)`}></path>

            {/* Line */}
            <path
              data-chart-line
              fill="none"
              stroke="#15803d"
              stroke-width="3"
              stroke-linecap="round"
              stroke-linejoin="round"></path>

            {/* Data points */}
            <g data-chart-points></g>
          </svg>

          {/* X-axis labels */}
          <div
            class="absolute bottom-0 left-0 right-0 flex justify-between px-2 text-xs font-bold text-base-content/40 uppercase tracking-wider hidden"
            data-x-labels
          >
          </div>

          {/* Tooltip (absolute within chart container) */}
          <div
            class="absolute z-10 px-3 py-2 bg-neutral text-base-content/60-content text-xs font-medium rounded-lg shadow-lg pointer-events-none opacity-0 transition-opacity"
            style="transform: translate(-50%, -100%); margin-top: -8px;"
            data-chart-tooltip
          >
            <div
              data-tooltip-date
              class="text-xs text-base-content/60-content/60 uppercase tracking-wider mb-1"
            >
            </div>
            <div data-tooltip-value class="font-bold"></div>
          </div>
        </div>
      </div>

      {/* Close button */}
      <div class="flex justify-end pt-2">
        <form method="dialog">
          <button
            type="submit"
            class="btn btn-outline btn-accent px-8 h-14 rounded-2xl font-bold text-base-content hover:bg-base-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent"
            data-close-history
          >
            Close
          </button>
        </form>
      </div>
    </div>
  </Modal>
</div>

<script>
  import { formatCurrency } from '@/lib/formatting/currency-client';

  // Track initialized modals to avoid duplicate handlers
  const initializedModals = new WeakSet<Element>();

  interface HistoryPoint {
    date: string;
    balance: number;
  }

  interface AccountHistoryData {
    id: string;
    name: string;
    type: string;
    currency: Currency;
    balance: number;
    history?: HistoryPoint[];
  }

  function initAccountHistoryModal() {
    document.querySelectorAll('[data-account-history-modal-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedModals.has(container)) return;
      initializedModals.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const modal = document.getElementById(id) as HTMLDialogElement | null;

      // Elements
      const nameEl = container.querySelector('[data-account-name]');
      const metaEl = container.querySelector('[data-account-meta]');
      const balanceEl = container.querySelector('[data-current-balance]');
      const changeBadge = container.querySelector('[data-change-badge]') as HTMLElement;
      const changeText = container.querySelector('[data-change-text]');
      const arrowUp = container.querySelector('[data-arrow-up]');
      const arrowDown = container.querySelector('[data-arrow-down]');

      // Chart elements
      const chartLoading = container.querySelector('[data-chart-loading]');
      const chartEmpty = container.querySelector('[data-chart-empty]');
      const chartSvg = container.querySelector('[data-chart-svg]') as SVGElement;
      const chartArea = container.querySelector('[data-chart-area]') as SVGPathElement;
      const chartLine = container.querySelector('[data-chart-line]') as SVGPathElement;
      const chartPoints = container.querySelector('[data-chart-points]');
      const xLabels = container.querySelector('[data-x-labels]');
      const tooltip = container.querySelector('[data-chart-tooltip]') as HTMLElement;
      const tooltipDate = container.querySelector('[data-tooltip-date]');
      const tooltipValue = container.querySelector('[data-tooltip-value]');

      // Timeframe buttons
      const weeklyBtn = container.querySelector('[data-timeframe="weekly"]') as HTMLButtonElement;
      const monthlyBtn = container.querySelector('[data-timeframe="monthly"]') as HTMLButtonElement;

      if (!modal) return;

      let currentData: AccountHistoryData | null = null;
      let currentTimeframe: 'weekly' | 'monthly' = 'monthly';

      // Fetch real history data from API
      const fetchHistory = async (accountId: string): Promise<HistoryPoint[]> => {
        try {
          const response = await fetch(`/api/accounts/${accountId}/history`);
          if (!response.ok) return [];
          const result = await response.json();
          const data = result.data || result;
          if (!Array.isArray(data)) return [];

          return data
            .map((entry: { balance: string; recorded_at: string | number }) => ({
              date: new Date(entry.recorded_at).toISOString().split('T')[0],
              balance: parseFloat(entry.balance) || 0,
            }))
            .sort(
              (a: HistoryPoint, b: HistoryPoint) =>
                new Date(a.date).getTime() - new Date(b.date).getTime()
            );
        } catch {
          return [];
        }
      };

      // Chart container for tooltip positioning
      const chartContainer = container.querySelector('[data-chart-container]') as HTMLElement;

      // SVG viewBox dimensions (must match the SVG viewBox attribute)
      const SVG_WIDTH = 800;
      const SVG_HEIGHT = 300;

      // Draw chart
      const drawChart = (data: HistoryPoint[], currency: Currency) => {
        if (!chartSvg || !chartArea || !chartLine || !chartPoints || !xLabels) return;

        if (data.length === 0) {
          chartSvg.classList.add('hidden');
          chartEmpty?.classList.remove('hidden');
          xLabels.classList.add('hidden');
          return;
        }

        chartSvg.classList.remove('hidden');
        chartEmpty?.classList.add('hidden');
        xLabels.classList.remove('hidden');

        const width = 800;
        const height = 280;
        const padding = { top: 20, bottom: 40, left: 10, right: 10 };

        const chartWidth = width - padding.left - padding.right;
        const chartHeight = height - padding.top - padding.bottom;

        // Find min/max
        const balances = data.map((d) => d.balance);
        const minBalance = Math.min(...balances) * 0.95;
        const maxBalance = Math.max(...balances) * 1.05;
        const range = maxBalance - minBalance || 1;

        // Calculate points
        const points = data.map((d, i) => {
          const x = padding.left + (i / (data.length - 1)) * chartWidth;
          const y = padding.top + chartHeight - ((d.balance - minBalance) / range) * chartHeight;
          return { x, y, ...d };
        });

        // Create line path
        const linePath = points.map((p, i) => `${i === 0 ? 'M' : 'L'} ${p.x} ${p.y}`).join(' ');

        // Create area path (closed)
        const areaPath =
          linePath +
          ` L ${points[points.length - 1].x} ${height - padding.bottom}` +
          ` L ${points[0].x} ${height - padding.bottom} Z`;

        chartLine.setAttribute('d', linePath);
        chartArea.setAttribute('d', areaPath);

        // Clear and add points
        chartPoints.innerHTML = '';
        points.forEach((p, i) => {
          const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
          g.setAttribute('data-point-index', String(i));
          g.style.cursor = 'pointer';

          // Invisible larger hit area for easier hovering
          const hitArea = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          hitArea.setAttribute('cx', String(p.x));
          hitArea.setAttribute('cy', String(p.y));
          hitArea.setAttribute('r', '14');
          hitArea.setAttribute('fill', 'transparent');
          g.appendChild(hitArea);

          // Visible dot (small, always shown)
          const dot = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
          dot.setAttribute('cx', String(p.x));
          dot.setAttribute('cy', String(p.y));
          dot.setAttribute('r', '3.5');
          dot.setAttribute('fill', '#15803d');
          dot.setAttribute('stroke', 'white');
          dot.setAttribute('stroke-width', '1.5');
          g.appendChild(dot);

          // Tooltip events on the group
          g.addEventListener('mouseenter', () => {
            dot.setAttribute('r', '6');
            dot.setAttribute('stroke-width', '2');
            const point = points[i];
            if (tooltipDate) {
              tooltipDate.textContent = new Date(point.date).toLocaleDateString('en-US', {
                month: 'short',
                day: 'numeric',
                year: 'numeric',
              });
            }
            if (tooltipValue) {
              tooltipValue.textContent = formatCurrency(point.balance, currency);
            }
            if (tooltip && chartContainer) {
              // Map SVG coordinates to container pixel coordinates
              const cw = chartContainer.clientWidth;
              const ch = chartContainer.clientHeight;
              const pixelX = (p.x / SVG_WIDTH) * cw;
              const pixelY = (p.y / SVG_HEIGHT) * ch;
              tooltip.style.left = `${pixelX}px`;
              tooltip.style.top = `${pixelY}px`;
              tooltip.style.opacity = '1';
            }
          });

          g.addEventListener('mouseleave', () => {
            dot.setAttribute('r', '3.5');
            dot.setAttribute('stroke-width', '1.5');
            if (tooltip) {
              tooltip.style.opacity = '0';
            }
          });

          chartPoints.appendChild(g);
        });

        // Update x-axis labels
        xLabels.innerHTML = '';
        const labelCount = Math.min(data.length, 8);
        const step = Math.floor(data.length / labelCount);

        for (let i = 0; i < data.length; i += step) {
          const point = data[i];
          const label = document.createElement('span');
          label.textContent = new Date(point.date).toLocaleDateString('en-US', {
            month: 'short',
            day: 'numeric',
          });
          xLabels.appendChild(label);
        }
      };

      // Update display with data
      // SECURITY: Use textContent (not innerHTML) to prevent XSS from user data
      const updateDisplay = (data: AccountHistoryData, timeframe: 'weekly' | 'monthly') => {
        if (nameEl) nameEl.textContent = data.name;
        if (metaEl) metaEl.textContent = `${data.type} • ${data.currency} Accounts`;
        if (balanceEl) balanceEl.textContent = formatCurrency(data.balance, data.currency);

        // Get history for timeframe
        const history = data.history || [];
        const displayHistory = timeframe === 'weekly' ? history.slice(-7) : history.slice(-30);

        // Calculate change
        const startBalance = displayHistory[0]?.balance || data.balance;
        const changePercent =
          startBalance !== 0 ? ((data.balance - startBalance) / startBalance) * 100 : 0;
        const isPositive = changePercent >= 0;

        if (changeBadge) {
          changeBadge.className = `flex items-center gap-1.5 mt-2 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-widest ${
            isPositive ? 'bg-success/10 text-success' : 'bg-error/10 text-error'
          }`;
        }
        if (arrowUp) arrowUp.classList.toggle('hidden', !isPositive);
        if (arrowDown) arrowDown.classList.toggle('hidden', isPositive);
        if (changeText) {
          changeText.textContent = `${Math.abs(changePercent).toFixed(2)}% (${timeframe === 'weekly' ? 'weekly' : 'monthly'})`;
        }

        // Update timeframe buttons
        if (weeklyBtn && monthlyBtn) {
          const activeClasses = 'bg-accent text-white shadow-sm';
          const inactiveClasses = 'text-base-content/50';

          weeklyBtn.className = `px-4 py-2 text-xs font-bold rounded-lg uppercase tracking-widest transition-all ${
            timeframe === 'weekly' ? activeClasses : inactiveClasses
          }`;
          monthlyBtn.className = `px-4 py-2 text-xs font-bold rounded-lg uppercase tracking-widest transition-all ${
            timeframe === 'monthly' ? activeClasses : inactiveClasses
          }`;
        }

        // Hide loading, draw chart
        chartLoading?.classList.add('hidden');
        drawChart(displayHistory, data.currency);
      };

      // Listen for open-account-history event
      const handleOpenHistory = (async (e: CustomEvent<AccountHistoryData>) => {
        currentData = e.detail;
        currentTimeframe = 'monthly';

        // Show loading
        chartLoading?.classList.remove('hidden');
        chartSvg?.classList.add('hidden');
        chartEmpty?.classList.add('hidden');

        modal.showModal();

        // Fetch real history data from API
        const history = await fetchHistory(currentData.id);
        currentData.history = history;

        // Delay to allow modal animation
        setTimeout(() => {
          updateDisplay(currentData!, currentTimeframe);
        }, 100);
      }) as EventListener;

      document.addEventListener('open-account-history', handleOpenHistory);

      // Clean up event listener on Astro page transitions to prevent memory leaks
      document.addEventListener(
        'astro:before-swap',
        () => {
          document.removeEventListener('open-account-history', handleOpenHistory);
        },
        { once: true }
      );

      // Handle timeframe buttons
      weeklyBtn?.addEventListener('click', () => {
        if (currentData) {
          currentTimeframe = 'weekly';
          updateDisplay(currentData, currentTimeframe);
        }
      });

      monthlyBtn?.addEventListener('click', () => {
        if (currentData) {
          currentTimeframe = 'monthly';
          updateDisplay(currentData, currentTimeframe);
        }
      });

      // Reset data when modal closes (form method="dialog" triggers this)
      modal.addEventListener('close', () => {
        currentData = null;
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccountHistoryModal);
  } else {
    initAccountHistoryModal();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAccountHistoryModal);
</script>
