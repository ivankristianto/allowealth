---
/**
 * AssetPageHeader Component
 *
 * Header section for the Assets page with title, subtitle, month navigation,
 * and action buttons. Part of the Global Portfolio page redesign.
 *
 * The Add Asset button triggers a modal for adding new assets.
 * Month navigation uses URL-based navigation (full page reload per month change).
 *
 * @param {string} title - Main heading (default: "Global Portfolio")
 * @param {string} subtitle - Description text
 * @param {string} className - Additional CSS classes
 * @param {string} defaultCategoryId - Default category ID for new assets
 * @param {string} currentMonth - Formatted month/year display string
 * @param {string} prevMonthUrl - URL for previous month navigation
 * @param {string} nextMonthUrl - URL for next month navigation
 * @param {boolean} isNextDisabled - Whether next month button is disabled
 * @param {string} currentMonthResetUrl - URL to reset to current month
 */

import { Plus, Settings, ChevronLeft, ChevronRight, CalendarDays } from '@lucide/astro';

export interface Props {
  title?: string;
  subtitle?: string;
  className?: string;
  defaultCategoryId?: string;
  currentMonth?: string;
  prevMonthUrl?: string;
  nextMonthUrl?: string;
  isNextDisabled?: boolean;
  currentMonthResetUrl?: string;
}

const {
  title = 'Global Portfolio',
  subtitle = 'Manage and track your distributed household wealth.',
  className = '',
  defaultCategoryId = '',
  currentMonth,
  prevMonthUrl,
  nextMonthUrl,
  isNextDisabled = false,
  currentMonthResetUrl,
} = Astro.props;

const headerClasses = [
  'flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<header class={headerClasses}>
  {/* Title and subtitle */}
  <div>
    <h1 class="text-2xl font-bold text-base-content tracking-tight leading-none">{title}</h1>
    <p class="text-sm text-base-content/60 mt-2 font-medium">{subtitle}</p>
  </div>

  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4">
    {/* Month Navigation - only shown when currentMonth is provided */}
    {currentMonth && (
      <div class="flex items-center gap-1" data-testid="asset-month-selector">
        {prevMonthUrl ? (
          <a
            href={prevMonthUrl}
            class="btn btn-sm btn-square bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all"
            aria-label="Previous month"
            data-testid="asset-prev-month-btn"
          >
            <ChevronLeft size={18} class="stroke-current" aria-hidden="true" />
          </a>
        ) : (
          <button type="button" class="btn btn-sm btn-square bg-base-100 border border-base-300 rounded-xl opacity-30 cursor-not-allowed" disabled aria-label="Previous month (disabled)">
            <ChevronLeft size={18} class="stroke-current" aria-hidden="true" />
          </button>
        )}

        <div class="px-4 py-2 bg-base-100 border border-base-300 rounded-xl text-sm font-bold text-base-content min-w-[130px] text-center">
          {currentMonth}
        </div>

        {nextMonthUrl && !isNextDisabled ? (
          <a
            href={nextMonthUrl}
            class="btn btn-sm btn-square bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all"
            aria-label="Next month"
            data-testid="asset-next-month-btn"
          >
            <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
          </a>
        ) : (
          <button type="button" class="btn btn-sm btn-square bg-base-100 border border-base-300 rounded-xl opacity-30 cursor-not-allowed" disabled aria-label="Next month (disabled)">
            <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
          </button>
        )}

        {currentMonthResetUrl && (
          <a
            href={currentMonthResetUrl}
            class="btn btn-sm bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all gap-1 ml-1"
            aria-label="Go to current month"
            data-testid="asset-current-month-btn"
          >
            <CalendarDays size={16} class="stroke-current" aria-hidden="true" />
            <span class="text-xs">Today</span>
          </a>
        )}
      </div>
    )}

    {/* Actions */}
    <div class="flex items-center gap-2">
      <a
        href="/assets/categories"
        class="btn btn-ghost btn-sm gap-2 rounded-2xl"
        aria-label="Manage asset categories"
        data-testid="manage-asset-categories-btn"
      >
        <Settings size={16} class="stroke-current" aria-hidden="true" />
        <span>Categories</span>
      </a>
      <button
        type="button"
        class="btn btn-accent gap-2 rounded-2xl shadow-md hover:shadow-lg transition-all"
        aria-label="Add new asset"
        data-add-asset-btn
        data-default-category-id={defaultCategoryId}
        data-testid="add-asset-btn"
      >
        <Plus size={18} class="stroke-current" aria-hidden="true" />
        <span>Add Asset</span>
      </button>
    </div>
  </div>
</header>

<script>
  // Track initialized buttons to avoid duplicate listeners
  const initializedAddButtons = new WeakSet<Element>();

  function initAddAssetButton() {
    document.querySelectorAll('[data-add-asset-btn]').forEach((button) => {
      if (initializedAddButtons.has(button)) return;
      initializedAddButtons.add(button);

      button.addEventListener('click', () => {
        const defaultCategoryId = button.getAttribute('data-default-category-id') || '';
        // Dispatch event to open the asset form modal in add mode
        document.dispatchEvent(
          new CustomEvent('open-asset-form', {
            detail: {
              // No id means add mode
              name: '',
              categoryId: defaultCategoryId,
              currency: 'IDR',
              balance: '',
            },
          })
        );
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAddAssetButton);
  } else {
    initAddAssetButton();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAddAssetButton);
</script>
