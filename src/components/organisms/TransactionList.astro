---
/**
 * Transaction List Component
 *
 * Full transaction list with pagination and filtering.
 *
 * @param {Array} transactions - Array of transactions
 * @param {number} total - Total number of transactions
 * @param {number} page - Current page number
 * @param {number} pageSize - Number of transactions per page
 * @param {string} baseUrl - Base URL for pagination
 * @param {Array} categories - Available categories for filters
 * @param {Array} assets - Available assets for filters
 * @param {Object} filters - Current filter values
 * @param {boolean} showFilters - Show filter panel
 */

import TransactionCard from '../molecules/TransactionCard.astro';
import TransactionFilters from '../molecules/TransactionFilters.astro';
import EmptyState from '../atoms/EmptyState.astro';
import Badge from '../atoms/Badge.astro';
import DeleteConfirmationModal from './DeleteConfirmationModal.astro';
import { ArrowLeft, Download, ArrowRight, Plus, ChevronLeft, ChevronRight } from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  transactions: TransactionOutput[];
  total: number;
  page: number;
  pageSize: number;
  baseUrl: string;
  categories?: Array<{ id: string; name: string; type: string }>;
  assets?: Array<{ id: string; name: string; type: string }>;
  filters?: Record<string, string>;
  showFilters?: boolean;
}

const {
  transactions = [],
  total = 0,
  page = 1,
  pageSize = 50,
  baseUrl,
  categories = [],
  assets = [],
  filters = {},
  showFilters = true,
} = Astro.props;

const totalPages = Math.ceil(total / pageSize);
const hasPrev = page > 1;
const hasNext = page < totalPages;

// Build URL for filters
const buildUrl = (newPage: number) => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  params.set('page', newPage.toString());
  return `${baseUrl}?${params.toString()}`;
};

// Build URL with current filters for export
const buildExportUrl = () => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  const queryString = params.toString();
  return queryString ? `/transactions/export?${queryString}` : '/transactions/export';
};

// Build direct API export URL with current filters
const buildDirectExportUrl = () => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  const queryString = params.toString();
  return queryString ? `/api/transactions/export?${queryString}` : '/api/transactions/export';
};
---

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h2 class="text-2xl font-bold text-base-content">Transactions</h2>
    <div class="flex gap-2">
      <a href="/transactions/import" class="btn btn-outline btn-sm gap-2">
        <ArrowLeft size={22} class="stroke-current" aria-hidden="true" />
        Import CSV
      </a>
      <a href={buildDirectExportUrl()} class="btn btn-success btn-sm gap-2" download>
        <Download size={22} class="stroke-current" aria-hidden="true" />
        Download CSV
      </a>
      <a href={buildExportUrl()} class="btn btn-outline btn-sm gap-2">
        <ArrowRight size={22} class="stroke-current" aria-hidden="true" />
        Export Options
      </a>
      <a href="/transactions/add" class="btn btn-accent gap-2">
        <Plus size={22} class="stroke-current" aria-hidden="true" />
        Add Transaction
      </a>
    </div>
  </div>

  <!-- Delete Confirmation Modal using Modal.astro pattern -->
  <DeleteConfirmationModal
    id="delete-transaction-modal"
    title="Delete Transaction"
    description="Are you sure you want to delete this transaction? This action cannot be undone."
    confirmLabel="Delete Transaction"
    cancelLabel="Cancel"
  />

  {
    showFilters && (
      <details class="collapse collapse-arrow bg-base-200" open={Object.keys(filters).length > 0}>
        <summary class="collapse-title font-medium">
          Filters
          {Object.keys(filters).length > 0 && (
            <Badge variant="primary" size="sm" className="ml-2">
              {Object.keys(filters).length} active
            </Badge>
          )}
        </summary>
        <div class="collapse-content">
          <TransactionFilters
            action={baseUrl}
            categories={categories}
            assets={assets}
            values={filters}
            count={total}
          />
        </div>
      </details>
    )
  }

  <div class="card bg-base-100 shadow border border-base-300">
    <div class="card-body p-0">
      {
        transactions.length > 0 ? (
          <>
            {/* Header - Hidden on mobile */}
            <div class="hidden sm:flex items-center gap-4 px-6 py-4 bg-base-200/50 text-sm font-medium text-base-content/60">
              <div class="w-20 lg:w-24">Date</div>
              <div class="flex-1">Description</div>
              <div>Payment</div>
              <div class="text-right">Amount</div>
              <div class="w-20" />
            </div>

            {/* Transaction list using unified TransactionCard component */}
            <div class="divide-y divide-base-200">
              {transactions.map((transaction) => (
                <TransactionCard transaction={transaction} showActions={true} />
              ))}
            </div>

            {totalPages > 1 && (
              <div class="flex flex-col sm:flex-row items-center justify-between gap-3 px-4 sm:px-6 py-4 border-t border-base-200">
                {/* Desktop: Show full text, Mobile: Hide */}
                <div class="hidden sm:block text-sm text-base-content/60">
                  Showing {(page - 1) * pageSize + 1} to {Math.min(page * pageSize, total)} of{' '}
                  {total} transactions
                </div>

                {/* Pagination controls */}
                <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-end">
                  {/* Previous button */}
                  {hasPrev ? (
                    <a
                      href={buildUrl(page - 1)}
                      class="btn btn-sm btn-outline min-h-[44px] min-w-[44px] sm:min-w-0"
                      aria-label="Previous page"
                    >
                      <ChevronLeft size={20} class="stroke-current" aria-hidden="true" />
                      <span class="hidden sm:inline">Previous</span>
                    </a>
                  ) : (
                    <button
                      class="btn btn-sm btn-outline min-h-[44px] min-w-[44px] sm:min-w-0"
                      disabled
                      aria-label="Previous page"
                    >
                      <ChevronLeft size={20} class="stroke-current" aria-hidden="true" />
                      <span class="hidden sm:inline">Previous</span>
                    </button>
                  )}

                  {/* Page indicator */}
                  <span class="text-sm font-medium text-base-content/70 px-2">
                    {page} / {totalPages}
                  </span>

                  {/* Next button */}
                  {hasNext ? (
                    <a
                      href={buildUrl(page + 1)}
                      class="btn btn-sm btn-outline min-h-[44px] min-w-[44px] sm:min-w-0"
                      aria-label="Next page"
                    >
                      <span class="hidden sm:inline">Next</span>
                      <ChevronRight size={20} class="stroke-current" aria-hidden="true" />
                    </a>
                  ) : (
                    <button
                      class="btn btn-sm btn-outline min-h-[44px] min-w-[44px] sm:min-w-0"
                      disabled
                      aria-label="Next page"
                    >
                      <span class="hidden sm:inline">Next</span>
                      <ChevronRight size={20} class="stroke-current" aria-hidden="true" />
                    </button>
                  )}
                </div>
              </div>
            )}
          </>
        ) : (
          <div class="py-12">
            <EmptyState
              title="No transactions found"
              message={
                Object.keys(filters).length > 0
                  ? 'Try adjusting your filters or add a new transaction.'
                  : 'Start tracking by adding your first transaction.'
              }
              actionLabel="Add Transaction"
              actionHref="/transactions/add"
            />
          </div>
        )
      }
    </div>
  </div>
</div>

<script src="./TransactionList.client.ts"></script>
