---
/**
 * Transaction List Component
 *
 * Full transaction list with pagination and filtering.
 *
 * @param {Array} transactions - Array of transactions
 * @param {number} total - Total number of transactions
 * @param {number} page - Current page number
 * @param {number} pageSize - Number of transactions per page
 * @param {string} baseUrl - Base URL for pagination
 * @param {Array} categories - Available categories for filters
 * @param {Array} paymentMethods - Available payment methods for filters
 * @param {Object} filters - Current filter values
 * @param {boolean} showFilters - Show filter panel
 */

import TransactionRow from '../molecules/TransactionRow.astro';
import TransactionFilters from '../molecules/TransactionFilters.astro';
import EmptyState from '../atoms/EmptyState.astro';
import Icon from '../atoms/Icon.astro';
import Button from '../atoms/Button.astro';
import Badge from '../atoms/Badge.astro';
import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  transactions: TransactionOutput[];
  total: number;
  page: number;
  pageSize: number;
  baseUrl: string;
  categories?: Array<{ id: string; name: string; type: string }>;
  paymentMethods?: Array<{ id: string; name: string; type: string }>;
  filters?: Record<string, string>;
  showFilters?: boolean;
}

const {
  transactions = [],
  total = 0,
  page = 1,
  pageSize = 50,
  baseUrl,
  categories = [],
  paymentMethods = [],
  filters = {},
  showFilters = true,
} = Astro.props;

const totalPages = Math.ceil(total / pageSize);
const hasPrev = page > 1;
const hasNext = page < totalPages;

// Build URL for filters
const buildUrl = (newPage: number) => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  params.set('page', newPage.toString());
  return `${baseUrl}?${params.toString()}`;
};

// Build URL with current filters for export
const buildExportUrl = () => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  const queryString = params.toString();
  return queryString ? `/transactions/export?${queryString}` : '/transactions/export';
};
---

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h2 class="text-2xl font-bold">Transactions</h2>
    <div class="flex gap-2">
      <a href="/transactions/import" class="btn btn-outline btn-sm gap-2">
        <Icon name="arrow-left" size="sm" />
        Import CSV
      </a>
      <a href={buildExportUrl()} class="btn btn-outline btn-sm gap-2">
        <Icon name="arrow-right" size="sm" />
        Export CSV
      </a>
      <a href="/transactions/add" class="btn btn-primary gap-2">
        <Icon name="plus" size="sm" />
        Add Transaction
      </a>
    </div>
  </div>

  <!-- Delete Confirmation Dialog -->
  <dialog id="delete-dialog" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Delete Transaction</h3>
      <p class="py-4">
        Are you sure you want to delete this transaction? This action cannot be undone.
      </p>
      <div id="delete-dialog-details" class="bg-base-200 rounded-lg p-3 mb-4 text-sm">
        <!-- Transaction details will be inserted here -->
      </div>
      <div id="delete-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn">Cancel</button>
        </form>
        <button id="confirm-delete-btn" class="btn btn-error"> Delete Transaction </button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  {
    showFilters && (
      <details class="collapse collapse-arrow bg-base-200" open={Object.keys(filters).length > 0}>
        <summary class="collapse-title font-medium">
          Filters
          {Object.keys(filters).length > 0 && (
            <Badge variant="primary" size="sm" className="ml-2">
              {Object.keys(filters).length} active
            </Badge>
          )}
        </summary>
        <div class="collapse-content">
          <TransactionFilters
            action={baseUrl}
            categories={categories}
            paymentMethods={paymentMethods}
            values={filters}
            count={total}
          />
        </div>
      </details>
    )
  }

  <div class="card bg-base-100 shadow border border-base-300">
    <div class="card-body p-0">
      {
        transactions.length > 0 ? (
          <>
            <div class="hidden md:flex items-center gap-4 px-4 py-3 bg-base-200 text-sm font-medium text-neutral-500">
              <div class="w-24">Date</div>
              <div class="flex-1">Description</div>
              <div class="hidden sm:block">Payment</div>
              <div class="text-right">Amount</div>
              <div class="w-20" />
            </div>

            <div class="divide-y divide-base-200">
              {transactions.map((transaction) => (
                <TransactionRow
                  transaction={transaction}
                  editUrl={`/transactions/edit/${transaction.id}`}
                  deleteUrl={`/transactions/delete/${transaction.id}`}
                  showActions={true}
                />
              ))}
            </div>

            {totalPages > 1 && (
              <div class="flex items-center justify-between px-4 py-3 border-t border-base-200">
                <div class="text-sm text-neutral-500">
                  Showing {(page - 1) * pageSize + 1} to {Math.min(page * pageSize, total)} of{' '}
                  {total} transactions
                </div>
                <div class="flex gap-2">
                  {hasPrev ? (
                    <a href={buildUrl(page - 1)} class="btn btn-sm btn-outline">
                      <Icon name="chevron-up" size="sm" className="rotate-180" />
                      Previous
                    </a>
                  ) : (
                    <button class="btn btn-sm btn-outline" disabled>
                      <Icon name="chevron-up" size="sm" className="rotate-180" />
                      Previous
                    </button>
                  )}

                  <span class="btn btn-sm btn-ghost">
                    Page {page} of {totalPages}
                  </span>

                  {hasNext ? (
                    <a href={buildUrl(page + 1)} class="btn btn-sm btn-outline">
                      Next
                      <Icon name="chevron-up" size="sm" className="rotate-180" />
                    </a>
                  ) : (
                    <button class="btn btn-sm btn-outline" disabled>
                      Next
                      <Icon name="chevron-up" size="sm" className="rotate-180" />
                    </button>
                  )}
                </div>
              </div>
            )}
          </>
        ) : (
          <div class="py-12">
            <EmptyState
              title="No transactions found"
              message={
                Object.keys(filters).length > 0
                  ? 'Try adjusting your filters or add a new transaction.'
                  : 'Start tracking by adding your first transaction.'
              }
              actionLabel="Add Transaction"
              actionHref="/transactions/add"
            />
          </div>
        )
      }
    </div>
  </div>
</div>

<script is:inline define:vars={{ transactions }}>
  // Delete transaction handler using dialog
  let transactionToDelete = null;
  let rowToDelete = null;

  const dialog = document.getElementById('delete-dialog');
  const confirmDeleteBtn = document.getElementById('confirm-delete-btn');
  const detailsDiv = document.getElementById('delete-dialog-details');
  const errorDiv = document.getElementById('delete-error');

  // Helper function to show inline error
  function showDialogError(element, message) {
    if (element) {
      element.textContent = message;
      element.classList.remove('hidden');
    }
  }

  function hideDialogError(element) {
    if (element) {
      element.classList.add('hidden');
      element.textContent = '';
    }
  }

  // Add click handlers to delete buttons
  document.querySelectorAll('[data-delete-transaction]').forEach((button) => {
    button.addEventListener('click', async (e) => {
      const target = e.currentTarget;
      const transactionId = target.getAttribute('data-delete-transaction');
      const row = target.closest('[data-transaction-row]');

      // Find transaction data
      const transaction = transactions.find((t) => t.id === transactionId);

      if (!transaction || !row) return;

      transactionToDelete = transactionId;
      rowToDelete = row;

      // Hide any previous errors
      hideDialogError(errorDiv);

      // Populate dialog with transaction details
      const amount = parseFloat(transaction.amount) || 0;
      const formattedAmount = new Intl.NumberFormat('en-US', {
        style: 'currency',
        currency: transaction.currency,
      }).format(amount);

      detailsDiv.innerHTML = `
        <div class="grid grid-cols-2 gap-2">
          <div class="text-base-content/70">Category:</div>
          <div class="font-medium">${transaction.category.name}</div>
          <div class="text-base-content/70">Amount:</div>
          <div class="font-medium">${formattedAmount}</div>
          <div class="text-base-content/70">Date:</div>
          <div class="font-medium">${new Date(transaction.transaction_date).toLocaleDateString()}</div>
          ${
            transaction.description
              ? `
            <div class="text-base-content/70">Description:</div>
            <div class="font-medium">${transaction.description}</div>
          `
              : ''
          }
        </div>
      `;

      // Show dialog
      dialog.showModal();
    });
  });

  // Handle confirm delete button
  confirmDeleteBtn.addEventListener('click', async () => {
    if (!transactionToDelete) return;

    // Hide any previous errors
    hideDialogError(errorDiv);

    // Disable button during request
    confirmDeleteBtn.disabled = true;
    confirmDeleteBtn.innerHTML = '<span class="loading loading-spinner"></span> Deleting...';

    try {
      const response = await fetch(`/api/transactions/${transactionToDelete}`, {
        method: 'DELETE',
        credentials: 'include',
      });

      const data = await response.json();

      if (response.ok && data.success) {
        // Show success toast
        if (window.showToast) {
          window.showToast('Transaction deleted successfully', 'success');
        }

        // Remove row from DOM with animation
        if (rowToDelete) {
          rowToDelete.style.transition = 'opacity 0.3s, transform 0.3s';
          rowToDelete.style.opacity = '0';
          rowToDelete.style.transform = 'translateX(-100%)';

          setTimeout(() => {
            rowToDelete.remove();

            // Check if list is empty and reload if needed
            const remainingRows = document.querySelectorAll('[data-transaction-row]');
            if (remainingRows.length === 0) {
              window.location.reload();
            }
          }, 300);
        }

        // Close dialog
        dialog.close();
      } else {
        // Show inline error
        showDialogError(errorDiv, data.error?.message || 'Failed to delete transaction');
      }
    } catch (error) {
      // Show inline error
      showDialogError(errorDiv, 'Failed to delete transaction. Please try again.');
    } finally {
      // Re-enable button
      confirmDeleteBtn.disabled = false;
      confirmDeleteBtn.innerHTML = 'Delete Transaction';
      transactionToDelete = null;
      rowToDelete = null;
    }
  });
</script>
