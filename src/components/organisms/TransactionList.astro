---
/**
 * Transaction List Component
 *
 * Full transaction list with pagination and filtering.
 *
 * @param {Array} transactions - Array of transactions
 * @param {number} total - Total number of transactions
 * @param {number} page - Current page number
 * @param {number} pageSize - Number of transactions per page
 * @param {string} baseUrl - Base URL for pagination
 * @param {Array} categories - Available categories for filters
 * @param {Array} paymentMethods - Available payment methods for filters
 * @param {Object} filters - Current filter values
 * @param {boolean} showFilters - Show filter panel
 */

import TransactionRow from '../molecules/TransactionRow.astro';
import TransactionFilters from '../molecules/TransactionFilters.astro';
import EmptyState from '../atoms/EmptyState.astro';
import Badge from '../atoms/Badge.astro';
import { ArrowLeft, Download, ArrowRight, Plus, ChevronLeft } from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  transactions: TransactionOutput[];
  total: number;
  page: number;
  pageSize: number;
  baseUrl: string;
  categories?: Array<{ id: string; name: string; type: string }>;
  paymentMethods?: Array<{ id: string; name: string; type: string }>;
  filters?: Record<string, string>;
  showFilters?: boolean;
}

const {
  transactions = [],
  total = 0,
  page = 1,
  pageSize = 50,
  baseUrl,
  categories = [],
  paymentMethods = [],
  filters = {},
  showFilters = true,
} = Astro.props;

const totalPages = Math.ceil(total / pageSize);
const hasPrev = page > 1;
const hasNext = page < totalPages;

// Build URL for filters
const buildUrl = (newPage: number) => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  params.set('page', newPage.toString());
  return `${baseUrl}?${params.toString()}`;
};

// Build URL with current filters for export
const buildExportUrl = () => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  const queryString = params.toString();
  return queryString ? `/transactions/export?${queryString}` : '/transactions/export';
};

// Build direct API export URL with current filters
const buildDirectExportUrl = () => {
  const params = new URLSearchParams();
  Object.entries(filters).forEach(([key, value]) => {
    if (value) params.set(key, value);
  });
  const queryString = params.toString();
  return queryString ? `/api/transactions/export?${queryString}` : '/api/transactions/export';
};
---

<div class="space-y-6">
  <div class="flex justify-between items-center">
    <h2 class="text-2xl font-bold">Transactions</h2>
    <div class="flex gap-2">
      <a href="/transactions/import" class="btn btn-outline btn-sm gap-2">
        <ArrowLeft size={16} class="stroke-current" aria-hidden="true" />
        Import CSV
      </a>
      <a href={buildDirectExportUrl()} class="btn btn-success btn-sm gap-2" download>
        <Download size={16} class="stroke-current" aria-hidden="true" />
        Download CSV
      </a>
      <a href={buildExportUrl()} class="btn btn-outline btn-sm gap-2">
        <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
        Export Options
      </a>
      <a href="/transactions/add" class="btn btn-primary gap-2">
        <Plus size={16} class="stroke-current" aria-hidden="true" />
        Add Transaction
      </a>
    </div>
  </div>

  <!-- Delete Confirmation Dialog -->
  <dialog id="delete-dialog" class="modal">
    <div class="modal-box">
      <h3 class="font-bold text-lg">Delete Transaction</h3>
      <p class="py-4">
        Are you sure you want to delete this transaction? This action cannot be undone.
      </p>
      <div id="delete-dialog-details" class="bg-base-200 rounded-lg p-3 mb-4 text-sm">
        <!-- Transaction details will be inserted here -->
      </div>
      <div id="delete-error" class="hidden alert alert-error text-sm mb-4" role="alert"></div>
      <div class="modal-action">
        <form method="dialog">
          <button class="btn">Cancel</button>
        </form>
        <button id="confirm-delete-btn" class="btn btn-error"> Delete Transaction </button>
      </div>
    </div>
    <form method="dialog" class="modal-backdrop">
      <button>close</button>
    </form>
  </dialog>

  {
    showFilters && (
      <details class="collapse collapse-arrow bg-base-200" open={Object.keys(filters).length > 0}>
        <summary class="collapse-title font-medium">
          Filters
          {Object.keys(filters).length > 0 && (
            <Badge variant="primary" size="sm" className="ml-2">
              {Object.keys(filters).length} active
            </Badge>
          )}
        </summary>
        <div class="collapse-content">
          <TransactionFilters
            action={baseUrl}
            categories={categories}
            paymentMethods={paymentMethods}
            values={filters}
            count={total}
          />
        </div>
      </details>
    )
  }

  <div class="card bg-base-100 shadow border border-base-300">
    <div class="card-body p-0">
      {
        transactions.length > 0 ? (
          <>
            <div class="hidden md:flex items-center gap-4 px-4 py-3 bg-base-200 text-sm font-medium text-neutral-500">
              <div class="w-24">Date</div>
              <div class="flex-1">Description</div>
              <div class="hidden sm:block">Payment</div>
              <div class="text-right">Amount</div>
              <div class="w-20" />
            </div>

            <div class="divide-y divide-base-200">
              {transactions.map((transaction) => (
                <TransactionRow
                  transaction={transaction}
                  editUrl={`/transactions/edit/${transaction.id}`}
                  deleteUrl={`/transactions/delete/${transaction.id}`}
                  showActions={true}
                />
              ))}
            </div>

            {totalPages > 1 && (
              <div class="flex items-center justify-between px-4 py-3 border-t border-base-200">
                <div class="text-sm text-neutral-500">
                  Showing {(page - 1) * pageSize + 1} to {Math.min(page * pageSize, total)} of{' '}
                  {total} transactions
                </div>
                <div class="flex gap-2">
                  {hasPrev ? (
                    <a href={buildUrl(page - 1)} class="btn btn-sm btn-outline">
                      <ChevronLeft size={16} class="stroke-current" aria-hidden="true" />
                      Previous
                    </a>
                  ) : (
                    <button class="btn btn-sm btn-outline" disabled>
                      <ChevronLeft size={16} class="stroke-current" aria-hidden="true" />
                      Previous
                    </button>
                  )}

                  <span class="btn btn-sm btn-ghost">
                    Page {page} of {totalPages}
                  </span>

                  {hasNext ? (
                    <a href={buildUrl(page + 1)} class="btn btn-sm btn-outline">
                      Next
                      <ChevronLeft size={16} class="stroke-current rotate-180" aria-hidden="true" />
                    </a>
                  ) : (
                    <button class="btn btn-sm btn-outline" disabled>
                      Next
                      <ChevronLeft size={16} class="stroke-current rotate-180" aria-hidden="true" />
                    </button>
                  )}
                </div>
              </div>
            )}
          </>
        ) : (
          <div class="py-12">
            <EmptyState
              title="No transactions found"
              message={
                Object.keys(filters).length > 0
                  ? 'Try adjusting your filters or add a new transaction.'
                  : 'Start tracking by adding your first transaction.'
              }
              actionLabel="Add Transaction"
              actionHref="/transactions/add"
            />
          </div>
        )
      }
    </div>
  </div>
</div>

<script src="./TransactionList.client.ts"></script>
