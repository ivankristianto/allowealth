---
/**
 * ForecastTable Component
 *
 * Displays recurring forecast data in a table with monthly projections.
 * Follows the BudgetTable design pattern with proper header styling,
 * dividers, and consistent padding.
 */

import { Wallet } from '@lucide/astro';
import { formatCurrency, formatMonthHeader } from '@/lib/formatting';
import type { ForecastRow, ForecastCurrencyTotals } from '@/lib/types/recurring';
export interface Props {
  rows: ForecastRow[];
  totals: ForecastCurrencyTotals[];
  monthKeys: string[];
}

const { rows = [], totals = [], monthKeys = [] } = Astro.props;

function formatSignedAmount(amount: string, type: 'income' | 'expense', currency: string): string {
  const numeric = Number.parseFloat(amount);
  const signed = type === 'expense' ? -Math.abs(numeric) : Math.abs(numeric);
  return formatCurrency(signed.toFixed(2), currency);
}

function formatNegativeAmount(amount: string, currency: string): string {
  const numeric = Number.parseFloat(amount);
  return formatCurrency((-Math.abs(numeric)).toFixed(2), currency);
}
---

{
  rows.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-box bg-base-200">
        <Wallet size={32} class="stroke-base-content/40" aria-hidden="true" />
      </div>
      <h3 class="mb-2 text-lg font-bold text-base-content">No recurring items found</h3>
      <p class="max-w-sm text-sm text-base-content/60">
        No recurring transactions match the selected filters. Try adjusting your filters or create
        new recurring transactions.
      </p>
    </div>
  ) : (
    <div class="bg-base-100 rounded-box border border-base-300 shadow-sm">
      <div class="overflow-hidden rounded-box">
        <div class="relative isolate" data-scroll-container>
          <div
            class="pointer-events-none absolute bottom-0 right-0 top-0 z-20 w-12 rounded-r-box bg-gradient-to-l from-base-100 via-base-100/80 to-transparent transition-opacity duration-200"
            data-scroll-fade
            aria-hidden="true"
          />
          <div class="max-h-[60vh] overflow-x-auto overflow-y-auto bg-base-100" data-scroll-body>
            <table class="w-max min-w-full border-collapse text-left">
              <caption class="sr-only">Recurring forecast by month</caption>
              <thead>
                <tr class="border-b border-base-300 bg-base-200">
                  <th class="sticky left-0 z-30 w-72 min-w-72 max-w-72 overflow-hidden border-r border-base-300 bg-base-200 px-6 py-4 text-xs font-bold uppercase tracking-widest text-base-content/40 shadow-lg">
                    Recurring
                  </th>
                  {monthKeys.map((key) => (
                    <th class="min-w-40 px-4 py-4 text-right text-xs font-bold uppercase tracking-widest text-base-content/40 whitespace-nowrap">
                      {formatMonthHeader(key)}
                    </th>
                  ))}
                </tr>
              </thead>
              <tbody class="divide-y divide-base-300">
                {rows.map((row) => (
                  <tr
                    class="group transition-colors hover:bg-base-200/30"
                    {...(row.status === 'paused'
                      ? { 'aria-describedby': `status-${row.templateId}` }
                      : {})}
                  >
                    <th
                      scope="row"
                      class="sticky left-0 z-10 w-72 min-w-72 max-w-72 overflow-hidden border-r border-base-300 bg-base-100 px-6 py-5 text-left shadow-lg transition-colors group-hover:bg-base-200"
                    >
                      <div class="flex min-w-0 items-start gap-2.5">
                        <span
                          class:list={[
                            'mt-1.5 inline-block h-2 w-2 shrink-0 rounded-full',
                            row.templateType === 'income' ? 'bg-success' : 'bg-error',
                          ]}
                          aria-hidden="true"
                        />
                        <div class="min-w-0 flex-1 overflow-hidden">
                          <div class="flex min-w-0 items-center gap-2">
                            <span
                              title={row.templateName}
                              class="block min-w-0 flex-1 truncate text-sm font-bold text-base-content"
                            >
                              {row.templateName}
                            </span>
                            {row.status === 'paused' && (
                              <div
                                id={`status-${row.templateId}`}
                                class="tooltip tooltip-right"
                                data-tip="Excluded from totals while paused"
                              >
                                <span class="badge badge-ghost badge-xs whitespace-nowrap cursor-help">
                                  Paused
                                </span>
                              </div>
                            )}
                          </div>
                          <div class="mt-1 truncate text-xs text-base-content/50">
                            <span>{row.account.name}</span>
                            <span class="mx-1 text-base-content/30">&bull;</span>
                            <span
                              class:list={[
                                'font-semibold',
                                row.templateType === 'income' ? 'text-success' : 'text-error',
                              ]}
                            >
                              {row.templateType === 'income' ? 'Income' : 'Expense'}
                            </span>
                          </div>
                          <div class="mt-1 truncate text-xs text-base-content/40">
                            <span class="text-base-content/50">{row.frequencyLabel}</span>
                          </div>
                        </div>
                      </div>
                    </th>
                    {monthKeys.map((key) => (
                      <td class="min-w-40 px-4 py-5 text-right text-sm font-medium whitespace-nowrap">
                        {row.months[key] != null ? (
                          <span>
                            {formatSignedAmount(row.months[key]!, row.templateType, row.currency)}
                          </span>
                        ) : (
                          <span class="text-base-content/20">&mdash;</span>
                        )}
                      </td>
                    ))}
                  </tr>
                ))}
              </tbody>

              <tfoot class="sticky bottom-0 z-20">
                {totals.map((total) => (
                  <>
                    <tr class="border-t-2 border-base-300 bg-base-100">
                      <th class="sticky left-0 z-30 w-72 min-w-72 max-w-72 overflow-hidden border-r border-base-300 bg-base-100 px-6 pt-5 pb-2 text-left text-xs font-bold uppercase tracking-widest text-base-content/40 shadow-lg">
                        Totals ({total.currency})
                      </th>
                      {monthKeys.map(() => (
                        <td class="bg-base-100" />
                      ))}
                    </tr>
                    <tr class="group bg-base-100 transition-colors hover:bg-base-200/30">
                      <th
                        scope="row"
                        class="sticky left-0 z-30 w-72 min-w-72 max-w-72 overflow-hidden border-r border-base-300 bg-base-100 px-6 py-3 text-left text-sm font-bold text-success shadow-lg transition-colors group-hover:bg-base-200"
                      >
                        Income
                      </th>
                      {monthKeys.map((key) => (
                        <td class="min-w-40 bg-base-100 px-4 py-3 text-right text-sm font-medium text-success whitespace-nowrap">
                          {total.months[key]
                            ? formatCurrency(total.months[key].income, total.currency)
                            : '—'}
                        </td>
                      ))}
                    </tr>
                    <tr class="group bg-base-100 transition-colors hover:bg-base-200/30">
                      <th
                        scope="row"
                        class="sticky left-0 z-30 w-72 min-w-72 max-w-72 overflow-hidden border-r border-base-300 bg-base-100 px-6 py-3 text-left text-sm font-bold text-error shadow-lg transition-colors group-hover:bg-base-200"
                      >
                        Expense
                      </th>
                      {monthKeys.map((key) => (
                        <td class="min-w-40 bg-base-100 px-4 py-3 text-right text-sm font-medium text-error whitespace-nowrap">
                          {total.months[key]
                            ? formatNegativeAmount(total.months[key].expense, total.currency)
                            : '—'}
                        </td>
                      ))}
                    </tr>
                    <tr class="group bg-base-100 font-bold transition-colors hover:bg-base-200/30">
                      <th
                        scope="row"
                        class="sticky left-0 z-30 w-72 min-w-72 max-w-72 overflow-hidden border-r border-base-300 bg-base-100 px-6 py-3 text-left text-sm text-info shadow-lg transition-colors group-hover:bg-base-200"
                      >
                        Net
                      </th>
                      {monthKeys.map((key) => (
                        <td class="min-w-40 bg-base-100 px-4 py-3 text-right text-sm font-bold text-info whitespace-nowrap">
                          {total.months[key]
                            ? formatCurrency(total.months[key].net, total.currency)
                            : '—'}
                        </td>
                      ))}
                    </tr>
                  </>
                ))}
              </tfoot>
            </table>
          </div>
        </div>
      </div>
    </div>
  )
}

<style is:inline>
  [data-scroll-container][data-scrolled-end] [data-scroll-fade] {
    opacity: 0;
  }
</style>

<script>
  const CONTROLLER_KEY = '__forecastTableScrollFadeController';
  const LIFECYCLE_KEY = '__forecastTableScrollFadeLifecycleBound';

  type ForecastTableWindow = Window & {
    [CONTROLLER_KEY]?: AbortController;
    [LIFECYCLE_KEY]?: boolean;
  };

  function updateScrollFade(container: HTMLElement): void {
    const body = container.querySelector<HTMLElement>('[data-scroll-body]');
    if (!body) return;

    const { scrollLeft, clientWidth, scrollWidth } = body;
    const atEnd = scrollLeft + clientWidth >= scrollWidth - 4;
    container.toggleAttribute('data-scrolled-end', atEnd);
  }

  function initForecastTableScrollFade(): void {
    if (typeof window === 'undefined' || typeof document === 'undefined') return;

    const forecastWindow = window as ForecastTableWindow;
    forecastWindow[CONTROLLER_KEY]?.abort();

    const controller = new AbortController();
    forecastWindow[CONTROLLER_KEY] = controller;
    const { signal } = controller;

    document.querySelectorAll<HTMLElement>('[data-scroll-container]').forEach((container) => {
      const body = container.querySelector<HTMLElement>('[data-scroll-body]');
      if (!body) return;

      const handleScroll = () => {
        updateScrollFade(container);
      };

      body.addEventListener('scroll', handleScroll, { passive: true, signal });
      window.addEventListener('resize', handleScroll, { signal });
      updateScrollFade(container);
    });
  }

  function setupForecastTableScrollFadeLifecycle(): void {
    if (typeof window === 'undefined' || typeof document === 'undefined') return;

    const forecastWindow = window as ForecastTableWindow;

    if (!forecastWindow[LIFECYCLE_KEY]) {
      forecastWindow[LIFECYCLE_KEY] = true;

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initForecastTableScrollFade, { once: true });
      }

      document.addEventListener('astro:page-load', initForecastTableScrollFade);
    }

    if (document.readyState !== 'loading') {
      initForecastTableScrollFade();
    }
  }

  setupForecastTableScrollFadeLifecycle();
</script>
