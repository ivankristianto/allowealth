---
/**
 * Admin Workspace Table
 *
 * Displays workspace list in a table with name, status, member/transaction/account counts,
 * and creation date. Each row links to the workspace details page.
 * Uses the Card atom component for design system consistency.
 */
import Card from '@/components/atoms/Card.astro';
import type { WorkspaceStats } from '@/services/super-admin.service';
import { Building2 } from '@lucide/astro';

interface Props {
  workspaces: WorkspaceStats[];
}

const { workspaces } = Astro.props;
---

<Card padding="sm">
  <div class="overflow-x-auto rounded-2xl border border-base-300/80 bg-base-100">
    <table class="table table-sm">
      <thead class="bg-base-200/70 text-xs uppercase tracking-wide text-base-content/70">
        <tr>
          <th>Name</th>
          <th>Status</th>
          <th>Members</th>
          <th>Transactions</th>
          <th>Accounts</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        {
          workspaces.length === 0 ? (
            <tr>
              <td colspan="6" class="text-center py-10 text-base-content/60">
                <Building2
                  size={28}
                  class="stroke-current mx-auto mb-2 opacity-50"
                  aria-hidden="true"
                />
                No workspaces matched your filters
              </td>
            </tr>
          ) : (
            workspaces.map((ws) => (
              <tr
                class="hover:bg-base-200/50 cursor-pointer border-b border-base-200/80 last:border-b-0 transition-colors touch-manipulation"
                data-href={`/admin/workspaces/${ws.id}`}
              >
                <td class="font-semibold text-base-content">
                  <a
                    href={`/admin/workspaces/${ws.id}`}
                    class="link link-hover link-primary text-base"
                  >
                    {ws.name}
                  </a>
                </td>
                <td>
                  <span
                    class={`badge badge-sm ${ws.status === 'active' ? 'badge-success' : 'badge-warning'}`}
                  >
                    {ws.status}
                  </span>
                </td>
                <td class="font-medium">{ws.memberCount}</td>
                <td class="font-medium">{ws.transactionCount}</td>
                <td class="font-medium">{ws.accountCount}</td>
                <td class="text-base-content/70">{new Date(ws.createdAt).toLocaleDateString()}</td>
              </tr>
            ))
          )
        }
      </tbody>
    </table>
  </div>
</Card>

<script>
  import { navigate } from 'astro:transitions/client';

  function initWorkspaceTable() {
    const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>('tr[data-href]'));
    for (const row of rows) {
      if (row.dataset.bound === 'true') continue;
      row.dataset.bound = 'true';
      const href = row.dataset.href;

      row.addEventListener('click', (e: MouseEvent) => {
        if (e.target instanceof HTMLElement && e.target.closest('a')) return;
        if (href) navigate(href);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkspaceTable);
  } else {
    initWorkspaceTable();
  }
  document.addEventListener('astro:page-load', initWorkspaceTable);
</script>
