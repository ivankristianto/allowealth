---
/**
 * Admin Workspace Table
 *
 * Displays workspace list in a table with name, status, member/transaction/asset counts,
 * and creation date. Each row links to the workspace details page.
 */
import type { WorkspaceStats } from '@/services/super-admin.service';

interface Props {
  workspaces: WorkspaceStats[];
}

const { workspaces } = Astro.props;
---

<div class="overflow-x-auto">
  <table class="table table-sm">
    <thead>
      <tr>
        <th>Name</th>
        <th>Status</th>
        <th>Members</th>
        <th>Transactions</th>
        <th>Assets</th>
        <th>Created</th>
      </tr>
    </thead>
    <tbody>
      {
        workspaces.length === 0 ? (
          <tr>
            <td colspan="6" class="text-center py-8 text-base-content/60">
              No workspaces found
            </td>
          </tr>
        ) : (
          workspaces.map((ws) => (
            <tr class="hover cursor-pointer" data-href={`/admin/workspaces/${ws.id}`}>
              <td class="font-semibold">{ws.name}</td>
              <td>
                <span
                  class={`badge badge-sm ${ws.status === 'active' ? 'badge-success' : 'badge-warning'}`}
                >
                  {ws.status}
                </span>
              </td>
              <td>{ws.memberCount}</td>
              <td>{ws.transactionCount}</td>
              <td>{ws.assetCount}</td>
              <td>{new Date(ws.createdAt).toLocaleDateString()}</td>
            </tr>
          ))
        )
      }
    </tbody>
  </table>
</div>

<script>
  function initWorkspaceTable() {
    const rows = Array.from(document.querySelectorAll<HTMLTableRowElement>('tr[data-href]'));
    for (const row of rows) {
      row.addEventListener('click', () => {
        const href = row.dataset.href;
        if (href) window.location.href = href;
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initWorkspaceTable);
  } else {
    initWorkspaceTable();
  }
  document.addEventListener('astro:page-load', initWorkspaceTable);
</script>
