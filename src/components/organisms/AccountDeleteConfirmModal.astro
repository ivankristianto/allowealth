---
/**
 * AccountDeleteConfirmModal Component
 *
 * Modal for confirming accounts deactivation.
 * Based on the ConfirmationModal pattern.
 *
 * @param {string} id - Modal ID
 */

import ConfirmationModal from '../molecules/ConfirmationModal.astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div data-account-delete-modal-container data-id={id} data-testid="account-delete-modal">
  <ConfirmationModal
    id={id}
    title="Deactivate Account"
    description="Deactivate this account?"
    confirmLabel="Deactivate"
    confirmVariant="warning"
    confirmLoadingLabel="Deactivating..."
    iconVariant="warning"
    confirmTestId="confirm-delete-btn"
  >
    <div slot="details" class="bg-base-200 rounded-2xl p-4" data-account-details>
      <div class="flex items-center justify-between">
        <div>
          <p class="font-bold text-base-content" data-account-name>Account Name</p>
          <p class="text-xs text-base-content/50 mt-1" data-account-type>Type</p>
        </div>
        <div class="text-right">
          <p class="font-bold" data-account-balance>Balance</p>
          <span
            class="inline-block px-2 py-0.5 rounded-md text-xs font-bold tracking-wider uppercase bg-base-300 text-base-content/60"
            data-account-currency
          >
            Currency
          </span>
        </div>
      </div>
    </div>

    <div slot="details" class="text-sm text-base-content/60 bg-base-200 p-3 rounded-xl">
      Once deactivated: hidden from active accounts, transaction history preserved, can be
      reactivated later by admin.
    </div>
  </ConfirmationModal>
</div>

<script>
  import { addToast } from '@lib/stores/toastStore';
  import { formatCurrency } from '@/lib/formatting/currency-client';
  import { getCsrfHeaders } from '@/lib/csrf-client';
  import {
    clearConfirmError,
    closeConfirmationModal,
    getConfirmationModalElements,
    resetConfirmationModal,
    setConfirmLoading,
    showConfirmError,
  } from '@/components/molecules/ConfirmationModal.client';

  // Track initialized modals to avoid duplicate handlers
  const initializedModals = new WeakSet<Element>();

  interface AccountCloseData {
    id: string;
    name: string;
    type: string;
    balance: number;
    currency: 'IDR' | 'USD';
  }

  function initAccountDeleteModal() {
    document.querySelectorAll('[data-account-delete-modal-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedModals.has(container)) return;
      initializedModals.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const { modal, confirmButton, cancelButton, errorElement } = getConfirmationModalElements(
        container,
        id
      );

      // Detail elements
      const nameEl = container.querySelector('[data-account-name]');
      const typeEl = container.querySelector('[data-account-type]');
      const balanceEl = container.querySelector('[data-account-balance]');
      const currencyEl = container.querySelector('[data-account-currency]');

      if (!modal || !confirmButton) return;

      // Store current account data for closure
      let currentAccountId: string | null = null;
      let currentAccountBalance = 0;
      let currentAccountCurrency: 'IDR' | 'USD' = 'IDR';

      // Function to populate modal with account data
      // SECURITY: Use textContent (not innerHTML) to prevent XSS from user data
      const populateModal = (data: AccountCloseData) => {
        currentAccountId = data.id;
        currentAccountBalance = data.balance;
        currentAccountCurrency = data.currency;
        if (nameEl) nameEl.textContent = data.name;
        if (typeEl) typeEl.textContent = data.type;
        if (balanceEl) {
          balanceEl.textContent = formatCurrency(data.balance, data.currency);
          // Apply currency color
          balanceEl.classList.remove('text-success', 'text-info');
          balanceEl.classList.add(data.currency === 'IDR' ? 'text-success' : 'text-info');
        }
        if (currencyEl) {
          currencyEl.textContent = data.currency;
          currencyEl.classList.remove('bg-success/10', 'text-success', 'bg-info/10', 'text-info');
          currencyEl.classList.add(
            data.currency === 'IDR' ? 'bg-success/10' : 'bg-info/10',
            data.currency === 'IDR' ? 'text-success' : 'text-info'
          );
        }
      };

      // Function to reset modal
      const resetModal = () => {
        currentAccountId = null;
        currentAccountBalance = 0;
        currentAccountCurrency = 'IDR';
        resetConfirmationModal(confirmButton, errorElement);
      };

      // Listen for open-account-close event
      const handleOpenClose = ((e: CustomEvent<AccountCloseData>) => {
        populateModal(e.detail);
        modal.showModal();
      }) as EventListener;

      document.addEventListener('open-account-close', handleOpenClose);

      // Clean up event listener on Astro page transitions to prevent memory leaks
      document.addEventListener(
        'astro:before-swap',
        () => {
          document.removeEventListener('open-account-close', handleOpenClose);
        },
        { once: true }
      );

      // Reset modal when closed (form method="dialog" triggers this)
      modal.addEventListener('close', resetModal);

      cancelButton?.addEventListener('click', () => {
        resetModal();
        closeConfirmationModal(modal);
      });

      // Handle confirm close
      confirmButton.addEventListener('click', async () => {
        if (!currentAccountId) return;

        // Validate account ID format (nanoid)
        const nanoidPattern = /^[A-Za-z0-9_-]{21}$/;
        if (!nanoidPattern.test(currentAccountId)) {
          showConfirmError(errorElement, 'Invalid account ID format.');
          return;
        }

        // Client-side balance check
        if (currentAccountBalance !== 0) {
          showConfirmError(
            errorElement,
            `Cannot deactivate account with balance of ${formatCurrency(currentAccountBalance, currentAccountCurrency)}. Transfer funds out first.`
          );
          return;
        }

        // Clear previous errors
        clearConfirmError(errorElement);

        // Show loading state
        setConfirmLoading(confirmButton, true);

        try {
          const response = await fetch(`/api/accounts/${currentAccountId}/close`, {
            method: 'POST',
            headers: getCsrfHeaders(),
          });

          if (!response.ok) {
            const errorData = await response.json();
            throw new Error(errorData.message || 'Failed to deactivate account');
          }

          // Success
          addToast('Account deactivated successfully', 'success');
          closeConfirmationModal(modal);

          // Dispatch event for page update
          document.dispatchEvent(
            new CustomEvent('account-closed', {
              detail: { accountId: currentAccountId },
            })
          );

          // Reload page to show updated data
          setTimeout(() => window.location.reload(), 500);
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Failed to deactivate account';
          showConfirmError(errorElement, message);
          addToast(message, 'error');
        } finally {
          setConfirmLoading(confirmButton, false);
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccountDeleteModal);
  } else {
    initAccountDeleteModal();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAccountDeleteModal);
</script>
