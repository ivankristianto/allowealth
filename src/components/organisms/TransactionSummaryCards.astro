---
/**
 * Transaction Summary Cards
 *
 * Three summary cards showing Monthly Income, Monthly Expenses, and Net Savings.
 * Matches POC design with icons, large typography, and subtle backgrounds.
 *
 * @param {number} monthlyIncome - Total income for the selected period
 * @param {number} monthlyExpenses - Total expenses for the selected period
 * @param {number} transactionCount - Number of expense transactions
 * @param {string} periodLabel - Period label (e.g., "January 2024")
 * @param {string} currency - Currency code (IDR or USD)
 * @param {boolean} loading - Show loading state
 * @param {string} error - Error message
 */

import StatLabel from '../atoms/StatLabel.astro';
import { TrendingUp, TrendingDown, Wallet } from '@lucide/astro';
import Skeleton from '../atoms/Skeleton.astro';
import { formatCurrency } from '@/lib/tokens';

export interface Props {
  monthlyIncome?: number;
  monthlyExpenses?: number;
  transactionCount?: number;
  periodLabel?: string;
  currency?: 'IDR' | 'USD';
  loading?: boolean;
  error?: string;
}

const {
  monthlyIncome = 0,
  monthlyExpenses = 0,
  transactionCount = 0,
  periodLabel = '',
  currency = 'IDR',
  loading = false,
  error = '',
} = Astro.props;

const netSavings = monthlyIncome - monthlyExpenses;
const netSavingsClass = netSavings >= 0 ? 'text-primary' : 'text-error';

// Card base classes
const cardClasses = [
  'card bg-base-100 border border-base-300 rounded-3xl shadow-sm relative overflow-hidden group',
  'transition-all hover:shadow-md',
].join(' ');

const iconContainerClasses = [
  'absolute top-0 right-0 p-4 opacity-5 group-hover:opacity-10 transition-opacity',
].join(' ');
---

{
  error ? (
    <div class="alert alert-error rounded-3xl" role="alert">
      <p>{error}</p>
    </div>
  ) : loading ? (
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class={cardClasses}>
        <div class="card-body p-8">
          <Skeleton height="0.75rem" width="50%" className="mb-4" />
          <Skeleton height="2.25rem" width="80%" className="mb-3" />
          <Skeleton height="0.75rem" width="40%" />
        </div>
      </div>
      <div class={cardClasses}>
        <div class="card-body p-8">
          <Skeleton height="0.75rem" width="50%" className="mb-4" />
          <Skeleton height="2.25rem" width="80%" className="mb-3" />
          <Skeleton height="0.75rem" width="40%" />
        </div>
      </div>
      <div class={cardClasses}>
        <div class="card-body p-8">
          <Skeleton height="0.75rem" width="50%" className="mb-4" />
          <Skeleton height="2.25rem" width="80%" className="mb-3" />
          <Skeleton height="0.75rem" width="40%" />
        </div>
      </div>
    </div>
  ) : (
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6"
      id="summary-cards-container"
      data-summary-container
      data-currency={currency}
    >
      <div class={cardClasses} data-summary-card="income">
        <div class={iconContainerClasses}>
          <TrendingUp size={48} class="stroke-current text-success" aria-hidden="true" />
        </div>
        <div class="card-body p-8">
          <StatLabel>Monthly Income</StatLabel>
          <h3
            class="text-3xl font-bold text-success mt-4 leading-none tracking-tight"
            data-summary-income
          >
            {formatCurrency(monthlyIncome, currency)}
          </h3>
          {periodLabel && (
            <p
              class="text-[10px] font-bold text-success/60 mt-3 uppercase tracking-wider"
              data-summary-period
            >
              {periodLabel}
            </p>
          )}
        </div>
      </div>

      <div class={cardClasses} data-summary-card="expenses">
        <div class={iconContainerClasses}>
          <TrendingDown size={48} class="stroke-current text-error" aria-hidden="true" />
        </div>
        <div class="card-body p-8">
          <StatLabel>Monthly Expenses</StatLabel>
          <h3
            class="text-3xl font-bold text-error mt-4 leading-none tracking-tight"
            data-summary-expense
          >
            {formatCurrency(monthlyExpenses, currency)}
          </h3>
          <p
            class="text-[10px] font-bold text-error/60 mt-3 uppercase tracking-wider"
            data-summary-count
          >
            {transactionCount} items
          </p>
        </div>
      </div>

      <div class={cardClasses} data-summary-card="savings">
        <div class={iconContainerClasses}>
          <Wallet size={48} class="stroke-current text-primary" aria-hidden="true" />
        </div>
        <div class="card-body p-8">
          <StatLabel>Net Savings</StatLabel>
          <h3
            class={`text-3xl font-bold mt-4 leading-none tracking-tight ${netSavingsClass}`}
            data-summary-net
          >
            {formatCurrency(netSavings, currency)}
          </h3>
          {periodLabel && (
            <p
              class="text-[10px] font-bold text-base-content/40 mt-3 uppercase tracking-wider"
              data-summary-period
            >
              {periodLabel}
            </p>
          )}
        </div>
      </div>
    </div>
  )
}
