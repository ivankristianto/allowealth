---
/**
 * Transaction Summary Cards
 *
 * Three summary cards showing Monthly Income, Monthly Expenses, and Net Savings.
 * Matches POC design with icons, large typography, and subtle backgrounds.
 *
 * @param {number} monthlyIncome - Total income for the selected period
 * @param {number} monthlyExpenses - Total expenses for the selected period
 * @param {number} transactionCount - Number of expense transactions
 * @param {string} periodLabel - Period label (e.g., "January 2024")
 * @param {string} currency - Currency code (IDR or USD)
 * @param {boolean} loading - Show loading state
 * @param {string} error - Error message
 */

// External packages
import { TrendingUp, TrendingDown, Wallet } from '@lucide/astro';

// Internal aliases - lib
import { formatCurrency } from '@/lib/formatting';

// Relative imports - components
import StatCard from '../atoms/StatCard.astro';
import Skeleton from '../atoms/Skeleton.astro';

export interface Props {
  monthlyIncome?: number;
  monthlyExpenses?: number;
  transactionCount?: number;
  periodLabel?: string;
  currency?: 'IDR' | 'USD';
  loading?: boolean;
  error?: string;
}

const {
  monthlyIncome = 0,
  monthlyExpenses = 0,
  transactionCount = 0,
  periodLabel = '',
  currency = 'IDR',
  loading = false,
  error = '',
} = Astro.props;

const netSavings = monthlyIncome - monthlyExpenses;
const netSavingsClass = netSavings >= 0 ? 'text-success' : 'text-error';

// Card base classes - responsive padding and rounded corners
const cardClasses = [
  'card bg-base-100 border border-base-300 rounded-2xl sm:rounded-card shadow-sm relative overflow-hidden group',
  'transition-all hover:shadow-md',
].join(' ');
---

{
  error ? (
    <div class="alert alert-error rounded-3xl" role="alert">
      <p>{error}</p>
    </div>
  ) : loading ? (
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6">
      <div class={cardClasses}>
        <div class="card-body p-4 sm:p-6 lg:p-8">
          <Skeleton height="0.75rem" width="50%" className="mb-3 sm:mb-4" />
          <Skeleton height="1.5rem" width="80%" className="sm:h-9 mb-2 sm:mb-3" />
          <Skeleton height="0.75rem" width="40%" />
        </div>
      </div>
      <div class={cardClasses}>
        <div class="card-body p-4 sm:p-6 lg:p-8">
          <Skeleton height="0.75rem" width="50%" className="mb-3 sm:mb-4" />
          <Skeleton height="1.5rem" width="80%" className="sm:h-9 mb-2 sm:mb-3" />
          <Skeleton height="0.75rem" width="40%" />
        </div>
      </div>
      <div class={cardClasses}>
        <div class="card-body p-4 sm:p-6 lg:p-8">
          <Skeleton height="0.75rem" width="50%" className="mb-3 sm:mb-4" />
          <Skeleton height="1.5rem" width="80%" className="sm:h-9 mb-2 sm:mb-3" />
          <Skeleton height="0.75rem" width="40%" />
        </div>
      </div>
    </div>
  ) : (
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-4 sm:gap-6"
      id="summary-cards-container"
      data-summary-container
      data-currency={currency}
    >
      <StatCard
        title="Monthly Income"
        value={formatCurrency(monthlyIncome, currency)}
        subtitle={periodLabel || undefined}
        valueColor="text-success"
        subtitleColor="text-success/60"
        iconVariant="success"
        className="transition-all hover:shadow-md"
        data-summary-card="income"
      >
        <TrendingUp slot="icon" size={48} class="stroke-current" aria-hidden="true" />
      </StatCard>

      <StatCard
        title="Monthly Expenses"
        value={formatCurrency(monthlyExpenses, currency)}
        subtitle={`${transactionCount} items`}
        valueColor="text-error"
        subtitleColor="text-error/60"
        iconVariant="error"
        className="transition-all hover:shadow-md"
        data-summary-card="expenses"
      >
        <TrendingDown slot="icon" size={48} class="stroke-current" aria-hidden="true" />
      </StatCard>

      <StatCard
        title="Net Savings"
        value={formatCurrency(netSavings, currency)}
        subtitle={periodLabel || undefined}
        valueColor={netSavingsClass}
        subtitleColor="text-base-content/40"
        className="transition-all hover:shadow-md"
        data-summary-card="savings"
      >
        <Wallet slot="icon" size={48} class="stroke-current text-primary" aria-hidden="true" />
      </StatCard>
    </div>
  )
}
