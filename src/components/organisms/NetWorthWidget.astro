---
/**
 * NetWorthWidget Component
 *
 * Displays total net worth with IDR and USD amounts, growth badge,
 * and local/global assets breakdown.
 * Follows Oasis Finance v1.0.0 design system specifications.
 *
 * @param {number} totalIDR - Total net worth in IDR
 * @param {number} totalUSD - Total net worth in USD
 * @param {number} localAssets - Local assets value in IDR
 * @param {number} globalAssets - Global assets value in USD
 * @param {number} growthPercentage - Growth percentage for badge
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import { Landmark, TrendingUp, Wallet, Plus } from '@lucide/astro';
import { formatCurrency } from '@/lib/tokens';
import IconBadge from '@/components/atoms/IconBadge.astro';
import StatLabel from '@/components/atoms/StatLabel.astro';
import Card from '@/components/atoms/Card.astro';

export interface Props {
  totalIDR: number;
  totalUSD: number;
  localAssets: number;
  globalAssets: number;
  growthPercentage: number;
  loading?: boolean;
  error?: string;
  className?: string;
}

const {
  totalIDR,
  totalUSD,
  localAssets,
  globalAssets,
  growthPercentage,
  loading = false,
  error,
  className = '',
} = Astro.props;

// Determine if this is an empty state
// Falsy check handles null, undefined, NaN, and exactly 0
// Small positive/negative floats (e.g., 0.01) will correctly show normal state
const isEmpty = !totalIDR && !totalUSD && !localAssets && !globalAssets;

// Growth badge styling based on percentage (positive = success, negative = error)
const isPositiveGrowth = growthPercentage >= 0;
const growthLabel = `${isPositiveGrowth ? '+' : ''}${growthPercentage.toFixed(1)}% growth`;

// Growth badge classes - use explicit classes for Tailwind JIT compatibility
const growthBadgeClasses = [
  'text-xs font-bold px-3 py-1.5 rounded-full inline-flex items-center gap-1.5',
  isPositiveGrowth ? 'bg-success/10 text-success' : 'bg-error/10 text-error',
].join(' ');

// Card content classes
const cardClasses = [
  'relative overflow-hidden group',
  loading && 'pointer-events-none opacity-70',
  className,
]
  .filter(Boolean)
  .join(' ');

// Determine the role and aria attributes based on state
const cardRole = error ? 'alert' : 'region';
const ariaLive = error ? 'polite' : undefined;
const ariaLabelledBy = !error && !loading ? 'net-worth-label' : undefined;
const ariaBusy = loading ? 'true' : undefined;
const ariaLabel = loading ? 'Loading net worth data...' : undefined;

// Note: Spacing classes (mb-6, mt-3, gap-3, etc.) use Tailwind's built-in spacing scale
// which directly maps to design system tokens (--spacing-6 = 1.5rem = 24px, etc.)
// See: tokens.css for spacing token definitions
---

<Card
  padding="lg"
  rounded="card-lg"
  className={cardClasses}
  role={cardRole as any}
  aria-live={ariaLive}
  aria-labelledby={ariaLabelledBy}
  aria-busy={ariaBusy}
  aria-label={ariaLabel}
>
  {
    error ? (
      // Error State
      <div class="flex items-center gap-3 text-error">
        <div class="p-2 bg-error/10 rounded-xl">
          <TrendingUp size={20} class="stroke-current" aria-hidden="true" />
        </div>
        <div>
          <p class="font-semibold text-sm">Unable to load net worth</p>
          <p class="text-xs opacity-80">{error}</p>
        </div>
      </div>
    ) : loading ? (
      // Loading Skeleton State
      <div class="space-y-4" aria-hidden="true">
        <div class="flex justify-between items-start">
          <div class="w-16 h-16 bg-success/10 rounded-2xl animate-pulse" aria-hidden="true" />
          <div class="h-7 w-24 bg-success/10 rounded-full animate-pulse" aria-hidden="true" />
        </div>
        <div class="space-y-2">
          <div class="h-4 w-32 bg-base-300/50 rounded animate-pulse" aria-hidden="true" />
          <div class="h-10 w-48 bg-base-300/50 rounded animate-pulse" aria-hidden="true" />
          <div class="h-7 w-36 bg-base-300/50 rounded animate-pulse" aria-hidden="true" />
        </div>
        <div class="h-px bg-base-200" aria-hidden="true" />
        <div class="space-y-3">
          <div class="flex justify-between">
            <div class="h-5 w-24 bg-base-300/50 rounded animate-pulse" aria-hidden="true" />
            <div class="h-5 w-28 bg-base-300/50 rounded animate-pulse" aria-hidden="true" />
          </div>
          <div class="flex justify-between">
            <div class="h-5 w-24 bg-base-300/50 rounded animate-pulse" aria-hidden="true" />
            <div class="h-5 w-28 bg-base-300/50 rounded animate-pulse" aria-hidden="true" />
          </div>
        </div>
      </div>
    ) : isEmpty ? (
      // Empty State
      <div class="flex flex-col items-center justify-center py-4 text-center">
        <div class="w-16 h-16 rounded-2xl bg-base-200 flex items-center justify-center mb-4">
          <Wallet size={32} class="stroke-base-content/40" aria-hidden="true" />
        </div>
        <h3 class="text-lg font-bold text-base-content mb-2">No assets yet</h3>
        <p class="text-sm text-base-content/60 max-w-[200px] mb-4">
          Add your first asset to start tracking your net worth.
        </p>
        <a href="/assets/add" class="btn btn-accent btn-sm gap-2">
          <Plus size={16} aria-hidden="true" />
          Add Asset
        </a>
      </div>
    ) : (
      // Normal State
      <>
        {/* Header: Icon Badge + Growth Badge */}
        <div class="flex justify-between items-start mb-6">
          <IconBadge variant="success" size="md">
            <Landmark size={24} class="stroke-current" aria-hidden="true" />
          </IconBadge>
          <span class={growthBadgeClasses} aria-label={`Net worth growth: ${growthLabel}`}>
            <TrendingUp size={12} class="stroke-current" aria-hidden="true" />
            {growthLabel}
          </span>
        </div>

        {/* Total Net Worth Label */}
        <span id="net-worth-label">
          <StatLabel size="sm" color="neutral">
            Total net worth
          </StatLabel>
        </span>

        {/* Primary Amount (IDR) */}
        <div class="mt-3">
          <h3
            class="text-2xl sm:text-3xl font-bold text-base-content tracking-tighter leading-none"
            aria-label={`Total net worth: ${formatCurrency(totalIDR, 'IDR')}`}
          >
            {formatCurrency(totalIDR, 'IDR')}
          </h3>
          {/* Secondary Amount (USD) */}
          <p
            class="text-base sm:text-lg font-semibold text-base-content/60 mt-1.5 tracking-tight"
            aria-label={`Equivalent to ${formatCurrency(totalUSD, 'USD')} USD`}
          >
            {formatCurrency(totalUSD, 'USD')}
          </p>
        </div>

        {/* Divider */}
        <div class="mt-6 pt-6 border-t border-base-200 space-y-3">
          {/* Local Assets Breakdown */}
          <div class="flex justify-between text-base font-medium leading-none">
            <span class="text-base-content/60">Local assets</span>
            <span
              class="text-base-content font-bold"
              aria-label={`Local assets: ${formatCurrency(localAssets, 'IDR')}`}
            >
              {formatCurrency(localAssets, 'IDR')}
            </span>
          </div>
          {/* Global Assets Breakdown */}
          <div class="flex justify-between text-base font-medium leading-none">
            <span class="text-base-content/60">Global assets</span>
            <span
              class="text-base-content font-bold"
              aria-label={`Global assets: ${formatCurrency(globalAssets, 'USD')}`}
            >
              {formatCurrency(globalAssets, 'USD')}
            </span>
          </div>
        </div>
      </>
    )
  }
</Card>
