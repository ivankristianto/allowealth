---
import { AlertCircle, Clock3, CheckCircle2, MinusCircle } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import type { RecurringCalendarDay } from '@/lib/types/recurring';

export interface Props {
  calendarData: RecurringCalendarDay[];
  year: number;
  month: number;
  loading?: boolean;
}

const { calendarData = [], year, month, loading = false } = Astro.props;

const monthDate = new Date(year, month - 1, 1);
const monthLabel = monthDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const daysInMonth = new Date(year, month, 0).getDate();
const firstDayMondayIndex = (monthDate.getDay() + 6) % 7;

const dayMap = new Map(calendarData.map((day) => [day.date, day.occurrences]));
const todayIso = new Date().toISOString().slice(0, 10);

const cells: Array<{ day: number | null; date: string | null }> = [];
for (let i = 0; i < firstDayMondayIndex; i += 1) {
  cells.push({ day: null, date: null });
}
for (let day = 1; day <= daysInMonth; day += 1) {
  const date = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  cells.push({ day, date });
}

function statusIcon(status: 'pending' | 'confirmed' | 'skipped', date: string) {
  if (status === 'pending' && date < todayIso) {
    return 'overdue';
  }
  if (status === 'pending') {
    return 'pending';
  }
  if (status === 'confirmed') {
    return 'confirmed';
  }
  return 'skipped';
}
---

<div class="space-y-4" data-recurring-calendar>
  <div class="flex flex-wrap items-center gap-4 text-xs text-base-content/70">
    <span class="inline-flex items-center gap-1"
      ><AlertCircle size={14} class="text-error" /> Overdue</span
    >
    <span class="inline-flex items-center gap-1"
      ><Clock3 size={14} class="text-warning" /> Pending</span
    >
    <span class="inline-flex items-center gap-1"
      ><CheckCircle2 size={14} class="text-success" /> Confirmed</span
    >
    <span class="inline-flex items-center gap-1"
      ><MinusCircle size={14} class="text-base-content/50" /> Skipped</span
    >
  </div>

  {
    loading ? (
      <div class="rounded-card border border-base-300 bg-base-100 p-10 text-center">
        <h3 class="text-lg font-semibold">Loading calendar for {monthLabel}...</h3>
      </div>
    ) : calendarData.length === 0 ? (
      <div class="rounded-card border border-base-300 bg-base-100 p-10 text-center">
        <h3 class="text-lg font-semibold">No recurring transactions scheduled for {monthLabel}.</h3>
      </div>
    ) : (
      <>
        <div class="hidden md:block @container">
          <div class="grid grid-cols-7 gap-px rounded-card border border-base-300 overflow-hidden bg-base-300">
            {['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((weekday) => (
              <div class="bg-base-200 px-3 py-2 text-xs font-bold uppercase tracking-widest text-base-content/50">
                {weekday}
              </div>
            ))}

            {cells.map((cell) => {
              if (!cell.day || !cell.date) {
                return <div class="min-h-28 bg-base-200/40" />;
              }

              const occurrences = dayMap.get(cell.date) || [];

              return (
                <div class="min-h-28 bg-base-100 p-2 space-y-2">
                  <div class="text-xs font-semibold text-base-content/70">{cell.day}</div>
                  <div class="space-y-1">
                    {occurrences.map((occurrence) => {
                      const icon = statusIcon(occurrence.status, occurrence.due_date);
                      const payload = JSON.stringify(occurrence);

                      return (
                        <div class="w-full rounded-lg border border-base-300 bg-base-100 px-2 py-1.5 text-xs space-y-1">
                          <div class="flex items-center gap-1 min-w-0">
                            {icon === 'overdue' && (
                              <AlertCircle size={12} class="text-error shrink-0" />
                            )}
                            {icon === 'pending' && (
                              <Clock3 size={12} class="text-warning shrink-0" />
                            )}
                            {icon === 'confirmed' && (
                              <CheckCircle2 size={12} class="text-success shrink-0" />
                            )}
                            {icon === 'skipped' && (
                              <MinusCircle size={12} class="text-base-content/50 shrink-0" />
                            )}
                            <span class="truncate">{occurrence.templateName}</span>
                          </div>
                          <div class="text-[11px] text-base-content/60">
                            {formatCurrency(occurrence.templateAmount, occurrence.currency)}
                          </div>
                          {occurrence.status === 'pending' && (
                            <div class="flex items-center gap-1 pt-1">
                              <button
                                type="button"
                                class="btn btn-xs btn-primary flex-1 min-h-7"
                                data-open-confirm-modal
                                data-occurrence={payload}
                              >
                                Confirm
                              </button>
                              <button
                                type="button"
                                class="btn btn-xs btn-warning flex-1 min-h-7"
                                data-open-skip-modal
                                data-occurrence={payload}
                              >
                                Skip
                              </button>
                            </div>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <div class="md:hidden space-y-3">
          {calendarData.map((day) => (
            <article class="rounded-card border border-base-300 bg-base-100 p-4 space-y-2">
              <h3 class="text-sm font-bold text-base-content/70">{day.date}</h3>
              <div class="space-y-2">
                {day.occurrences.map((occurrence) => {
                  const icon = statusIcon(occurrence.status, occurrence.due_date);
                  const payload = JSON.stringify(occurrence);

                  return (
                    <div class="w-full rounded-lg border border-base-300 px-3 py-2 text-left space-y-2">
                      <div class="flex items-center justify-between gap-2">
                        <div class="inline-flex items-center gap-1.5 min-w-0">
                          {icon === 'overdue' && (
                            <AlertCircle size={14} class="text-error shrink-0" />
                          )}
                          {icon === 'pending' && <Clock3 size={14} class="text-warning shrink-0" />}
                          {icon === 'confirmed' && (
                            <CheckCircle2 size={14} class="text-success shrink-0" />
                          )}
                          {icon === 'skipped' && (
                            <MinusCircle size={14} class="text-base-content/50 shrink-0" />
                          )}
                          <span class="truncate text-sm">{occurrence.templateName}</span>
                        </div>
                        <span class="text-xs font-semibold">
                          {formatCurrency(occurrence.templateAmount, occurrence.currency)}
                        </span>
                      </div>
                      {occurrence.status === 'pending' && (
                        <div class="grid grid-cols-2 gap-2">
                          <button
                            type="button"
                            class="btn btn-sm btn-primary min-h-10"
                            data-open-confirm-modal
                            data-occurrence={payload}
                          >
                            Confirm
                          </button>
                          <button
                            type="button"
                            class="btn btn-sm btn-warning min-h-10"
                            data-open-skip-modal
                            data-occurrence={payload}
                          >
                            Skip
                          </button>
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </article>
          ))}
        </div>
      </>
    )
  }
</div>
