---
import { CircleAlert, CircleCheck, CircleMinus, Clock3 } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import EmptyState from '@/components/atoms/EmptyState.astro';
import Spinner from '@/components/atoms/Spinner.astro';
import type { RecurringCalendarDay } from '@/lib/types/recurring';

export interface Props {
  calendarData: RecurringCalendarDay[];
  year: number;
  month: number;
  loading?: boolean;
}

const { calendarData = [], year, month, loading = false } = Astro.props;

const monthDate = new Date(year, month - 1, 1);
const monthLabel = monthDate.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
const daysInMonth = new Date(year, month, 0).getDate();
const firstDayMondayIndex = (monthDate.getDay() + 6) % 7;

const dayMap = new Map(calendarData.map((day) => [day.date, day.occurrences]));
const todayIso = new Date().toISOString().slice(0, 10);

const cells: Array<{ day: number | null; date: string | null }> = [];
for (let i = 0; i < firstDayMondayIndex; i += 1) {
  cells.push({ day: null, date: null });
}
for (let day = 1; day <= daysInMonth; day += 1) {
  const date = `${year}-${String(month).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  cells.push({ day, date });
}

function statusIcon(status: 'pending' | 'confirmed' | 'skipped', date: string) {
  if (status === 'pending' && date < todayIso) {
    return 'overdue';
  }
  if (status === 'pending') {
    return 'pending';
  }
  if (status === 'confirmed') {
    return 'confirmed';
  }
  return 'skipped';
}

const statusChipClasses: Record<string, string> = {
  overdue: 'border-error/30 bg-error/5',
  pending: 'border-warning/30 bg-warning/5',
  confirmed: 'border-success/30 bg-success/5',
  skipped: 'border-base-300 bg-base-200/50',
};
---

<div class="space-y-4" data-recurring-calendar>
  <div class="flex flex-wrap items-center gap-3 text-xs">
    <span class="text-base-content/40 font-bold uppercase tracking-wider">Legend:</span>
    <span
      class="inline-flex items-center gap-1.5 rounded-lg border border-error/30 bg-error/5 px-2.5 py-1 font-medium"
    >
      <CircleAlert size={12} class="text-error" aria-hidden="true" /> Overdue
    </span>
    <span
      class="inline-flex items-center gap-1.5 rounded-lg border border-warning/30 bg-warning/5 px-2.5 py-1 font-medium"
    >
      <Clock3 size={12} class="text-warning" aria-hidden="true" /> Pending
    </span>
    <span
      class="inline-flex items-center gap-1.5 rounded-lg border border-success/30 bg-success/5 px-2.5 py-1 font-medium"
    >
      <CircleCheck size={12} class="text-success" aria-hidden="true" /> Confirmed
    </span>
    <span
      class="inline-flex items-center gap-1.5 rounded-lg border border-base-300 bg-base-200/50 px-2.5 py-1 font-medium text-base-content/50"
    >
      <CircleMinus size={12} aria-hidden="true" /> Skipped
    </span>
  </div>

  {
    loading ? (
      <div class="rounded-2xl border border-base-300 bg-base-100 p-12 text-center shadow-sm">
        <Spinner size="lg" />
        <p class="mt-3 text-sm font-medium text-base-content/60">
          Loading calendar for {monthLabel}...
        </p>
      </div>
    ) : calendarData.length === 0 ? (
      <div class="rounded-2xl border border-base-300 bg-base-100 shadow-sm">
        <EmptyState
          title={`No recurring transactions for ${monthLabel}`}
          message="Create templates or check another month."
          iconName="calendar"
          variant="centered"
        />
      </div>
    ) : (
      <>
        {/* Desktop calendar grid */}
        <div class="hidden md:block @container">
          <div class="grid grid-cols-7 gap-px rounded-2xl border border-base-300 overflow-hidden bg-base-300 shadow-sm">
            {['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'].map((weekday) => (
              <div class="bg-base-200 px-3 py-2.5 text-xs font-bold uppercase tracking-wider text-base-content/40 text-center">
                {weekday}
              </div>
            ))}

            {cells.map((cell) => {
              if (!cell.day || !cell.date) {
                return <div class="min-h-28 bg-base-100/60" />;
              }

              const occurrences = dayMap.get(cell.date) || [];
              const isToday = cell.date === todayIso;

              return (
                <div
                  class:list={[
                    'min-h-28 bg-base-100 p-2 space-y-1.5',
                    isToday && 'ring-2 ring-accent/40 ring-inset bg-accent/3',
                  ]}
                >
                  <div
                    class:list={[
                      'text-xs font-bold inline-flex items-center justify-center',
                      isToday
                        ? 'bg-accent text-accent-content rounded-lg w-6 h-6'
                        : 'text-base-content/50',
                    ]}
                  >
                    {cell.day}
                  </div>
                  <div class="space-y-1">
                    {occurrences.map((occurrence) => {
                      const icon = statusIcon(occurrence.status, occurrence.due_date);
                      const payload = JSON.stringify(occurrence);
                      const chipClass = statusChipClasses[icon] ?? '';
                      const canAct =
                        occurrence.status === 'pending' && !(occurrence.due_date > todayIso);

                      return (
                        <div
                          class={`w-full rounded-lg border px-2 py-1.5 text-xs space-y-1 ${chipClass}`}
                        >
                          <div class="flex items-center gap-1 min-w-0">
                            {icon === 'overdue' && (
                              <CircleAlert
                                size={11}
                                class="text-error shrink-0"
                                aria-hidden="true"
                              />
                            )}
                            {icon === 'pending' && (
                              <Clock3 size={11} class="text-warning shrink-0" aria-hidden="true" />
                            )}
                            {icon === 'confirmed' && (
                              <CircleCheck
                                size={11}
                                class="text-success shrink-0"
                                aria-hidden="true"
                              />
                            )}
                            {icon === 'skipped' && (
                              <CircleMinus
                                size={11}
                                class="text-base-content/50 shrink-0"
                                aria-hidden="true"
                              />
                            )}
                            <span class="truncate font-medium">{occurrence.templateName}</span>
                          </div>
                          <div class="text-[11px] text-base-content/50 font-medium">
                            {formatCurrency(occurrence.templateAmount, occurrence.currency)}
                          </div>
                          {canAct && (
                            <div class="flex items-center gap-1 pt-0.5">
                              <button
                                type="button"
                                class="btn btn-xs btn-accent flex-1 min-h-6 rounded-lg font-semibold"
                                data-open-confirm-modal
                                data-occurrence={payload}
                              >
                                Confirm
                              </button>
                              <button
                                type="button"
                                class="btn btn-xs btn-outline btn-warning flex-1 min-h-6 rounded-lg font-semibold"
                                data-open-skip-modal
                                data-occurrence={payload}
                              >
                                Skip
                              </button>
                            </div>
                          )}
                        </div>
                      );
                    })}
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        {/* Mobile list view */}
        <div class="md:hidden space-y-3">
          {calendarData.map((day) => {
            const isToday = day.date === todayIso;
            const dayDate = new Date(`${day.date}T00:00:00`);
            const dayLabel = dayDate.toLocaleDateString('en-US', {
              weekday: 'short',
              month: 'short',
              day: 'numeric',
            });

            return (
              <article
                class:list={[
                  'rounded-2xl border bg-base-100 p-4 space-y-2.5 shadow-sm',
                  isToday ? 'border-accent/40 ring-1 ring-accent/20' : 'border-base-300',
                ]}
              >
                <div class="flex items-center gap-2">
                  {isToday && <span class="w-2 h-2 rounded-full bg-accent shrink-0" />}
                  <h3 class="text-sm font-bold text-base-content/70">
                    {dayLabel}
                    {isToday && <span class="ml-1.5 text-accent text-xs font-bold">Today</span>}
                  </h3>
                </div>
                <div class="space-y-2">
                  {day.occurrences.map((occurrence) => {
                    const icon = statusIcon(occurrence.status, occurrence.due_date);
                    const payload = JSON.stringify(occurrence);
                    const chipClass = statusChipClasses[icon] ?? '';
                    const canAct =
                      occurrence.status === 'pending' && !(occurrence.due_date > todayIso);

                    return (
                      <div
                        class={`w-full rounded-xl border px-3 py-2.5 text-left space-y-2 ${chipClass}`}
                      >
                        <div class="flex items-center justify-between gap-2">
                          <div class="inline-flex items-center gap-1.5 min-w-0">
                            {icon === 'overdue' && (
                              <CircleAlert
                                size={14}
                                class="text-error shrink-0"
                                aria-hidden="true"
                              />
                            )}
                            {icon === 'pending' && (
                              <Clock3 size={14} class="text-warning shrink-0" aria-hidden="true" />
                            )}
                            {icon === 'confirmed' && (
                              <CircleCheck
                                size={14}
                                class="text-success shrink-0"
                                aria-hidden="true"
                              />
                            )}
                            {icon === 'skipped' && (
                              <CircleMinus
                                size={14}
                                class="text-base-content/50 shrink-0"
                                aria-hidden="true"
                              />
                            )}
                            <span class="truncate text-sm font-medium">
                              {occurrence.templateName}
                            </span>
                          </div>
                          <span class="text-xs font-bold whitespace-nowrap">
                            {formatCurrency(occurrence.templateAmount, occurrence.currency)}
                          </span>
                        </div>
                        {canAct && (
                          <div class="grid grid-cols-2 gap-2">
                            <button
                              type="button"
                              class="btn btn-sm btn-accent min-h-10 rounded-xl font-semibold"
                              data-open-confirm-modal
                              data-occurrence={payload}
                            >
                              Confirm
                            </button>
                            <button
                              type="button"
                              class="btn btn-sm btn-outline btn-warning min-h-10 rounded-xl font-semibold"
                              data-open-skip-modal
                              data-occurrence={payload}
                            >
                              Skip
                            </button>
                          </div>
                        )}
                      </div>
                    );
                  })}
                </div>
              </article>
            );
          })}
        </div>
      </>
    )
  }
</div>
