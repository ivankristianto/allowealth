---
import { RefreshCw, CheckCircle } from '@lucide/astro';
import RecurringPendingCard from '@/components/molecules/RecurringPendingCard.astro';
import type { RecurringOccurrenceOutput } from '@/lib/types/recurring';

export interface Props {
  occurrences: RecurringOccurrenceOutput[];
  hasTemplates?: boolean;
  monthLabel?: string;
}

const { occurrences = [], hasTemplates = false, monthLabel = '' } = Astro.props;
---

<section class="space-y-4" data-testid="recurring-pending-section">
  <div class="flex items-center justify-between">
    <h2 class="text-sm font-bold uppercase tracking-widest text-base-content/50">
      Pending This Month ({occurrences.length})
    </h2>
  </div>

  {
    occurrences.length > 0 ? (
      <div class="space-y-3" id="recurring-pending-list">
        {occurrences.map((occurrence) => (
          <RecurringPendingCard occurrence={occurrence} />
        ))}
      </div>
    ) : hasTemplates ? (
      <div class="rounded-card border border-base-300 bg-base-100 p-8 text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-success/10 text-success">
          <CheckCircle size={24} aria-hidden="true" />
        </div>
        <h3 class="text-lg font-semibold text-base-content">All caught up!</h3>
        <p class="mt-2 text-sm text-base-content/60">
          {monthLabel ? `No pending bills for ${monthLabel}.` : 'No pending bills for this period.'}
        </p>
      </div>
    ) : (
      <div class="rounded-card border border-base-300 bg-base-100 p-8 text-center">
        <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-accent/10 text-accent">
          <RefreshCw size={24} aria-hidden="true" />
        </div>
        <h3 class="text-lg font-semibold text-base-content">No recurring transactions yet</h3>
        <p class="mt-2 text-sm text-base-content/60">
          Create your first recurring template to start tracking upcoming bills and income.
        </p>
        <button type="button" class="btn btn-primary btn-sm mt-5" data-open-recurring-template>
          + New Template
        </button>
      </div>
    )
  }
</section>
