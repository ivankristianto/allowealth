---
import Modal from '@/components/molecules/Modal.astro';
import { CircleMinus } from '@lucide/astro';
import Button from '@/components/atoms/Button.astro';
---

<Modal
  id="recurring-skip-modal"
  size="sm"
  closable={false}
  backdropClose={true}
  ariaLabel="Skip this occurrence"
>
  <form slot="default" id="recurring-skip-form" class="flex flex-col gap-6" novalidate>
    <div class="flex items-center gap-4">
      <div
        class="w-12 h-12 rounded-2xl flex items-center justify-center bg-warning/10 text-warning"
      >
        <CircleMinus size={24} class="stroke-current" aria-hidden="true" />
      </div>
      <div class="flex-1">
        <h2 class="text-2xl font-bold tracking-tight text-primary leading-none" data-modal-title>
          Skip this occurrence?
        </h2>
        <p class="text-base-content/60 text-sm mt-2 font-medium" data-modal-subtitle>
          You can optionally provide a reason.
        </p>
      </div>
    </div>

    <div
      id="recurring-skip-modal-error"
      class="hidden alert alert-error text-sm rounded-2xl"
      role="alert"
      aria-live="polite"
      data-confirm-error
    >
    </div>

    <div class="space-y-4">
      <div class="rounded-xl border border-base-300 bg-base-200/40 px-3 py-2.5">
        <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50">
          Occurrence
        </p>
        <p class="mt-1 text-sm font-medium text-base-content/80" data-skip-template-name></p>
      </div>

      <label class="form-control gap-1.5">
        <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50"
          >Reason (optional)</span
        >
        <textarea
          class="textarea textarea-bordered min-h-24 w-full rounded-lg border border-base-300 bg-base-100 text-sm font-medium focus:outline-none focus:border-warning focus-visible:ring-2 focus-visible:ring-warning/30"
          maxlength="200"
          placeholder="Add a note for why this occurrence is skipped"
          data-skip-reason></textarea>
        <span class="text-right text-xs text-base-content/60" aria-live="polite" data-skip-counter>
          0 / 200 characters
        </span>
      </label>
    </div>

    <div class="flex gap-4 pt-2">
      <Button
        type="button"
        variant="ghost"
        className="flex-1 h-14 font-bold border-0"
        data-confirm-cancel
      >
        Cancel
      </Button>
      <Button
        type="button"
        variant="warning"
        className="flex-1 h-14 font-bold"
        data-confirm-action
        data-loading-text="Skipping..."
        data-testid="skip-confirm-btn"
      >
        Skip
      </Button>
    </div>
  </form>
</Modal>
