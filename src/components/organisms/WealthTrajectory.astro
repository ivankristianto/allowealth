---
/**
 * WealthTrajectory Component
 *
 * Displays the forecast reality-check balance chart and summary cards.
 *
 * @param {ForecastTimelinePoint[]} timeline - Full monthly timeline from the forecast API
 * @param {ForecastChartWindow} chartWindow - Focused default viewport metadata
 * @param {object} summary - Reality-check summary statistics
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import Card from '@/components/atoms/Card.astro';
import StatLabel from '@/components/atoms/StatLabel.astro';
import Skeleton from '@/components/atoms/Skeleton.astro';
import { formatCurrencyCompact } from '@/lib/formatting';
import type { Currency } from '@/lib/constants/currency';
import type {
  ForecastChartWindow,
  ForecastRealityCheckSummary,
  ForecastTimelinePoint,
} from '@/lib/forecast';

export interface Props {
  timeline: ForecastTimelinePoint[];
  chartWindow?: ForecastChartWindow;
  summary: ForecastRealityCheckSummary;
  currency?: Currency;
  loading?: boolean;
  error?: string;
  className?: string;
}

const {
  timeline = [],
  chartWindow = {
    startIndex: 0,
    endIndex: -1,
    startKey: null,
    endKey: null,
    latestActualKey: null,
  },
  summary = {
    latestActualKey: null,
    latestActualBalance: 0,
    plannedEndingBalance: 0,
    currentTrajectoryEndingBalance: 0,
    totalForecastInterest: 0,
    trailingAverageNetSavings: 0,
  },
  currency = 'IDR',
  loading = false,
  error,
  className = '',
} = Astro.props;

// Generate unique ID for this chart instance
const chartId = `wealth-trajectory-chart-${Math.random().toString(36).slice(2, 11)}`;
const hasChartWindow = chartWindow.endIndex >= chartWindow.startIndex && chartWindow.endIndex >= 0;
const visibleTimeline = hasChartWindow
  ? timeline.slice(chartWindow.startIndex, chartWindow.endIndex + 1)
  : timeline;
const visibleChartWindow = {
  startIndex: visibleTimeline.length > 0 ? 0 : -1,
  endIndex: visibleTimeline.length > 0 ? visibleTimeline.length - 1 : -1,
  startKey: visibleTimeline[0]?.key ?? null,
  endKey: visibleTimeline[visibleTimeline.length - 1]?.key ?? null,
  latestActualKey:
    visibleTimeline.findLast((point) => point.actualBalance !== null)?.key ??
    chartWindow.latestActualKey,
};

// Serialize chart payload for client-side script
const serializedChartPayload = JSON.stringify({
  timeline: visibleTimeline,
  chartWindow: visibleChartWindow,
})
  .replace(/</g, '\\u003c')
  .replace(/>/g, '\\u003e')
  .replace(/&/g, '\\u0026');
---

<Card
  padding="lg"
  rounded="card-lg"
  className={className}
  role="region"
  aria-label="Wealth trajectory forecast"
>
  <div class="space-y-6 md:space-y-8">
    {/* Header */}
    <div class="flex-shrink-0">
      <h2 class="text-xl md:text-2xl font-bold text-base-content leading-none tracking-tight">
        Wealth Growth
      </h2>
      <p class="text-sm text-base-content/60 mt-2 font-medium">
        Compare planned growth against actual balances and the current trajectory across the focused
        forecast window.
      </p>
    </div>

    {/* Loading State */}
    {
      loading ? (
        <div class="space-y-6">
          {/* Chart skeleton */}
          <Skeleton
            variant="rectangular"
            width="100%"
            height="300px"
            className="md:h-[400px] rounded-card"
          />

          {/* Summary cards skeletons */}
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
            {Array.from({ length: 3 }).map(() => (
              <div class="p-5 md:p-6 bg-base-200/40 rounded-2xl md:rounded-xl border border-base-300/50 space-y-2">
                <Skeleton variant="text" width="40%" height="12px" />
                <Skeleton variant="heading" width="75%" height="28px" />
              </div>
            ))}
          </div>
        </div>
      ) : error ? (
        /* Error State */
        <div class="p-12 text-center">
          <p class="text-error font-medium" role="alert">
            {error}
          </p>
        </div>
      ) : timeline.length === 0 ? (
        /* Empty State */
        <div class="p-12 text-center">
          <p class="text-base-content/60 font-medium">
            Forecast needs historical balances before it can compare plan versus reality.
          </p>
        </div>
      ) : (
        /* Chart and Summary */
        <>
          {/* Chart Container */}
          <div
            id={`${chartId}-container`}
            class="h-[300px] md:h-[400px] w-full bg-base-200/20 rounded-card p-4 md:p-8 border border-base-300/50"
            data-chart-data={serializedChartPayload}
            data-chart-id={chartId}
            data-currency={currency}
          >
            <canvas
              id={chartId}
              aria-label="Wealth trajectory line chart showing planned, actual, and current trajectory balances"
              role="img"
            />
          </div>

          <table class="sr-only" aria-label="Wealth trajectory data table">
            <thead>
              <tr>
                <th>Period</th>
                <th>Planned Balance</th>
                <th>Actual Balance</th>
                <th>Current Trajectory</th>
              </tr>
            </thead>
            <tbody>
              {visibleTimeline.map((point) => (
                <tr>
                  <td>{point.dateLabel}</td>
                  <td>{point.plannedBalance ?? '—'}</td>
                  <td>{point.actualBalance ?? '—'}</td>
                  <td>{point.currentTrajectoryBalance ?? '—'}</td>
                </tr>
              ))}
            </tbody>
          </table>

          {/* Summary Statistics Cards */}
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
            {/* Latest Actual Balance */}
            <div class="p-5 md:p-6 bg-base-200/40 rounded-2xl md:rounded-xl border border-base-300/50">
              <StatLabel size="sm" color="neutral" className="mb-2">
                LATEST ACTUAL BALANCE
              </StatLabel>
              <h3 class="text-xl md:text-2xl font-bold text-base-content">
                {formatCurrencyCompact(summary.latestActualBalance, currency)}
              </h3>
            </div>

            {/* Planned Ending Balance */}
            <div class="p-5 md:p-6 bg-base-200/40 rounded-2xl md:rounded-xl border border-base-300/50">
              <StatLabel size="sm" color="neutral" className="mb-2">
                PLANNED ENDING BALANCE
              </StatLabel>
              <h3 class="text-xl md:text-2xl font-bold text-accent">
                {formatCurrencyCompact(summary.plannedEndingBalance, currency)}
              </h3>
            </div>

            {/* Current Trajectory Ending Balance */}
            <div class="p-5 md:p-6 bg-base-200/40 rounded-2xl md:rounded-xl border border-base-300/50">
              <StatLabel size="sm" color="neutral" className="mb-2">
                CURRENT TRAJECTORY ENDING BALANCE
              </StatLabel>
              <h3 class="text-xl md:text-2xl font-bold text-success">
                {formatCurrencyCompact(summary.currentTrajectoryEndingBalance, currency)}
              </h3>
            </div>
          </div>
        </>
      )
    }
  </div>
</Card>

<script>
  import { Chart } from '@/lib/chart-setup';
  import { isValidCurrency } from '@/lib/constants/currency';
  import { formatCurrencyCompact } from '@/lib/formatting/currency-client';
  import { colors } from '@/lib/tokens';
  import { createChartLifecycle, isDarkTheme } from '@/lib/utils/chart-lifecycle';
  import {
    buildWealthTrajectoryChartSeries,
    type WealthTrajectoryChartPayload,
  } from '@/components/organisms/WealthTrajectory.client';
  import type { Currency } from '@/lib/constants/currency';

  interface ChartInstance {
    chart: Chart<'line'>;
    data: WealthTrajectoryChartPayload;
  }

  // Store chart instances globally for cleanup and expose to window for client-side updates
  const charts: Record<string, ChartInstance> = {};
  (window as any).wealthTrajectoryCharts = charts;

  /**
   * Update chart colors based on current theme
   */
  function updateChartThemeColors(): void {
    const dark = isDarkTheme();

    Object.values(charts).forEach(({ chart }) => {
      if (chart.options.plugins?.tooltip) {
        chart.options.plugins.tooltip.backgroundColor = dark
          ? 'rgba(248, 250, 252, 0.95)'
          : 'rgba(15, 23, 42, 0.9)';
        chart.options.plugins.tooltip.titleColor = dark ? colors.primary : colors.primaryLight;
        chart.options.plugins.tooltip.bodyColor = dark ? colors.primary : colors.primaryLight;
        chart.update('none');
      }
    });
  }

  function readThemeColor(variableName: string, fallback: string): string {
    const value = getComputedStyle(document.documentElement).getPropertyValue(variableName).trim();
    return value || fallback;
  }

  /**
   * Initialize wealth trajectory chart
   */
  function initWealthTrajectoryChart(
    chartId: string,
    payload: WealthTrajectoryChartPayload,
    currency: Currency
  ): void {
    const canvas = document.getElementById(chartId) as HTMLCanvasElement;
    if (!canvas) return;

    // Destroy existing chart if it exists
    if (charts[chartId]?.chart) {
      charts[chartId].chart.destroy();
    }

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Prepare chart data
    const { labels, plannedBalance, actualBalance, currentTrajectoryBalance } =
      buildWealthTrajectoryChartSeries(payload.timeline, payload.chartWindow);
    if (labels.length === 0) return;

    const dark = isDarkTheme();

    const plannedColor = readThemeColor('--color-accent', colors.accent);
    const actualColor = readThemeColor('--color-info', colors.info);
    const currentTrajectoryColor = readThemeColor('--color-warning', colors.warning);
    const gridColor = dark ? 'rgba(148, 163, 184, 0.1)' : 'rgba(148, 163, 184, 0.15)';
    const textColor = dark ? colors.slate[400] : colors.slate[500];

    const chart = new Chart<'line'>(ctx, {
      type: 'line',
      data: {
        labels,
        datasets: [
          {
            label: 'Planned Balance',
            data: plannedBalance,
            borderColor: plannedColor,
            backgroundColor: plannedColor,
            borderWidth: 3,
            fill: false,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 6,
            pointBackgroundColor: plannedColor,
            spanGaps: false,
          },
          {
            label: 'Actual Balance',
            data: actualBalance,
            borderColor: actualColor,
            backgroundColor: actualColor,
            borderWidth: 3,
            fill: false,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 6,
            pointBackgroundColor: actualColor,
            spanGaps: false, // Don't connect null values
          },
          {
            label: 'Current Trajectory',
            data: currentTrajectoryBalance,
            borderColor: currentTrajectoryColor,
            backgroundColor: currentTrajectoryColor,
            borderWidth: 3,
            borderDash: [8, 6],
            fill: false,
            tension: 0.4,
            pointRadius: 0,
            pointHoverRadius: 6,
            pointBackgroundColor: currentTrajectoryColor,
            spanGaps: false,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
        },
        plugins: {
          legend: {
            display: true,
            position: 'top',
            align: 'center',
            labels: {
              color: textColor,
              font: {
                size: 12,
                weight: 600 as any,
              },
              usePointStyle: true,
              pointStyle: 'circle',
              padding: 16,
            },
          },
          tooltip: {
            backgroundColor: dark ? 'rgba(248, 250, 252, 0.95)' : 'rgba(15, 23, 42, 0.9)',
            titleColor: dark ? colors.primary : colors.primaryLight,
            bodyColor: dark ? colors.primary : colors.primaryLight,
            padding: 12,
            cornerRadius: 8,
            displayColors: true,
            callbacks: {
              label: (context) => {
                const label = context.dataset.label || '';
                const value = context.parsed.y;
                if (value === null) return '';
                return `${label}: ${formatCurrencyCompact(value, currency)}`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: {
              display: false,
            },
            ticks: {
              color: textColor,
              font: {
                size: 10,
                weight: 600 as any,
              },
              maxRotation: 0,
              autoSkip: true,
              maxTicksLimit: 12,
            },
            border: {
              display: false,
            },
          },
          y: {
            grid: {
              color: gridColor,
            },
            ticks: {
              color: textColor,
              font: {
                size: 10,
                weight: 600 as any,
              },
              callback: (value) => {
                return formatCurrencyCompact(Number(value), currency);
              },
            },
            border: {
              display: false,
            },
          },
        },
      },
    });

    // @TODO: P3 - Remove 'as any' type assertion by properly typing the chart variable
    charts[chartId] = { chart: chart as any, data: payload };
  }

  function isNullableFiniteNumber(value: unknown): value is number | null {
    return value === null || (typeof value === 'number' && isFinite(value));
  }

  function parseChartData(raw: unknown): WealthTrajectoryChartPayload | null {
    if (!raw || typeof raw !== 'object') return null;

    const candidate = raw as Partial<WealthTrajectoryChartPayload>;
    if (!Array.isArray(candidate.timeline) || !candidate.chartWindow) return null;

    const validTimeline = candidate.timeline.filter(
      (item) =>
        typeof item?.key === 'string' &&
        typeof item?.dateLabel === 'string' &&
        item.dateLabel.length > 0 &&
        item.dateLabel.length <= 50 &&
        isNullableFiniteNumber(item?.plannedBalance) &&
        isNullableFiniteNumber(item?.actualBalance) &&
        isNullableFiniteNumber(item?.currentTrajectoryBalance)
    );
    if (
      typeof candidate.chartWindow.startIndex !== 'number' ||
      typeof candidate.chartWindow.endIndex !== 'number'
    ) {
      return null;
    }

    return validTimeline.length > 0
      ? {
          timeline: validTimeline,
          chartWindow: candidate.chartWindow,
        }
      : null;
  }

  const lifecycle = createChartLifecycle<WealthTrajectoryChartPayload>({
    containerSelector: '[id^="wealth-trajectory-chart-"][id$="-container"]',
    parseData: parseChartData,
    onInit: (container, data) => {
      const chartId = container.querySelector('canvas')?.id;
      if (!chartId || charts[chartId]) return;
      const currencyAttr = container.getAttribute('data-currency');
      const currency: Currency =
        currencyAttr && isValidCurrency(currencyAttr) ? currencyAttr : 'IDR';
      initWealthTrajectoryChart(chartId, data, currency);
    },
    onThemeChange: updateChartThemeColors,
    onCleanup: () => {
      Object.keys(charts).forEach((chartId) => {
        const entry = charts[chartId];
        if (entry?.chart) {
          try {
            entry.chart.destroy();
          } catch (e) {
            // Chart may already be destroyed
          }
        }
        delete charts[chartId];
      });
    },
  });

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', lifecycle.init);
  } else {
    lifecycle.init();
  }

  // Cleanup on page navigation/unload
  window.addEventListener('beforeunload', lifecycle.cleanup);

  // For Astro View Transitions
  // @TODO: P2 - Performance: Check if charts exist before reinitializing to avoid unnecessary work
  document.addEventListener('astro:before-swap', lifecycle.cleanup);
  document.addEventListener('astro:after-swap', lifecycle.init);
</script>
