---
/**
 * AccountsWidget Component
 *
 * Displays total accounts and total debt grouped by currency.
 */
import { Landmark, Wallet, CreditCard } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import EmptyState from '@/components/atoms/EmptyState.astro';
import DashboardWidget from '@/components/organisms/DashboardWidget.astro';
import Skeleton from '@/components/atoms/Skeleton.astro';
import StatLabel from '@/components/atoms/StatLabel.astro';
import IconBadge from '@/components/atoms/IconBadge.astro';

export interface Props {
  accountTotals: Array<{ currency: Currency; amount: number }>;
  debtTotals?: Array<{ currency: Currency; amount: number }>;
  primaryCurrency: Currency;
  secondaryCurrency?: Currency | null;
  loading?: boolean;
  className?: string;
}

const {
  accountTotals,
  debtTotals = [],
  primaryCurrency,
  secondaryCurrency = null,
  loading = false,
  className = '',
} = Astro.props;

const orderedCurrencies = [primaryCurrency, ...(secondaryCurrency ? [secondaryCurrency] : [])];
const sortByWorkspacePreference = (
  a: { currency: Currency },
  b: { currency: Currency }
): number => {
  const aIndex = orderedCurrencies.indexOf(a.currency);
  const bIndex = orderedCurrencies.indexOf(b.currency);
  if (aIndex !== -1 && bIndex !== -1) return aIndex - bIndex;
  if (aIndex !== -1) return -1;
  if (bIndex !== -1) return 1;
  return a.currency.localeCompare(b.currency);
};

const normalizeTotals = (
  totals: Array<{ currency: Currency; amount: number }>
): Array<{ currency: Currency; amount: number }> => {
  const preferred = orderedCurrencies.map((currency) => ({
    currency,
    amount: totals.find((row) => row.currency === currency)?.amount ?? 0,
  }));
  const extras = totals
    .filter((row) => !orderedCurrencies.includes(row.currency))
    .sort(sortByWorkspacePreference);
  return [...preferred, ...extras];
};

const normalizedAccountTotals = normalizeTotals(accountTotals);
const normalizedDebtTotals = normalizeTotals(debtTotals);
const hasAccountValue = normalizedAccountTotals.some((row) => row.amount > 0);
const hasDebtValue = normalizedDebtTotals.some((row) => row.amount > 0);

const isEmpty = !hasAccountValue && !hasDebtValue;
const hasDebt = hasDebtValue;
const hasNoAccounts = !hasAccountValue;

const badge =
  'inline-flex items-center px-1.5 py-0.5 rounded text-xs font-bold uppercase tracking-wider shrink-0';

const cardClasses = [
  'relative overflow-hidden',
  loading && 'pointer-events-none opacity-70',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<DashboardWidget
  loading={loading}
  isEmpty={isEmpty}
  ariaLabel={loading ? 'Loading account summary...' : 'Account summary'}
  testId="dashboard-accounts-widget"
  class={cardClasses}
>
  <!-- Loading skeleton -->
  <div slot="loading" aria-hidden="true">
    <div class="flex items-center gap-3">
      <Skeleton variant="rectangular" width="2.75rem" height="2.75rem" className="rounded-2xl" />
      <Skeleton variant="text" width="8rem" />
    </div>

    <div class="mt-6">
      <div class="flex items-center gap-2 mb-3">
        <Skeleton variant="circular" width="16px" height="16px" />
        <Skeleton variant="text" width="6rem" />
      </div>
      <div class="space-y-2">
        <Skeleton variant="text" width="85%" height="20px" />
        <Skeleton variant="text" width="70%" height="20px" />
      </div>
    </div>

    <div class="border-t border-base-300 pt-5 mt-5">
      <div class="flex items-center gap-2 mb-3">
        <Skeleton variant="circular" width="16px" height="16px" />
        <Skeleton variant="text" width="5rem" />
      </div>
      <Skeleton variant="text" width="60%" height="20px" />
    </div>
  </div>

  <!-- Empty state -->
  <EmptyState
    slot="empty"
    title="No accounts yet"
    message="Add your first account to start tracking your finances."
    iconName="wallet"
    actionLabel="Add Account"
    actionHref="/accounts"
    variant="centered"
    className="py-4"
  />

  <!-- Normal content -->
  <div class="@container">
    <div class="flex items-center gap-3">
      <IconBadge variant="accent" size="sm">
        <Landmark size={20} class="stroke-current" aria-hidden="true" />
      </IconBadge>
      <StatLabel size="md" color="neutral">Your Accounts</StatLabel>
    </div>

    <div class="mt-6">
      <div class="flex items-center gap-2 mb-3">
        <Wallet size={16} class="stroke-current text-success" aria-hidden="true" />
        <StatLabel size="sm" color="neutral">Total Balance</StatLabel>
      </div>
      <div class="space-y-2">
        {
          normalizedAccountTotals.map((row, index) => (
            <div class="flex items-center gap-2.5">
              <span
                class={`${badge} ${index === 0 ? 'bg-success/10 text-success' : 'bg-info/10 text-info'}`}
              >
                {row.currency}
              </span>
              <p
                class={`text-lg font-bold tracking-tight leading-none truncate ${index === 0 ? 'text-success' : 'text-info'}`}
              >
                {formatCurrency(row.amount, row.currency)}
              </p>
            </div>
          ))
        }
        {hasNoAccounts && <p class="text-sm text-base-content/40">No accounts</p>}
      </div>
    </div>

    {
      hasDebt && (
        <div class="border-t border-base-300 pt-5 mt-5">
          <div class="flex items-center gap-2 mb-3">
            <CreditCard size={16} class="stroke-current text-error" aria-hidden="true" />
            <StatLabel size="sm" color="neutral">
              Total Debt
            </StatLabel>
          </div>
          <div class="space-y-2">
            {normalizedDebtTotals.map((row, index) => (
              <div class="flex items-center gap-2.5">
                <span
                  class={`${badge} ${index === 0 ? 'bg-success/10 text-success' : 'bg-info/10 text-info'}`}
                >
                  {row.currency}
                </span>
                <p class="text-lg font-bold text-error tracking-tight leading-none truncate">
                  {formatCurrency(row.amount, row.currency)}
                </p>
              </div>
            ))}
          </div>
        </div>
      )
    }
  </div>
</DashboardWidget>
