---
import {
  CircleMinus,
  CirclePlus,
  EllipsisVertical,
  Pause,
  Play,
  Ban,
  Pencil,
  Search,
} from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import ProgressBar from '@/components/atoms/ProgressBar.astro';
import RecurringTemplateRow from '@/components/molecules/RecurringTemplateRow.astro';
import EmptyState from '@/components/atoms/EmptyState.astro';
import type { RecurringTemplateOutput } from '@/lib/types/recurring';

export interface Props {
  templates: RecurringTemplateOutput[];
  total?: number;
  page?: number;
  limit?: number;
  type?: string;
  search?: string;
}

const { templates = [], total = 0, page = 1, limit = 20, type = 'all', search = '' } = Astro.props;

const totalPages = Math.max(1, Math.ceil(total / limit));
const startItem = total === 0 ? 0 : (page - 1) * limit + 1;
const endItem = Math.min(page * limit, total);
const paginationButtonClass =
  'btn btn-sm rounded-2xl border border-base-300 bg-base-100 text-base-content hover:bg-base-200 hover:border-accent focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 min-h-[44px] min-w-[44px] sm:min-w-0';
const paginationCurrentClass =
  'inline-flex items-center justify-center min-h-[44px] rounded-2xl border border-base-300 bg-base-200 px-3 text-sm font-medium text-base-content';

const statusClassMap: Record<RecurringTemplateOutput['status'], string> = {
  active: 'badge-success',
  paused: 'badge-warning',
  completed: 'badge-ghost',
  cancelled: 'badge-error',
};

function daySuffix(day: number): string {
  const mod10 = day % 10;
  const mod100 = day % 100;
  if (mod10 === 1 && mod100 !== 11) return `${day}st`;
  if (mod10 === 2 && mod100 !== 12) return `${day}nd`;
  if (mod10 === 3 && mod100 !== 13) return `${day}rd`;
  return `${day}th`;
}
---

<section class="space-y-3 sm:space-y-4" data-testid="recurring-template-list">
  {/* Filter bar */}
  <div class="flex flex-wrap items-center gap-2">
    <div class="flex items-center gap-1">
      <button
        data-filter-type="all"
        class:list={[
          'btn btn-sm btn-ghost rounded-xl font-semibold',
          type === 'all' && 'btn-active',
        ]}
      >
        All
      </button>
      <button
        data-filter-type="expense"
        class:list={[
          'btn btn-sm btn-ghost rounded-xl font-semibold',
          type === 'expense' && 'btn-active',
        ]}
      >
        Expenses
      </button>
      <button
        data-filter-type="income"
        class:list={[
          'btn btn-sm btn-ghost rounded-xl font-semibold',
          type === 'income' && 'btn-active',
        ]}
      >
        Income
      </button>
    </div>
    <div class="flex-1"></div>
    <label class="input input-sm input-bordered flex items-center gap-2 w-48 rounded-xl">
      <Search size={14} class="text-base-content/40" aria-hidden="true" />
      <input
        type="search"
        placeholder="Search..."
        class="grow bg-transparent border-none outline-none text-sm"
        data-template-search
        value={search}
      />
    </label>
  </div>
  {
    templates.length === 0 ? (
      <div class="rounded-2xl border border-base-300 bg-base-100 shadow-sm">
        <EmptyState
          title="No recurring transactions found"
          message={
            search
              ? `No results for "${search}".`
              : 'Set up recurring bills or income to automate your tracking.'
          }
          iconName="receipt"
          variant="centered"
        />
      </div>
    ) : (
      <>
        {/* Desktop table */}
        <div class="hidden md:block overflow-x-auto rounded-2xl border border-base-300 bg-base-100 shadow-sm">
          <table class="table table-zebra">
            <thead>
              <tr class="border-b border-base-300">
                <th class="text-xs font-bold uppercase tracking-wider text-base-content/40">
                  Name
                </th>
                <th class="text-xs font-bold uppercase tracking-wider text-base-content/40">
                  Amount
                </th>
                <th class="text-xs font-bold uppercase tracking-wider text-base-content/40">
                  Recurrence
                </th>
                <th class="text-xs font-bold uppercase tracking-wider text-base-content/40">
                  Status
                </th>
                <th class="w-12" />
              </tr>
            </thead>
            <tbody>
              {templates.map((template) => (
                <RecurringTemplateRow template={template} />
              ))}
            </tbody>
          </table>

          {/* Pagination */}
          {totalPages > 1 && (
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3 px-4 sm:px-6 py-4 border-t border-base-300">
              <span class="hidden sm:block text-sm text-base-content/60">
                {startItem}-{endItem} of {total}
              </span>
              <div class="flex items-center gap-2 w-full sm:w-auto justify-between sm:justify-end">
                <button
                  class={paginationButtonClass}
                  disabled={page <= 1}
                  data-template-page={page - 1}
                  aria-label="Previous page"
                >
                  Previous
                </button>

                <span class={paginationCurrentClass}>
                  {page} / {totalPages}
                </span>

                <button
                  class={paginationButtonClass}
                  disabled={page >= totalPages}
                  data-template-page={page + 1}
                  aria-label="Next page"
                >
                  Next
                </button>
              </div>
            </div>
          )}
        </div>

        {/* Mobile cards */}
        <div class="md:hidden space-y-3">
          {templates.map((template) => {
            const payload = JSON.stringify(template);
            const installmentProgress =
              template.is_installment && template.total_occurrences
                ? Math.min(
                    100,
                    Math.round((template.confirmedCount / template.total_occurrences) * 100)
                  )
                : 0;

            return (
              <article
                class:list={[
                  'rounded-2xl border border-base-300 bg-base-100 p-4 space-y-3 shadow-sm hover:shadow-md transition-shadow duration-200',
                  template.status === 'paused' && 'opacity-60',
                ]}
                data-testid="recurring-template-row"
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="min-w-0">
                    <div class="flex items-center gap-2">
                      {template.type === 'expense' ? (
                        <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-error/10 shrink-0">
                          <CircleMinus size={14} class="text-error" aria-hidden="true" />
                        </div>
                      ) : (
                        <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-success/10 shrink-0">
                          <CirclePlus size={14} class="text-success" aria-hidden="true" />
                        </div>
                      )}
                      <h3 class="font-semibold truncate" title={template.name}>
                        {template.name}
                      </h3>
                    </div>
                    <p class="text-sm font-bold text-base-content mt-1 ml-9">
                      {formatCurrency(template.amount, template.currency)}
                    </p>
                  </div>
                  <div class="flex items-center gap-2 shrink-0">
                    <span class={`badge badge-sm font-bold ${statusClassMap[template.status]}`}>
                      {template.status}
                    </span>
                    <div class="dropdown dropdown-end">
                      <button
                        type="button"
                        tabindex={0}
                        class="btn btn-ghost btn-sm btn-square rounded-xl"
                        aria-label="Template actions"
                      >
                        <EllipsisVertical size={16} aria-hidden="true" />
                      </button>
                      <ul
                        tabindex={0}
                        class="dropdown-content z-40 menu p-2 shadow-lg bg-base-100 rounded-2xl w-44 border border-base-300"
                      >
                        <li>
                          <button
                            type="button"
                            class="rounded-xl"
                            data-template-action="edit"
                            data-template={payload}
                          >
                            <Pencil size={15} aria-hidden="true" />
                            Edit
                          </button>
                        </li>
                        {template.status === 'active' ? (
                          <li>
                            <button
                              type="button"
                              class="rounded-xl"
                              data-template-action="pause"
                              data-template-id={template.id}
                            >
                              <Pause size={15} aria-hidden="true" />
                              Pause
                            </button>
                          </li>
                        ) : template.status === 'paused' ? (
                          <li>
                            <button
                              type="button"
                              class="rounded-xl"
                              data-template-action="resume"
                              data-template-id={template.id}
                            >
                              <Play size={15} aria-hidden="true" />
                              Resume
                            </button>
                          </li>
                        ) : null}
                        {template.status !== 'cancelled' && template.status !== 'completed' && (
                          <li>
                            <button
                              type="button"
                              data-template-action="cancel"
                              data-template-id={template.id}
                              data-template-name={template.name}
                              class="text-error rounded-xl"
                            >
                              <Ban size={15} aria-hidden="true" />
                              Cancel
                            </button>
                          </li>
                        )}
                      </ul>
                    </div>
                  </div>
                </div>

                {template.is_installment && template.total_occurrences && (
                  <div class="flex items-center gap-2 ml-9">
                    <ProgressBar value={installmentProgress} size="sm" className="w-16" />
                    <span class="text-xs text-base-content/60 font-medium">
                      {template.confirmedCount}/{template.total_occurrences}
                    </span>
                  </div>
                )}

                <div class="text-xs text-base-content/50 ml-9 font-medium">
                  <span>Every {daySuffix(template.day_of_month)}</span>
                  {template.nextDueDate && (
                    <>
                      <span class="mx-2 text-base-content/30">&middot;</span>
                      <span>Next: {template.nextDueDate}</span>
                    </>
                  )}
                </div>
              </article>
            );
          })}

          {/* Mobile pagination */}
          {totalPages > 1 && (
            <div class="flex flex-col sm:flex-row items-center justify-between gap-3 px-2 sm:px-0 py-3">
              <span class="text-sm text-base-content/60">
                {startItem}-{endItem} of {total}
              </span>
              <div class="flex items-center gap-2 w-full justify-between">
                <button
                  class={paginationButtonClass}
                  disabled={page <= 1}
                  data-template-page={page - 1}
                  aria-label="Previous page"
                >
                  Previous
                </button>

                <span class={paginationCurrentClass}>
                  {page} / {totalPages}
                </span>

                <button
                  class={paginationButtonClass}
                  disabled={page >= totalPages}
                  data-template-page={page + 1}
                  aria-label="Next page"
                >
                  Next
                </button>
              </div>
            </div>
          )}
        </div>
      </>
    )
  }
</section>
