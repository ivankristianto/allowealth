---
/**
 * AccountTable Component
 *
 * Table view for accounts grouped by class with inline header rows.
 * Group order: Liquid -> Debt -> Non-Liquid.
 */

import AccountTableRow from '@/components/molecules/AccountTableRow.astro';
import { formatCurrency } from '@/lib/formatting';
import {
  calculateClassAllocation,
  calculateGroupTotalsByCurrency,
  groupAccountsByClass,
} from '@/lib/utils/account';
import {
  ACCOUNT_CLASS_LABELS,
  ACCOUNT_TYPE_LABELS,
  type AccountClass,
  type AccountOutput,
} from '@/lib/types/account';
import type { Currency } from '@/lib/constants/currency';
import { Ellipsis, Eye, Pencil, PowerOff, TrendingUp, Wallet } from '@lucide/astro';
import Button from '@/components/atoms/Button.astro';

const ACCOUNT_CLASS_SUBTITLES: Record<AccountClass, string> = {
  liquid: 'Cash & equivalents',
  debt: 'Liabilities & loans',
  non_liquid: 'Investments & holdings',
};

const CLASS_ORDER: AccountClass[] = ['liquid', 'debt', 'non_liquid'];

const GROUP_COLORS: Record<
  AccountClass,
  {
    band: string;
    rail: string;
    label: string;
    meta: string;
    badge: string;
  }
> = {
  liquid: {
    band: 'bg-base-200/70',
    rail: 'bg-accent/20',
    label: 'text-accent',
    meta: 'text-base-content/60',
    badge: 'border border-accent/20 bg-accent/10 text-accent',
  },
  debt: {
    band: 'bg-base-200/70',
    rail: 'bg-warning/20',
    label: 'text-warning',
    meta: 'text-base-content/60',
    badge: 'border border-warning/20 bg-warning/10 text-warning',
  },
  non_liquid: {
    band: 'bg-base-200/70',
    rail: 'bg-info/20',
    label: 'text-info',
    meta: 'text-base-content/60',
    badge: 'border border-info/20 bg-info/10 text-info',
  },
};

export interface AccountWithDisplay extends AccountOutput {
  owner_name?: string;
  category_name?: string | null;
}

export interface Props {
  accounts: AccountWithDisplay[];
  primaryCurrency: Currency;
  currencyOrder: Currency[];
  isHistoricalView?: boolean;
}

const {
  accounts = [],
  primaryCurrency,
  currencyOrder = [],
  isHistoricalView = false,
} = Astro.props;

function formatShortDate(value: Date): string {
  return new Date(value).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
  });
}

function formatGroupTotal(amount: number, currency: Currency, groupClass: AccountClass): string {
  return formatCurrency(groupClass === 'debt' ? -Math.abs(amount) : amount, currency);
}

const accountsByClass = groupAccountsByClass(accounts);
const allocationByClass = calculateClassAllocation(accounts, primaryCurrency);

const groups = CLASS_ORDER.filter((classKey) => accountsByClass[classKey].length > 0).map(
  (classKey) => ({
    classKey,
    label: ACCOUNT_CLASS_LABELS[classKey],
    subtitle: ACCOUNT_CLASS_SUBTITLES[classKey],
    accounts: accountsByClass[classKey],
    totals: calculateGroupTotalsByCurrency(accountsByClass[classKey], currencyOrder).filter(
      (total) => total.amount > 0
    ),
    allocation: allocationByClass[classKey],
    colors: GROUP_COLORS[classKey],
  })
);

const sortableHeaderButtonClass =
  'inline-flex w-full items-center gap-2 rounded-md text-left transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent focus-visible:text-base-content/70';

const sortableHeaderButtonRightAlignedClass = `${sortableHeaderButtonClass} justify-end text-right`;
---

{
  groups.length === 0 ? (
    <div class="flex flex-col items-center justify-center py-16 text-center">
      <div class="mb-4 flex h-16 w-16 items-center justify-center rounded-2xl bg-base-200">
        <Wallet size={32} class="stroke-base-content/40" aria-hidden="true" />
      </div>
      <h2 class="mb-2 text-lg font-bold text-base-content">No accounts found</h2>
      <p class="max-w-sm text-sm text-neutral">
        Add your first account to start tracking your portfolio.
      </p>
    </div>
  ) : (
    <div class="rounded-card border border-base-300 bg-base-100 shadow-sm" data-account-table>
      <div class="overflow-hidden">
        <div class="hidden overflow-x-auto md:block">
          <table class="min-w-[1120px] w-full border-collapse text-left">
            <thead>
              <tr class="border-b border-base-300 bg-base-200/50">
                <th
                  class="px-3 py-4 pl-4 text-xs font-bold uppercase tracking-widest text-base-content/40 md:px-4 md:pl-6"
                  data-sort-key="name"
                  aria-sort="none"
                >
                  <button type="button" class={sortableHeaderButtonClass} data-sort-button>
                    <span>Account</span>
                    <span class="text-base-content/20" data-sort-indicator="name">
                      ^v
                    </span>
                  </button>
                </th>
                <th
                  class="px-3 py-4 text-xs font-bold uppercase tracking-widest text-base-content/40 md:px-4"
                  data-sort-key="type"
                  aria-sort="none"
                >
                  <button type="button" class={sortableHeaderButtonClass} data-sort-button>
                    <span>Type</span>
                    <span class="text-base-content/20" data-sort-indicator="type">
                      ^v
                    </span>
                  </button>
                </th>
                <th
                  class="px-3 py-4 text-xs font-bold uppercase tracking-widest text-base-content/40 md:px-4"
                  data-sort-key="category"
                  aria-sort="none"
                >
                  <button type="button" class={sortableHeaderButtonClass} data-sort-button>
                    <span>Category</span>
                    <span class="text-base-content/20" data-sort-indicator="category">
                      ^v
                    </span>
                  </button>
                </th>
                <th
                  class="px-3 py-4 text-xs font-bold uppercase tracking-widest text-base-content/40 md:px-4"
                  data-sort-key="owner"
                  aria-sort="none"
                >
                  <button type="button" class={sortableHeaderButtonClass} data-sort-button>
                    <span>Owner</span>
                    <span class="text-base-content/20" data-sort-indicator="owner">
                      ^v
                    </span>
                  </button>
                </th>
                <th
                  class="px-3 py-4 text-right text-xs font-bold uppercase tracking-widest text-base-content/40 md:px-4"
                  data-sort-key="balance"
                  aria-sort="none"
                >
                  <button
                    type="button"
                    class={sortableHeaderButtonRightAlignedClass}
                    data-sort-button
                  >
                    <span>Balance</span>
                    <span class="text-base-content/20" data-sort-indicator="balance">
                      ^v
                    </span>
                  </button>
                </th>
                <th
                  class="px-3 py-4 text-xs font-bold uppercase tracking-widest text-base-content/40 md:px-4"
                  data-sort-key="updated"
                  aria-sort="none"
                >
                  <button type="button" class={sortableHeaderButtonClass} data-sort-button>
                    <span>Updated</span>
                    <span class="text-base-content/20" data-sort-indicator="updated">
                      ^v
                    </span>
                  </button>
                </th>
                <th class="px-3 py-4 text-center text-xs font-bold uppercase tracking-widest text-base-content/40 md:px-4">
                  Actions
                </th>
              </tr>
            </thead>

            <tbody>
              {groups.map((group) => (
                <>
                  <tr
                    class={`border-y border-base-300 ${group.colors.band}`}
                    data-group-header={group.classKey}
                  >
                    <td colspan={7} class="px-3 py-3 md:px-4">
                      <div class="flex flex-wrap items-center justify-between gap-3">
                        <div class="flex flex-wrap items-center gap-2.5">
                          <span class={`h-7 w-1 rounded-full ${group.colors.rail}`} />
                          <span
                            class={`text-sm font-bold uppercase tracking-widest ${group.colors.label}`}
                          >
                            {group.label}
                          </span>
                          <span class={`text-xs ${group.colors.meta}`}>{group.subtitle}</span>
                          <span
                            class={`rounded-full px-2 py-0.5 text-xs font-semibold ${group.colors.badge}`}
                          >
                            {group.accounts.length}{' '}
                            {group.accounts.length === 1 ? 'account' : 'accounts'}
                          </span>
                        </div>

                        <div class="flex flex-wrap items-center justify-end gap-2 text-xs">
                          {group.totals.map((total, index) => (
                            <span
                              class={index === 0 ? 'text-base-content' : 'text-base-content/60'}
                            >
                              {formatGroupTotal(total.amount, total.currency, group.classKey)}
                            </span>
                          ))}
                          {group.allocation.percentage > 0 && (
                            <span
                              class={`rounded-full px-2.5 py-0.5 text-xs font-semibold ${group.colors.badge}`}
                            >
                              {group.allocation.percentage}% of {primaryCurrency}
                              {group.allocation.onTarget && <span aria-hidden="true">&check;</span>}
                            </span>
                          )}
                        </div>
                      </div>
                    </td>
                  </tr>

                  {group.accounts.map((account) => (
                    <AccountTableRow
                      id={account.id}
                      name={account.name}
                      type={account.type}
                      accountClass={account.account_class}
                      ownerUserId={account.created_by_user_id}
                      ownerName={account.owner_name}
                      categoryId={account.category_id}
                      categoryName={account.category_name}
                      currency={account.currency}
                      balance={Number.parseFloat(account.balance || '0')}
                      lastUpdated={new Date(account.last_updated)}
                      isHistoricalView={isHistoricalView}
                      isDimmed={account.currency !== primaryCurrency}
                    />
                  ))}
                </>
              ))}
            </tbody>
          </table>
        </div>

        <div class="md:hidden">
          {groups.map((group) => (
            <>
              <div
                class={`border-b border-base-300 px-3 py-3 ${group.colors.band}`}
                data-group-header={group.classKey}
              >
                <div class="flex items-start justify-between gap-3">
                  <div class="flex items-start gap-3">
                    <span class={`mt-0.5 h-8 w-1 rounded-full ${group.colors.rail}`} />
                    <div>
                      <div
                        class={`text-sm font-bold uppercase tracking-widest ${group.colors.label}`}
                      >
                        {group.label}
                      </div>
                      <div class={`mt-0.5 text-xs ${group.colors.meta}`}>{group.subtitle}</div>
                    </div>
                  </div>

                  {group.allocation.percentage > 0 && (
                    <span
                      class={`rounded-full px-2 py-0.5 text-xs font-semibold ${group.colors.badge}`}
                    >
                      {group.allocation.percentage}% of {primaryCurrency}
                      {group.allocation.onTarget && <span aria-hidden="true">&check;</span>}
                    </span>
                  )}
                </div>

                <div class="mt-2 flex flex-wrap items-center gap-2 text-xs text-base-content/70">
                  <span>
                    {group.accounts.length} {group.accounts.length === 1 ? 'account' : 'accounts'}
                  </span>
                  {group.totals.map((total) => (
                    <span>{formatGroupTotal(total.amount, total.currency, group.classKey)}</span>
                  ))}
                </div>
              </div>

              {group.accounts.map((account) => {
                const rawBalance = Number.parseFloat(account.balance || '0');
                const balance = Number.isFinite(rawBalance) ? rawBalance : 0;
                const isDebt = account.account_class === 'debt';
                const displayBalance = isDebt ? -Math.abs(balance) : balance;
                const isDimmed = account.currency !== primaryCurrency;
                const typeLabel = ACCOUNT_TYPE_LABELS[account.type] || account.type;
                const categoryLabel = account.category_name?.trim() || null;
                const secondaryMeta = [categoryLabel, account.owner_name]
                  .filter(Boolean)
                  .join(' | ');
                const formattedDate = formatShortDate(new Date(account.last_updated));

                return (
                  <div
                    class:list={['border-b border-base-300 px-3 py-3', isDimmed && 'opacity-50']}
                    data-account-table-row={account.id}
                    data-account-name={account.name.toLowerCase()}
                  >
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        <a
                          href={`/accounts/${account.id}`}
                          class="block truncate text-sm font-semibold text-base-content underline decoration-base-content/20 underline-offset-2 transition-colors hover:text-accent hover:decoration-accent"
                        >
                          {account.name}
                        </a>
                        <div class="mt-1 text-xs text-base-content/60">{typeLabel}</div>
                        {secondaryMeta && (
                          <div class="mt-1 text-xs text-base-content/50">{secondaryMeta}</div>
                        )}
                      </div>

                      {!isHistoricalView && (
                        <div class="dropdown dropdown-end shrink-0" data-dropdown-menu>
                          <button
                            type="button"
                            tabindex={0}
                            class="btn btn-ghost btn-xs btn-square min-h-11 min-w-11 rounded-lg border-0 text-base-content/50 hover:bg-base-200 hover:text-base-content"
                            aria-label={`Actions for ${account.name}`}
                            aria-haspopup="menu"
                          >
                            <Ellipsis size={16} class="stroke-current" aria-hidden="true" />
                          </button>

                          <ul
                            tabindex={0}
                            class="dropdown-content z-50 menu w-48 rounded-xl border border-base-300 bg-base-100 p-2 shadow-lg"
                            role="menu"
                          >
                            <li role="none">
                              <button
                                type="button"
                                role="menuitem"
                                class="flex items-center gap-2 rounded-xl"
                                aria-label={`Update ${account.name} balance`}
                                data-update-value-account={account.id}
                                data-account-name={account.name}
                                data-account-currency={account.currency}
                                data-account-balance={balance}
                                data-testid="account-update-value-btn"
                              >
                                <TrendingUp size={16} class="stroke-current" aria-hidden="true" />
                                Update Balance
                              </button>
                            </li>
                            <li role="none">
                              <button
                                type="button"
                                role="menuitem"
                                class="flex items-center gap-2 rounded-xl"
                                aria-label={`Edit ${account.name} details`}
                                data-edit-account={account.id}
                                data-account-name={account.name}
                                data-account-type={account.type}
                                data-account-category-id={account.category_id || ''}
                                data-account-category-name={categoryLabel}
                                data-account-owner-id={account.created_by_user_id || ''}
                                data-account-currency={account.currency}
                                data-account-balance={balance}
                                data-testid="account-edit-btn"
                              >
                                <Pencil size={16} class="stroke-current" aria-hidden="true" />
                                Edit Details
                              </button>
                            </li>
                            <li role="none">
                              <button
                                type="button"
                                role="menuitem"
                                class="flex items-center gap-2 rounded-xl"
                                aria-label={`View ${account.name} timeline`}
                                data-history-account={account.id}
                                data-account-name={account.name}
                                data-account-type={categoryLabel}
                                data-account-currency={account.currency}
                                data-account-balance={balance}
                                data-testid="account-history-btn"
                              >
                                <TrendingUp size={16} class="stroke-current" aria-hidden="true" />
                                View Timeline
                              </button>
                            </li>
                            <li role="none">
                              <a
                                href={`/accounts/${account.id}`}
                                role="menuitem"
                                class="flex items-center gap-2 rounded-xl"
                                aria-label={`View ${account.name} details`}
                              >
                                <Eye size={16} class="stroke-current" aria-hidden="true" />
                                Details
                              </a>
                            </li>
                            <li role="none">
                              <button
                                type="button"
                                role="menuitem"
                                class="flex items-center gap-2 rounded-xl text-warning"
                                aria-label={`Deactivate ${account.name}`}
                                data-close-account={account.id}
                                data-account-name={account.name}
                                data-account-type={categoryLabel}
                                data-account-currency={account.currency}
                                data-account-balance={balance}
                                data-testid="account-close-btn"
                              >
                                <PowerOff size={16} class="stroke-current" aria-hidden="true" />
                                Deactivate
                              </button>
                            </li>
                          </ul>
                        </div>
                      )}
                    </div>

                    <div class="mt-3 flex items-center justify-between gap-3">
                      <div>
                        <div
                          class:list={[
                            'text-sm font-semibold tabular-nums',
                            isDebt ? 'text-error' : 'text-base-content',
                          ]}
                        >
                          {formatCurrency(displayBalance, account.currency)}
                        </div>
                        <div class="mt-1 text-xs text-base-content/50">Updated {formattedDate}</div>
                      </div>

                      {isHistoricalView && (
                        <a
                          href={`/accounts/${account.id}`}
                          class="inline-flex items-center gap-1.5 rounded-xl px-3 py-2 text-xs font-bold uppercase tracking-widest text-base-content/50 transition-colors hover:bg-base-200 hover:text-accent"
                          aria-label={`View ${account.name} details`}
                        >
                          <Eye size={14} class="stroke-current" aria-hidden="true" />
                          Details
                        </a>
                      )}

                      {!isHistoricalView && (
                        <Button
                          type="button"
                          variant="ghost"
                          size="sm"
                          className="min-h-10 rounded-xl px-3 text-xs font-bold uppercase tracking-widest text-base-content/60 hover:border-accent/30 hover:bg-accent/10 hover:text-accent"
                          aria-label={`Toggle inline history for ${account.name}`}
                          aria-controls={`account-table-mobile-history-${account.id}`}
                          aria-expanded="false"
                          data-inline-history-toggle
                          data-history-account={account.id}
                        >
                          History
                        </Button>
                      )}
                    </div>

                    {!isHistoricalView && (
                      <div
                        id={`account-table-mobile-history-${account.id}`}
                        class="hidden"
                        data-history-wrapper
                        data-account-id={account.id}
                      >
                        <div
                          class="mt-3 rounded-2xl border border-base-300 bg-base-200/60 p-4"
                          data-history-container
                          data-account-id={account.id}
                          role="region"
                          aria-label={`Value history for ${account.name}`}
                          aria-live="polite"
                        />
                      </div>
                    )}
                  </div>
                );
              })}
            </>
          ))}
        </div>
      </div>
    </div>
  )
}
