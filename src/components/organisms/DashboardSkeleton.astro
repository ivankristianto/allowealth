---
/**
 * Dashboard Skeleton Component (Organism)
 *
 * Loading skeleton that matches the exact layout of the dashboard.
 * Uses DaisyUI skeleton classes with fixed heights to prevent layout shift.
 *
 * @param {string} className - Additional CSS classes
 */

import Card from '../atoms/Card.astro';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<div
  class={`dashboard-skeleton space-y-6 ${className}`}
  role="status"
  aria-live="polite"
  aria-label="Loading dashboard"
>
  <!-- Welcome Section Skeleton -->
  <div class="card bg-base-100 shadow-lg border border-base-300">
    <div class="card-body">
      <div class="h-8 bg-neutral-200 rounded w-1/3 skeleton mb-2"></div>
      <div class="h-4 bg-neutral-200 rounded w-2/3 skeleton"></div>
    </div>
  </div>

  <!-- Summary Cards Skeleton -->
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <div class="space-y-3">
          <div class="h-4 bg-neutral-200 rounded w-1/3 skeleton"></div>
          <div class="h-8 bg-neutral-200 rounded w-2/3 skeleton"></div>
          <div class="h-4 bg-neutral-200 rounded w-1/2 skeleton"></div>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <div class="space-y-3">
          <div class="h-4 bg-neutral-200 rounded w-1/3 skeleton"></div>
          <div class="h-20 bg-neutral-200 rounded skeleton"></div>
        </div>
      </div>
    </div>

    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <div class="space-y-3">
          <div class="h-4 bg-neutral-200 rounded w-1/3 skeleton"></div>
          <div class="h-8 bg-neutral-200 rounded w-1/2 skeleton"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Asset Update Todo List Skeleton -->
  <div class="card bg-base-100 shadow border border-base-300">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <div class="h-6 bg-neutral-200 rounded w-48 skeleton"></div>
        <div class="h-6 bg-neutral-200 rounded w-8 skeleton"></div>
      </div>

      <div class="space-y-3">
        {
          [1, 2, 3].map((i) => (
            <div key={i} class="flex items-center gap-4 p-3 bg-base-200 rounded-lg">
              <div class="w-8 h-8 bg-neutral-300 rounded-full skeleton" />
              <div class="flex-1 space-y-2">
                <div class="h-4 bg-neutral-300 rounded w-3/4 skeleton" />
                <div class="h-3 bg-neutral-300 rounded w-1/2 skeleton" />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Recent Transactions Skeleton -->
  <div class="card bg-base-100 shadow border border-base-300">
    <div class="card-body">
      <div class="flex items-center justify-between mb-4">
        <div class="h-6 bg-neutral-200 rounded w-48 skeleton"></div>
      </div>

      <div class="space-y-3">
        {
          [1, 2, 3, 4, 5].map((i) => (
            <div key={i} class="flex items-center gap-4 p-4 bg-base-200 rounded-lg">
              <div class="w-20 h-4 bg-neutral-300 rounded skeleton" />
              <div class="flex-1 space-y-2">
                <div class="h-4 bg-neutral-300 rounded w-3/4 skeleton" />
                <div class="h-3 bg-neutral-300 rounded w-1/2 skeleton" />
              </div>
              <div class="w-24 h-4 bg-neutral-300 rounded skeleton" />
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Quick Actions Skeleton -->
  <div class="card bg-base-100 shadow border border-base-300">
    <div class="card-body">
      <div class="h-6 bg-neutral-200 rounded w-32 skeleton mb-4"></div>
      <div class="flex gap-3">
        <div class="h-12 bg-neutral-200 rounded w-32 skeleton"></div>
        <div class="h-12 bg-neutral-200 rounded w-32 skeleton"></div>
        <div class="h-12 bg-neutral-200 rounded w-32 skeleton"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .skeleton {
    animation: pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.5;
    }
  }
</style>
