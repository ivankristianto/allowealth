---
/**
 * BudgetPageHeader Component
 *
 * Header section for the Budget page with title, month navigation,
 * and History/Copy action buttons.
 *
 * @param {string} title - Main heading (default: "Family Spending Targets")
 * @param {string} subtitle - Description text
 * @param {number} budgetCount - Number of budget categories being tracked
 * @param {string} currentMonth - Display name for current month (e.g., "January 2024")
 * @param {string} prevMonthUrl - URL for previous month navigation
 * @param {string} nextMonthUrl - URL for next month navigation
 * @param {boolean} isNextDisabled - Disable next month button (future months)
 * @param {boolean} showCopyButton - Show Copy to Next Month button
 * @param {string} className - Additional CSS classes
 */

import { ChevronLeft, ChevronRight, CalendarDays, History, Copy } from '@lucide/astro';

export interface Props {
  title?: string;
  subtitle?: string;
  budgetCount?: number;
  currentMonth: string;
  prevMonthUrl: string;
  nextMonthUrl?: string;
  isNextDisabled?: boolean;
  showCopyButton?: boolean;
  currentMonthResetUrl?: string;
  className?: string;
}

const {
  title = 'Family Spending Targets',
  subtitle,
  budgetCount = 0,
  currentMonth,
  prevMonthUrl,
  nextMonthUrl,
  isNextDisabled = false,
  showCopyButton = false,
  currentMonthResetUrl,
  className = '',
} = Astro.props;

// Generate dynamic subtitle if not provided
const displaySubtitle =
  subtitle ||
  (budgetCount > 0
    ? `Monitoring ${budgetCount} critical expense ${budgetCount === 1 ? 'category' : 'categories'} for our household.`
    : 'Set up spending limits to track your budget.');

const headerClasses = ['flex flex-col gap-4', className].filter(Boolean).join(' ');
---

<header class={headerClasses}>
  {/* First row: Title, subtitle, and month navigation */}
  <div class="flex flex-col lg:flex-row justify-between items-start lg:items-center gap-4">
    {/* Title and subtitle */}
    <div>
      <h1 class="text-2xl font-bold text-base-content tracking-tight leading-none">{title}</h1>
      <p class="text-sm text-base-content/60 mt-2 font-medium">{displaySubtitle}</p>
    </div>

    {/* Header actions + Month Navigation */}
    <div class="flex items-center gap-1" data-testid="budget-month-selector">
      {/* History */}
      <div class="tooltip tooltip-bottom" data-tip="View budget history">
        <a
          href="/budget/history"
          class="btn btn-sm bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all gap-1"
          aria-label="Budget history"
          data-testid="budget-history-btn"
        >
          <History size={16} class="stroke-current" aria-hidden="true" />
          <span class="text-xs">History</span>
        </a>
      </div>

      {/* Copy to Next Month */}
      {
        showCopyButton && (
          <div class="tooltip tooltip-bottom" data-tip="Copy budgets to next month">
            <button
              type="button"
              class="btn btn-sm bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all gap-1"
              id="copy-budget-btn"
              data-target-modal="copy-budget-modal"
              aria-label="Copy budgets to next month"
              data-testid="budget-copy-btn"
            >
              <Copy size={16} class="stroke-current" aria-hidden="true" />
              <span class="text-xs">Copy</span>
            </button>
          </div>
        )
      }

      {/* Separator */}
      <div class="w-px h-6 bg-base-300 mx-1"></div>

      <a
        href={prevMonthUrl}
        class="btn btn-sm btn-square bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all"
        aria-label="Previous month"
        data-testid="budget-prev-month-btn"
      >
        <ChevronLeft size={18} class="stroke-current" aria-hidden="true" />
      </a>

      <div
        class="px-4 py-2 bg-base-100 border border-base-300 rounded-xl text-sm font-bold text-base-content min-w-[130px] text-center"
      >
        {currentMonth}
      </div>

      {
        nextMonthUrl && !isNextDisabled ? (
          <a
            href={nextMonthUrl}
            class="btn btn-sm btn-square bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all"
            aria-label="Next month"
            data-testid="budget-next-month-btn"
          >
            <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
          </a>
        ) : (
          <button
            type="button"
            class="btn btn-sm btn-square bg-base-100 border border-base-300 rounded-xl opacity-30 cursor-not-allowed"
            disabled
            aria-label="Next month (disabled)"
            data-testid="budget-next-month-btn"
          >
            <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
          </button>
        )
      }

      {/* Current Month Reset Button - shown only when viewing a different month */}
      {
        currentMonthResetUrl && (
          <a
            href={currentMonthResetUrl}
            class="btn btn-sm bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all gap-1 ml-1"
            aria-label="Go to current month"
            data-testid="budget-current-month-btn"
          >
            <CalendarDays size={16} class="stroke-current" aria-hidden="true" />
            <span class="text-xs">Today</span>
          </a>
        )
      }
    </div>
  </div>
</header>

<script>
  const handlerMap = new WeakMap<HTMLElement, (e: Event) => void>();

  function initCopyBudgetButton() {
    const btn = document.getElementById('copy-budget-btn');
    if (!btn || handlerMap.has(btn)) return;

    const handler = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      const targetId = btn.getAttribute('data-target-modal');
      if (!targetId) return;
      const modal = document.getElementById(targetId) as HTMLDialogElement;
      if (modal) modal.showModal();
    };

    handlerMap.set(btn, handler);
    btn.addEventListener('click', handler);
  }

  function cleanupCopyBudgetButton() {
    const btn = document.getElementById('copy-budget-btn');
    if (btn) {
      const handler = handlerMap.get(btn);
      if (handler) {
        btn.removeEventListener('click', handler);
        handlerMap.delete(btn);
      }
    }
  }

  function registerCleanup() {
    document.addEventListener('astro:before-swap', cleanupCopyBudgetButton, { once: true });
  }

  initCopyBudgetButton();
  registerCleanup();

  document.addEventListener('astro:page-load', () => {
    initCopyBudgetButton();
    registerCleanup();
  });
</script>
