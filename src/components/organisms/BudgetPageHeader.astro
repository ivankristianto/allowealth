---
/**
 * BudgetPageHeader Component
 *
 * Header section for the Budget page with title, month navigation,
 * and action buttons.
 * Part of the premium Budget page redesign (Task 16).
 *
 * @param {string} title - Main heading (default: "Family Spending Targets")
 * @param {string} subtitle - Description text
 * @param {number} budgetCount - Number of budget categories being tracked
 * @param {string} currentMonth - Display name for current month (e.g., "January 2024")
 * @param {string} prevMonthUrl - URL for previous month navigation
 * @param {string} nextMonthUrl - URL for next month navigation
 * @param {boolean} isNextDisabled - Disable next month button (future months)
 * @param {boolean} showAiRebalancer - Show AI Rebalancer button
 * @param {string} className - Additional CSS classes
 */

import { Sparkles, ChevronLeft, ChevronRight, History } from '@lucide/astro';

export interface Props {
  title?: string;
  subtitle?: string;
  budgetCount?: number;
  currentMonth: string;
  prevMonthUrl: string;
  nextMonthUrl?: string;
  isNextDisabled?: boolean;
  showAiRebalancer?: boolean;
  className?: string;
}

const {
  title = 'Family Spending Targets',
  subtitle,
  budgetCount = 0,
  currentMonth,
  prevMonthUrl,
  nextMonthUrl,
  isNextDisabled = false,
  showAiRebalancer = true,
  className = '',
} = Astro.props;

// Generate dynamic subtitle if not provided
const displaySubtitle =
  subtitle ||
  (budgetCount > 0
    ? `Monitoring ${budgetCount} critical expense ${budgetCount === 1 ? 'category' : 'categories'} for our household.`
    : 'Set up spending limits to track your budget.');

const headerClasses = [
  'flex flex-col lg:flex-row justify-between items-start lg:items-center gap-6',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<header class={headerClasses}>
  {/* Title and subtitle */}
  <div>
    <h1 class="text-2xl font-bold text-base-content tracking-tight leading-none">{title}</h1>
    <p class="text-sm text-base-content/60 mt-2 font-medium">{displaySubtitle}</p>
  </div>

  {/* Actions: View History, AI Rebalancer, Month Navigation, Set New Budget */}
  <div class="flex flex-wrap items-center gap-3">
    {/* View History Button */}
    <a
      href="/budget/history"
      class="btn btn-outline gap-2 rounded-2xl border border-base-300 hover:border-accent/30 hover:text-accent hover:bg-transparent"
      aria-label="View budget history"
    >
      <History size={18} class="stroke-current" aria-hidden="true" />
      <span>View History</span>
    </a>

    {/* AI Rebalancer Button */}
    {
      showAiRebalancer && (
        <button
          type="button"
          class="btn btn-accent gap-2 rounded-2xl shadow-md hover:shadow-lg transition-all"
          data-ai-rebalancer
          aria-label="Open AI budget rebalancer"
        >
          <Sparkles size={18} class="stroke-current" aria-hidden="true" />
          <span>AI Rebalancer</span>
        </button>
      )
    }

    {/* Month Navigation */}
    <div class="flex items-center gap-1">
      <a
        href={prevMonthUrl}
        class="btn btn-sm btn-square bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all"
        aria-label="Previous month"
      >
        <ChevronLeft size={18} class="stroke-current" aria-hidden="true" />
      </a>

      <div
        class="px-4 py-2 bg-base-100 border border-base-300 rounded-xl text-sm font-bold text-base-content min-w-[130px] text-center"
      >
        {currentMonth}
      </div>

      {
        nextMonthUrl && !isNextDisabled ? (
          <a
            href={nextMonthUrl}
            class="btn btn-sm btn-square bg-base-100 border border-base-300 hover:border-accent/30 hover:text-accent rounded-xl transition-all"
            aria-label="Next month"
          >
            <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
          </a>
        ) : (
          <button
            type="button"
            class="btn btn-sm btn-square bg-base-100 border border-base-300 rounded-xl opacity-30 cursor-not-allowed"
            disabled
            aria-label="Next month (disabled)"
          >
            <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
          </button>
        )
      }
    </div>

    {/* Set New Budget Button */}
    <button
      type="button"
      class="btn btn-outline btn-accent gap-2 rounded-2xl border-2 hover:bg-accent/5"
      id="set-new-budget-btn"
      aria-label="Set new budget"
    >
      <span>Set New Budget</span>
    </button>
  </div>
</header>

<script>
  function initSetNewBudgetButton() {
    const btn = document.getElementById('set-new-budget-btn');
    if (!btn) return;

    // Remove any existing listeners by cloning
    const newBtn = btn.cloneNode(true) as HTMLButtonElement;
    btn.parentNode?.replaceChild(newBtn, btn);

    newBtn.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      const modal = document.getElementById('set-new-budget-modal') as HTMLDialogElement;
      if (modal) {
        modal.showModal();
      }
    });
  }

  // Initialize
  initSetNewBudgetButton();

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initSetNewBudgetButton);
</script>
