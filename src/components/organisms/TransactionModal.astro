---
/**
 * Transaction Modal Component
 *
 * Modal for adding or editing expense/income transactions.
 * Features type-specific icon and header styling.
 *
 * @param {string} id - Modal ID
 * @param {'expense' | 'income'} type - Transaction type
 * @param {'create' | 'edit'} mode - Modal mode
 * @param {string} transactionId - Transaction ID for edit mode
 * @param {boolean} open - Whether modal is open
 * @param {string} action - Form action URL
 * @param {Object} values - Default form values
 * @param {Array} categories - Available categories
 * @param {Array} assets - Available assets
 * @param {Record<string, string>} errors - Form errors
 * @param {boolean} showScanButton - Show scan button (expense only, create mode only)
 */

import Modal from '../molecules/Modal.astro';
import TransactionEntryForm from '../molecules/TransactionEntryForm.astro';
import { CircleMinus, CirclePlus, Sparkles, Pencil } from '@lucide/astro';

export interface Props {
  id: string;
  type?: 'expense' | 'income';
  mode?: 'create' | 'edit';
  transactionId?: string;
  open?: boolean;
  action: string;
  values?: {
    title?: string;
    amount?: string;
    currency?: 'IDR' | 'USD';
    category_id?: string;
    asset_id?: string;
    transaction_date?: string;
  };
  categories?: Array<{ id: string; name: string; type: string; currency?: string }>;
  assets?: Array<{ id: string; name: string; type: string }>;
  errors?: Record<string, string>;
  showScanButton?: boolean;
}

const {
  id,
  type = 'expense',
  mode = 'create',
  transactionId = '',
  open = false,
  action,
  values = {},
  categories = [],
  assets = [],
  errors = {},
  showScanButton = true,
} = Astro.props;

const isExpense = type === 'expense';
const isEditMode = mode === 'edit';
const title = isEditMode
  ? isExpense
    ? 'Edit Expense'
    : 'Edit Income'
  : isExpense
    ? 'New Expense'
    : 'New Income';
const subtitle = isEditMode
  ? 'Update the transaction details.'
  : 'Log a manual transaction to your ledger.';

// Icon styling based on type
const iconBgClass = isExpense ? 'bg-error/10' : 'bg-success/10';
const iconColorClass = isExpense ? 'text-error' : 'text-success';
---

<div data-transaction-modal-container data-id={id} data-type={type} data-mode={mode}>
  <Modal id={id} open={open} size="md" closable={false} backdropClose={true}>
    <!-- Custom header with icon -->
    <div slot="default" class="flex flex-col gap-6">
      <!-- Header section -->
      <div class="flex items-center gap-4">
        <!-- Type/Mode icon -->
        <div
          class:list={[
            'w-12 h-12 rounded-2xl flex items-center justify-center',
            isEditMode ? 'bg-accent/10' : iconBgClass,
          ]}
        >
          {
            isEditMode ? (
              <Pencil size={24} class="stroke-current text-accent" aria-hidden="true" />
            ) : isExpense ? (
              <CircleMinus
                size={24}
                class:list={['stroke-current', iconColorClass]}
                aria-hidden="true"
              />
            ) : (
              <CirclePlus
                size={24}
                class:list={['stroke-current', iconColorClass]}
                aria-hidden="true"
              />
            )
          }
        </div>

        <!-- Title and subtitle -->
        <div class="flex-1">
          <h2 class="text-2xl font-bold tracking-tight text-primary leading-none" data-modal-title>
            {title}
          </h2>
          <p class="text-neutral text-sm mt-2 font-medium" data-modal-subtitle>{subtitle}</p>
        </div>

        <!-- Scan button (expense only, create mode only) -->
        {
          !isEditMode && isExpense && showScanButton && (
            <button
              type="button"
              class="flex items-center gap-2 px-4 py-2.5 bg-accent/10 text-accent rounded-xl text-xs font-bold transition-all hover:bg-accent/20 border border-accent/20 group"
              data-scan-button
              aria-label="Scan receipt"
            >
              <Sparkles
                size={16}
                class="stroke-current group-hover:animate-pulse"
                aria-hidden="true"
              />
              <span>Scan</span>
            </button>
          )
        }
      </div>

      <!-- Form -->
      <TransactionEntryForm
        type={type}
        mode={mode}
        transactionId={transactionId}
        action={action}
        values={values}
        categories={categories}
        assets={assets}
        errors={errors}
        modalId={id}
      />
    </div>
  </Modal>
</div>

<script>
  import { addToast } from '@/lib/stores/toastStore';

  // Initialize transaction modal containers
  function initTransactionModals() {
    document.querySelectorAll('[data-transaction-modal-container]').forEach((container) => {
      const id = container.getAttribute('data-id');
      if (!id) return;

      // Handle scan button click (placeholder)
      const scanButton = container.querySelector('[data-scan-button]');
      scanButton?.addEventListener('click', () => {
        addToast('Receipt scanning coming soon!', 'info');
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionModals);
  } else {
    initTransactionModals();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initTransactionModals);
</script>
