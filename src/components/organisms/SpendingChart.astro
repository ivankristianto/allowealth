---
/**
 * SpendingChart Component
 *
 * Interactive donut chart showing spending breakdown by category.
 * Uses Chart.js with custom center text plugin and hover-synced legend.
 * Follows Allowealth v1.0.0 design system specifications.
 *
 * @param {SpendingCategory[]} data - Array of spending categories with percentages
 * @param {number} totalSpent - Total amount spent (for center text calculation)
 * @param {number} totalBudget - Total budget (for percentage calculation)
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import Card from '@/components/atoms/Card.astro';
import Skeleton from '@/components/atoms/Skeleton.astro';
import { Info } from '@lucide/astro';

export interface SpendingCategory {
  category: string;
  percentage: number;
  color?: string; // Optional override color
  otherCategoryNames?: string[];
}

export interface Props {
  data: SpendingCategory[];
  totalSpent?: number;
  totalBudget?: number;
  loading?: boolean;
  error?: string;
  className?: string;
}

const {
  data = [],
  totalSpent = 0,
  totalBudget = 0,
  loading = false,
  error,
  className = '',
} = Astro.props;

// Chart colors from POC design
const DEFAULT_COLORS = [
  '#ef4444', // red - Housing
  '#3b82f6', // blue - Groceries
  '#f59e0b', // orange - Dining
  '#8b5cf6', // purple - Transport
  '#10b981', // green - Savings/Other
];

// Calculate overall spending percentage
const overallPercentage = totalBudget > 0 ? (totalSpent / totalBudget) * 100 : 0;
const overallPercentageRounded = Math.round(overallPercentage);

// Serialize data for client-side script
const serializedData = JSON.stringify(data);
const serializedColors = JSON.stringify(DEFAULT_COLORS);

// Generate unique ID for this chart instance
const chartId = `spending-chart-${Math.random().toString(36).slice(2, 11)}`;
import Button from '@/components/atoms/Button.astro';
---

<Card
  padding="lg"
  rounded="card-lg"
  className={`h-full ${className}`}
  role="region"
  aria-label="Most spending categories"
  data-testid="spending-chart"
>
  <div class="@container flex flex-col gap-6">
    {/* Header */}
    <div>
      <h2 class="font-bold text-xl text-base-content leading-none tracking-tight">Top Spending</h2>
    </div>

    {/* Loading State */}
    {
      loading ? (
        <div class="flex flex-col @md:flex-row items-center gap-8 py-6">
          <div class="h-44 w-full shrink-0 @md:w-44">
            <Skeleton variant="circular" width="180" height="180" />
          </div>
          <div class="flex-1 w-full space-y-3">
            {Array.from({ length: 4 }).map(() => (
              <div class="flex items-center justify-between p-3.5 rounded-2xl">
                <div class="flex items-center gap-3">
                  <Skeleton variant="rectangular" width="14px" height="14px" />
                  <Skeleton variant="rectangular" width="96px" height="16px" />
                </div>
                <Skeleton variant="rectangular" width="40px" height="16px" />
              </div>
            ))}
          </div>
        </div>
      ) : error ? (
        /* Error State */
        <div class="p-12 text-center">
          <p class="text-error font-medium" role="alert">
            {error}
          </p>
        </div>
      ) : data.length === 0 ? (
        /* Empty State */
        <div class="p-12 text-center">
          <p class="text-base-content/60 font-medium">No spending data yet.</p>
        </div>
      ) : (
        /* Chart and Legend */
        <div
          class="flex flex-col @md:flex-row items-center gap-8 py-2"
          data-chart-data={serializedData}
          data-chart-colors={serializedColors}
          data-overall-percentage={overallPercentageRounded.toString()}
        >
          {/* Chart Container - Fixed size for proper center text alignment */}
          <div class="relative mx-auto h-44 w-44 shrink-0 @md:mx-0" id={`${chartId}-container`}>
            <canvas
              id={chartId}
              aria-label={`Spending breakdown chart showing ${data.length} categories`}
              role="img"
            />
            {/* Center Text - Updated via JS */}
            <div
              id={`${chartId}-center-text`}
              class="absolute inset-0 flex flex-col items-center justify-center pointer-events-none text-center transition-opacity duration-200"
              aria-hidden="true"
            >
              <span class="text-2xl font-bold text-base-content tracking-tighter">
                {overallPercentageRounded}%
              </span>
              <span class="text-xs font-bold text-base-content/50 tracking-wide mt-1 uppercase">
                Spent
              </span>
            </div>
          </div>

          {/* Legend - Using button elements for proper ARIA */}
          <div
            id={`${chartId}-legend`}
            class="flex-1 space-y-1.5 @xs:space-y-3 w-full"
            role="group"
            aria-label="Spending categories. Use arrow keys to navigate, Enter or Space to view details."
          >
            {data.slice(0, 5).map((item, index) => (
              <Button
                type="button"
                variant="ghost"
                data-category-index={index}
                className="spending-chart-legend-item h-auto w-full justify-between rounded-xl border border-transparent p-2.5 text-left opacity-80 hover:border-transparent hover:bg-base-200/50 hover:shadow-sm hover:opacity-100 @xs:rounded-2xl @xs:p-3.5"
                aria-pressed="false"
                aria-label={`${item.category}: ${item.percentage}%. Click to view details.${item.category === 'Other' && Array.isArray(item.otherCategoryNames) && item.otherCategoryNames.length > 0 ? ` Includes: ${item.otherCategoryNames.join(', ')}.` : ''}`}
              >
                <div class="flex items-center gap-2 @xs:gap-3">
                  <div
                    class="w-3 h-3 @xs:w-3.5 @xs:h-3.5 rounded-md @xs:rounded-lg shadow-sm shrink-0"
                    style={`background-color: ${item.color || DEFAULT_COLORS[index % DEFAULT_COLORS.length]}`}
                    aria-hidden="true"
                  />
                  <span
                    class="max-w-36 truncate text-sm font-semibold tracking-tight text-base-content @xs:max-w-48 @xs:text-base"
                    title={item.category}
                  >
                    {item.category}
                  </span>
                  {item.category === 'Other' &&
                    Array.isArray(item.otherCategoryNames) &&
                    item.otherCategoryNames.length > 0 && (
                      <div
                        class="tooltip tooltip-top"
                        data-tip={`Includes: ${item.otherCategoryNames.join(', ')}`}
                      >
                        <Info
                          size={14}
                          class="stroke-current text-base-content/40 shrink-0"
                          aria-hidden="true"
                        />
                      </div>
                    )}
                </div>
                <span class="text-sm @xs:text-base font-bold text-base-content">
                  {item.percentage}%
                </span>
              </Button>
            ))}
          </div>
        </div>
      )
    }

    {/* Screen Reader Data Table */}
    {
      !loading && !error && data.length > 0 && (
        <table class="sr-only" aria-label="Spending analysis data table">
          <thead>
            <tr>
              <th>Category</th>
              <th>Percentage</th>
            </tr>
          </thead>
          <tbody>
            {data.map((item) => (
              <tr>
                <td>{item.category}</td>
                <td>{item.percentage}%</td>
              </tr>
            ))}
          </tbody>
        </table>
      )
    }
  </div>
</Card>

<style>
  /* Focus visible styles for keyboard navigation */
  .spending-chart-legend-item:focus-visible {
    outline: 2px solid hsl(var(--a));
    outline-offset: 2px;
  }
</style>

<script>
  import { Chart } from '@/lib/chart-setup';
  import { safeParseJsonArray } from '@/lib/client-utils';
  import { createChartLifecycle } from '@/lib/utils/chart-lifecycle';
  import { getChartThemeColors } from '@/lib/utils/chart-theme';

  interface SpendingCategory {
    category: string;
    percentage: number;
    color?: string;
  }

  interface ChartData {
    chart: Chart<'doughnut'>;
    data: SpendingCategory[];
    colors: string[];
    activeIndex: number | null;
  }

  // Store chart instances globally for cleanup
  const charts: Record<string, ChartData> = {};

  /**
   * Update chart tooltip colors based on current theme
   * Called when theme changes via MutationObserver
   */
  function updateChartThemeColors(): void {
    const theme = getChartThemeColors();

    Object.values(charts).forEach(({ chart }) => {
      if (chart.options.plugins?.tooltip) {
        chart.options.plugins.tooltip.backgroundColor = theme.tooltipBg;
        chart.options.plugins.tooltip.titleColor = theme.tooltipTitle;
        chart.options.plugins.tooltip.bodyColor = theme.tooltipBody;
        chart.update('none');
      }
    });
  }

  /**
   * Initialize spending chart with Chart.js
   * Uses Intersection Observer for lazy loading
   */
  function initSpendingChart(chartId: string, data: SpendingCategory[], colors: string[]): void {
    const canvas = document.getElementById(chartId) as HTMLCanvasElement;
    const centerText = document.getElementById(`${chartId}-center-text`);
    const legendContainer = document.getElementById(`${chartId}-legend`);

    if (!canvas || !centerText || !legendContainer) {
      return;
    }

    // Destroy existing chart if it exists
    if (charts[chartId]?.chart) {
      charts[chartId].chart.destroy();
    }

    const chartValues = data.map((d) => d.percentage);
    const chartLabels = data.map((d) => d.category);
    const chartColors = data.map((d, i) => d.color || colors[i % colors.length]);

    const theme = getChartThemeColors();

    // Create new chart
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const chart = new Chart<'doughnut'>(ctx, {
      type: 'doughnut',
      data: {
        labels: chartLabels,
        datasets: [
          {
            data: chartValues,
            backgroundColor: chartColors,
            borderWidth: 0,
            spacing: 4,
            hoverOffset: 8,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: true,
        cutout: '70%',
        animation: {
          animateScale: true,
          animateRotate: true,
        },
        plugins: {
          legend: {
            display: false,
          },
          tooltip: {
            backgroundColor: theme.tooltipBg,
            titleColor: theme.tooltipTitle,
            bodyColor: theme.tooltipBody,
            padding: 12,
            cornerRadius: 8,
            displayColors: true,
            callbacks: {
              label: (context) => {
                const label = context.label || '';
                const value = context.parsed || 0;
                return `${label}: ${value}%`;
              },
            },
          },
        },
        onHover: (_event, elements) => {
          const activeIndex = elements.length > 0 ? elements[0].index : null;
          updateActiveState(chartId, activeIndex);
        },
      },
    });

    // Store chart instance
    charts[chartId] = {
      chart,
      data,
      colors,
      activeIndex: null,
    };

    // Add legend item event listeners
    const legendItems = legendContainer.querySelectorAll('.spending-chart-legend-item');
    legendItems.forEach((item, index) => {
      // Mouse enter
      item.addEventListener('mouseenter', () => {
        updateActiveState(chartId, index);
        if (charts[chartId]?.chart) {
          charts[chartId].chart.setActiveElements([{ datasetIndex: 0, index }]);
          charts[chartId].chart.update();
        }
      });

      // Mouse leave
      item.addEventListener('mouseleave', () => {
        updateActiveState(chartId, null);
        if (charts[chartId]?.chart) {
          charts[chartId].chart.setActiveElements([]);
          charts[chartId].chart.update();
        }
      });

      // Keyboard support with arrow key navigation
      item.addEventListener('keydown', (e: KeyboardEvent) => {
        const items = Array.from(
          legendContainer.querySelectorAll('.spending-chart-legend-item')
        ) as HTMLElement[];
        const currentIndex = items.indexOf(item as HTMLElement);

        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          // Toggle active state on keyboard activation
          const isActive = charts[chartId]?.activeIndex === index;
          updateActiveState(chartId, isActive ? null : index);
          if (charts[chartId]?.chart) {
            charts[chartId].chart.setActiveElements(isActive ? [] : [{ datasetIndex: 0, index }]);
            charts[chartId].chart.update();
          }
        } else if (e.key === 'ArrowDown' || e.key === 'ArrowRight') {
          e.preventDefault();
          const nextIndex = (currentIndex + 1) % items.length;
          items[nextIndex]?.focus();
        } else if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') {
          e.preventDefault();
          const prevIndex = (currentIndex - 1 + items.length) % items.length;
          items[prevIndex]?.focus();
        } else if (e.key === 'Home') {
          e.preventDefault();
          items[0]?.focus();
        } else if (e.key === 'End') {
          e.preventDefault();
          items[items.length - 1]?.focus();
        } else if (e.key === 'Escape') {
          e.preventDefault();
          updateActiveState(chartId, null);
          if (charts[chartId]?.chart) {
            charts[chartId].chart.setActiveElements([]);
            charts[chartId].chart.update();
          }
        }
      });

      // Focus event - update chart to show focused item
      item.addEventListener('focus', () => {
        updateActiveState(chartId, index);
        if (charts[chartId]?.chart) {
          charts[chartId].chart.setActiveElements([{ datasetIndex: 0, index }]);
          charts[chartId].chart.update();
        }
      });

      // Blur event - reset if no active item
      item.addEventListener('blur', () => {
        // Only reset if this was the active item
        if (charts[chartId]?.activeIndex === index) {
          updateActiveState(chartId, null);
          if (charts[chartId]?.chart) {
            charts[chartId].chart.setActiveElements([]);
            charts[chartId].chart.update();
          }
        }
      });
    });
  }

  /**
   * Update active state for chart and legend
   */
  function updateActiveState(chartId: string, activeIndex: number | null): void {
    const chartData = charts[chartId];
    if (!chartData) return;

    chartData.activeIndex = activeIndex;

    const centerText = document.getElementById(`${chartId}-center-text`);
    const legendContainer = document.getElementById(`${chartId}-legend`);

    if (!centerText || !legendContainer) return;

    // Update center text
    const percentageEl = centerText.querySelector('span:first-child');
    const labelEl = centerText.querySelector('span:last-child');

    if (activeIndex !== null && chartData.data[activeIndex]) {
      const item = chartData.data[activeIndex];
      if (percentageEl) percentageEl.textContent = `${item.percentage}%`;
      if (labelEl) labelEl.textContent = item.category.toUpperCase();
    } else {
      const overallPercentage = Math.round(
        chartData.data.reduce((sum, item) => sum + item.percentage, 0)
      );
      if (percentageEl) percentageEl.textContent = `${overallPercentage}%`;
      if (labelEl) labelEl.textContent = 'SPENT';
    }

    // Update legend styles and aria-pressed
    const legendItems = legendContainer.querySelectorAll('.spending-chart-legend-item');
    legendItems.forEach((item, index) => {
      if (activeIndex === null) {
        // Reset to default
        (item as HTMLElement).style.backgroundColor = '';
        (item as HTMLElement).style.opacity = '0.8';
        (item as HTMLElement).style.borderColor = 'transparent';
        item.setAttribute('aria-pressed', 'false');
      } else if (index === activeIndex) {
        // Active item - use base-200 which adapts to theme
        (item as HTMLElement).classList.add('bg-base-200');
        (item as HTMLElement).style.opacity = '1';
        (item as HTMLElement).classList.add('border-base-300');
        item.setAttribute('aria-pressed', 'true');
      } else {
        // Inactive item
        (item as HTMLElement).style.backgroundColor = '';
        (item as HTMLElement).style.opacity = '0.4';
        (item as HTMLElement).style.borderColor = 'transparent';
        item.setAttribute('aria-pressed', 'false');
      }
    });
  }

  function parseChartData(raw: unknown): SpendingCategory[] | null {
    if (!Array.isArray(raw)) return null;
    const validData = raw.filter(
      (item) =>
        typeof item?.percentage === 'number' &&
        isFinite(item.percentage) &&
        item.percentage >= 0 &&
        typeof item?.category === 'string' &&
        item.category.length > 0 &&
        item.category.length <= 100
    ) as SpendingCategory[];
    return validData.length > 0 ? validData : null;
  }

  function parseChartColors(raw: unknown): string[] | null {
    if (!Array.isArray(raw)) return null;
    const validColors = raw.filter((color) => typeof color === 'string') as string[];
    return validColors.length > 0 ? validColors : null;
  }

  const lifecycle = createChartLifecycle<{
    data: SpendingCategory[];
    colors: string[];
  }>({
    containerSelector: '[id^="spending-chart-"][id$="-container"]',
    parseData: (raw) => {
      const data = parseChartData(raw);
      return data ? { data, colors: [] } : null;
    },
    onInit: (container, payload) => {
      const dataSource = container.closest('[data-chart-colors]') ?? container;
      const colorsAttr = dataSource.getAttribute('data-chart-colors');
      const colors = parseChartColors(safeParseJsonArray(colorsAttr));
      if (!colors) return;
      const chartId = container.querySelector('canvas')?.id;
      if (!chartId || charts[chartId]) return;
      initSpendingChart(chartId, payload.data, colors);
    },
    onThemeChange: updateChartThemeColors,
    onCleanup: () => {
      Object.values(charts).forEach(({ chart }) => {
        try {
          chart.destroy();
        } catch (e) {
          // Chart may already be destroyed
        }
      });
      for (const key in charts) {
        delete charts[key];
      }
    },
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', lifecycle.init);
  } else {
    lifecycle.init();
  }

  window.addEventListener('beforeunload', lifecycle.cleanup);
  document.addEventListener('astro:before-swap', lifecycle.cleanup);
  document.addEventListener('astro:after-swap', lifecycle.init);
</script>
