---
/**
 * AccountUpdateValueModal Component
 *
 * Lightweight modal for recording balance updates to an existing account.
 * Separate from the Edit Account modal — only asks for Date, Balance, and Notes.
 *
 * Dispatches to POST /api/accounts/:id/balance with recorded_at timestamp.
 *
 * @param {string} id - Modal ID
 */

import Modal from '../molecules/Modal.astro';
import AmountInput from '../atoms/AmountInput.astro';
import { RefreshCw } from '@lucide/astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div
  data-account-update-value-modal-container
  data-id={id}
  data-testid="account-update-value-modal"
>
  <Modal id={id} size="sm" closable={false} backdropClose={true}>
    <div slot="default" class="flex flex-col gap-6">
      {/* Header with icon */}
      <div class="flex items-center gap-4">
        <div
          class="w-12 h-12 rounded-2xl flex items-center justify-center bg-warning/10 text-warning"
        >
          <RefreshCw size={24} class="stroke-current" aria-hidden="true" />
        </div>
        <div class="flex-1">
          <div class="flex items-center gap-2">
            <h2
              class="text-2xl font-bold tracking-tight text-primary leading-none"
              data-modal-title
            >
              Update Value
            </h2>
            <span
              class="px-2 py-0.5 rounded-md text-xs font-bold tracking-wider uppercase bg-base-200 text-base-content/50 hidden"
              data-modal-currency-badge></span>
          </div>
          <p class="text-neutral text-sm mt-2 font-medium" data-modal-subtitle>
            Record a new balance for this account.
          </p>
        </div>
      </div>

      {/* Form */}
      <form id={`${id}-form`} class="flex flex-col gap-6" aria-describedby={`${id}-error`}>
        <input type="hidden" name="account_id" id={`${id}-account-id`} value="" />

        {/* Date */}
        <div class="space-y-2">
          <label
            for={`${id}-date`}
            class="text-xs font-bold text-base-content/40 uppercase tracking-widest ml-1"
          >
            Date
          </label>
          <input
            id={`${id}-date`}
            name="date"
            type="date"
            required
            class="input input-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent"
            data-testid="update-value-date-input"
          />
        </div>

        {/* Balance */}
        <div class="space-y-2">
          <label
            for={`${id}-balance`}
            class="text-xs font-bold text-base-content/40 uppercase tracking-widest ml-1"
            data-balance-label
          >
            New Balance
          </label>
          <AmountInput
            id={`${id}-balance`}
            name="balance"
            currency="IDR"
            required
            placeholder="0"
            className="input-lg bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent placeholder:text-base-content/30 placeholder:font-normal"
            data-testid="update-value-balance-input"
          />
        </div>

        {/* Notes */}
        <div class="space-y-2">
          <label
            for={`${id}-notes`}
            class="text-xs font-bold text-base-content/40 uppercase tracking-widest ml-1"
          >
            Notes <span class="text-base-content/30">(optional)</span>
          </label>
          <textarea
            id={`${id}-notes`}
            name="notes"
            rows="2"
            placeholder="e.g. Monthly statement update"
            class="textarea textarea-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent placeholder:text-base-content/30 placeholder:font-normal"
            data-testid="update-value-notes-input"></textarea>
        </div>

        {/* Error message container */}
        <div
          id={`${id}-error`}
          class="hidden alert alert-error text-sm rounded-xl"
          role="alert"
          aria-live="polite"
        >
        </div>

        {/* Actions */}
        <div class="flex gap-4 pt-2">
          <button
            type="button"
            class="btn btn-ghost flex-1 h-14 rounded-2xl font-bold text-base-content hover:bg-base-200"
            data-cancel-update-value
          >
            Cancel
          </button>
          <button
            type="submit"
            class="btn btn-warning flex-1 h-14 rounded-2xl font-bold"
            data-submit-update-value
            data-testid="update-value-submit-btn"
          >
            Update Value
          </button>
        </div>
      </form>
    </div>
  </Modal>
</div>

<script>
  import { addToast } from '@lib/stores/toastStore';
  import { csrfFetch } from '@/lib/csrf-client';
  import { attachAmountFormatter, stripAmountFormatting } from '@/lib/formatting/amount-input';
  import { isValidCurrency, type Currency } from '@/lib/constants/currency';

  const initializedModals = new WeakSet<Element>();

  function initAccountUpdateValueModal() {
    document
      .querySelectorAll('[data-account-update-value-modal-container]')
      .forEach((container) => {
        if (initializedModals.has(container)) return;
        initializedModals.add(container);

        const id = container.getAttribute('data-id');
        if (!id) return;

        const modal = document.getElementById(id) as HTMLDialogElement | null;
        const form = document.getElementById(`${id}-form`) as HTMLFormElement | null;
        const cancelBtn = container.querySelector('[data-cancel-update-value]');
        const submitBtn = container.querySelector(
          '[data-submit-update-value]'
        ) as HTMLButtonElement;
        const errorDiv = document.getElementById(`${id}-error`);
        const accountIdInput = document.getElementById(
          `${id}-account-id`
        ) as HTMLInputElement | null;
        const dateInput = document.getElementById(`${id}-date`) as HTMLInputElement | null;
        const balanceInput = document.getElementById(`${id}-balance`) as HTMLInputElement | null;
        const notesInput = document.getElementById(`${id}-notes`) as HTMLTextAreaElement | null;
        const subtitleEl = container.querySelector('[data-modal-subtitle]');
        const currencyBadge = container.querySelector('[data-modal-currency-badge]') as HTMLElement;
        const balanceLabel = container.querySelector('[data-balance-label]') as HTMLElement;

        if (!modal || !form) return;

        let selectedCurrency: Currency = 'IDR';
        const balanceFormatter = balanceInput
          ? attachAmountFormatter(balanceInput, selectedCurrency)
          : null;

        // Compute today in local timezone (not UTC) to avoid date mismatch
        const now = new Date();
        const today = `${now.getFullYear()}-${String(now.getMonth() + 1).padStart(2, '0')}-${String(now.getDate()).padStart(2, '0')}`;
        if (dateInput) {
          dateInput.value = today;
          dateInput.max = today;
        }

        const resetForm = () => {
          form.reset();
          if (accountIdInput) accountIdInput.value = '';
          if (dateInput) dateInput.value = today;
          if (errorDiv) {
            errorDiv.textContent = '';
            errorDiv.classList.add('hidden');
          }
        };

        // Listen for open-account-update-value event
        const handleOpen = ((
          e: CustomEvent<{ id: string; name: string; currency: string; balance: number }>
        ) => {
          selectedCurrency = isValidCurrency(e.detail.currency) ? e.detail.currency : 'IDR';
          balanceFormatter?.updateCurrency(selectedCurrency);

          if (accountIdInput) accountIdInput.value = e.detail.id;
          if (subtitleEl) subtitleEl.textContent = `Record a new balance for ${e.detail.name}.`;
          if (currencyBadge) {
            currencyBadge.textContent = selectedCurrency;
            currencyBadge.classList.remove('hidden');
            // Currency colors: IDR=success, USD=info (only two currencies per schema enum)
            currencyBadge.className =
              'px-2 py-0.5 rounded-md text-xs font-bold tracking-wider uppercase ' +
              (selectedCurrency === 'IDR' ? 'bg-success/10 text-success' : 'bg-info/10 text-info');
          }
          if (balanceLabel) {
            balanceLabel.textContent = `New Balance (${selectedCurrency})`;
          }
          if (dateInput) dateInput.value = today;
          if (balanceInput) balanceInput.value = '';
          if (notesInput) notesInput.value = '';
          if (errorDiv) {
            errorDiv.textContent = '';
            errorDiv.classList.add('hidden');
          }
          modal.showModal();
        }) as EventListener;

        document.addEventListener('open-account-update-value', handleOpen);

        document.addEventListener(
          'astro:before-swap',
          () => {
            document.removeEventListener('open-account-update-value', handleOpen);
          },
          { once: true }
        );

        cancelBtn?.addEventListener('click', () => {
          resetForm();
          modal.close();
        });

        form.addEventListener('submit', async (e) => {
          e.preventDefault();

          const formData = new FormData(form);
          const accountId = formData.get('account_id') as string;
          const date = formData.get('date') as string;
          const balanceRaw = formData.get('balance') as string;
          const balance = stripAmountFormatting(balanceRaw, selectedCurrency);
          const notes = formData.get('notes') as string;

          if (errorDiv) {
            errorDiv.textContent = '';
            errorDiv.classList.add('hidden');
          }

          if (!accountId || !date || !balance) {
            if (errorDiv) {
              errorDiv.textContent = 'Please fill in all required fields.';
              errorDiv.classList.remove('hidden');
            }
            return;
          }

          const balanceNum = parseFloat(balance);
          if (isNaN(balanceNum) || balanceNum < 0 || !isFinite(balanceNum)) {
            if (errorDiv) {
              errorDiv.textContent = 'Please enter a valid positive number for balance.';
              errorDiv.classList.remove('hidden');
            }
            return;
          }

          // Validate max 2 decimal places (matches server-side regex)
          if (!/^\d+(\.\d{1,2})?$/.test(balance)) {
            if (errorDiv) {
              errorDiv.textContent = 'Balance can have at most 2 decimal places.';
              errorDiv.classList.remove('hidden');
            }
            return;
          }

          const accountIdPattern = /^[A-Za-z0-9_-]{21}$/;
          if (!accountIdPattern.test(accountId)) {
            if (errorDiv) {
              errorDiv.textContent = 'Invalid account ID format.';
              errorDiv.classList.remove('hidden');
            }
            return;
          }

          const originalText = submitBtn?.textContent || 'Update Value';
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Updating...';
          }

          try {
            // Convert date to ISO datetime string for recorded_at
            const recordedAt = new Date(date + 'T12:00:00').toISOString();

            const response = await csrfFetch(`/api/accounts/${accountId}/balance`, {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                balance,
                notes: notes || undefined,
                recorded_at: recordedAt,
              }),
            });

            if (!response.ok) {
              const errorData = await response.json();
              throw new Error(
                errorData.error?.message || errorData.message || 'Failed to update value'
              );
            }

            addToast('Account value updated successfully!', 'success');
            resetForm();
            modal.close();

            setTimeout(() => window.location.reload(), 500);
          } catch (err) {
            const message = err instanceof Error ? err.message : 'An error occurred';
            if (errorDiv) {
              errorDiv.textContent = message;
              errorDiv.classList.remove('hidden');
            }
            addToast(message, 'error');
          } finally {
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.textContent = originalText;
            }
          }
        });
      });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccountUpdateValueModal);
  } else {
    initAccountUpdateValueModal();
  }

  document.addEventListener('astro:page-load', initAccountUpdateValueModal);
</script>
