---
/**
 * DiagnosticsDisplay Component
 *
 * Displays system diagnostics information using the project's design system.
 * Keeps diagnostics fully visible while grouping the content into a summary-first layout.
 */

import type { DiagnosticsData } from '@/types/diagnostics';
import Card from '@/components/atoms/Card.astro';
import { APP_VERSION } from '@/lib/version';
import {
  Activity,
  Code,
  Database as DataLayerGlyph,
  Server,
  Settings,
  TriangleAlert,
  CircleCheck,
  CircleX,
} from '@lucide/astro';

interface Props {
  data: DiagnosticsData;
}

type StatusVariant = 'success' | 'error' | 'warning' | 'neutral';

const { data } = Astro.props;

function formatTimestamp(isoString: string): string {
  return new Date(isoString).toLocaleString();
}

function getEnvVarStatus(isSet: boolean, isSensitive: boolean) {
  if (!isSet) return { variant: 'error' as const, text: 'Missing' };
  if (isSensitive) return { variant: 'warning' as const, text: 'Sensitive' };
  return { variant: 'success' as const, text: 'Set' };
}

function badgeClass(variant: StatusVariant): string {
  const map = {
    success: 'badge-success',
    error: 'badge-error',
    warning: 'badge-warning',
    neutral: 'badge-neutral',
  };

  return `badge badge-sm ${map[variant]}`;
}

function toneClass(variant: StatusVariant): string {
  const map = {
    success: 'text-success bg-success/10',
    error: 'text-error bg-error/10',
    warning: 'text-warning bg-warning/10',
    neutral: 'text-base-content/60 bg-base-200',
  };

  return map[variant];
}

function iconTextClass(variant: StatusVariant): string {
  const map = {
    success: 'text-success',
    error: 'text-error',
    warning: 'text-warning',
    neutral: 'text-base-content/50',
  };

  return `h-3.5 w-3.5 stroke-current ${map[variant]}`;
}

function summaryMarkerClass(variant: StatusVariant): string {
  const map = {
    success: 'bg-success',
    error: 'bg-error',
    warning: 'bg-warning',
    neutral: 'bg-base-content/30',
  };

  return `h-2 w-2 rounded-full ${map[variant]}`;
}

function summaryGlyphClass(variant: StatusVariant): string {
  const map = {
    success: 'text-success/80',
    error: 'text-error/80',
    warning: 'text-warning/80',
    neutral: 'text-base-content/35',
  };

  return `h-4 w-4 stroke-current ${map[variant]}`;
}

const summaryReadoutRowClass =
  'grid grid-cols-[minmax(0,1fr)_minmax(0,1fr)] items-start gap-x-4 border-t border-base-200 py-3 first:border-t-0 first:pt-0';
const summaryReadoutLabelClass =
  'min-w-0 text-xs font-medium uppercase leading-6 tracking-[0.12em] text-base-content/55';
const summaryReadoutValueClass =
  'min-w-0 break-words text-right text-sm font-medium leading-6 text-base-content';
const summaryReadoutMonoValueClass =
  'min-w-0 break-words text-right font-mono text-sm leading-6 text-base-content';

const cacheStatusMap: Record<string, { variant: StatusVariant; text: string }> = {
  healthy: { variant: 'success', text: 'Healthy' },
  error: { variant: 'error', text: 'Error' },
  disabled: { variant: 'neutral', text: 'Disabled' },
};

const cacheStatus = cacheStatusMap[data.cache.status] ?? { variant: 'neutral', text: 'Unknown' };

const connStatus = data.database.isConnected
  ? { variant: 'success' as const, text: 'Connected' }
  : { variant: 'error' as const, text: 'Disconnected' };

const configurationStatus =
  data.configuration.missingRequired.length > 0
    ? { variant: 'error' as const, text: 'Action required' }
    : data.configuration.warnings.length > 0
      ? { variant: 'warning' as const, text: 'Review warnings' }
      : { variant: 'success' as const, text: 'Healthy' };

const runtimeSummaryVariant: StatusVariant = 'neutral';
const databaseDriverLabel = data.database.isD1 ? 'D1' : data.database.dialect;
const databasePlatformLabel = data.database.isD1 ? 'Cloudflare D1' : 'Local SQLite';
---

<section data-testid="diagnostics-summary" class="grid grid-cols-1 gap-4 xl:grid-cols-3">
  <Card padding="lg">
    <div class="flex h-full flex-col">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <div class="flex items-center gap-2">
            <span data-summary-marker="runtime" class={summaryMarkerClass(runtimeSummaryVariant)}
            ></span>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45">
              Runtime
            </p>
          </div>
        </div>
        <Server size={14} class={summaryGlyphClass(runtimeSummaryVariant)} aria-hidden="true" />
      </div>

      <p
        data-summary-value="runtime"
        class="mt-5 text-3xl font-semibold tracking-tight text-base-content"
      >
        {data.runtime.runtime}
      </p>

      <dl class="mt-5">
        <div class={summaryReadoutRowClass}>
          <dt class={summaryReadoutLabelClass}>Environment</dt>
          <dd class={summaryReadoutValueClass}>{data.runtime.environment}</dd>
        </div>

        <div class={summaryReadoutRowClass}>
          <dt class={summaryReadoutLabelClass}>App Version</dt>
          <dd class={summaryReadoutMonoValueClass}>v{APP_VERSION}</dd>
        </div>

        {
          data.runtime.region && (
            <div class={summaryReadoutRowClass}>
              <dt class={summaryReadoutLabelClass}>Region</dt>
              <dd class={summaryReadoutMonoValueClass}>{data.runtime.region}</dd>
            </div>
          )
        }
      </dl>
    </div>
  </Card>

  <Card padding="lg">
    <div class="flex h-full flex-col">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <div class="flex items-center gap-2">
            <span data-summary-marker="data-layer" class={summaryMarkerClass(connStatus.variant)}
            ></span>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45">
              Data Layer
            </p>
          </div>
        </div>
        <DataLayerGlyph
          size={14}
          class={summaryGlyphClass(connStatus.variant)}
          aria-hidden="true"
        />
      </div>

      <p class="mt-5 text-3xl font-semibold tracking-tight text-base-content">{connStatus.text}</p>

      <dl class="mt-5">
        <div class={summaryReadoutRowClass}>
          <dt class={summaryReadoutLabelClass}>Driver</dt>
          <dd class={summaryReadoutValueClass}>{databaseDriverLabel}</dd>
        </div>

        <div class={summaryReadoutRowClass}>
          <dt class={summaryReadoutLabelClass}>Platform</dt>
          <dd class={summaryReadoutValueClass}>{databasePlatformLabel}</dd>
        </div>

        {
          data.database.queryMetrics && (
            <div class={summaryReadoutRowClass}>
              <dt class={summaryReadoutLabelClass}>Queries</dt>
              <dd class={summaryReadoutValueClass}>
                {data.database.queryMetrics.totalQueries} checked
              </dd>
            </div>
          )
        }
      </dl>
    </div>
  </Card>

  <Card padding="lg">
    <div class="flex h-full flex-col">
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0">
          <div class="flex items-center gap-2">
            <span data-summary-marker="caching" class={summaryMarkerClass(cacheStatus.variant)}
            ></span>
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45">
              Caching
            </p>
          </div>
        </div>
        <Activity size={14} class={summaryGlyphClass(cacheStatus.variant)} aria-hidden="true" />
      </div>

      <p class="mt-5 text-3xl font-semibold tracking-tight text-base-content">{cacheStatus.text}</p>

      <dl class="mt-5">
        <div class={summaryReadoutRowClass}>
          <dt class={summaryReadoutLabelClass}>Driver</dt>
          <dd class={summaryReadoutValueClass}>{data.cache.driver}</dd>
        </div>

        <div class={summaryReadoutRowClass}>
          <dt class={summaryReadoutLabelClass}>Enabled</dt>
          <dd class={summaryReadoutValueClass}>{data.cache.isEnabled ? 'Yes' : 'No'}</dd>
        </div>
      </dl>
    </div>
  </Card>
</section>

<Card padding="lg" className="mt-6">
  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45">
          Configuration status
        </p>
        <p class="mt-1 text-sm text-base-content/60">
          Required configuration and deployment warnings stay visible near the top.
        </p>
      </div>
      <span class={badgeClass(configurationStatus.variant)}>{configurationStatus.text}</span>
    </div>

    {
      data.configuration.missingRequired.length > 0 && (
        <div class="alert alert-error" role="alert">
          <TriangleAlert size={20} class="shrink-0" aria-hidden="true" />
          <div>
            <h3 class="font-semibold">Missing Required Configuration</h3>
            <div class="mt-2 flex flex-wrap gap-2">
              {data.configuration.missingRequired.map((varName) => (
                <code class="rounded-md bg-black/10 px-2 py-1 text-xs font-medium">{varName}</code>
              ))}
            </div>
          </div>
        </div>
      )
    }

    {
      data.configuration.warnings.length > 0 && (
        <div class="alert alert-warning" role="alert">
          <TriangleAlert size={20} class="shrink-0" aria-hidden="true" />
          <div>
            <h3 class="font-semibold">Configuration Warnings</h3>
            <ul class="mt-1 space-y-1 text-sm text-base-content/80">
              {data.configuration.warnings.map((warning) => (
                <li>{warning}</li>
              ))}
            </ul>
          </div>
        </div>
      )
    }

    {
      data.configuration.isValid &&
        data.configuration.missingRequired.length === 0 &&
        data.configuration.warnings.length === 0 && (
          <div class="rounded-2xl border border-success/20 bg-success/5 px-4 py-3 text-sm text-base-content/70">
            Required configuration is present and no warnings were reported.
          </div>
        )
    }
  </div>
</Card>

<div class="mt-6 grid grid-cols-1 gap-6">
  <Card padding="lg">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div class="flex items-center gap-3">
        <div
          class="flex h-12 w-12 items-center justify-center rounded-2xl bg-primary/10 text-primary"
        >
          <Server size={24} class="stroke-current" aria-hidden="true" />
        </div>
        <div>
          <h2 class="text-xl font-semibold">Runtime Environment</h2>
          <p class="text-sm text-base-content/60">System information and deployment context</p>
        </div>
      </div>
      <span class="badge badge-outline">{data.runtime.runtime}</span>
    </div>

    <dl class="grid grid-cols-1 gap-x-8 gap-y-4 md:grid-cols-2">
      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">Environment</dt>
        <dd class="mt-1 text-sm text-base-content">{data.runtime.environment}</dd>
      </div>

      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">Runtime</dt>
        <dd class="mt-1 text-sm text-base-content">{data.runtime.runtime}</dd>
      </div>

      {
        data.runtime.region && (
          <div class="border-b border-base-300 py-2">
            <dt class="text-sm font-medium text-base-content/70">Region</dt>
            <dd class="mt-1 font-mono text-sm text-base-content">{data.runtime.region}</dd>
          </div>
        )
      }

      {
        data.runtime.nodeVersion && (
          <div class="border-b border-base-300 py-2">
            <dt class="text-sm font-medium text-base-content/70">Node Version</dt>
            <dd class="mt-1 font-mono text-sm text-base-content">{data.runtime.nodeVersion}</dd>
          </div>
        )
      }

      {
        data.runtime.bunVersion && (
          <div class="border-b border-base-300 py-2">
            <dt class="text-sm font-medium text-base-content/70">Bun Version</dt>
            <dd class="mt-1 font-mono text-sm text-base-content">{data.runtime.bunVersion}</dd>
          </div>
        )
      }

      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">App Version</dt>
        <dd class="mt-1 flex flex-wrap items-center gap-3 text-sm text-base-content">
          <span class="font-mono">v{APP_VERSION}</span>
          <a
            href="https://docs.allowealth.io/changelog/"
            target="_blank"
            rel="noopener noreferrer"
            class="link link-hover link-accent"
          >
            View changelog
          </a>
        </dd>
      </div>

      {
        data.runtime.workersCf && (
          <div class="border-b border-base-300 py-2 md:col-span-2">
            <dt class="text-sm font-medium text-base-content/70">Workers Metadata</dt>
            <dd class="mt-1 font-mono text-sm text-base-content">{data.runtime.workersCf}</dd>
          </div>
        )
      }
    </dl>
  </Card>

  <Card padding="lg">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-info/10 text-info">
          <DataLayerGlyph size={24} class="stroke-current" aria-hidden="true" />
        </div>
        <div>
          <h2 class="text-xl font-semibold">Database</h2>
          <p class="text-sm text-base-content/60">Connection, dialect, and query diagnostics</p>
        </div>
      </div>
      <span class={badgeClass(connStatus.variant)}>{connStatus.text}</span>
    </div>

    <dl class="grid grid-cols-1 gap-x-8 gap-y-4 md:grid-cols-2">
      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">Dialect</dt>
        <dd class="mt-1 text-sm text-base-content">
          {data.database.isD1 ? 'D1' : data.database.dialect}
        </dd>
      </div>

      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">Connection</dt>
        <dd class="mt-1 flex items-center gap-2 text-sm text-base-content">
          {
            connStatus.variant === 'success' ? (
              <CircleCheck size={16} class="text-success" aria-hidden="true" />
            ) : (
              <CircleX size={16} class="text-error" aria-hidden="true" />
            )
          }
          <span>{connStatus.text}</span>
        </dd>
      </div>

      <div class="py-2 md:col-span-2">
        <dt class="text-sm font-medium text-base-content/70">Database URL</dt>
        <dd class="mt-2">
          <code class="block overflow-x-auto rounded-md bg-base-200 px-3 py-2 text-xs">
            {data.database.url}
          </code>
        </dd>
      </div>

      {
        data.database.queryMetrics && (
          <div class="rounded-2xl border border-base-300 bg-base-200/50 p-4 md:col-span-2">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45">
              Query Metrics
            </p>
            <dl class="mt-3 grid grid-cols-1 gap-3 sm:grid-cols-3">
              <div>
                <dt class="text-sm text-base-content/60">Total Queries</dt>
                <dd class="mt-1 text-base font-semibold text-base-content">
                  {data.database.queryMetrics.totalQueries}
                </dd>
              </div>
              <div>
                <dt class="text-sm text-base-content/60">Average Latency</dt>
                <dd class="mt-1 text-base font-semibold text-base-content">
                  {data.database.queryMetrics.avgLatency}ms
                </dd>
              </div>
              <div>
                <dt class="text-sm text-base-content/60">Slow Queries</dt>
                <dd class="mt-1 text-base font-semibold text-base-content">
                  {data.database.queryMetrics.slowQueries}
                </dd>
              </div>
            </dl>
          </div>
        )
      }
    </dl>
  </Card>

  <Card padding="lg">
    <div class="mb-6 flex items-start justify-between gap-4">
      <div class="flex items-center gap-3">
        <div
          class="flex h-12 w-12 items-center justify-center rounded-2xl bg-accent/10 text-accent"
        >
          <Activity size={24} class="stroke-current" aria-hidden="true" />
        </div>
        <div>
          <h2 class="text-xl font-semibold">Cache</h2>
          <p class="text-sm text-base-content/60">Driver configuration and health state</p>
        </div>
      </div>
      <span class={badgeClass(cacheStatus.variant)}>{cacheStatus.text}</span>
    </div>

    <dl class="grid grid-cols-1 gap-x-8 gap-y-4 md:grid-cols-2">
      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">Driver</dt>
        <dd class="mt-1 text-sm text-base-content">{data.cache.driver}</dd>
      </div>

      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">Status</dt>
        <dd class="mt-1 text-sm text-base-content">{cacheStatus.text}</dd>
      </div>

      <div class="border-b border-base-300 py-2">
        <dt class="text-sm font-medium text-base-content/70">Enabled</dt>
        <dd class="mt-1 text-sm text-base-content">{data.cache.isEnabled ? 'Yes' : 'No'}</dd>
      </div>

      {
        data.cache.config.ttl && (
          <div class="border-b border-base-300 py-2">
            <dt class="text-sm font-medium text-base-content/70">Default TTL</dt>
            <dd class="mt-1 text-sm text-base-content">{data.cache.config.ttl}s</dd>
          </div>
        )
      }

      {
        data.cache.config.maxSize && (
          <div class="border-b border-base-300 py-2">
            <dt class="text-sm font-medium text-base-content/70">Max Size</dt>
            <dd class="mt-1 text-sm text-base-content">{data.cache.config.maxSize} items</dd>
          </div>
        )
      }

      {
        data.cache.upstashConfig && (
          <div class="rounded-2xl border border-base-300 bg-base-200/50 p-4 md:col-span-2">
            <p class="text-xs font-semibold uppercase tracking-[0.18em] text-base-content/45">
              Upstash
            </p>
            <dl class="mt-3 grid grid-cols-1 gap-3">
              <div>
                <dt class="text-sm text-base-content/60">URL</dt>
                <dd class="mt-1">
                  <code class="block overflow-x-auto rounded-md bg-base-100 px-3 py-2 text-xs">
                    {data.cache.upstashConfig.url}
                  </code>
                </dd>
              </div>
              <div>
                <dt class="text-sm text-base-content/60">REST URL</dt>
                <dd class="mt-1">
                  <code class="block overflow-x-auto rounded-md bg-base-100 px-3 py-2 text-xs">
                    {data.cache.upstashConfig.restUrl}
                  </code>
                </dd>
              </div>
            </dl>
          </div>
        )
      }

      {
        data.cache.lastError && (
          <div class="rounded-2xl border border-error/30 bg-error/5 p-4 md:col-span-2">
            <dt class="text-sm font-medium text-error">Last Error</dt>
            <dd class="mt-2 text-xs text-error">{data.cache.lastError}</dd>
          </div>
        )
      }
    </dl>
  </Card>
</div>

<Card padding="lg" className="mt-6">
  <div class="mb-6 flex items-center gap-3">
    <div
      class="flex h-12 w-12 items-center justify-center rounded-2xl bg-secondary/10 text-secondary"
    >
      <Settings size={24} class="stroke-current" aria-hidden="true" />
    </div>
    <div>
      <h2 class="text-xl font-semibold">Environment Variables</h2>
      <p class="text-sm text-base-content/60">
        Non-sensitive runtime and application configuration values
      </p>
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="table table-zebra table-sm">
      <thead>
        <tr>
          <th>Name</th>
          <th>Value</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        {
          data.environment.map((envVar) => {
            const status = getEnvVarStatus(envVar.isSet, envVar.isSensitive);

            return (
              <tr>
                <td>
                  <code class="text-sm">{envVar.name}</code>
                </td>
                <td>
                  <code
                    class={`block max-w-xs overflow-x-auto rounded-md bg-base-300 px-3 py-1.5 text-sm ${envVar.isSensitive ? 'text-warning' : ''}`}
                  >
                    {envVar.value}
                  </code>
                </td>
                <td>
                  <div class="flex items-center gap-2">
                    <div
                      class={`flex h-6 w-6 items-center justify-center rounded-lg ${toneClass(status.variant)}`}
                    >
                      {status.variant === 'success' ? (
                        <CircleCheck class={iconTextClass(status.variant)} aria-hidden="true" />
                      ) : status.variant === 'error' ? (
                        <CircleX class={iconTextClass(status.variant)} aria-hidden="true" />
                      ) : (
                        <Code class={iconTextClass(status.variant)} aria-hidden="true" />
                      )}
                    </div>
                    <span class={badgeClass(status.variant)}>{status.text}</span>
                  </div>
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</Card>

<footer class="py-4 text-center text-sm text-base-content/50">
  Last updated: <time datetime={data.timestamp} class="font-mono"
    >{formatTimestamp(data.timestamp)}</time
  >
</footer>
