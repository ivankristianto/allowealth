---
/**
 * Payment Method Confirm Modal Component
 *
 * Modal for confirming deactivate/activate payment methods.
 * Uses the same Modal pattern as other modals in the application.
 *
 * @param {string} id - Modal ID
 * @param {'deactivate' | 'activate'} action - Action type
 */

import ConfirmationModal from '../molecules/ConfirmationModal.astro';
import { Ban, RefreshCw } from '@lucide/astro';

export interface Props {
  id: string;
  action: 'deactivate' | 'activate';
}

const { id, action } = Astro.props;

const isDeactivate = action === 'deactivate';
const title = isDeactivate ? 'Deactivate Payment Method' : 'Reactivate Payment Method';
const description = isDeactivate
  ? 'Are you sure you want to deactivate this payment method? It will no longer appear in transaction forms, but existing transactions will remain unchanged.'
  : 'Are you sure you want to reactivate this payment method? It will become available for use in transaction forms again.';
const confirmLabel = isDeactivate ? 'Deactivate' : 'Reactivate';
const confirmVariant = isDeactivate ? 'warning' : 'success';
const confirmLoadingLabel = isDeactivate ? 'Deactivating...' : 'Reactivating...';
const iconVariant = isDeactivate ? 'warning' : 'success';
const iconComponent = isDeactivate ? Ban : RefreshCw;
---

<div data-payment-method-confirm-modal data-id={id} data-action={action}>
  <ConfirmationModal
    id={id}
    title={title}
    description={description}
    icon={iconComponent}
    iconVariant={iconVariant}
    confirmLabel={confirmLabel}
    confirmVariant={confirmVariant}
    confirmLoadingLabel={confirmLoadingLabel}
  />
</div>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { getCsrfHeaders } from '@/lib/csrf-client';
  import {
    clearConfirmError,
    closeConfirmationModal,
    getConfirmationModalElements,
    resetConfirmationModal,
    setConfirmLoading,
    showConfirmError,
  } from '@/components/molecules/ConfirmationModal.client';

  // Track initialized containers
  const initializedContainers = new WeakSet<Element>();

  function initPaymentMethodConfirmModals() {
    document.querySelectorAll('[data-payment-method-confirm-modal]').forEach((container) => {
      if (initializedContainers.has(container)) return;
      initializedContainers.add(container);

      const id = container.getAttribute('data-id');
      const actionType = container.getAttribute('data-action') as 'deactivate' | 'activate';
      if (!id) return;

      const { modal, confirmButton, cancelButton, errorElement } = getConfirmationModalElements(
        container,
        id
      );

      if (!modal || !confirmButton) return;

      let currentMethodId: string | null = null;

      // Handle cancel button
      cancelButton?.addEventListener('click', () => {
        resetConfirmationModal(confirmButton, errorElement);
        closeConfirmationModal(modal);
      });

      // Handle confirm button
      confirmButton.addEventListener('click', async () => {
        if (!currentMethodId) return;

        const isDeactivate = actionType === 'deactivate';

        // Clear errors
        clearConfirmError(errorElement);

        // Show loading state
        setConfirmLoading(confirmButton, true);

        try {
          const response = await fetch(`/api/payment-methods/${currentMethodId}`, {
            method: 'PUT',
            credentials: 'include',
            headers: {
              'Content-Type': 'application/json',
              ...getCsrfHeaders(),
            },
            body: JSON.stringify({ is_active: !isDeactivate }),
          });

          const result = await response.json();

          if (!response.ok || !result.success) {
            throw new Error(result.error?.message || 'Operation failed');
          }

          // Success
          addToast(
            isDeactivate ? 'Payment method deactivated!' : 'Payment method reactivated!',
            'success'
          );
          closeConfirmationModal(modal);

          // Reload page to show updated data
          window.location.reload();
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Operation failed';
          showConfirmError(errorElement, message);
          addToast(message, 'error');
        } finally {
          setConfirmLoading(confirmButton, false);
        }
      });

      // TODO: P2 - Replace window global function with custom events pattern
      // Example: document.addEventListener('payment-method-confirm:open', (e) => { ... })
      // Expose function to open modal
      const fnName = actionType === 'deactivate' ? 'openDeactivateModal' : 'openActivateModal';
      (window as any)[fnName] = (methodId: string) => {
        currentMethodId = methodId;
        clearConfirmError(errorElement);
        if (!modal.open) {
          modal.showModal();
        }
      };
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initPaymentMethodConfirmModals);
  } else {
    initPaymentMethodConfirmModals();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initPaymentMethodConfirmModals);
</script>
