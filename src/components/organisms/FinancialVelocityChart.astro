---
/**
 * FinancialVelocityChart Component
 *
 * Interactive bar chart showing financial velocity (income vs expenses) over time.
 * Uses Chart.js for rendering with grouped bars.
 * Follows Oasis Finance v1.0.0 design system specifications.
 *
 * @param {TrendDataPoint[]} data - Array of monthly trend data (income and expenses)
 * @param {string} subtitle - Subtitle text (e.g., "TRAILING 3 MONTHS")
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import Card from '@/components/atoms/Card.astro';
import StatLabel from '@/components/atoms/StatLabel.astro';
import Skeleton from '@/components/atoms/Skeleton.astro';

export interface TrendDataPoint {
  name: string; // Month label (e.g., "Jan", "Feb")
  income: number;
  expenses: number;
}

export interface Props {
  data: TrendDataPoint[];
  subtitle?: string;
  loading?: boolean;
  error?: string;
  className?: string;
}

const {
  data = [],
  subtitle = 'TRAILING 3 MONTHS',
  loading = false,
  error,
  className = '',
} = Astro.props;

// Serialize data for client-side script with XSS prevention
const serializedData = JSON.stringify(data)
  .replace(/</g, '\\u003c')
  .replace(/>/g, '\\u003e')
  .replace(/&/g, '\\u0026');

// Generate unique ID for this chart instance
const chartId = `financial-velocity-chart-${Math.random().toString(36).slice(2, 11)}`;
---

<Card
  padding="lg"
  rounded="card-lg"
  className={className}
  role="region"
  aria-label="Financial velocity over time"
>
  <div class="flex flex-col gap-6 md:gap-8">
    {/* Header */}
    <div class="flex justify-between items-center">
      <h4 class="font-bold text-base md:text-lg text-base-content tracking-tight">
        Financial Velocity
      </h4>
      <StatLabel size="sm" color="neutral">{subtitle}</StatLabel>
    </div>

    {/* Loading State */}
    {
      loading ? (
        <div class="py-6 min-h-[300px]">
          <Skeleton variant="rectangular" width="100%" height="300px" className="rounded-2xl" />
        </div>
      ) : error ? (
        /* Error State */
        <div class="p-12 text-center">
          <p class="text-error font-medium" role="alert">
            {error}
          </p>
        </div>
      ) : data.length === 0 ? (
        /* Empty State */
        <div class="p-12 text-center">
          <p class="text-base-content/60 font-medium">No trend data available.</p>
        </div>
      ) : (
        /* Chart Container */
        <div
          class="h-[300px] w-full min-h-[300px]"
          data-chart-data={serializedData}
          id={`${chartId}-container`}
        >
          <canvas
            id={chartId}
            aria-label={`Financial velocity bar chart showing income and expenses for ${data.length} periods`}
            role="img"
          />
        </div>
      )
    }

    {/* Screen Reader Data Table */}
    {
      !loading && !error && data.length > 0 && (
        <table class="sr-only" aria-label="Financial velocity data table">
          <thead>
            <tr>
              <th>Period</th>
              <th>Income</th>
              <th>Expenses</th>
            </tr>
          </thead>
          <tbody>
            {data.map((item) => (
              <tr>
                <td>{item.name}</td>
                <td>{item.income}</td>
                <td>{item.expenses}</td>
              </tr>
            ))}
          </tbody>
        </table>
      )
    }
  </div>
</Card>

<style>
  /* Visually hide but keep accessible for screen readers */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }
</style>

<script>
  import Chart from 'chart.js/auto';

  interface TrendDataPoint {
    name: string;
    income: number;
    expenses: number;
  }

  interface ChartData {
    [chartId: string]: {
      chart: Chart<'bar', number[], string>;
      data: TrendDataPoint[];
    };
  }

  // Store chart instances globally for cleanup
  const charts: ChartData = {};

  // Store observer reference for cleanup
  let chartObserver: IntersectionObserver | null = null;
  let themeObserver: MutationObserver | null = null;
  let systemThemeMediaQuery: MediaQueryList | null = null;

  /**
   * Cleanup all chart instances and observers
   */
  function cleanupCharts(): void {
    const chartIds = Object.keys(charts);
    chartIds.forEach((chartId) => {
      const entry = charts[chartId];
      if (entry?.chart) {
        try {
          entry.chart.destroy();
        } catch (e) {
          console.warn('Failed to destroy chart:', chartId, e);
        }
      }
      delete charts[chartId];
    });

    if (chartObserver) {
      chartObserver.disconnect();
      chartObserver = null;
    }

    if (themeObserver) {
      themeObserver.disconnect();
      themeObserver = null;
    }

    if (systemThemeMediaQuery) {
      systemThemeMediaQuery.removeEventListener('change', handleSystemThemeChange);
      systemThemeMediaQuery = null;
    }
  }

  /**
   * Check if current theme is dark
   */
  function isDarkTheme(): boolean {
    const theme = document.documentElement.getAttribute('data-theme');
    if (theme) return theme === 'dark';
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  }

  /**
   * Handle system theme preference change
   */
  function handleSystemThemeChange(): void {
    const explicitTheme = document.documentElement.getAttribute('data-theme');
    if (!explicitTheme) {
      updateChartThemeColors();
    }
  }

  /**
   * Update chart colors based on current theme
   */
  function updateChartThemeColors(): void {
    const dark = isDarkTheme();

    Object.values(charts).forEach(({ chart }) => {
      // Update tooltip colors
      if (chart.options.plugins?.tooltip) {
        chart.options.plugins.tooltip.backgroundColor = dark
          ? 'rgba(248, 250, 252, 0.95)'
          : 'rgba(15, 23, 42, 0.9)';
        chart.options.plugins.tooltip.titleColor = dark ? '#0f172a' : '#fff';
        chart.options.plugins.tooltip.bodyColor = dark ? '#0f172a' : '#fff';
      }

      // Update legend colors
      if (chart.options.plugins?.legend?.labels) {
        chart.options.plugins.legend.labels.color = dark ? '#94a3b8' : '#64748b';
      }

      // Update axis colors
      if (chart.options.scales?.x?.ticks) {
        chart.options.scales.x.ticks.color = dark ? '#94a3b8' : '#64748b';
      }
      if (chart.options.scales?.y?.ticks) {
        chart.options.scales.y.ticks.color = dark ? '#94a3b8' : '#64748b';
      }
      if (chart.options.scales?.y?.grid) {
        chart.options.scales.y.grid.color = dark
          ? 'rgba(148, 163, 184, 0.1)'
          : 'rgba(148, 163, 184, 0.15)';
      }

      chart.update('none');
    });
  }

  /**
   * Initialize theme observer
   */
  function initThemeObserver(): void {
    if (themeObserver) {
      themeObserver.disconnect();
    }

    themeObserver = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.type === 'attributes' && mutation.attributeName === 'data-theme') {
          updateChartThemeColors();
        }
      });
    });

    themeObserver.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ['data-theme'],
    });

    if (window.matchMedia) {
      systemThemeMediaQuery = window.matchMedia('(prefers-color-scheme: dark)');
      systemThemeMediaQuery.addEventListener('change', handleSystemThemeChange);
    }
  }

  /**
   * Initialize financial velocity chart with Chart.js
   */
  function initFinancialVelocityChart(chartId: string, data: TrendDataPoint[]): void {
    const canvas = document.getElementById(chartId) as HTMLCanvasElement;
    if (!canvas) return;

    // Destroy existing chart if it exists
    if (charts[chartId]?.chart) {
      charts[chartId].chart.destroy();
    }

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const labels = data.map((d) => d.name);
    const incomeData = data.map((d) => d.income);
    const expensesData = data.map((d) => d.expenses);

    const dark = isDarkTheme();
    const gridColor = dark ? 'rgba(148, 163, 184, 0.1)' : 'rgba(148, 163, 184, 0.15)';
    const textColor = dark ? '#94a3b8' : '#64748b';

    const chart = new Chart(ctx, {
      type: 'bar',
      data: {
        labels,
        datasets: [
          {
            label: 'Income',
            data: incomeData,
            backgroundColor: '#10b981', // emerald-500 (success)
            borderRadius: 6,
            borderSkipped: false,
          },
          {
            label: 'Expenses',
            data: expensesData,
            backgroundColor: '#ef4444', // red-500 (error)
            borderRadius: 6,
            borderSkipped: false,
          },
        ],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: {
          mode: 'index',
          intersect: false,
        },
        plugins: {
          legend: {
            display: true,
            position: 'bottom',
            labels: {
              color: textColor,
              font: {
                size: 10,
                weight: 700,
              },
              usePointStyle: true,
              pointStyle: 'circle',
              padding: 20,
            },
          },
          tooltip: {
            backgroundColor: dark ? 'rgba(248, 250, 252, 0.95)' : 'rgba(15, 23, 42, 0.9)',
            titleColor: dark ? '#0f172a' : '#fff',
            bodyColor: dark ? '#0f172a' : '#fff',
            padding: 12,
            cornerRadius: 12,
            displayColors: true,
            callbacks: {
              label: (context) => {
                const label = context.dataset.label || '';
                const value = context.parsed.y;
                // Format value as currency
                const formatted = new Intl.NumberFormat('id-ID', {
                  minimumFractionDigits: 0,
                  maximumFractionDigits: 0,
                }).format(value);
                return `${label}: Rp ${formatted}`;
              },
            },
          },
        },
        scales: {
          x: {
            grid: {
              display: false,
            },
            ticks: {
              color: textColor,
              font: {
                size: 10,
                weight: 700,
              },
            },
            border: {
              display: false,
            },
          },
          y: {
            display: false,
            grid: {
              color: gridColor,
            },
            border: {
              display: false,
            },
            beginAtZero: true,
          },
        },
      },
    });

    charts[chartId] = { chart, data };
  }

  /**
   * Initialize all charts with Intersection Observer
   */
  function initAllCharts(): void {
    cleanupCharts();
    initThemeObserver();

    const chartContainers = document.querySelectorAll(
      '[id^="financial-velocity-chart-"][id$="-container"]'
    );

    chartObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const container = entry.target as HTMLElement;
            chartObserver?.unobserve(container); // Unobserve immediately to prevent memory leaks

            const chartId = container.querySelector('canvas')?.id;
            if (chartId && !charts[chartId]) {
              try {
                const dataAttr = container.getAttribute('data-chart-data');
                if (dataAttr) {
                  const rawData = JSON.parse(dataAttr) as TrendDataPoint[];
                  // Validate chart data to prevent security issues and rendering errors
                  const validData = rawData.filter(
                    (item) =>
                      typeof item.income === 'number' &&
                      isFinite(item.income) &&
                      item.income >= 0 &&
                      typeof item.expenses === 'number' &&
                      isFinite(item.expenses) &&
                      item.expenses >= 0 &&
                      typeof item.name === 'string' &&
                      item.name.length > 0 &&
                      item.name.length <= 100
                  );
                  if (validData.length > 0) {
                    initFinancialVelocityChart(chartId, validData);
                  }
                }
              } catch (e) {
                console.warn('Failed to initialize chart:', chartId, e);
              }
            }
          }
        });
      },
      { rootMargin: '50px' }
    );

    chartContainers.forEach((container) => {
      if (chartObserver) chartObserver.observe(container);
    });
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllCharts);
  } else {
    initAllCharts();
  }

  // Cleanup on page navigation/unload
  window.addEventListener('beforeunload', cleanupCharts);

  // For Astro View Transitions
  document.addEventListener('astro:before-swap', cleanupCharts);
  document.addEventListener('astro:after-swap', initAllCharts);
</script>
