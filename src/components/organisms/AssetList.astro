---
/**
 * Asset List Component (Organism)
 *
 * Displays all assets for the user with:
 * - Asset name, type, balance, currency
 * - Grouped by type and currency
 * - Actions to edit, update balance, view history
 *
 * @param {Array} assets - Array of asset data
 * @param {string} currency - Filter currency (optional)
 * @param {string} className - Additional CSS classes
 */

import { formatCurrency } from '@/lib/tokens';
import { formatAssetType } from '@/lib/types/asset';
import EmptyState from '../atoms/EmptyState.astro';
import { Pencil, Eye, TrendingUp, Wallet } from '@lucide/astro';
import type { AssetOutput } from '@/lib/types/asset';

export interface Props {
  assets: AssetOutput[];
  currency?: 'IDR' | 'USD';
  type?: string;
  className?: string;
  baseUrl?: string;
}

const { assets, className = '', baseUrl = '/assets' } = Astro.props;

// Group assets by type
const assetsByType = assets.reduce(
  (acc, asset) => {
    if (!acc[asset.type]) {
      acc[asset.type] = [];
    }
    acc[asset.type].push(asset);
    return acc;
  },
  {} as Record<string, AssetOutput[]>
);

// Calculate totals
const totalsByCurrency = assets.reduce(
  (acc, asset) => {
    if (!acc[asset.currency]) {
      acc[asset.currency] = '0';
    }
    const currentTotal = parseFloat(acc[asset.currency]);
    const assetBalance = parseFloat(asset.balance);
    acc[asset.currency] = (currentTotal + assetBalance).toString();
    return acc;
  },
  {} as Record<string, string>
);

// Asset type order for display
const assetTypeOrder: Record<string, number> = {
  bank_account: 1,
  mutual_fund: 2,
  stock: 3,
  bond: 4,
  crypto: 5,
  other: 6,
};

// Sort types by defined order
const sortedTypes = Object.keys(assetsByType).sort(
  (a, b) => (assetTypeOrder[a] || 99) - (assetTypeOrder[b] || 99)
);

// Get currency color class
const getCurrencyClass = (currency: string): string => {
  return currency === 'IDR' ? 'text-success' : 'text-info';
};
---

<div class={`space-y-6 ${className}`} data-asset-list>
  {/* Assets Header */}
  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
    <div>
      <h2 class="text-2xl font-bold">Assets</h2>
      <p class="text-neutral-600">Track your assets across different types and currencies</p>
    </div>
    <div class="flex items-center gap-2">
      <a href={`${baseUrl}/add`} class="btn btn-primary gap-2">
        <Wallet size={18} class="stroke-current" aria-hidden="true" />
        Add Asset
      </a>
    </div>
  </div>

  {/* Totals Summary */}
  {
    Object.keys(totalsByCurrency).length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {Object.entries(totalsByCurrency).map(([curr, total]) => (
          <div class="card bg-base-100 shadow border border-base-300">
            <div class="card-body py-4">
              <div class="flex items-center justify-between">
                <span class="text-neutral-600">Total Assets ({curr})</span>
                <span class={`text-2xl font-bold ${getCurrencyClass(curr)}`}>
                  {formatCurrency(parseFloat(total), curr as 'IDR' | 'USD')}
                </span>
              </div>
            </div>
          </div>
        ))}
      </div>
    )
  }

  {/* Assets by Type */}
  {
    assets.length > 0 ? (
      <div class="space-y-6">
        {sortedTypes.map((assetType) => {
          const typeAssets = assetsByType[assetType];
          const typeTotal = typeAssets.reduce((sum, asset) => sum + parseFloat(asset.balance), 0);
          const typeCurrency = typeAssets[0]?.currency || 'IDR';

          return (
            <div class="card bg-base-100 shadow border border-base-300 overflow-hidden">
              <div class="card-body p-0">
                {/* Type Header */}
                <div class="px-6 py-4 bg-base-200 border-b border-base-300">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-3">
                      <h3 class="text-lg font-semibold">{formatAssetType(assetType as any)}</h3>
                      <span class="badge badge-neutral">{typeAssets.length}</span>
                    </div>
                    <span class={`text-lg font-bold ${getCurrencyClass(typeCurrency)}`}>
                      {formatCurrency(typeTotal, typeCurrency as 'IDR' | 'USD')}
                    </span>
                  </div>
                </div>

                {/* Assets List */}
                <div class="divide-y divide-base-200">
                  {typeAssets.map((asset) => (
                    <div class="px-6 py-4 hover:bg-base-100/50 transition-colors">
                      {/* Mobile View - Card Layout */}
                      <div class="lg:hidden space-y-2">
                        <div class="flex items-center justify-between">
                          <span class="font-semibold">{asset.name}</span>
                          <span class={`font-bold ${getCurrencyClass(asset.currency)}`}>
                            {formatCurrency(parseFloat(asset.balance), asset.currency)}
                          </span>
                        </div>
                        <div class="flex items-center justify-between text-sm text-neutral-600">
                          <span>Currency</span>
                          <span class={`font-medium ${getCurrencyClass(asset.currency)}`}>
                            {asset.currency}
                          </span>
                        </div>
                        <div class="flex items-center justify-between text-sm text-neutral-600">
                          <span>Last Updated</span>
                          <span>{new Date(asset.last_updated).toLocaleDateString()}</span>
                        </div>
                        <div class="pt-2 flex items-center gap-2">
                          <button
                            class="btn btn-ghost btn-xs gap-1"
                            onclick={`openUpdateBalanceModal("${asset.id}")`}
                          >
                            <TrendingUp size={12} class="stroke-current" aria-hidden="true" />
                            Update Balance
                          </button>
                          <a
                            href={`${baseUrl}/edit/${asset.id}`}
                            class="btn btn-ghost btn-xs gap-1"
                          >
                            <Pencil size={12} class="stroke-current" aria-hidden="true" />
                            Edit
                          </a>
                          <a
                            href={`${baseUrl}/history/${asset.id}`}
                            class="btn btn-ghost btn-xs gap-1"
                          >
                            <Eye size={12} class="stroke-current" aria-hidden="true" />
                            History
                          </a>
                        </div>
                      </div>

                      {/* Desktop View - Table Row */}
                      <div class="hidden lg:grid lg:grid-cols-12 gap-4 items-center">
                        <div class="lg:col-span-5">
                          <span class="font-medium">{asset.name}</span>
                        </div>
                        <div class="lg:col-span-2">
                          <span class={`badge ${getCurrencyClass(asset.currency)} badge-outline`}>
                            {asset.currency}
                          </span>
                        </div>
                        <div class="lg:col-span-2 text-right">
                          <span class={`font-semibold ${getCurrencyClass(asset.currency)}`}>
                            {formatCurrency(parseFloat(asset.balance), asset.currency)}
                          </span>
                        </div>
                        <div class="lg:col-span-2 text-right text-sm text-neutral-600">
                          {new Date(asset.last_updated).toLocaleDateString()}
                        </div>
                        <div class="lg:col-span-1">
                          <div class="flex items-center gap-1 justify-end">
                            <button
                              class="btn btn-ghost btn-xs btn-square"
                              title={`Update ${asset.name} balance`}
                              aria-label={`Update ${asset.name} balance`}
                              onclick={`openUpdateBalanceModal("${asset.id}")`}
                            >
                              <TrendingUp size={14} class="stroke-current" aria-hidden="true" />
                            </button>
                            <a
                              href={`${baseUrl}/edit/${asset.id}`}
                              class="btn btn-ghost btn-xs btn-square"
                              title={`Edit ${asset.name}`}
                              aria-label={`Edit ${asset.name}`}
                            >
                              <Pencil size={14} class="stroke-current" aria-hidden="true" />
                            </a>
                            <a
                              href={`${baseUrl}/history/${asset.id}`}
                              class="btn btn-ghost btn-xs btn-square"
                              title={`View ${asset.name} history`}
                              aria-label={`View ${asset.name} history`}
                            >
                              <Eye size={14} class="stroke-current" aria-hidden="true" />
                            </a>
                          </div>
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      // Empty state
      <div class="card bg-base-100 shadow border border-base-300">
        <div class="card-body">
          <EmptyState
            title="No assets tracked yet"
            message="Add your first asset to start tracking your net worth across different types and currencies."
            actionLabel="Add Your First Asset"
            actionHref={`${baseUrl}/add`}
          />
        </div>
      </div>
    )
  }
</div>

<script>
  // Asset List Client-side script
  // Handles update balance functionality

  interface UpdateBalanceResponse {
    success: boolean;
    data?: any;
    error?: {
      message: string;
      code?: string;
      details?: Array<{ message: string }>;
    };
  }

  document.addEventListener('DOMContentLoaded', () => {
    const container = document.querySelector('[data-asset-list]');
    if (!container) return;

    const updateBalanceModal = document.getElementById('update-balance-modal') as HTMLDialogElement;
    const updateBalanceForm = document.getElementById('update-balance-form') as HTMLFormElement;
    const updateBalanceFormError = document.getElementById('update-balance-form-error');
    const updateBalanceCancelBtn = document.getElementById('update-balance-cancel-btn');
    const submitButton = updateBalanceForm?.querySelector(
      'button[type="submit"]'
    ) as HTMLButtonElement;

    // Show form error
    function showFormError(message: string) {
      if (updateBalanceFormError) {
        updateBalanceFormError.textContent = message;
        updateBalanceFormError.classList.remove('hidden');
      }
    }

    // Clear form error
    function clearFormError() {
      if (updateBalanceFormError) {
        updateBalanceFormError.textContent = '';
        updateBalanceFormError.classList.add('hidden');
      }
    }

    // Reset form
    function resetForm() {
      updateBalanceForm?.reset();
      const assetIdInput = updateBalanceForm?.querySelector(
        '[name="asset_id"]'
      ) as HTMLInputElement;
      if (assetIdInput) assetIdInput.value = '';
      clearFormError();
    }

    // Show loading state
    function setLoading(isLoading: boolean) {
      if (submitButton) {
        submitButton.disabled = isLoading;
        submitButton.innerHTML = isLoading
          ? '<span class="loading loading-spinner loading-sm"></span> Updating...'
          : 'Update Balance';
      }
    }

    // Show toast notification
    function showToast(message: string, type: 'success' | 'error' = 'success') {
      // Create toast element
      const toast = document.createElement('div');
      toast.className = `alert alert-${type} shadow-lg fixed top-4 right-4 z-50 max-w-sm`;
      toast.setAttribute('role', 'alert');

      // Use Lucide icon paths for consistency
      const iconSvg =
        type === 'success'
          ? '<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="m9 12 2 2 4-4"/></svg>'
          : '<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="m15 9-6 6"/><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 6 6"/></svg>';

      toast.innerHTML = `
        ${iconSvg}
        <span>${message}</span>
      `;

      document.body.appendChild(toast);

      // Auto-remove after 3 seconds
      setTimeout(() => {
        toast.remove();
      }, 3000);
    }

    // Refresh the asset list by reloading the page
    function refreshAssetData() {
      window.location.reload();
    }

    // Function to open update balance modal
    function openUpdateBalanceModal(assetId: string) {
      const form = updateBalanceForm;
      if (form) {
        (form.querySelector('[name="asset_id"]') as HTMLInputElement).value = assetId;
      }

      clearFormError();
      updateBalanceModal?.showModal();
    }

    // Expose function globally for onclick handlers
    (window as any).openUpdateBalanceModal = openUpdateBalanceModal;

    // Form submission
    updateBalanceForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearFormError();

      const formData = new FormData(updateBalanceForm);
      const assetId = formData.get('asset_id') as string;

      if (!assetId) {
        showFormError('Asset ID is missing');
        return;
      }

      const balance = formData.get('balance') as string;
      const notes = formData.get('notes') as string;

      // Validate balance (parse as number for validation, but send as string)
      const balanceNum = parseFloat(balance);
      if (isNaN(balanceNum) || balanceNum < 0) {
        showFormError('Balance must be a valid positive number');
        return;
      }

      const data = {
        balance,
        notes: notes || null,
      };

      setLoading(true);

      try {
        const response = await fetch(`/api/assets/${assetId}/balance`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        const result = (await response.json()) as UpdateBalanceResponse;

        if (!response.ok || !result.success) {
          if (result.error?.details) {
            showFormError(result.error.details.map((d) => d.message).join(', '));
          } else {
            showFormError(result.error?.message || 'Failed to update balance');
          }
        } else {
          showToast('Balance updated successfully', 'success');
          resetForm();
          updateBalanceModal?.close();
          setTimeout(() => refreshAssetData(), 500);
        }
      } catch (err) {
        showFormError('Network error. Please try again.');
      } finally {
        setLoading(false);
      }
    });

    // Cancel button handler
    updateBalanceCancelBtn?.addEventListener('click', () => {
      resetForm();
      updateBalanceModal?.close();
    });

    // Reset form when modal closes without saving
    updateBalanceModal?.addEventListener('close', (e) => {
      if ((e.target as HTMLDialogElement).returnValue === '') {
        resetForm();
      }
    });
  });
</script>

<!-- Update Balance Modal -->
<dialog id="update-balance-modal" class="modal">
  <div class="modal-box">
    <h3 class="font-bold text-lg mb-4">Update Asset Balance</h3>
    <form id="update-balance-form" class="space-y-4">
      <input type="hidden" name="asset_id" value="" />

      <div class="form-control">
        <label for="balance" class="label">
          <span class="label-text">New Balance</span>
        </label>
        <input
          type="number"
          id="balance"
          name="balance"
          class="input input-bordered"
          placeholder="Enter new balance"
          step="0.01"
          min="0"
          required
        />
      </div>

      <div class="form-control">
        <label for="notes" class="label">
          <span class="label-text">Notes (optional)</span>
        </label>
        <textarea
          id="notes"
          name="notes"
          class="textarea textarea-bordered"
          placeholder="Add a note about this update..."
          rows="3"></textarea>
      </div>

      <div id="update-balance-form-error" class="hidden text-error text-sm"></div>

      <div class="modal-action">
        <button type="button" id="update-balance-cancel-btn" class="btn btn-ghost">Cancel</button>
        <button type="submit" class="btn btn-primary">Update Balance</button>
      </div>
    </form>
  </div>
  <form method="dialog" class="modal-backdrop">
    <button>close</button>
  </form>
</dialog>
