---
/**
 * CategorySpendingTable Component
 *
 * Table displaying spending per category data with budget, status, and drill-down actions.
 * Follows Oasis Finance v1.0.0 design system specifications.
 *
 * @param {CategoryIntelligence[]} categories - Array of category data
 * @param {Function} onDrillDown - Callback for drill-down button clicks (category name)
 * @param {string} subtitle - Subtitle text (e.g., "SORTED BY AMOUNT SPENT")
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import StatLabel from '@/components/atoms/StatLabel.astro';
import Skeleton from '@/components/atoms/Skeleton.astro';
import CategoryIcon from '@/components/atoms/CategoryIcon.astro';
import { formatCurrency } from '@/lib/formatting';
import { getCategoryColor } from '@/lib/tokens';
import { getIconForCategory } from '@/lib/utils/categoryIcons';
import { Eye } from '@lucide/astro';

export interface CategoryIntelligence {
  id: string;
  name: string;
  spent: number;
  budgetLimit?: number | null; // null or undefined means "Not Set"
  icon?: string; // Lucide icon name
  color?: string; // Tailwind background color class
}

export interface Props {
  categories: CategoryIntelligence[];
  subtitle?: string;
  loading?: boolean;
  error?: string;
  className?: string;
  range?: 'monthly' | 'yearly';
  currency?: 'IDR' | 'USD';
}

const {
  categories = [],
  subtitle = 'SORTED BY AMOUNT SPENT',
  loading = false,
  error,
  className = '',
  range = 'monthly',
  currency = 'IDR',
} = Astro.props;

// Calculate percentage for each category
const categoriesWithPercentage = categories.map((cat) => {
  const percentage =
    cat.budgetLimit && cat.budgetLimit > 0 ? (cat.spent / cat.budgetLimit) * 100 : null;

  const iconName = getIconForCategory(cat.name, cat.icon);

  return {
    ...cat,
    percentage,
    iconName,
    color: cat.color || getCategoryColor(cat.name),
  };
});
---

<div
  class={`bg-base-100 rounded-card border border-base-300 shadow-sm ${className}`}
  role="region"
  aria-label="Spending per category table"
>
  <div class="overflow-hidden">
    {/* Header */}
    <div class="p-6 md:p-8 border-b border-base-300">
      <h4 class="font-bold text-base md:text-lg text-base-content tracking-tight">
        Spending per Category
      </h4>
      <StatLabel size="sm" color="neutral" className="mt-1">{subtitle}</StatLabel>
    </div>

    {/* Loading State */}
    {
      loading ? (
        <div class="p-6 md:p-8 space-y-4">
          {Array.from({ length: 7 }).map(() => (
            <div class="flex items-center gap-4">
              <Skeleton variant="circular" width="40" height="40" />
              <Skeleton variant="text" width="120" height="20" />
              <div class="flex-1" />
              <Skeleton variant="text" width="100" height="20" />
              <Skeleton variant="text" width="100" height="20" />
              <Skeleton variant="text" width="80" height="20" />
              <Skeleton variant="rectangular" width="100" height="32" className="rounded-xl" />
            </div>
          ))}
        </div>
      ) : error ? (
        /* Error State */
        <div class="p-12 text-center">
          <p class="text-error font-medium" role="alert">
            {error}
          </p>
        </div>
      ) : categories.length === 0 ? (
        /* Empty State */
        <div class="p-12 text-center">
          <p class="text-base-content/60 font-medium">No category data available.</p>
        </div>
      ) : (
        /* Table */
        <div class="table-scroll-hint">
          <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
              <thead>
                <tr class="bg-base-200/50 border-b border-base-300">
                  <th class="px-6 md:px-8 py-4 md:py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest">
                    Category
                  </th>
                  <th class="px-6 md:px-8 py-4 md:py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
                    Total Spent
                  </th>
                  <th class="px-6 md:px-8 py-4 md:py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
                    Allocated Budget
                  </th>
                  <th class="px-6 md:px-8 py-4 md:py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-center">
                    Status
                  </th>
                  {range === 'monthly' && (
                    <th class="px-6 md:px-8 py-4 md:py-5 text-xs font-bold text-base-content/40 uppercase tracking-widest text-right">
                      Action
                    </th>
                  )}
                </tr>
              </thead>
              <tbody class="divide-y divide-base-300">
                {categoriesWithPercentage.map((cat) => (
                  <tr class="group hover:bg-base-200/30 transition-colors">
                    {/* Category with Icon */}
                    <td class="px-6 md:px-8 py-5 md:py-6">
                      <div class="flex items-center gap-3 md:gap-4">
                        <CategoryIcon icon={cat.iconName} color={cat.color} size="md" />
                        <span class="text-sm font-bold text-base-content">{cat.name}</span>
                      </div>
                    </td>

                    {/* Total Spent */}
                    <td class="px-6 md:px-8 py-5 md:py-6 text-right">
                      <span class="text-sm font-bold text-base-content">
                        {formatCurrency(cat.spent, currency)}
                      </span>
                    </td>

                    {/* Budget Quota */}
                    <td class="px-6 md:px-8 py-5 md:py-6 text-right">
                      <span class="text-sm font-medium text-base-content/60">
                        {cat.budgetLimit && cat.budgetLimit > 0
                          ? formatCurrency(cat.budgetLimit, currency)
                          : 'Not Set'}
                      </span>
                    </td>

                    {/* Status */}
                    <td class="px-6 md:px-8 py-5 md:py-6 text-center">
                      <div class="inline-flex items-center gap-2">
                        {cat.percentage !== null ? (
                          <>
                            <div class="w-16 h-1.5 bg-base-200 rounded-full overflow-hidden">
                              <div
                                class={`h-full ${cat.percentage > 100 ? 'bg-error' : 'bg-accent'} transition-all duration-300`}
                                style={`width: ${Math.min(cat.percentage, 100)}%`}
                                role="progressbar"
                                aria-valuenow={Math.round(cat.percentage)}
                                aria-valuemin={0}
                                aria-valuemax={100}
                                aria-label={`${Math.round(cat.percentage)}% of budget used`}
                              />
                            </div>
                            <span
                              class={`text-xs font-bold ${cat.percentage > 100 ? 'text-error' : 'text-base-content/60'}`}
                            >
                              {Math.round(cat.percentage)}%
                            </span>
                          </>
                        ) : (
                          <span class="text-xs font-bold text-base-content/30 uppercase">
                            Untracked
                          </span>
                        )}
                      </div>
                    </td>

                    {/* Action */}
                    {range === 'monthly' && (
                      <td class="px-6 md:px-8 py-5 md:py-6 text-right">
                        <button
                          type="button"
                          data-view-details
                          data-category-id={cat.id}
                          data-category-name={cat.name}
                          data-category-icon={cat.iconName}
                          data-category-color={cat.color}
                          data-spent={cat.spent}
                          data-budget-limit={cat.budgetLimit}
                          class="inline-flex items-center gap-1.5 text-base-content/40 hover:text-base-content hover:bg-base-200/50 px-3 md:px-4 py-3 md:py-2 rounded-xl text-xs font-bold uppercase tracking-widest transition-all focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
                          aria-label={`View detailed breakdown for ${cat.name}`}
                        >
                          <Eye size={12} class="stroke-current" aria-hidden="true" />
                          <span>Details</span>
                        </button>
                      </td>
                    )}
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )
    }
  </div>
</div>
