---
/**
 * Summary Cards Component (Organism)
 *
 * Displays three summary cards on the dashboard:
 * - Total Assets Card (IDR + USD + converted total)
 * - Monthly Spent Card (progress bar, percentage, color-coded)
 * - Budget Health Card (alert count, status indicator)
 *
 * @param {Object} data - Summary data object
 * @param {boolean} loading - Show loading skeleton
 * @param {boolean} error - Show error state
 * @param {string} className - Additional CSS classes
 */

import Card from '../atoms/Card.astro';
import StatCard from '../atoms/StatCard.astro';
import Badge from '../atoms/Badge.astro';
import ProgressBar from '../atoms/ProgressBar.astro';
import EmptyState from '../atoms/EmptyState.astro';
import Skeleton from '../atoms/Skeleton.astro';
import { formatCurrency, formatPercentage } from '@/lib/formatting';
import { decimalSubtract } from '@/lib/utils/decimal';
import { CircleAlert, DollarSign, Calendar, ShieldCheck, ChevronRight } from '@lucide/astro';

// Icon sizing hierarchy (from largest to smallest):
// - 48px: Empty state illustration (prominent visual cue)
// - 24px: Error state alert (attention-grabbing)
// - 20px: Card header icons (medium emphasis)
// - 16px: Navigation/interactive icons (subtle)

export interface SummaryCardsData {
  totalAssets: {
    idr: string;
    usd: string;
    converted: string;
    convertedCurrency: 'IDR' | 'USD';
  };
  monthlySpent: {
    spent: string;
    budget: string;
    currency: 'IDR' | 'USD';
    percentage: number;
  };
  budgetHealth: {
    alertCount: number;
    status: 'healthy' | 'warning' | 'exceeded';
  };
}

export interface Props {
  data?: SummaryCardsData;
  loading?: boolean;
  error?: boolean;
  className?: string;
}

const { data, loading = false, error = false, className = '' } = Astro.props;

// Calculate remaining budget using decimal arithmetic
const monthlySpentRemaining = data
  ? decimalSubtract(data.monthlySpent.budget, data.monthlySpent.spent)
  : '0';

// Determine if we should show empty state
const isEmpty =
  !loading && !error && (!data || (data.totalAssets.idr === '0' && data.totalAssets.usd === '0'));

// Budget status colors
const getBudgetStatusColor = (status: string): string => {
  switch (status) {
    case 'healthy':
      return 'text-success';
    case 'warning':
      return 'text-warning';
    case 'exceeded':
      return 'text-error';
    default:
      return 'text-neutral';
  }
};

const getBudgetStatusBadge = (status: string): 'success' | 'warning' | 'error' | 'neutral' => {
  switch (status) {
    case 'healthy':
      return 'success';
    case 'warning':
      return 'warning';
    case 'exceeded':
      return 'error';
    default:
      return 'neutral';
  }
};

const getProgressStatus = (percentage: number): 'ok' | 'warning' | 'danger' => {
  if (percentage >= 100) return 'danger';
  if (percentage >= 80) return 'warning';
  return 'ok';
};
---

<div
  class={`grid grid-cols-1 md:grid-cols-3 gap-4 ${className}`}
  data-summary-cards
  role="region"
  aria-label="Financial summary"
>
  {
    error ? (
      // Error state
      <div class="col-span-full" role="alert" aria-live="assertive">
        <Card className="border-error">
          <div class="flex items-center gap-3 text-error">
            <CircleAlert size={24} class="shrink-0" aria-hidden="true" />
            <div>
              <p class="font-semibold">Unable to load summary data</p>
              <p class="text-sm">Please try again later</p>
            </div>
          </div>
        </Card>
      </div>
    ) : loading ? (
      // Loading skeleton
      <div role="status" aria-live="polite" aria-label="Loading financial summary">
        <Card>
          <div class="space-y-3" aria-hidden="true">
            <Skeleton variant="text" width="33%" />
            <Skeleton variant="heading" width="66%" />
            <Skeleton variant="text" width="50%" />
          </div>
        </Card>
        <Card>
          <div class="space-y-3" aria-hidden="true">
            <Skeleton variant="text" width="33%" />
            <Skeleton variant="rectangular" width="100%" height="5rem" className="rounded" />
          </div>
        </Card>
        <Card>
          <div class="space-y-3" aria-hidden="true">
            <Skeleton variant="text" width="33%" />
            <Skeleton variant="heading" width="50%" />
          </div>
        </Card>
        <Card>
          <div class="space-y-3" aria-hidden="true">
            <Skeleton variant="text" width="33%" />
            <Skeleton variant="rectangular" width="100%" height="5rem" className="rounded" />
          </div>
        </Card>
        <Card>
          <div class="space-y-3" aria-hidden="true">
            <Skeleton variant="text" width="33%" />
            <Skeleton variant="heading" width="50%" />
          </div>
        </Card>
      </div>
    ) : isEmpty ? (
      // Empty state
      <div class="col-span-full" role="status" aria-live="polite">
        <Card>
          <EmptyState
            title="No data yet"
            message="Start by adding your assets and transactions"
            iconName="trending"
            variant="centered"
            className="py-0"
          />
        </Card>
      </div>
    ) : (
      // Normal state with data
      <>
        {/* Total Assets Card */}
        <StatCard
          title="Total Assets"
          value={formatCurrency(data!.totalAssets.converted, data!.totalAssets.convertedCurrency)}
          valueColor="text-success"
          iconVariant="accent"
          className="transition-all hover:shadow-md"
        >
          <DollarSign slot="icon" size={48} class="stroke-current" aria-hidden="true" />
          <div slot="details" class="space-y-2">
            <div class="flex justify-between items-baseline">
              <span class="text-sm text-neutral">IDR:</span>
              <span class="font-semibold text-lg text-success">
                {formatCurrency(data!.totalAssets.idr, 'IDR')}
              </span>
            </div>
            <div class="flex justify-between items-baseline">
              <span class="text-sm text-neutral">USD:</span>
              <span class="font-semibold text-lg text-info">
                {formatCurrency(data!.totalAssets.usd, 'USD')}
              </span>
            </div>
          </div>
        </StatCard>

        {/* Monthly Spent Card */}
        <StatCard
          title="This Month"
          value={formatCurrency(data!.monthlySpent.spent, data!.monthlySpent.currency)}
          subtitle={`of ${formatCurrency(data!.monthlySpent.budget, data!.monthlySpent.currency)}`}
          subtitleColor="text-base-content/60"
          iconVariant="accent"
          className="transition-all hover:shadow-md"
        >
          <Calendar slot="icon" size={48} class="stroke-current" aria-hidden="true" />
          <div slot="details" class="space-y-2">
            <div class="text-right">
              <span
                class={`text-lg font-semibold ${getBudgetStatusColor(
                  data!.monthlySpent.percentage >= 100
                    ? 'exceeded'
                    : data!.monthlySpent.percentage >= 80
                      ? 'warning'
                      : 'ok'
                )}`}
              >
                {formatPercentage(data!.monthlySpent.percentage)}
              </span>
            </div>
            <ProgressBar
              value={data!.monthlySpent.percentage}
              status={getProgressStatus(data!.monthlySpent.percentage)}
              size="sm"
              ariaLabel={`Budget progress: ${formatPercentage(data!.monthlySpent.percentage)} used`}
            />
            <p class="text-xs text-neutral text-center">
              {data!.monthlySpent.percentage >= 100
                ? `Over budget by ${formatPercentage(data!.monthlySpent.percentage - 100)}`
                : `${formatCurrency(monthlySpentRemaining, data!.monthlySpent.currency)} remaining`}
            </p>
          </div>
        </StatCard>

        {/* Budget Health Card */}
        <StatCard
          title="Budget Health"
          value={`${data!.budgetHealth.alertCount}`}
          subtitle={`alert${data!.budgetHealth.alertCount !== 1 ? 's' : ''}`}
          subtitleColor="text-base-content/60"
          valueColor={getBudgetStatusColor(data!.budgetHealth.status)}
          iconVariant="accent"
          className="transition-all hover:shadow-md"
        >
          <ShieldCheck slot="icon" size={48} class="stroke-current" aria-hidden="true" />
          <div slot="details" class="space-y-3">
            <Badge variant={getBudgetStatusBadge(data!.budgetHealth.status)} size="lg">
              {data!.budgetHealth.status === 'healthy'
                ? 'On Track'
                : data!.budgetHealth.status === 'warning'
                  ? 'Review'
                  : 'Action Needed'}
            </Badge>
            <a
              href="/budget"
              class="flex items-center justify-center gap-2 w-full py-2 px-4 bg-base-200 hover:bg-base-300 rounded-lg transition-colors text-sm font-medium group"
              aria-label="View budget details"
            >
              View Budget
              <ChevronRight
                size={16}
                class="group-hover:translate-x-1 transition-transform"
                aria-hidden="true"
              />
            </a>
          </div>
        </StatCard>
      </>
    )
  }
</div>
