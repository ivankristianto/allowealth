---
/**
 * Summary Cards Component (Organism)
 *
 * Displays three summary cards on the dashboard:
 * - Total Assets Card (IDR + USD + converted total)
 * - Monthly Spent Card (progress bar, percentage, color-coded)
 * - Budget Health Card (alert count, status indicator)
 *
 * @param {Object} data - Summary data object
 * @param {boolean} loading - Show loading skeleton
 * @param {boolean} error - Show error state
 * @param {string} className - Additional CSS classes
 */

import Card from '../atoms/Card.astro';
import Badge from '../atoms/Badge.astro';
import Spinner from '../atoms/Spinner.astro';
import { formatCurrency, formatPercentage, colors } from '@/lib/tokens';

export interface SummaryCardsData {
  totalAssets: {
    idr: number;
    usd: number;
    converted: number;
    convertedCurrency: 'IDR' | 'USD';
  };
  monthlySpent: {
    spent: number;
    budget: number;
    currency: 'IDR' | 'USD';
    percentage: number;
  };
  budgetHealth: {
    alertCount: number;
    status: 'healthy' | 'warning' | 'exceeded';
  };
}

export interface Props {
  data?: SummaryCardsData;
  loading?: boolean;
  error?: boolean;
  className?: string;
}

const { data, loading = false, error = false, className = '' } = Astro.props;

// Determine if we should show empty state
const isEmpty =
  !loading && !error && (!data || (data.totalAssets.idr === 0 && data.totalAssets.usd === 0));

// Budget status colors
const getBudgetStatusColor = (status: string): string => {
  switch (status) {
    case 'healthy':
      return 'text-success';
    case 'warning':
      return 'text-warning';
    case 'exceeded':
      return 'text-error';
    default:
      return 'text-neutral';
  }
};

const getBudgetStatusBadge = (status: string): 'success' | 'warning' | 'error' | 'neutral' => {
  switch (status) {
    case 'healthy':
      return 'success';
    case 'warning':
      return 'warning';
    case 'exceeded':
      return 'error';
    default:
      return 'neutral';
  }
};

const getProgressColor = (percentage: number): string => {
  if (percentage >= 100) return 'bg-error';
  if (percentage >= 80) return 'bg-warning';
  return 'bg-success';
};

const getProgressClass = (percentage: number): string => {
  if (percentage >= 100) return 'progress-error';
  if (percentage >= 80) return 'progress-warning';
  return 'progress-success';
};
---

<div class={`grid grid-cols-1 md:grid-cols-3 gap-4 ${className}`} data-summary-cards>
  {
    error ? (
      // Error state
      <div class="col-span-full">
        <Card className="border-error">
          <div class="flex items-center gap-3 text-error">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <div>
              <p class="font-semibold">Unable to load summary data</p>
              <p class="text-sm">Please try again later</p>
            </div>
          </div>
        </Card>
      </div>
    ) : loading ? (
      // Loading skeleton
      <>
        <Card className="animate-pulse">
          <div class="space-y-3">
            <div class="h-4 bg-neutral-200 rounded w-1/3" />
            <div class="h-8 bg-neutral-200 rounded w-2/3" />
            <div class="h-4 bg-neutral-200 rounded w-1/2" />
          </div>
        </Card>
        <Card className="animate-pulse">
          <div class="space-y-3">
            <div class="h-4 bg-neutral-200 rounded w-1/3" />
            <div class="h-20 bg-neutral-200 rounded" />
          </div>
        </Card>
        <Card className="animate-pulse">
          <div class="space-y-3">
            <div class="h-4 bg-neutral-200 rounded w-1/3" />
            <div class="h-8 bg-neutral-200 rounded w-1/2" />
          </div>
        </Card>
      </>
    ) : isEmpty ? (
      // Empty state
      <div class="col-span-full">
        <Card>
          <div class="text-center py-8">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-12 w-12 mx-auto mb-4 text-neutral-400"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"
              />
            </svg>
            <h3 class="text-lg font-semibold mb-2">No data yet</h3>
            <p class="text-neutral-500">Start by adding your assets and transactions</p>
          </div>
        </Card>
      </div>
    ) : (
      // Normal state with data
      <>
        {/* Total Assets Card */}
        <Card hoverable className="group">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-sm font-medium text-neutral-600 uppercase tracking-wide">
              Total Assets
            </h3>
            <div class="p-2 bg-success/10 rounded-lg group-hover:bg-success/20 transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-success"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
            </div>
          </div>

          <div class="space-y-2 mb-4">
            <div class="flex justify-between items-baseline">
              <span class="text-sm text-neutral-500">IDR:</span>
              <span class="font-semibold text-lg" style="color: {colors.currency.idr}">
                {formatCurrency(data!.totalAssets.idr, 'IDR')}
              </span>
            </div>
            <div class="flex justify-between items-baseline">
              <span class="text-sm text-neutral-500">USD:</span>
              <span class="font-semibold text-lg" style="color: {colors.currency.usd}">
                {formatCurrency(data!.totalAssets.usd, 'USD')}
              </span>
            </div>
          </div>

          <div class="pt-3 border-t border-neutral-200">
            <div class="flex justify-between items-baseline">
              <span class="text-sm text-neutral-600">Total:</span>
              <span class="font-bold text-xl text-success">
                {formatCurrency(data!.totalAssets.converted, data!.totalAssets.convertedCurrency)}
              </span>
            </div>
          </div>
        </Card>

        {/* Monthly Spent Card */}
        <Card hoverable className="group">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-sm font-medium text-neutral-600 uppercase tracking-wide">This Month</h3>
            <div class="p-2 bg-info/10 rounded-lg group-hover:bg-info/20 transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-info"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"
                />
              </svg>
            </div>
          </div>

          <div class="mb-4">
            <div class="flex justify-between items-baseline mb-2">
              <span class="text-2xl font-bold">
                {formatCurrency(data!.monthlySpent.spent, data!.monthlySpent.currency)}
              </span>
              <span class="text-sm text-neutral-500">
                of {formatCurrency(data!.monthlySpent.budget, data!.monthlySpent.currency)}
              </span>
            </div>
            <div class="text-right">
              <span
                class={`text-lg font-semibold ${getBudgetStatusColor(
                  data!.monthlySpent.percentage >= 100
                    ? 'exceeded'
                    : data!.monthlySpent.percentage >= 80
                      ? 'warning'
                      : 'ok'
                )}`}
              >
                {formatPercentage(data!.monthlySpent.percentage)}
              </span>
            </div>
          </div>

          <div class="space-y-2">
            <progress
              class={`progress progress-neutral w-full ${getProgressClass(data!.monthlySpent.percentage)}`}
              value={data!.monthlySpent.percentage}
              max="100"
              aria-label={`Budget progress: ${formatPercentage(data!.monthlySpent.percentage)} used`}
            />
            <p class="text-xs text-neutral-500 text-center">
              {data!.monthlySpent.percentage >= 100
                ? `Over budget by ${formatPercentage(data!.monthlySpent.percentage - 100)}`
                : `${formatCurrency(data!.monthlySpent.budget - data!.monthlySpent.spent, data!.monthlySpent.currency)} remaining`}
            </p>
          </div>
        </Card>

        {/* Budget Health Card */}
        <Card hoverable className="group">
          <div class="flex items-start justify-between mb-4">
            <h3 class="text-sm font-medium text-neutral-600 uppercase tracking-wide">
              Budget Health
            </h3>
            <div class="p-2 bg-warning/10 rounded-lg group-hover:bg-warning/20 transition-colors">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-5 w-5 text-warning"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                />
              </svg>
            </div>
          </div>

          <div class="flex items-center gap-4 mb-4">
            <div class="flex-1">
              <div class={`text-3xl font-bold ${getBudgetStatusColor(data!.budgetHealth.status)}`}>
                {data!.budgetHealth.alertCount}
              </div>
              <div class="text-sm text-neutral-500">
                alert{data!.budgetHealth.alertCount !== 1 ? 's' : ''}
              </div>
            </div>

            <Badge variant={getBudgetStatusBadge(data!.budgetHealth.status)} size="lg">
              {data!.budgetHealth.status === 'healthy'
                ? 'On Track'
                : data!.budgetHealth.status === 'warning'
                  ? 'Review'
                  : 'Action Needed'}
            </Badge>
          </div>

          <a
            href="/budget"
            class="flex items-center justify-center gap-2 w-full py-2 px-4 bg-base-200 hover:bg-base-300 rounded-lg transition-colors text-sm font-medium group"
            aria-label="View budget details"
          >
            View Budget
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 group-hover:translate-x-1 transition-transform"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 5l7 7-7 7"
              />
            </svg>
          </a>
        </Card>
      </>
    )
  }
</div>
