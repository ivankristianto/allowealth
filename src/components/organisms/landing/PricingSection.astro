---
/**
 * PricingSection Component
 *
 * Pricing table with 3 tiers: Starter, Pro (featured), Expert.
 * Auth state is detected client-side via auth_hint cookie (see PublicAuthCta.client.ts).
 */

import { Check } from '@lucide/astro';
import { pricingTiers } from '@/lib/landing-content';
import Button from '@/components/atoms/Button.astro';
---

<section id="pricing" class="relative z-10 px-6 py-24 sm:py-40" aria-labelledby="pricing-title">
  <div class="max-w-7xl mx-auto text-center">
    <!-- Section Header -->
    <h2
      id="pricing-title"
      class="text-3xl sm:text-4xl md:text-6xl font-black text-base-content tracking-tighter mb-12 sm:mb-20"
    >
      Simple, Transparent.
    </h2>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-10" role="list">
      {
        pricingTiers.map((tier) => {
          const isFeatured = tier.featured;
          const tierSlug = tier.name.toLowerCase();

          return (
            <article
              class={`relative p-8 sm:p-12 rounded-3xl sm:rounded-4xl border transition-all hover:scale-105 flex flex-col ${
                isFeatured
                  ? 'bg-primary text-primary-content border-transparent shadow-2xl'
                  : 'bg-base-100 border-base-300 shadow-xl'
              }`}
              data-pricing-card
              data-tier={tierSlug}
              role="listitem"
            >
              {/* Featured Badge */}
              {isFeatured && (
                <div class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-accent text-white text-xs font-bold uppercase tracking-widest px-5 py-2 rounded-full shadow-lg">
                  Most Popular
                </div>
              )}

              {/* Tier Name */}
              <h3
                class={`text-lg sm:text-xl font-bold uppercase tracking-widest mb-3 ${
                  isFeatured ? 'text-primary-content/60' : 'text-neutral'
                }`}
              >
                {tier.name}
              </h3>

              {/* Price */}
              <div class="flex items-baseline justify-center gap-1 mb-4 sm:mb-6">
                <span
                  class={`text-4xl sm:text-5xl font-black ${
                    isFeatured ? 'text-primary-content' : 'text-base-content'
                  }`}
                >
                  {tier.price}
                </span>
                <span
                  class={`text-sm font-bold ${
                    isFeatured ? 'text-primary-content/60' : 'text-neutral'
                  }`}
                >
                  /month
                </span>
              </div>

              {/* Description */}
              <p
                class={`text-sm font-medium mb-8 sm:mb-12 ${
                  isFeatured ? 'text-primary-content/60' : 'text-neutral'
                }`}
              >
                {tier.description}
              </p>

              {/* Feature List */}
              <ul class="space-y-4 sm:space-y-5 mb-10 sm:mb-16 text-left flex-1" role="list">
                {tier.features.map((feature) => (
                  <li class="flex items-center gap-3 sm:gap-4 text-sm font-bold">
                    <div
                      class={`w-5 h-5 rounded-full flex items-center justify-center shrink-0 ${
                        isFeatured ? 'bg-accent/20 text-accent' : 'bg-success/10 text-success'
                      }`}
                    >
                      <Check size={12} class="stroke-current stroke-[3]" aria-hidden="true" />
                    </div>
                    <span class={isFeatured ? 'text-primary-content' : 'text-base-content'}>
                      {feature}
                    </span>
                  </li>
                ))}
              </ul>

              {/* CTA Button */}
              <Button
                variant={isFeatured ? 'accent' : 'secondary'}
                href="/signup"
                size="lg"
                className="w-full"
                data-auth-cta
                data-auth-href="/transactions"
              >
                Select Plan
              </Button>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
