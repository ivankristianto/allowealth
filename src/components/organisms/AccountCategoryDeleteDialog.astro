---
/**
 * AccountCategoryDeleteDialog Component
 *
 * Confirmation dialog for deleting account categories.
 *
 * @param {string} id - Dialog ID
 */

import ConfirmationModal from '../molecules/ConfirmationModal.astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div data-account-category-delete-dialog-container data-id={id} data-category-id="">
  <ConfirmationModal
    id={id}
    title="Delete Category"
    description="This action cannot be undone."
    confirmLabel="Delete"
    confirmVariant="error"
    confirmLoadingLabel="Deleting..."
    iconVariant="error"
    confirmTestId="confirm-delete-btn"
  >
    <div slot="details" class="p-4 bg-base-200/50 rounded-2xl border border-base-300">
      <p class="text-xs uppercase tracking-widest text-base-content/50 font-medium">Category</p>
      <p class="text-base font-bold text-base-content mt-2" data-category-name></p>
      <p class="text-sm text-base-content/60 mt-1" data-category-meta></p>
    </div>

    <p slot="details" class="text-base-content/70 text-sm">
      Accounts assigned to this category must be reassigned before deletion.
    </p>
  </ConfirmationModal>
</div>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { getCsrfHeaders } from '@/lib/csrf-client';
  import { navigate } from 'astro:transitions/client';
  import {
    clearConfirmError,
    closeConfirmationModal,
    getConfirmationModalElements,
    resetConfirmationModal,
    setConfirmLoading,
    showConfirmError,
  } from '@/components/molecules/ConfirmationModal.client';

  // Track which dialog containers have been initialized
  const initializedContainers = new WeakSet<Element>();

  // Initialize account category delete dialog containers
  function initAccountCategoryDeleteDialogs() {
    document
      .querySelectorAll('[data-account-category-delete-dialog-container]')
      .forEach((container) => {
        // Skip if already initialized
        if (initializedContainers.has(container)) return;
        initializedContainers.add(container);

        const id = container.getAttribute('data-id');
        if (!id) return;

        const { modal, confirmButton, cancelButton, errorElement } = getConfirmationModalElements(
          container,
          id
        );

        if (!modal || !confirmButton) return;

        // Cancel button - close dialog
        cancelButton?.addEventListener('click', () => {
          resetConfirmationModal(confirmButton, errorElement);
          closeConfirmationModal(modal);
        });

        // Confirm delete button
        confirmButton.addEventListener('click', async () => {
          // Get category ID from container data attribute (set by page script)
          const categoryId = container.getAttribute('data-category-id') || '';
          if (!categoryId) return;

          // Clear errors
          clearConfirmError(errorElement);

          // Show loading state
          setConfirmLoading(confirmButton, true);

          try {
            const response = await fetch(`/api/account-categories/${categoryId}`, {
              method: 'DELETE',
              headers: getCsrfHeaders(),
            });

            const result = await response.json();

            if (!response.ok || !result.success) {
              const errorMessage = result.error?.message || 'Failed to delete category';
              throw new Error(errorMessage);
            }

            // Success
            addToast('Category deleted successfully!', 'success');
            closeConfirmationModal(modal);

            // Reload page to show updated categories
            const url = new URL(window.location.href);
            navigate(url.pathname + url.search);
          } catch (err) {
            const message = err instanceof Error ? err.message : 'Failed to delete category';
            showConfirmError(errorElement, message);
            addToast(message, 'error');
          } finally {
            // Reset button state
            setConfirmLoading(confirmButton, false);
          }
        });
      });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccountCategoryDeleteDialogs);
  } else {
    initAccountCategoryDeleteDialogs();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAccountCategoryDeleteDialogs);
</script>
