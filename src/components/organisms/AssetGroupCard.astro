---
/**
 * AssetGroupCard Component
 *
 * Collapsible card section for grouping assets by type.
 * Shows count badge, totals by currency, and expand/collapse functionality.
 *
 * Part of the Global Portfolio page redesign.
 *
 * @param {string} type - Asset type name (e.g., "Bank Account", "Stock")
 * @param {number} count - Number of assets in this group
 * @param {number} totalIdr - Total value in IDR (if any assets in IDR)
 * @param {number} totalUsd - Total value in USD (if any assets in USD)
 * @param {boolean} defaultExpanded - Whether to start expanded
 * @param {string} groupId - Unique ID for this group (used for collapse state)
 * @param {string} className - Additional CSS classes
 */

import { ChevronUp } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';

export interface Props {
  type: string;
  count: number;
  totalIdr?: number;
  totalUsd?: number;
  defaultExpanded?: boolean;
  groupId: string;
  className?: string;
}

const {
  type,
  count,
  totalIdr = 0,
  totalUsd = 0,
  defaultExpanded = true,
  groupId,
  className = '',
} = Astro.props;

// Generate subtitle based on type
const subtitle = `Managing your ${type.toLowerCase()} holdings`;

const cardClasses = [
  'bg-base-100 rounded-card border border-base-300 shadow-sm overflow-hidden transition-all duration-300',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  class={cardClasses}
  data-asset-group={groupId}
  data-testid="asset-group"
  data-asset-type={groupId}
>
  {/* Collapsible Header Button */}
  <button
    type="button"
    class="w-full p-6 lg:px-8 lg:py-6 flex items-center justify-between text-left transition-colors hover:bg-base-100/80 group"
    data-group-toggle={groupId}
    aria-expanded={defaultExpanded}
    aria-controls={`group-content-${groupId}`}
  >
    <div>
      <div class="flex items-center gap-3">
        <h3 class="text-lg lg:text-xl font-bold text-base-content tracking-tight leading-none">
          {type}
        </h3>
        <span
          class="px-2 py-0.5 bg-base-200 text-base-content/70 rounded-lg text-xs font-bold leading-none"
        >
          {count}
        </span>
      </div>
      <p class="text-xs font-medium text-base-content/50 mt-2">{subtitle}</p>
    </div>

    <div class="flex items-center gap-6 lg:gap-8">
      {/* Totals - hidden on mobile */}
      <div class="text-right hidden sm:block">
        {
          totalIdr > 0 && (
            <p class="text-sm font-bold text-success leading-none">
              {formatCurrency(totalIdr, 'IDR')}
            </p>
          )
        }
        {
          totalUsd > 0 && (
            <p class:list={['text-sm font-bold text-info leading-none', totalIdr > 0 && 'mt-1.5']}>
              {formatCurrency(totalUsd, 'USD')}
            </p>
          )
        }
      </div>

      {/* Expand/Collapse Icon */}
      <ChevronUp
        size={20}
        class="stroke-current text-base-content/40 transition-transform duration-300 group-aria-expanded:rotate-0 -rotate-180"
        data-group-icon={groupId}
        aria-hidden="true"
      />
    </div>
  </button>

  {/* Collapsible Content */}
  <div
    id={`group-content-${groupId}`}
    class="divide-y divide-base-200 border-t border-base-200 transition-all duration-300 ease-in-out"
    data-group-content={groupId}
    data-expanded={defaultExpanded}
  >
    <slot />
  </div>
</div>

<script>
  // Track initialized elements to avoid duplicate listeners
  const initializedGroupToggles = new WeakSet<Element>();

  function initAssetGroupToggles() {
    document.querySelectorAll('[data-group-toggle]').forEach((button) => {
      // Skip if already initialized
      if (initializedGroupToggles.has(button)) return;
      initializedGroupToggles.add(button);

      const groupId = button.getAttribute('data-group-toggle');
      if (!groupId) return;

      const content = document.querySelector(
        `[data-group-content="${groupId}"]`
      ) as HTMLElement | null;
      const icon = document.querySelector(`[data-group-icon="${groupId}"]`) as HTMLElement | null;

      if (!content) return;

      // Set initial state based on data-expanded attribute
      const isExpanded = content.dataset.expanded === 'true';
      if (!isExpanded) {
        content.style.maxHeight = '0px';
        content.style.opacity = '0';
        content.style.overflow = 'hidden';
        button.setAttribute('aria-expanded', 'false');
        if (icon) {
          icon.classList.remove('rotate-0');
          icon.classList.add('-rotate-180');
        }
      } else {
        content.style.maxHeight = 'none';
        content.style.opacity = '1';
        button.setAttribute('aria-expanded', 'true');
        if (icon) {
          icon.classList.add('rotate-0');
          icon.classList.remove('-rotate-180');
        }
      }

      button.addEventListener('click', () => {
        const currentlyExpanded = button.getAttribute('aria-expanded') === 'true';

        if (currentlyExpanded) {
          // Collapse
          content.style.maxHeight = content.scrollHeight + 'px';
          // Force reflow
          content.offsetHeight;
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
          content.style.overflow = 'hidden';
          button.setAttribute('aria-expanded', 'false');
          content.dataset.expanded = 'false';
          if (icon) {
            icon.classList.remove('rotate-0');
            icon.classList.add('-rotate-180');
          }
        } else {
          // Expand
          content.style.overflow = 'hidden';
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          button.setAttribute('aria-expanded', 'true');
          content.dataset.expanded = 'true';
          if (icon) {
            icon.classList.add('rotate-0');
            icon.classList.remove('-rotate-180');
          }

          // Remove max-height after transition to allow dynamic content
          setTimeout(() => {
            if (content.dataset.expanded === 'true') {
              content.style.maxHeight = 'none';
              content.style.overflow = 'visible';
            }
          }, 300);
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAssetGroupToggles);
  } else {
    initAssetGroupToggles();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAssetGroupToggles);
</script>
