---
/**
 * AssetCategoryModal Component
 *
 * Modal for creating or editing asset categories.
 *
 * @param {string} id - Modal ID
 * @param {'create' | 'edit'} mode - Modal mode
 * @param {boolean} open - Whether modal is open
 * @param {Object} values - Default form values
 */

import Modal from '../molecules/Modal.astro';
import { Plus, Pencil } from '@lucide/astro';

export interface Props {
  id: string;
  mode?: 'create' | 'edit';
  open?: boolean;
  values?: {
    id?: string;
    name?: string;
    description?: string;
    type?: 'asset' | 'liability';
  };
  errors?: Record<string, string>;
}

const { id, mode = 'create', open = false, values = {}, errors = {} } = Astro.props;

const isEditMode = mode === 'edit';
const title = isEditMode ? 'Edit Category' : 'Add Category';
const subtitle = isEditMode
  ? 'Update the category details.'
  : 'Create a new category for your assets or liabilities.';
---

<div data-asset-category-modal-container data-id={id} data-mode={mode}>
  <Modal id={id} open={open} size="md" closable={false} backdropClose={true}>
    <div slot="default" class="flex flex-col gap-6">
      <!-- Header -->
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-2xl flex items-center justify-center bg-accent/10">
          {
            isEditMode ? (
              <Pencil size={24} class="stroke-current text-accent" aria-hidden="true" />
            ) : (
              <Plus size={24} class="stroke-current text-accent" aria-hidden="true" />
            )
          }
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-bold tracking-tight text-primary leading-none" data-modal-title>
            {title}
          </h2>
          <p class="text-neutral text-sm mt-2 font-medium" data-modal-subtitle>{subtitle}</p>
        </div>
      </div>

      <!-- Form -->
      <form data-asset-category-form class="flex flex-col gap-5">
        <input type="hidden" name="id" value={values.id || ''} />

        <div class="form-control">
          <label class="label py-1" for={`${id}-name`}>
            <span class="text-xs uppercase tracking-widest text-base-content/50 font-medium">
              Category Name
              <span class="sr-only">(required)</span>
            </span>
          </label>
          <input
            type="text"
            name="name"
            id={`${id}-name`}
            class="input input-bordered w-full h-10 text-xs bg-base-200 focus:ring-2 focus:ring-accent focus:ring-opacity-20 focus:outline-none focus:ring-offset-2"
            required
            maxlength="100"
            placeholder="e.g., Real Estate"
            value={values.name || ''}
            data-testid="asset-category-name-input"
          />
          {errors.name && <span class="text-error text-xs mt-1">{errors.name}</span>}
        </div>

        <div class="form-control">
          <label class="label py-1" for={`${id}-description`}>
            <span class="text-xs uppercase tracking-widest text-base-content/50 font-medium">
              Description
              <span class="text-base-content/30">(optional)</span>
            </span>
          </label>
          <textarea
            name="description"
            id={`${id}-description`}
            class="textarea textarea-bordered w-full text-xs bg-base-200 min-h-[96px] focus:ring-2 focus:ring-accent focus:ring-opacity-20 focus:outline-none focus:ring-offset-2"
            maxlength="500"
            placeholder="Short note about this category"
            data-testid="asset-category-description-input">{values.description || ''}</textarea
          >
          <span class="text-base-content/40 text-xs mt-1">Max 500 characters</span>
          {errors.description && <span class="text-error text-xs mt-1">{errors.description}</span>}
        </div>

        <div class="form-control">
          <label class="label py-1" for={`${id}-type`}>
            <span class="text-xs uppercase tracking-widest text-base-content/50 font-medium">
              Type
              <span class="sr-only">(required)</span>
            </span>
          </label>
          <select
            name="type"
            id={`${id}-type`}
            class="select select-bordered w-full h-10 text-xs bg-base-200 focus:ring-2 focus:ring-accent focus:ring-opacity-20 focus:outline-none focus:ring-offset-2"
            required
            data-testid="asset-category-type-select"
          >
            <option value="asset" selected={values.type === 'asset' || !values.type}>
              Asset
            </option>
            <option value="liability" selected={values.type === 'liability'}>Liability</option>
          </select>
          {errors.type && <span class="text-error text-xs mt-1">{errors.type}</span>}
        </div>

        <!-- Global error -->
        <div class="hidden alert alert-error text-sm" role="alert" data-form-error></div>

        <!-- Actions -->
        <div class="flex gap-4 pt-4">
          <button
            type="button"
            class="flex-1 btn btn-ghost h-14 rounded-full font-bold"
            data-cancel
          >
            Cancel
          </button>
          <button
            type="submit"
            class="flex-[2] btn btn-accent h-14 rounded-full font-bold"
            data-testid="asset-category-submit-btn"
          >
            <span data-submit-text>{isEditMode ? 'Update Category' : 'Save Category'}</span>
          </button>
        </div>
      </form>
    </div>
  </Modal>
</div>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { getCsrfHeaders } from '@/lib/csrf-client';

  // Track which modal containers have been initialized
  const initializedContainers = new WeakSet<Element>();

  // Initialize asset category modal containers
  function initAssetCategoryModals() {
    document.querySelectorAll('[data-asset-category-modal-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedContainers.has(container)) return;
      initializedContainers.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const modal = document.getElementById(id) as HTMLDialogElement;
      const form = container.querySelector('[data-asset-category-form]') as HTMLFormElement;
      const cancelBtn = container.querySelector('[data-cancel]');
      const errorDiv = container.querySelector('[data-form-error]') as HTMLElement | null;
      const titleEl = container.querySelector('[data-modal-title]');
      const subtitleEl = container.querySelector('[data-modal-subtitle]');
      const submitText = container.querySelector('[data-submit-text]');

      if (!modal || !form) return;

      // Reset form state
      const resetForm = () => {
        form.reset();
        const idInput = form.querySelector('[name="id"]') as HTMLInputElement | null;
        if (idInput) idInput.value = '';
        errorDiv?.classList.add('hidden');
        if (errorDiv) errorDiv.textContent = '';

        // Reset mode to create
        if (titleEl) titleEl.textContent = 'Add Category';
        if (subtitleEl)
          subtitleEl.textContent = 'Create a new category for your assets or liabilities.';
        if (submitText) submitText.textContent = 'Save Category';
        container.setAttribute('data-mode', 'create');
      };

      // Cancel button - reset and close
      cancelBtn?.addEventListener('click', () => {
        resetForm();
        modal.close();
      });

      // Reset form when modal closes
      modal.addEventListener('close', () => {
        resetForm();
      });

      // Form submission
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
        const originalText = submitText?.textContent || 'Save';
        const mode = container.getAttribute('data-mode') as 'create' | 'edit';

        // Clear errors
        errorDiv?.classList.add('hidden');
        if (errorDiv) errorDiv.textContent = '';

        const formData = new FormData(form);
        const categoryId = (formData.get('id') as string) || '';
        const name = (formData.get('name') as string) || '';
        const description = (formData.get('description') as string) || '';
        const type = (formData.get('type') as string) || 'asset';

        // Validate
        if (!name.trim()) {
          if (errorDiv) {
            errorDiv.textContent = 'Category name is required.';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        if (name.trim().length > 100) {
          if (errorDiv) {
            errorDiv.textContent = 'Category name must be 100 characters or less.';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        if (description.length > 500) {
          if (errorDiv) {
            errorDiv.textContent = 'Description must be 500 characters or less.';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        const payload = {
          name: name.trim(),
          description: description.trim() || null,
          isLiability: type === 'liability',
        };

        // Show loading state
        if (submitBtn) {
          submitBtn.disabled = true;
          if (submitText) submitText.textContent = 'Saving...';
        }

        try {
          const url =
            mode === 'edit' && categoryId
              ? `/api/asset-categories/${categoryId}`
              : '/api/asset-categories';
          const method = mode === 'edit' && categoryId ? 'PUT' : 'POST';

          const response = await fetch(url, {
            method,
            headers: getCsrfHeaders({ 'Content-Type': 'application/json' }),
            body: JSON.stringify(payload),
          });

          const result = await response.json();

          if (!response.ok || !result.success) {
            const errorMessage = result.error?.message || 'Failed to save category';
            throw new Error(errorMessage);
          }

          // Success
          addToast(
            mode === 'edit' ? 'Category updated successfully!' : 'Category created successfully!',
            'success'
          );
          resetForm();
          modal.close();

          // Reload page to show updated categories
          const urlParams = new URL(window.location.href);
          window.location.href = urlParams.pathname + urlParams.search;
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Failed to save category';
          if (errorDiv) {
            errorDiv.textContent = message;
            errorDiv.classList.remove('hidden');
          }
          addToast(message, 'error');
        } finally {
          // Reset button state
          if (submitBtn) {
            submitBtn.disabled = false;
            if (submitText) submitText.textContent = originalText;
          }
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAssetCategoryModals);
  } else {
    initAssetCategoryModals();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAssetCategoryModals);
</script>
