---
/**
 * SetNewBudgetModal Component
 *
 * Modal for setting a new budget allocation for a category.
 * Allows selecting an expense category and setting a monthly spending limit.
 * Uses the Budget API (POST /api/budgets for create, PUT /api/budgets/:id for update).
 *
 * @param {string} id - Modal ID
 * @param {Array} categories - Available expense categories
 * @param {string} currency - Currency for budget (IDR or USD)
 * @param {number} month - Budget month (1-12)
 * @param {number} year - Budget year
 * @param {Array} budgets - Existing budgets for the month (to determine create vs update)
 */

import Modal from '../molecules/Modal.astro';
import FormField from '../molecules/FormField.astro';
import { ChartNoAxesCombined } from '@lucide/astro';

interface BudgetRecord {
  id: string;
  category_id: string;
  budget_amount: string;
}

export interface Props {
  id: string;
  categories: Array<{ id: string; name: string; type: string }>;
  currency?: 'IDR' | 'USD';
  month: number;
  year: number;
  budgets?: BudgetRecord[];
}

const { id, categories = [], currency = 'IDR', month, year, budgets = [] } = Astro.props;

// Filter to expense categories only (show all, user can set/update any budget)
const expenseCategories = categories.filter((c) => c.type === 'expense');

// Create a map of category_id -> budget for quick lookup
const budgetMap = new Map(budgets.map((b) => [b.category_id, b]));

// P3: TODO - Extract monthNames to shared utility (src/lib/utils/date.ts)
// This array is duplicated in SetNewBudgetModal, CopyBudgetModal, and budget/index.astro
const monthNames = [
  'January',
  'February',
  'March',
  'April',
  'May',
  'June',
  'July',
  'August',
  'September',
  'October',
  'November',
  'December',
];
const monthName = monthNames[month - 1] || `Month ${month}`;
---

<div data-set-budget-modal-container data-id={id} data-testid="set-new-budget-modal">
  <Modal id={id} title="" size="md" closable={false} className="[&_.modal-box]:rounded-card">
    <div class="space-y-6">
      {/* Header with icon */}
      <div class="flex items-center gap-4">
        <div
          class="w-12 h-12 rounded-2xl flex items-center justify-center bg-accent/10 text-accent"
        >
          <ChartNoAxesCombined size={24} class="stroke-current" aria-hidden="true" />
        </div>
        <div>
          <h2 class="text-xl font-bold tracking-tight text-base-content leading-none">
            Set New Budget
          </h2>
          <p class="text-base-content/60 text-sm mt-2 font-medium">
            Configure spending limits for {monthName}
            {year}.
          </p>
        </div>
      </div>

      {/* Form */}
      <form id={`${id}-form`} class="space-y-6">
        {/* Category Select */}
        <FormField label="Category" htmlFor={`${id}-category`} required>
          <select
            id={`${id}-category`}
            name="category_id"
            required
            class="select select-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent"
          >
            {
              expenseCategories.map((category, index) => {
                const existingBudget = budgetMap.get(category.id);
                return (
                  <option
                    value={category.id}
                    selected={!existingBudget && index === 0}
                    disabled={!!existingBudget}
                    data-budget-id={existingBudget?.id || ''}
                    data-budget-amount={existingBudget?.budget_amount || '0'}
                  >
                    {category.name}
                    {existingBudget ? ' (already set)' : ''}
                  </option>
                );
              })
            }
          </select>
          {/* Warning when category already has budget */}
          <div
            id={`${id}-budget-exists-warning`}
            class="hidden text-sm text-info flex items-center gap-2 mt-2"
          >
            <span
              >This category already has a budget set. Saving will update the existing budget.</span
            >
          </div>
        </FormField>

        {/* Budget Amount */}
        <FormField label={`Monthly Limit (${currency})`} htmlFor={`${id}-amount`} required>
          <input
            id={`${id}-amount`}
            name="budget_amount"
            type="number"
            required
            min="0"
            step="0.01"
            placeholder={currency === 'IDR' ? 'e.g. 5,000,000' : 'e.g. 500'}
            class="input input-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent placeholder:text-base-content/30 placeholder:font-normal"
          />
        </FormField>

        {/* Hidden fields for currency, month, year */}
        <input type="hidden" name="currency" value={currency} />
        <input type="hidden" name="month" value={month} />
        <input type="hidden" name="year" value={year} />

        {/* Error message container */}
        <div id={`${id}-error`} class="hidden alert alert-error text-sm rounded-xl" role="alert">
        </div>

        {/* ARIA live region for screen reader announcements (P1 accessibility) */}
        <div id={`${id}-status`} class="sr-only" role="status" aria-live="polite"></div>

        {/* Actions */}
        <div class="flex items-center gap-4 pt-4">
          <button
            type="button"
            class="flex-1 py-4 text-base-content/60 font-bold hover:bg-base-200 rounded-2xl transition-colors"
            data-cancel-budget
          >
            Cancel
          </button>
          <button
            type="submit"
            class="flex-[2] btn btn-accent py-4 rounded-2xl font-bold text-base shadow-lg shadow-accent/20 hover:shadow-xl transition-all"
            disabled={expenseCategories.length === 0}
          >
            Set Budget
          </button>
        </div>
      </form>
    </div>
  </Modal>
</div>

<script>
  import { addToast } from '@lib/stores/toastStore';
  // P2: TODO - Consider using csrfFetch wrapper for cleaner code
  import { getCsrfHeaders } from '@/lib/csrf-client';

  // Track initialized modals to avoid duplicate handlers
  const initializedModals = new WeakSet<Element>();

  function initSetBudgetModal() {
    document.querySelectorAll('[data-set-budget-modal-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedModals.has(container)) return;
      initializedModals.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const modal = document.getElementById(id) as HTMLDialogElement | null;
      const form = document.getElementById(`${id}-form`) as HTMLFormElement | null;
      const cancelBtn = container.querySelector('[data-cancel-budget]');
      const errorDiv = document.getElementById(`${id}-error`);
      const statusDiv = document.getElementById(`${id}-status`);
      const categorySelect = document.getElementById(`${id}-category`) as HTMLSelectElement | null;
      const warningDiv = document.getElementById(`${id}-budget-exists-warning`);

      if (!modal || !form || !categorySelect) return;

      // Function to check and show warning for existing budget
      const checkExistingBudget = () => {
        const selectedOption = categorySelect.options[categorySelect.selectedIndex];
        const budgetAmount = parseFloat(selectedOption?.dataset.budgetAmount || '0');

        if (warningDiv) {
          if (budgetAmount > 0) {
            warningDiv.classList.remove('hidden');
          } else {
            warningDiv.classList.add('hidden');
          }
        }
      };

      // Check on category change
      categorySelect.addEventListener('change', checkExistingBudget);

      // Auto-select first available (non-disabled) option
      const firstAvailable = categorySelect.querySelector(
        'option:not([disabled])'
      ) as HTMLOptionElement;
      if (firstAvailable) firstAvailable.selected = true;

      // Check initial state
      checkExistingBudget();

      // Handle cancel button - reset form and close
      cancelBtn?.addEventListener('click', () => {
        form.reset();
        if (errorDiv) {
          errorDiv.textContent = '';
          errorDiv.classList.add('hidden');
        }
        if (warningDiv) {
          warningDiv.classList.add('hidden');
        }
        modal.close();
      });

      // Handle form submission with loading state
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = submitBtn?.textContent || 'Set Budget';

        const formData = new FormData(form);
        const categoryId = formData.get('category_id') as string;
        const budgetAmount = formData.get('budget_amount') as string;
        const currency = formData.get('currency') as string;
        const month = parseInt(formData.get('month') as string, 10);
        const year = parseInt(formData.get('year') as string, 10);

        // Client-side validation (P0: prevents confusing server errors)
        const parsedAmount = parseFloat(budgetAmount);
        if (isNaN(parsedAmount) || parsedAmount <= 0) {
          if (errorDiv) {
            errorDiv.textContent = 'Budget amount must be a positive number';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        // Check if budget already exists for this category
        const selectedOption = categorySelect.options[categorySelect.selectedIndex];
        const existingBudgetId = selectedOption?.dataset.budgetId;

        // Clear previous errors
        if (errorDiv) {
          errorDiv.textContent = '';
          errorDiv.classList.add('hidden');
        }

        // Show loading state and announce to screen readers (P1 accessibility)
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Saving...';
        }
        if (statusDiv) {
          statusDiv.textContent = 'Saving budget...';
        }

        try {
          let response: Response;

          if (existingBudgetId) {
            // Update existing budget via PUT /api/budgets/:id
            response = await fetch(`/api/budgets/${existingBudgetId}`, {
              method: 'PUT',
              headers: getCsrfHeaders({
                'Content-Type': 'application/json',
              }),
              body: JSON.stringify({
                budget_amount: budgetAmount,
              }),
            });
          } else {
            // Create new budget via POST /api/budgets
            response = await fetch('/api/budgets', {
              method: 'POST',
              headers: getCsrfHeaders({
                'Content-Type': 'application/json',
              }),
              body: JSON.stringify({
                category_id: categoryId,
                month,
                year,
                budget_amount: budgetAmount,
                currency,
              }),
            });
          }

          if (!response.ok) {
            const errorData = await response.json();
            throw new Error(errorData.message || 'Failed to set budget');
          }

          const responseData = await response.json();
          const newBudgetId = responseData.data?.id || existingBudgetId;

          // Success - announce to screen readers, close modal and show toast
          if (statusDiv) {
            statusDiv.textContent = 'Budget saved successfully';
          }
          addToast('Budget saved successfully!', 'success');
          form.reset();
          modal.close();

          // Update the data attributes with new budget info
          if (selectedOption) {
            selectedOption.dataset.budgetAmount = budgetAmount;
            selectedOption.dataset.budgetId = newBudgetId;
          }

          // Dispatch custom event so page can update if needed
          document.dispatchEvent(
            new CustomEvent('budget-updated', {
              detail: {
                categoryId,
                budgetId: newBudgetId,
                budgetAmount,
                currency,
                month,
                year,
              },
            })
          );
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Failed to set budget';
          if (errorDiv) {
            errorDiv.textContent = message;
            errorDiv.classList.remove('hidden');
          }
        } finally {
          // Reset button state
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSetBudgetModal);
  } else {
    initSetBudgetModal();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initSetBudgetModal);
</script>
