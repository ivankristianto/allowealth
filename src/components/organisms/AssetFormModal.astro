---
/**
 * AssetFormModal Component
 *
 * Modal for adding or editing assets.
 * Supports both create (POST /api/assets) and edit (PUT /api/assets/:id) modes.
 *
 * Based on the Global Portfolio PoC design with premium styling.
 *
 * @param {string} id - Modal ID
 * @param {'add' | 'edit'} mode - Modal mode
 * @param {string} currency - Default currency
 */

import Modal from '../molecules/Modal.astro';
import { Store } from '@lucide/astro';
import { DEFAULT_ASSET_CATEGORIES } from '@/lib/constants';

export interface Props {
  id: string;
  mode?: 'add' | 'edit';
  currency?: 'IDR' | 'USD';
  categories?: Array<{
    id: string;
    name: string;
    is_liability: boolean;
    is_system: boolean;
    sort_order: number;
  }>;
}

const { id, mode = 'add', currency = 'IDR', categories = [] } = Astro.props;

const isEditMode = mode === 'edit';
const title = isEditMode ? 'Edit Asset' : 'Register Asset';
const subtitle = isEditMode
  ? 'Update the details of your asset.'
  : 'Add a new account, fund or security to your portfolio.';
const submitLabel = isEditMode ? 'Save Changes' : 'Register Asset';

const categoryOptions = categories.length
  ? categories.map((category) => ({
      value: category.id,
      label: category.name,
    }))
  : DEFAULT_ASSET_CATEGORIES.map((category) => ({
      value: category.legacyType,
      label: category.name,
    }));
---

<div data-asset-form-modal-container data-id={id} data-mode={mode} data-testid="asset-form-modal">
  <Modal id={id} size="md" closable={false} backdropClose={true}>
    <div slot="default" class="flex flex-col gap-6">
      {/* Header with icon */}
      <div class="flex items-center gap-4">
        <div
          class="w-12 h-12 rounded-2xl flex items-center justify-center bg-accent/10 text-accent"
        >
          <Store size={24} class="stroke-current" aria-hidden="true" />
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-bold tracking-tight text-primary leading-none" data-modal-title>
            {title}
          </h2>
          <p class="text-neutral text-sm mt-2 font-medium" data-modal-subtitle>
            {subtitle}
          </p>
        </div>
      </div>

      {/* Form */}
      <form id={`${id}-form`} class="flex flex-col gap-6" aria-describedby={`${id}-error`}>
        {/* Hidden field for asset ID (edit mode) */}
        <input type="hidden" name="asset_id" id={`${id}-asset-id`} value="" />

        {/* Asset Name */}
        <div class="space-y-2">
          <label
            for={`${id}-name`}
            class="text-xs font-bold text-base-content/40 uppercase tracking-widest ml-1"
          >
            Asset Name
          </label>
          <input
            id={`${id}-name`}
            name="name"
            type="text"
            required
            placeholder="e.g. Mandiri Savings / AAPL Stock"
            class="input input-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent placeholder:text-base-content/30 placeholder:font-normal"
            data-testid="asset-name-input"
          />
        </div>

        {/* Asset Category */}
        <div class="space-y-2">
          <div class="flex justify-between items-center">
            <label
              for={`${id}-categoryId`}
              class="text-xs font-bold text-base-content/40 uppercase tracking-widest ml-1"
            >
              Asset Category
            </label>
            {/* P3: TODO - Implement custom category creation feature */}
            <button
              type="button"
              class="text-xs font-bold text-accent uppercase tracking-widest hover:underline"
              data-toggle-custom-type
            >
              Create New Category
            </button>
          </div>

          {/* Select dropdown (default) */}
          <select
            id={`${id}-categoryId`}
            name="categoryId"
            required
            class="select select-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent"
            data-category-select
            data-testid="asset-category-select"
          >
            {
              categoryOptions.map((category) => (
                <option value={category.value}>{category.label}</option>
              ))
            }
          </select>

          {/* Custom type input (hidden by default) */}
          <input
            id={`${id}-custom-type`}
            name="custom_type"
            type="text"
            placeholder="Enter new category name..."
            class="hidden input input-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent placeholder:text-base-content/30 placeholder:font-normal"
            data-custom-type-input
          />
        </div>

        {/* Currency and Balance */}
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {/* Currency */}
          <div class="space-y-2">
            <label
              for={`${id}-currency`}
              class="text-xs font-bold text-base-content/40 uppercase tracking-widest ml-1"
            >
              Currency
            </label>
            <select
              id={`${id}-currency`}
              name="currency"
              required
              class="select select-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent"
              data-testid="asset-currency-select"
            >
              <option value="IDR" selected={currency === 'IDR'}>IDR</option>
              <option value="USD" selected={currency === 'USD'}>USD</option>
            </select>
          </div>

          {/* Balance */}
          <div class="space-y-2">
            <label
              for={`${id}-balance`}
              class="text-xs font-bold text-base-content/40 uppercase tracking-widest ml-1"
            >
              {isEditMode ? 'Current Balance' : 'Initial Balance'}
            </label>
            <input
              id={`${id}-balance`}
              name="balance"
              type="text"
              inputmode="decimal"
              required
              placeholder="0"
              class="input input-lg w-full bg-base-200 border border-base-300 rounded-2xl font-bold text-base-content focus:ring-2 focus:ring-accent focus:outline-none focus:border-accent placeholder:text-base-content/30 placeholder:font-normal"
            />
          </div>
        </div>

        {/* Error message container */}
        <div
          id={`${id}-error`}
          class="hidden alert alert-error text-sm rounded-xl"
          role="alert"
          aria-live="polite"
        >
        </div>

        {/* Actions */}
        <div class="flex gap-4 pt-2">
          <button
            type="button"
            class="btn btn-ghost flex-1 h-14 rounded-2xl font-bold text-base-content hover:bg-base-200 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-accent"
            data-cancel-asset-form
          >
            Cancel
          </button>
          <button
            type="submit"
            class="btn btn-accent flex-1 h-14 rounded-2xl font-bold"
            data-submit-asset-form
            data-testid="asset-submit-btn"
          >
            {submitLabel}
          </button>
        </div>
      </form>
    </div>
  </Modal>
</div>

<script>
  import { addToast } from '@lib/stores/toastStore';
  import { csrfFetch } from '@/lib/csrf-client';
  import { attachAmountFormatter, stripAmountFormatting } from '@/lib/formatting/amount-input';
  import type { Currency } from '@/lib/constants/currency';

  // Track initialized modals to avoid duplicate handlers
  const initializedModals = new WeakSet<Element>();

  interface AssetFormData {
    id?: string;
    name: string;
    categoryId?: string;
    categoryName?: string;
    currency: 'IDR' | 'USD';
    balance: string;
  }

  function initAssetFormModal() {
    document.querySelectorAll('[data-asset-form-modal-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedModals.has(container)) return;
      initializedModals.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const modal = document.getElementById(id) as HTMLDialogElement | null;
      const form = document.getElementById(`${id}-form`) as HTMLFormElement | null;
      const cancelBtn = container.querySelector('[data-cancel-asset-form]');
      const submitBtn = container.querySelector('[data-submit-asset-form]') as HTMLButtonElement;
      const errorDiv = document.getElementById(`${id}-error`);

      // Form fields
      const assetIdInput = document.getElementById(`${id}-asset-id`) as HTMLInputElement | null;
      const nameInput = document.getElementById(`${id}-name`) as HTMLInputElement | null;
      const categorySelect = document.getElementById(
        `${id}-categoryId`
      ) as HTMLSelectElement | null;
      const currencySelect = document.getElementById(`${id}-currency`) as HTMLSelectElement | null;
      const balanceInput = document.getElementById(`${id}-balance`) as HTMLInputElement | null;
      const createCategoryBtn = container.querySelector('[data-toggle-custom-type]');

      // Title and subtitle for dynamic updates
      const titleEl = container.querySelector('[data-modal-title]');
      const subtitleEl = container.querySelector('[data-modal-subtitle]');

      if (!modal || !form) return;

      // Attach amount formatter for thousand separators on balance input
      let balanceFormatterHandle: ReturnType<typeof attachAmountFormatter> | null = null;
      if (balanceInput) {
        const initialCurrency = (currencySelect?.value || 'IDR') as Currency;
        balanceFormatterHandle = attachAmountFormatter(balanceInput, initialCurrency);
      }

      // Update formatter currency when currency select changes
      currencySelect?.addEventListener('change', () => {
        balanceFormatterHandle?.updateCurrency(currencySelect.value as Currency);
      });

      createCategoryBtn?.addEventListener('click', () => {
        if (typeof (window as any).openAssetCategoryModal === 'function') {
          (window as any).openAssetCategoryModal('create');
        } else {
          window.location.href = '/assets/categories';
        }
      });

      // Balance label element for dynamic update (scoped to this modal's container)
      const balanceLabel = container.querySelector(`label[for="${id}-balance"]`);

      // Function to populate form for edit mode
      const populateForm = (data: AssetFormData) => {
        if (assetIdInput) assetIdInput.value = data.id || '';
        if (nameInput) nameInput.value = data.name || '';
        if (categorySelect) {
          if (data.categoryId) {
            categorySelect.value = data.categoryId;
          } else if (data.categoryName) {
            const options = Array.from(categorySelect.options);
            const match = options.find(
              (option) => option.textContent?.trim() === data.categoryName
            );
            if (match) {
              categorySelect.value = match.value;
            }
          }
        }
        if (currencySelect) currencySelect.value = data.currency || 'IDR';
        if (balanceInput) balanceInput.value = data.balance || '';

        // Update title/subtitle for edit mode
        if (data.id && titleEl && subtitleEl) {
          titleEl.textContent = 'Edit Asset';
          subtitleEl.textContent = 'Update the details of your asset.';
          if (submitBtn) submitBtn.textContent = 'Save Changes';
          if (balanceLabel) balanceLabel.textContent = 'Updated Balance';
        }

        // Hide balance field in edit mode (balance updates go through Update Value modal)
        const balanceField = container.querySelector(`#${id}-balance`)?.closest('.space-y-2');
        if (balanceField) {
          (balanceField as HTMLElement).style.display = data.id ? 'none' : '';
        }
      };

      // Function to reset form
      const resetForm = () => {
        form.reset();
        if (assetIdInput) assetIdInput.value = '';
        if (errorDiv) {
          errorDiv.textContent = '';
          errorDiv.classList.add('hidden');
        }

        // Reset title/subtitle for add mode
        if (titleEl && subtitleEl) {
          titleEl.textContent = 'Register Asset';
          subtitleEl.textContent = 'Add a new account, fund or security to your portfolio.';
          if (submitBtn) submitBtn.textContent = 'Register Asset';
          if (balanceLabel) balanceLabel.textContent = 'Initial Balance';
        }

        // Show balance field for add mode
        const balanceField = container.querySelector(`#${id}-balance`)?.closest('.space-y-2');
        if (balanceField) {
          (balanceField as HTMLElement).style.display = '';
        }
      };

      // Listen for open-asset-form event to populate data
      // SECURITY: Use named handler for proper cleanup on page transitions
      const handleOpenForm = ((e: CustomEvent<AssetFormData>) => {
        // Populate form if editing (has id), otherwise reset for add mode
        if (e.detail.id) {
          populateForm(e.detail);
        } else {
          resetForm();
        }
        modal.showModal();
      }) as EventListener;

      document.addEventListener('open-asset-form', handleOpenForm);

      // Clean up event listener on Astro page transitions to prevent memory leaks
      document.addEventListener(
        'astro:before-swap',
        () => {
          document.removeEventListener('open-asset-form', handleOpenForm);
        },
        { once: true }
      );

      // Handle cancel button
      cancelBtn?.addEventListener('click', () => {
        resetForm();
        modal.close();
      });

      // Handle form submission
      form.addEventListener('submit', async (e) => {
        e.preventDefault();

        const formData = new FormData(form);
        const assetId = formData.get('asset_id') as string;
        const name = formData.get('name') as string;
        const categoryId = formData.get('categoryId') as string;
        const currency = formData.get('currency') as string;
        const balance = formData.get('balance') as string;

        // Clear previous errors
        if (errorDiv) {
          errorDiv.textContent = '';
          errorDiv.classList.add('hidden');
        }

        // Validation
        const isEdit = Boolean(assetIdInput?.value);
        if (!name || !categoryId || !currency || (!isEdit && !balance)) {
          if (errorDiv) {
            errorDiv.textContent = 'Please fill in all required fields.';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        // Balance validation - strip formatting then validate (only when balance is provided)
        const selectedCurrency = (currencySelect?.value || 'IDR') as Currency;
        const strippedBalance = balance ? stripAmountFormatting(balance, selectedCurrency) : '';
        if (balance) {
          const balanceNum = Number(strippedBalance);
          if (isNaN(balanceNum) || balanceNum < 0 || !isFinite(balanceNum)) {
            if (errorDiv) {
              errorDiv.textContent = 'Please enter a valid positive number for balance.';
              errorDiv.classList.remove('hidden');
            }
            return;
          }
        }

        // Asset ID validation - ensure nanoid format if editing
        const assetIdPattern = /^[A-Za-z0-9_-]{21}$/;
        if (assetId && !assetIdPattern.test(assetId)) {
          if (errorDiv) {
            errorDiv.textContent = 'Invalid asset ID format.';
            errorDiv.classList.remove('hidden');
          }
          return;
        }

        // Show loading state
        const originalText = submitBtn?.textContent || 'Submit';
        if (submitBtn) {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Saving...';
        }

        try {
          const isEdit = Boolean(assetId);
          const url = isEdit ? `/api/assets/${assetId}` : '/api/assets';
          const method = isEdit ? 'PUT' : 'POST';

          // For edit, we need to update balance separately if it changed
          const payload: Record<string, string> = {
            name,
            currency,
          };

          const categoryIdPattern = /^[A-Za-z0-9_-]{21}$/;
          if (categoryIdPattern.test(categoryId)) {
            payload.categoryId = categoryId;
          } else {
            payload.type = categoryId;
          }

          // For create, include balance (stripped of formatting); for update, use balance endpoint
          if (!isEdit) {
            payload.balance = strippedBalance;
          }

          const response = await csrfFetch(url, {
            method,
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
          });

          if (!response.ok) {
            const errorData = await response.json();
            throw new Error(
              errorData.error?.message ||
                errorData.message ||
                `Failed to ${isEdit ? 'update' : 'create'} asset`
            );
          }

          // Success
          addToast(`Asset ${isEdit ? 'updated' : 'created'} successfully!`, 'success');
          resetForm();
          modal.close();

          // Dispatch event for page refresh
          document.dispatchEvent(
            new CustomEvent('asset-saved', {
              detail: { assetId, name, categoryId, currency, balance, isEdit },
            })
          );

          // Reload page to show updated data
          setTimeout(() => window.location.reload(), 500);
        } catch (err) {
          const message = err instanceof Error ? err.message : 'An error occurred';
          if (errorDiv) {
            errorDiv.textContent = message;
            errorDiv.classList.remove('hidden');
          }
        } finally {
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.textContent = originalText;
          }
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAssetFormModal);
  } else {
    initAssetFormModal();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAssetFormModal);
</script>
