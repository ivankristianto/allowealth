---
/**
 * MfaSetupModal
 *
 * Better Auth-backed TOTP setup:
 * 1) Confirm the current password
 * 2) Show the authenticator secret
 * 3) Verify the current TOTP code to finalize setup
 */

import Modal from '@/components/molecules/Modal.astro';
import { ShieldCheck } from '@lucide/astro';

export interface Props {
  id?: string;
}

const { id = 'mfa-setup-modal' } = Astro.props;
---

<div data-mfa-setup-modal-container data-id={id}>
  <Modal id={id} title="" size="md" closable={false} className="[&_.modal-box]:rounded-3xl">
    <div class="space-y-6">
      <div class="flex items-center gap-4">
        <div
          class="w-12 h-12 rounded-2xl flex items-center justify-center bg-accent/10 text-accent"
        >
          <ShieldCheck size={24} class="stroke-current" aria-hidden="true" />
        </div>
        <div>
          <h2 class="text-xl font-bold tracking-tight text-base-content leading-none">
            Enable Multi-Factor Authentication
          </h2>
          <p class="text-base-content/60 text-sm mt-2 font-medium">
            Scan your authenticator app, then verify with a 6-digit code.
          </p>
        </div>
      </div>

      <form data-step="credentials" class="space-y-4">
        <div class="form-control">
          <label for={`${id}-password`} class="label">
            <span class="label-text font-semibold">Account password</span>
          </label>
          <input
            id={`${id}-password`}
            name="password"
            type="password"
            autocomplete="current-password"
            placeholder="Enter your password"
            class="input input-bordered w-full"
            data-testid="mfa-password-input"
          />
        </div>

        <div class="hidden alert alert-error text-sm" data-mfa-password-error role="alert"></div>

        <div class="flex items-center gap-4 pt-2">
          <button
            type="button"
            class="btn btn-ghost flex-1 rounded-2xl font-semibold"
            data-mfa-cancel-setup
          >
            Cancel
          </button>
          <button
            type="submit"
            class="flex-[2] btn btn-accent rounded-2xl"
            data-mfa-start
            data-testid="mfa-start-btn"
          >
            Continue
          </button>
        </div>
      </form>

      <div data-step="loading" class="hidden space-y-3">
        <div class="alert alert-info">
          <span class="loading loading-spinner loading-sm"></span>
          <span>Preparing your authenticator setup...</span>
        </div>
      </div>

      <div data-step="setup" class="hidden space-y-4">
        <div class="rounded-2xl border border-base-300 bg-base-200 p-4 space-y-2">
          <p class="text-sm text-base-content/70">
            Add a new TOTP account in your authenticator app, then paste the secret below.
          </p>
          <p class="text-xs font-semibold uppercase tracking-wider text-base-content/60">
            Setup key
          </p>
          <code class="font-mono text-sm break-all" data-manual-code></code>
        </div>
        <button type="button" class="btn btn-outline w-full rounded-2xl" data-mfa-continue>
          I have scanned this code
        </button>
      </div>

      <form data-step="verify" class="hidden space-y-4">
        <div class="form-control">
          <label for={`${id}-code`} class="label">
            <span class="label-text font-semibold">Verification code</span>
          </label>
          <input
            id={`${id}-code`}
            name="code"
            type="text"
            inputmode="numeric"
            autocomplete="one-time-code"
            placeholder="000000"
            maxlength="6"
            class="input input-bordered w-full text-center text-2xl tracking-[0.5em] font-bold"
            data-testid="mfa-verification-input"
          />
        </div>

        <div class="hidden alert alert-error text-sm" data-mfa-error role="alert"></div>

        <div class="flex items-center gap-4 pt-2">
          <button
            type="button"
            class="btn btn-ghost flex-1 rounded-2xl font-semibold"
            data-mfa-cancel
          >
            Cancel
          </button>
          <button
            type="submit"
            class="flex-[2] btn btn-accent rounded-2xl"
            data-mfa-verify-btn
            data-testid="mfa-verify-btn"
          >
            Verify & Enable
          </button>
        </div>
      </form>
    </div>
  </Modal>
</div>

<script>
  import { authClient } from '@/lib/auth/client';
  import { addToast } from '@/lib/stores/toastStore';

  const initializedContainers = new WeakSet<Element>();

  function getAuthErrorMessage(error: unknown, fallbackMessage: string): string {
    if (
      error &&
      typeof error === 'object' &&
      'message' in error &&
      typeof error.message === 'string'
    ) {
      return error.message;
    }

    if (error && typeof error === 'object' && 'error' in error) {
      const nestedError = error.error;
      if (
        nestedError &&
        typeof nestedError === 'object' &&
        'message' in nestedError &&
        typeof nestedError.message === 'string'
      ) {
        return nestedError.message;
      }
    }

    if (
      error &&
      typeof error === 'object' &&
      'statusText' in error &&
      typeof error.statusText === 'string'
    ) {
      return error.statusText;
    }

    return fallbackMessage;
  }

  function getSecretFromTotpUri(totpURI: string): string {
    try {
      const parsedURL = new URL(totpURI);
      return parsedURL.searchParams.get('secret') ?? '';
    } catch {
      return '';
    }
  }

  function initMfaSetupModal() {
    document
      .querySelectorAll<HTMLElement>('[data-mfa-setup-modal-container]')
      .forEach((container) => {
        if (initializedContainers.has(container)) return;
        initializedContainers.add(container);

        const id = container.dataset.id;
        if (!id) return;

        const modal = document.getElementById(id) as HTMLDialogElement | null;
        const stepCredentials = container.querySelector<HTMLFormElement>(
          '[data-step="credentials"]'
        );
        const stepLoading = container.querySelector<HTMLElement>('[data-step="loading"]');
        const stepSetup = container.querySelector<HTMLElement>('[data-step="setup"]');
        const stepVerify = container.querySelector<HTMLFormElement>('[data-step="verify"]');
        const manualCode = container.querySelector<HTMLElement>('[data-manual-code]');
        const passwordInput = container.querySelector<HTMLInputElement>('input[name="password"]');
        const passwordError = container.querySelector<HTMLElement>('[data-mfa-password-error]');
        const codeInput = container.querySelector<HTMLInputElement>('input[name="code"]');
        const errorEl = container.querySelector<HTMLElement>('[data-mfa-error]');
        const cancelSetupBtn =
          container.querySelector<HTMLButtonElement>('[data-mfa-cancel-setup]');
        const cancelBtn = container.querySelector<HTMLButtonElement>('[data-mfa-cancel]');
        const startBtn = container.querySelector<HTMLButtonElement>('[data-mfa-start]');
        const continueBtn = container.querySelector<HTMLButtonElement>('[data-mfa-continue]');
        const verifyBtn = container.querySelector<HTMLButtonElement>('[data-mfa-verify-btn]');

        if (
          !modal ||
          !stepCredentials ||
          !stepLoading ||
          !stepSetup ||
          !stepVerify ||
          !manualCode ||
          !passwordInput ||
          !codeInput
        ) {
          return;
        }

        let setupPassword = '';
        let backupCodes: string[] = [];

        const setStep = (step: 'credentials' | 'loading' | 'setup' | 'verify') => {
          stepCredentials.classList.toggle('hidden', step !== 'credentials');
          stepLoading.classList.toggle('hidden', step !== 'loading');
          stepSetup.classList.toggle('hidden', step !== 'setup');
          stepVerify.classList.toggle('hidden', step !== 'verify');
        };

        const clearPasswordError = () => {
          if (!passwordError) return;
          passwordError.textContent = '';
          passwordError.classList.add('hidden');
        };

        const showPasswordError = (message: string) => {
          if (!passwordError) return;
          passwordError.textContent = message;
          passwordError.classList.remove('hidden');
        };

        const clearError = () => {
          if (!errorEl) return;
          errorEl.textContent = '';
          errorEl.classList.add('hidden');
        };

        const showError = (message: string) => {
          if (!errorEl) return;
          errorEl.textContent = message;
          errorEl.classList.remove('hidden');
        };

        const resetModal = () => {
          clearPasswordError();
          clearError();
          setupPassword = '';
          backupCodes = [];
          passwordInput.value = '';
          codeInput.value = '';
          manualCode.textContent = '';
          startBtn?.removeAttribute('disabled');
          verifyBtn?.removeAttribute('disabled');
        };

        const openSetup = () => {
          resetModal();
          setStep('credentials');
          modal.showModal();
          requestAnimationFrame(() => passwordInput.focus());
        };

        document.addEventListener('mfa:open-setup', () => {
          openSetup();
        });

        cancelSetupBtn?.addEventListener('click', () => {
          modal.close();
        });

        cancelBtn?.addEventListener('click', () => {
          modal.close();
        });

        stepCredentials.addEventListener('submit', async (event) => {
          event.preventDefault();
          clearPasswordError();
          clearError();

          const password = passwordInput.value;
          if (!password) {
            showPasswordError('Please enter your account password.');
            return;
          }

          if (startBtn) startBtn.disabled = true;
          setupPassword = password;
          setStep('loading');

          try {
            const result = await authClient.twoFactor.enable({
              password,
              issuer: 'Allowealth',
            });

            if (result.error) {
              throw result.error;
            }

            const totpURI = result.data?.totpURI;
            backupCodes = result.data?.backupCodes ?? [];

            if (!totpURI) {
              throw new Error('Authenticator setup details were not returned.');
            }

            manualCode.textContent = getSecretFromTotpUri(totpURI);
            setStep('setup');
          } catch (error) {
            setStep('credentials');
            showPasswordError(getAuthErrorMessage(error, 'Failed to initialize MFA setup.'));
          } finally {
            if (startBtn) startBtn.disabled = false;
          }
        });

        continueBtn?.addEventListener('click', () => {
          clearError();
          setStep('verify');
          codeInput.focus();
        });

        stepVerify.addEventListener('submit', async (event) => {
          event.preventDefault();
          clearError();

          const code = codeInput.value.trim();
          if (!/^\d{6}$/.test(code)) {
            showError('Please enter a valid 6-digit code.');
            return;
          }

          if (verifyBtn) verifyBtn.disabled = true;

          try {
            const result = await authClient.twoFactor.verifyTotp({ code });
            if (result.error) {
              throw result.error;
            }

            modal.close();
            addToast('MFA enabled successfully.', 'success');

            document.dispatchEvent(
              new CustomEvent('mfa-setup-complete', {
                detail: {
                  backupCodes,
                  password: setupPassword,
                },
              })
            );
          } catch (error) {
            const message = getAuthErrorMessage(error, 'Failed to verify setup code.');
            showError(message);
          } finally {
            if (verifyBtn) verifyBtn.disabled = false;
          }
        });
      });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initMfaSetupModal);
  } else {
    initMfaSetupModal();
  }

  document.addEventListener('astro:page-load', initMfaSetupModal);
</script>
