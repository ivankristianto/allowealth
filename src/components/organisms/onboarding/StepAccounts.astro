---
/**
 * StepAccounts — Onboarding Step 2
 *
 * Account creation for grounding budgets in reality.
 * Shows existing accounts and allows adding new ones.
 */

import { ArrowLeft, ArrowRight, Plus } from '@lucide/astro';
import AmountInput from '@/components/atoms/AmountInput.astro';
import { ACCOUNT_TYPE_LABELS, type AccountType } from '@/lib/types/account';
import type { Currency } from '@/lib/constants/currency';
import { CURRENCY_META } from '@/lib/constants/currency';
import { formatAmountForDisplay } from '@/lib/formatting/amount-input';

export interface SimpleAccount {
  id: string;
  name: string;
  type: AccountType;
  balance: string;
  currency: Currency;
}

export interface Props {
  accounts: SimpleAccount[];
  currencies: Currency[];
}

const { accounts, currencies } = Astro.props;
const primaryCurrency = currencies[0];

// Account types suitable for onboarding (most common ones)
const onboardingAccountTypes: AccountType[] = ['bank_account', 'cash', 'e_wallet', 'credit_card'];
---

<div class="space-y-6">
  <p class="max-w-2xl text-base leading-relaxed text-base-content/70">
    Add the accounts you use daily. Start with one or two important accounts first. You can add more
    anytime.
  </p>

  {
    accounts.length > 0 && (
      <div id="onboarding-accounts-list" class="space-y-2.5">
        <p class="text-sm font-semibold text-base-content/70">Accounts added</p>
        {accounts.map((account) => (
          <div class="flex items-center justify-between rounded-xl border border-base-300 bg-base-100 px-4 py-3">
            <div>
              <p class="font-semibold text-base-content">{account.name}</p>
              <p class="text-xs text-base-content/55">{ACCOUNT_TYPE_LABELS[account.type]}</p>
            </div>
            <div class="text-right">
              <p class="font-bold text-base-content">
                {CURRENCY_META[account.currency].symbol}{' '}
                {formatAmountForDisplay(account.balance, account.currency)}
              </p>
              <p class="text-xs text-base-content/55">{account.currency}</p>
            </div>
          </div>
        ))}
      </div>
    )
  }

  <form
    id="onboarding-account-form"
    class="space-y-4 rounded-xl border border-base-300 bg-base-200/50 p-4 sm:p-5"
    novalidate
  >
    <h3 class="text-sm font-semibold text-base-content/75">Add an account</h3>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <div class="form-control gap-1.5">
        <label class="label px-0" for="account-name">
          <span class="label-text font-medium text-base-content">Account name</span>
        </label>
        <input
          type="text"
          id="account-name"
          name="name"
          class="input input-bordered w-full rounded-lg border border-base-300"
          placeholder="e.g., Main Checking"
          required
        />
      </div>

      <div class="form-control gap-1.5">
        <label class="label px-0" for="account-type">
          <span class="label-text font-medium text-base-content">Type</span>
        </label>
        <select
          id="account-type"
          name="type"
          class="select select-bordered w-full rounded-lg border border-base-300"
          required
        >
          {
            onboardingAccountTypes.map((type) => (
              <option value={type}>{ACCOUNT_TYPE_LABELS[type]}</option>
            ))
          }
        </select>
      </div>
    </div>

    <div class="form-control gap-1.5">
      <label class="label px-0" for="account-balance">
        <span class="label-text font-medium text-base-content">Current balance</span>
      </label>
      <div class="join w-full">
        {
          currencies.length > 1 ? (
            <select
              id="account-currency"
              name="currency"
              class="select select-bordered join-item w-24 rounded-l-lg rounded-r-none border border-base-300"
            >
              {currencies.map((c) => (
                <option value={c} selected={c === primaryCurrency}>
                  {c}
                </option>
              ))}
            </select>
          ) : (
            <span class="btn btn-disabled join-item w-24 rounded-l-lg rounded-r-none">
              {primaryCurrency}
            </span>
          )
        }
        <AmountInput
          id="account-balance"
          name="balance"
          currency={primaryCurrency}
          required={true}
          placeholder="0"
          className="join-item rounded-l-none rounded-r-lg border border-base-300 input-bordered"
        />
      </div>
      {currencies.length === 1 && <input type="hidden" name="currency" value={primaryCurrency} />}
    </div>

    <div
      id="account-error"
      class="alert alert-error hidden rounded-lg border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
      role="alert"
    >
    </div>

    <button
      type="submit"
      class="btn btn-outline min-h-[44px] w-full gap-2 rounded-lg border-base-300 sm:rounded-xl"
    >
      <Plus size={16} class="stroke-current" aria-hidden="true" />
      Add account
    </button>
  </form>

  <p class="text-sm leading-relaxed text-base-content/60">
    Each account starts with your current balance so your budget reflects reality from day one.
  </p>

  <div class="flex justify-between gap-3 pt-1">
    <a
      href="/onboarding?reset=currency"
      class="btn btn-ghost min-h-[44px] gap-2 rounded-lg sm:rounded-xl"
    >
      <ArrowLeft size={16} class="stroke-current" aria-hidden="true" />
      Back
    </a>
    <button
      type="button"
      id="onboarding-accounts-continue"
      class="btn btn-accent min-h-[44px] gap-2 rounded-lg px-6 sm:rounded-xl"
      disabled={accounts.length === 0}
    >
      Continue
      <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
    </button>
  </div>
</div>

<script>
  import { csrfFetch } from '@/lib/csrf-client';
  import { attachAmountFormatter, stripAmountFormatting } from '@/lib/formatting/amount-input';

  function initStepAccounts() {
    const form = document.getElementById('onboarding-account-form') as HTMLFormElement | null;
    const continueBtn = document.getElementById('onboarding-accounts-continue');
    const errorDiv = document.getElementById('account-error');

    if (!form) return;

    const balanceInput = document.getElementById('account-balance') as HTMLInputElement | null;
    const currencySelect = document.getElementById('account-currency') as HTMLSelectElement | null;

    if (balanceInput) {
      const initialCurrency = (currencySelect?.value ??
        balanceInput.dataset.amountCurrency ??
        'IDR') as import('@/lib/constants/currency').Currency;
      const formatter = attachAmountFormatter(balanceInput, initialCurrency);

      // Keep formatter in sync when user changes currency
      currencySelect?.addEventListener('change', () => {
        formatter.updateCurrency(
          currencySelect.value as import('@/lib/constants/currency').Currency
        );
      });
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }

      const formData = new FormData(form);
      const name = (formData.get('name') as string).trim();
      const type = formData.get('type') as string;
      const currency = formData.get('currency') as string;
      const rawBalance = formData.get('balance') as string;
      const balance = stripAmountFormatting(rawBalance);

      if (!name) {
        if (errorDiv) {
          errorDiv.textContent = 'Account name is required';
          errorDiv.classList.remove('hidden');
        }
        return;
      }

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;

      try {
        const res = await csrfFetch('/api/accounts', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, type, balance: balance || '0', currency }),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error?.message || 'Failed to create account');
        }

        // Reload to show new account in list (stay on step 2)
        window.location.href = '/onboarding?reset=accounts';
      } catch (err) {
        if (errorDiv) {
          errorDiv.textContent = err instanceof Error ? err.message : 'An error occurred';
          errorDiv.classList.remove('hidden');
        }
        btn.disabled = false;
      }
    });

    // Continue button navigates to next step
    continueBtn?.addEventListener('click', () => {
      window.location.href = '/onboarding';
    });
  }

  document.addEventListener('astro:page-load', initStepAccounts);
</script>
