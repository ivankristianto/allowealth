---
/**
 * StepAllocate — Onboarding Step 4
 *
 * Budget allocation with real-time progress bar.
 * Pre-fills smart defaults based on income and category percentages.
 */

import { ArrowLeft, ArrowRight } from '@lucide/astro';
import AmountInput from '@/components/atoms/AmountInput.astro';
import type { Currency } from '@/lib/constants/currency';
import { CURRENCY_META } from '@/lib/constants/currency';
import { DEFAULT_EXPENSE_CATEGORIES } from '@/lib/constants/default-categories';

export interface CategoryForAllocation {
  id: string;
  name: string;
  icon: string | null;
  color: string | null;
}

export interface Props {
  categories: CategoryForAllocation[];
  income: Record<string, string>;
  currencies: Currency[];
}

const { categories, income, currencies } = Astro.props;
const primaryCurrency = currencies[0];
const totalIncome = parseFloat(income[primaryCurrency] || '0');

// Build default amounts from category percentages
const defaultAmounts = new Map<string, string>();
for (const cat of categories) {
  const defaultCat = DEFAULT_EXPENSE_CATEGORIES.find((d) => d.name === cat.name);
  if (defaultCat && totalIncome > 0) {
    const amount = Math.round((totalIncome * defaultCat.budgetPercent) / 100);
    defaultAmounts.set(cat.id, amount.toString());
  }
}
---

<div class="space-y-6" data-onboarding-allocate data-allocation-total={totalIncome.toString()}>
  <p class="max-w-2xl text-base leading-relaxed text-base-content/70">
    Give every amount a job. Adjust the suggested category budgets until the allocation reflects how
    you actually spend.
  </p>

  <div class="rounded-xl border border-base-300 bg-base-200/50 p-4 sm:p-5">
    <div class="mb-2 flex items-center justify-between text-sm font-semibold text-base-content/65">
      <span>
        Allocated:
        <span data-allocation-allocated class="text-base-content">0</span>
      </span>
      <span>
        Remaining:
        <span data-allocation-remaining class="text-base-content"
          >{totalIncome.toLocaleString()}</span
        >
      </span>
    </div>

    <div class="h-3 w-full overflow-hidden rounded-full bg-base-300">
      <div
        data-allocation-bar
        class="h-3 rounded-full bg-accent transition-all duration-300"
        style="width: 0%"
      >
      </div>
    </div>

    <p class="mt-2 text-xs text-base-content/55">
      Total income: {CURRENCY_META[primaryCurrency].symbol}
      {totalIncome.toLocaleString()}
    </p>
  </div>

  <form id="onboarding-allocate-form" class="space-y-3" novalidate>
    {
      categories.map((cat) => (
        <div class="grid grid-cols-1 gap-3 rounded-xl border border-base-300 bg-base-100 px-4 py-3 sm:grid-cols-[minmax(0,1fr)_10rem] sm:items-center">
          <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-base-content">{cat.name}</p>
          </div>
          <AmountInput
            id={`budget-${cat.id}`}
            name={`budget_${cat.id}`}
            currency={primaryCurrency}
            value={defaultAmounts.get(cat.id) || ''}
            placeholder="0"
            className="w-full rounded-lg border border-base-300 input-bordered input-sm"
            data-testid={`budget-input-${cat.id}`}
          />
        </div>
      ))
    }

    <input type="hidden" name="currency" value={primaryCurrency} />

    <div
      id="allocate-error"
      class="alert alert-error hidden rounded-lg border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
      role="alert"
    >
    </div>

    <div class="flex justify-between gap-3 pt-2">
      <a
        href="/onboarding?reset=income"
        class="btn btn-ghost min-h-[44px] gap-2 rounded-lg sm:rounded-xl"
      >
        <ArrowLeft size={16} class="stroke-current" aria-hidden="true" />
        Back
      </a>
      <button type="submit" class="btn btn-accent min-h-[44px] gap-2 rounded-lg px-6 sm:rounded-xl">
        Continue
        <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
      </button>
    </div>
  </form>
</div>

<script>
  import './StepAllocate.client';
  import { csrfFetch } from '@/lib/csrf-client';
  import { stripAmountFormatting } from '@/lib/formatting/amount-input';

  function initStepAllocateForm() {
    const form = document.getElementById('onboarding-allocate-form') as HTMLFormElement | null;
    const errorDiv = document.getElementById('allocate-error');

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }

      const formData = new FormData(form);
      const currency = formData.get('currency') as string;
      const now = new Date();
      const month = now.getMonth() + 1;
      const year = now.getFullYear();

      const budgets: Array<{ categoryId: string; amount: string; currency: string }> = [];

      for (const [key, value] of formData.entries()) {
        if (key.startsWith('budget_')) {
          const categoryId = key.replace('budget_', '');
          const amount = stripAmountFormatting(value as string);
          if (amount && parseFloat(amount) > 0) {
            budgets.push({ categoryId, amount, currency });
          }
        }
      }

      if (budgets.length === 0) {
        if (errorDiv) {
          errorDiv.textContent = 'Please allocate at least one category';
          errorDiv.classList.remove('hidden');
        }
        return;
      }

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.classList.add('loading');

      try {
        const res = await csrfFetch('/api/onboarding/budgets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ budgets, month, year }),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to save budgets');
        }

        window.location.href = '/onboarding';
      } catch (err) {
        if (errorDiv) {
          errorDiv.textContent = err instanceof Error ? err.message : 'An error occurred';
          errorDiv.classList.remove('hidden');
        }
      } finally {
        btn.disabled = false;
        btn.classList.remove('loading');
      }
    });
  }

  document.addEventListener('astro:page-load', initStepAllocateForm);
</script>
