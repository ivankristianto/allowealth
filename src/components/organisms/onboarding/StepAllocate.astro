---
/**
 * StepAllocate — Onboarding Step 4
 *
 * Budget allocation with real-time progress bar.
 * Pre-fills smart defaults based on income and category percentages.
 */

import { ArrowLeft, ArrowRight, Pencil, Plus, Trash2 } from '@lucide/astro';
import AmountInput from '@/components/atoms/AmountInput.astro';
import Modal from '@/components/molecules/Modal.astro';
import ConfirmationModal from '@/components/molecules/ConfirmationModal.astro';
import type { Currency } from '@/lib/constants/currency';
import { CURRENCY_META } from '@/lib/constants/currency';
import { DEFAULT_EXPENSE_CATEGORIES } from '@/lib/constants/default-categories';

export interface CategoryForAllocation {
  id: string;
  name: string;
  icon: string | null;
  color: string | null;
}

export interface Props {
  categories: CategoryForAllocation[];
  income: Record<string, string>;
  currencies: Currency[];
}

const { categories, income, currencies } = Astro.props;
const primaryCurrency = currencies[0];
const totalIncome = parseFloat(income[primaryCurrency] || '0');

// Build default amounts from category percentages
const defaultAmounts = new Map<string, string>();
for (const cat of categories) {
  const defaultCat = DEFAULT_EXPENSE_CATEGORIES.find((d) => d.name === cat.name);
  if (defaultCat && totalIncome > 0) {
    const amount = Math.round((totalIncome * defaultCat.budgetPercent) / 100);
    defaultAmounts.set(cat.id, amount.toString());
  }
}
---

<div class="space-y-6" data-onboarding-allocate data-allocation-total={totalIncome.toString()}>
  <p class="max-w-2xl text-base leading-relaxed text-base-content/70">
    Give every amount a job. Adjust the suggested category budgets until the allocation reflects how
    you actually spend.
  </p>

  <div class="rounded-xl border border-base-300 bg-base-200/50 p-4 sm:p-5">
    <div class="mb-2 flex items-center justify-between text-sm font-semibold text-base-content/65">
      <span>
        Allocated:
        <span data-allocation-allocated class="text-base-content">0</span>
      </span>
      <span>
        Remaining:
        <span data-allocation-remaining class="text-base-content"
          >{totalIncome.toLocaleString()}</span
        >
      </span>
    </div>

    <div class="h-3 w-full overflow-hidden rounded-full bg-base-300">
      <div
        data-allocation-bar
        class="h-3 rounded-full bg-accent transition-all duration-300"
        style="width: 0%"
      >
      </div>
    </div>

    <p class="mt-2 text-xs text-base-content/55">
      Total income: {CURRENCY_META[primaryCurrency].symbol}
      {totalIncome.toLocaleString()}
    </p>
  </div>

  <div class="space-y-3 rounded-xl border border-base-300 bg-base-200/40 p-4 sm:p-5">
    <div class="space-y-1">
      <p class="text-sm font-semibold text-base-content">Manage categories</p>
      <p class="text-xs text-base-content/60">
        Add, rename, or remove categories before saving your budget allocation.
      </p>
    </div>

    <form
      id="onboarding-add-category-form"
      class="flex flex-col gap-2 sm:flex-row sm:items-end"
      novalidate
    >
      <div class="form-control flex-1 gap-1.5">
        <label class="label px-0 pb-0" for="new-category-name">
          <span class="label-text text-xs font-medium text-base-content/70">New category name</span>
        </label>
        <input
          id="new-category-name"
          name="name"
          type="text"
          class="input input-bordered w-full rounded-lg border border-base-300"
          placeholder="e.g., Education"
          minlength="3"
          maxlength="100"
          required
        />
      </div>
      <button
        type="submit"
        class="btn btn-outline min-h-[44px] gap-2 rounded-lg border-base-300 sm:rounded-xl"
      >
        <Plus size={16} class="stroke-current" aria-hidden="true" />
        Add category
      </button>
    </form>
  </div>

  <form id="onboarding-allocate-form" class="space-y-3" novalidate>
    {
      categories.map((cat) => (
        <div class="grid grid-cols-1 gap-3 rounded-xl border border-base-300 bg-base-100 px-4 py-3 sm:grid-cols-[minmax(0,1fr)_10rem_auto] sm:items-center">
          <div class="min-w-0">
            <p class="truncate text-sm font-semibold text-base-content">{cat.name}</p>
          </div>
          <AmountInput
            id={`budget-${cat.id}`}
            name={`budget_${cat.id}`}
            currency={primaryCurrency}
            value={defaultAmounts.get(cat.id) || ''}
            placeholder="0"
            className="w-full rounded-lg border border-base-300 input-bordered input-sm"
            data-testid={`budget-input-${cat.id}`}
          />
          <div class="flex justify-end gap-1.5 sm:justify-start">
            <button
              type="button"
              class="btn btn-ghost btn-square btn-sm rounded-lg"
              data-category-action="rename"
              data-category-id={cat.id}
              data-category-name={cat.name}
              aria-label={`Rename ${cat.name}`}
              title={`Rename ${cat.name}`}
            >
              <Pencil size={14} class="stroke-current" aria-hidden="true" />
            </button>
            <button
              type="button"
              class="btn btn-ghost btn-square btn-sm rounded-lg text-error hover:bg-error/10"
              data-category-action="delete"
              data-category-id={cat.id}
              data-category-name={cat.name}
              aria-label={`Delete ${cat.name}`}
              title={`Delete ${cat.name}`}
            >
              <Trash2 size={14} class="stroke-current" aria-hidden="true" />
            </button>
          </div>
        </div>
      ))
    }

    <input type="hidden" name="currency" value={primaryCurrency} />

    <div
      id="allocate-category-error"
      class="alert alert-error hidden rounded-lg border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
      role="alert"
    >
    </div>

    <div
      id="allocate-error"
      class="alert alert-error hidden rounded-lg border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
      role="alert"
    >
    </div>

    <div class="flex justify-between gap-3 pt-2">
      <a
        href="/onboarding?reset=income"
        class="btn btn-ghost min-h-[44px] gap-2 rounded-lg sm:rounded-xl"
      >
        <ArrowLeft size={16} class="stroke-current" aria-hidden="true" />
        Back
      </a>
      <button type="submit" class="btn btn-accent min-h-[44px] gap-2 rounded-lg px-6 sm:rounded-xl">
        Continue
        <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
      </button>
    </div>
  </form>

  <Modal
    id="onboarding-category-rename-modal"
    size="sm"
    closable={false}
    backdropClose={true}
    ariaLabel="Rename Category"
  >
    <div slot="default" class="space-y-5">
      <div class="space-y-1">
        <h2 class="text-xl font-bold tracking-tight text-primary leading-none">Rename Category</h2>
        <p class="text-sm text-base-content/70">
          Update the category name before finalizing your budget allocation.
        </p>
      </div>

      <form id="onboarding-rename-category-form" class="space-y-3" novalidate>
        <input type="hidden" name="categoryId" />
        <div class="form-control gap-1.5">
          <label class="label px-0 pb-0" for="onboarding-rename-category-name">
            <span class="label-text text-xs font-medium text-base-content/70">Category name</span>
          </label>
          <input
            id="onboarding-rename-category-name"
            name="name"
            type="text"
            class="input input-bordered w-full rounded-lg border border-base-300"
            minlength="3"
            maxlength="100"
            required
          />
        </div>

        <div
          id="onboarding-rename-category-error"
          class="alert alert-error hidden rounded-lg border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
          role="alert"
        >
        </div>

        <div class="flex gap-3 pt-1">
          <button
            type="button"
            id="onboarding-rename-category-cancel"
            class="btn btn-ghost min-h-[44px] flex-1 rounded-lg sm:rounded-xl"
          >
            Cancel
          </button>
          <button
            type="submit"
            id="onboarding-rename-category-submit"
            class="btn btn-accent min-h-[44px] flex-1 rounded-lg sm:rounded-xl"
          >
            Save
          </button>
        </div>
      </form>
    </div>
  </Modal>

  <div data-onboarding-delete-modal-container>
    <ConfirmationModal
      id="onboarding-category-delete-modal"
      title="Delete Category"
      description="This only removes it from your active onboarding categories."
      confirmLabel="Delete"
      confirmVariant="error"
      confirmLoadingLabel="Deleting..."
      iconVariant="error"
    >
      <div
        slot="details"
        class="rounded-xl border border-base-300 bg-base-200/40 px-4 py-3 text-sm text-base-content/80"
      >
        <p class="text-xs font-semibold uppercase tracking-wide text-base-content/60">Category</p>
        <p id="onboarding-delete-category-name" class="mt-1 font-semibold text-base-content"></p>
      </div>
    </ConfirmationModal>
  </div>
</div>

<script>
  import './StepAllocate.client';
  import { csrfFetch } from '@/lib/csrf-client';
  import { stripAmountFormatting } from '@/lib/formatting/amount-input';
  import { isValidCurrency, type Currency } from '@/lib/constants/currency';
  import {
    clearConfirmError,
    closeConfirmationModal,
    getConfirmationModalElements,
    setConfirmLoading,
    showConfirmError,
  } from '@/components/molecules/ConfirmationModal.client';

  function initStepAllocateForm() {
    const form = document.getElementById('onboarding-allocate-form') as HTMLFormElement | null;
    const addCategoryForm = document.getElementById(
      'onboarding-add-category-form'
    ) as HTMLFormElement | null;
    const errorDiv = document.getElementById('allocate-error');
    const categoryErrorDiv = document.getElementById('allocate-category-error');
    const renameModal = document.getElementById(
      'onboarding-category-rename-modal'
    ) as HTMLDialogElement | null;
    const renameForm = document.getElementById(
      'onboarding-rename-category-form'
    ) as HTMLFormElement | null;
    const renameCategoryIdInput = renameForm?.querySelector<HTMLInputElement>(
      'input[name="categoryId"]'
    );
    const renameNameInput = renameForm?.querySelector<HTMLInputElement>('input[name="name"]');
    const renameSubmitButton = document.getElementById(
      'onboarding-rename-category-submit'
    ) as HTMLButtonElement | null;
    const renameCancelButton = document.getElementById(
      'onboarding-rename-category-cancel'
    ) as HTMLButtonElement | null;
    const renameErrorDiv = document.getElementById('onboarding-rename-category-error');
    const deleteCategoryName = document.getElementById('onboarding-delete-category-name');
    const deleteModalContainer = document.querySelector('[data-onboarding-delete-modal-container]');
    const {
      modal: deleteModal,
      confirmButton: deleteConfirmButton,
      cancelButton: deleteCancelButton,
      errorElement: deleteErrorElement,
    } = deleteModalContainer
      ? getConfirmationModalElements(deleteModalContainer, 'onboarding-category-delete-modal')
      : {
          modal: null,
          confirmButton: null,
          cancelButton: null,
          errorElement: null,
        };

    let pendingDeleteCategory: { id: string; name: string } | null = null;

    if (!form) return;

    function getErrorMessage(payload: unknown, fallback: string): string {
      if (!payload || typeof payload !== 'object') return fallback;
      const maybeError = (payload as { error?: unknown }).error;
      if (typeof maybeError === 'string') return maybeError;
      if (
        maybeError &&
        typeof maybeError === 'object' &&
        typeof (maybeError as { message?: unknown }).message === 'string'
      ) {
        return (maybeError as { message: string }).message;
      }
      return fallback;
    }

    function showCategoryError(message: string) {
      if (!categoryErrorDiv) return;
      categoryErrorDiv.textContent = message;
      categoryErrorDiv.classList.remove('hidden');
    }

    function clearCategoryError() {
      if (!categoryErrorDiv) return;
      categoryErrorDiv.classList.add('hidden');
      categoryErrorDiv.textContent = '';
    }

    function showRenameError(message: string) {
      if (!renameErrorDiv) return;
      renameErrorDiv.textContent = message;
      renameErrorDiv.classList.remove('hidden');
    }

    function clearRenameError() {
      if (!renameErrorDiv) return;
      renameErrorDiv.classList.add('hidden');
      renameErrorDiv.textContent = '';
    }

    function reloadAllocationStep() {
      window.location.href = '/onboarding?reset=allocation';
    }

    addCategoryForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearCategoryError();
      const formData = new FormData(addCategoryForm);
      const name = String(formData.get('name') ?? '').trim();

      if (name.length < 3) {
        showCategoryError('Category name must be at least 3 characters');
        return;
      }

      const btn = addCategoryForm.querySelector(
        'button[type="submit"]'
      ) as HTMLButtonElement | null;
      if (btn) {
        btn.disabled = true;
        btn.classList.add('loading');
      }

      try {
        const res = await csrfFetch('/api/categories', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            type: 'expense',
            icon: 'tag',
            color: 'bg-primary',
          }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(getErrorMessage(data, 'Failed to add category'));
        }

        window.location.href = '/onboarding?reset=allocation';
      } catch (err) {
        showCategoryError(err instanceof Error ? err.message : 'An error occurred');
      } finally {
        if (btn) {
          btn.disabled = false;
          btn.classList.remove('loading');
        }
      }
    });

    renameCancelButton?.addEventListener('click', () => {
      clearRenameError();
      if (renameModal) {
        closeConfirmationModal(renameModal);
      }
    });

    renameModal?.addEventListener('close', () => {
      clearRenameError();
      renameForm?.reset();
      if (renameCategoryIdInput) renameCategoryIdInput.value = '';
    });

    renameForm?.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearCategoryError();
      clearRenameError();

      const categoryId = renameCategoryIdInput?.value.trim() || '';
      const nextName = renameNameInput?.value.trim() || '';

      if (!categoryId) return;
      if (nextName.length < 3) {
        showRenameError('Category name must be at least 3 characters');
        return;
      }

      if (renameSubmitButton) {
        renameSubmitButton.disabled = true;
        renameSubmitButton.classList.add('loading');
      }

      try {
        const res = await csrfFetch(`/api/categories/${categoryId}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name: nextName }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(getErrorMessage(data, 'Failed to rename category'));
        }

        reloadAllocationStep();
      } catch (err) {
        showRenameError(err instanceof Error ? err.message : 'An error occurred');
      } finally {
        if (renameSubmitButton) {
          renameSubmitButton.disabled = false;
          renameSubmitButton.classList.remove('loading');
        }
      }
    });

    deleteCancelButton?.addEventListener('click', () => {
      clearConfirmError(deleteErrorElement);
      closeConfirmationModal(deleteModal);
    });

    deleteModal?.addEventListener('close', () => {
      pendingDeleteCategory = null;
      if (deleteCategoryName) deleteCategoryName.textContent = '';
      clearConfirmError(deleteErrorElement);
      setConfirmLoading(deleteConfirmButton, false);
    });

    deleteConfirmButton?.addEventListener('click', async () => {
      if (!pendingDeleteCategory) return;
      clearCategoryError();
      clearConfirmError(deleteErrorElement);
      setConfirmLoading(deleteConfirmButton, true);

      try {
        const res = await csrfFetch(`/api/categories/${pendingDeleteCategory.id}`, {
          method: 'DELETE',
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(getErrorMessage(data, 'Failed to delete category'));
        }

        reloadAllocationStep();
      } catch (err) {
        showConfirmError(
          deleteErrorElement,
          err instanceof Error ? err.message : 'Failed to delete category'
        );
      } finally {
        setConfirmLoading(deleteConfirmButton, false);
      }
    });

    form.addEventListener('click', (e) => {
      const button = (e.target as HTMLElement).closest<HTMLButtonElement>('[data-category-action]');
      if (!button) return;
      e.preventDefault();
      clearCategoryError();

      const action = button.dataset.categoryAction;
      const categoryId = button.dataset.categoryId;
      const currentName = button.dataset.categoryName ?? 'category';

      if (!categoryId || !action) return;

      if (action === 'rename') {
        if (renameCategoryIdInput) renameCategoryIdInput.value = categoryId;
        if (renameNameInput) {
          renameNameInput.value = currentName;
          queueMicrotask(() => renameNameInput.focus());
        }
        clearRenameError();
        renameModal?.showModal();
        return;
      }

      if (action === 'delete') {
        pendingDeleteCategory = { id: categoryId, name: currentName };
        if (deleteCategoryName) {
          deleteCategoryName.textContent = currentName;
        }
        clearConfirmError(deleteErrorElement);
        deleteModal?.showModal();
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }

      const formData = new FormData(form);
      const rawCurrency = formData.get('currency');
      const currency: Currency =
        typeof rawCurrency === 'string' && isValidCurrency(rawCurrency) ? rawCurrency : 'IDR';
      const now = new Date();
      const month = now.getMonth() + 1;
      const year = now.getFullYear();

      const budgets: Array<{ categoryId: string; amount: string; currency: string }> = [];

      for (const [key, value] of formData.entries()) {
        if (key.startsWith('budget_')) {
          const categoryId = key.replace('budget_', '');
          const amount = stripAmountFormatting(value as string, currency);
          if (amount && parseFloat(amount) > 0) {
            budgets.push({ categoryId, amount, currency });
          }
        }
      }

      if (budgets.length === 0) {
        if (errorDiv) {
          errorDiv.textContent = 'Please allocate at least one category';
          errorDiv.classList.remove('hidden');
        }
        return;
      }

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.classList.add('loading');

      try {
        const res = await csrfFetch('/api/onboarding/budgets', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ budgets, month, year }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(getErrorMessage(data, 'Failed to save budgets'));
        }

        window.location.href = '/onboarding';
      } catch (err) {
        if (errorDiv) {
          errorDiv.textContent = err instanceof Error ? err.message : 'An error occurred';
          errorDiv.classList.remove('hidden');
        }
      } finally {
        btn.disabled = false;
        btn.classList.remove('loading');
      }
    });
  }

  document.addEventListener('astro:page-load', initStepAllocateForm);
</script>
