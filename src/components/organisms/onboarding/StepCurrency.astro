---
/**
 * StepCurrency — Onboarding Step 1
 *
 * Currency selection for the workspace.
 * Primary currency is required, secondary is optional.
 */

import { ArrowRight } from '@lucide/astro';
import { CURRENCY_OPTIONS, CURRENCY_META } from '@/lib/constants/currency';

export interface Props {
  currentCurrency?: string;
  currentSecondaryCurrency?: string;
}

const { currentCurrency, currentSecondaryCurrency } = Astro.props;
---

<div class="space-y-6">
  <p class="max-w-2xl text-base leading-relaxed text-base-content/70">
    Everything in Allowealth is organized by currency. Pick the one you use most, then optionally
    add a secondary currency for cross-currency accounts.
  </p>

  <form id="onboarding-currency-form" class="space-y-5" novalidate>
    <div class="form-control w-full gap-1.5">
      <label class="label px-0" for="primary-currency">
        <span class="label-text font-semibold text-base-content">Primary currency</span>
        <span class="label-text-alt font-medium text-error">Required</span>
      </label>
      <select
        id="primary-currency"
        name="currency"
        class="select select-bordered w-full rounded-lg border border-base-300"
        required
      >
        {
          CURRENCY_OPTIONS.map((opt) => (
            <option value={opt.value} selected={opt.value === currentCurrency}>
              {CURRENCY_META[opt.value].flagEmoji} {opt.label}
            </option>
          ))
        }
      </select>
    </div>

    <div class="rounded-lg border border-base-300 bg-base-200/50 p-3 sm:p-4">
      <label class="label cursor-pointer justify-start gap-3 p-0" for="use-secondary">
        <input
          type="checkbox"
          id="use-secondary"
          class="checkbox checkbox-sm"
          checked={!!currentSecondaryCurrency}
          data-onboarding-secondary-toggle
        />
        <span class="label-text text-sm text-base-content">I also use a second currency</span>
      </label>

      <div
        id="secondary-currency-container"
        class:list={['mt-4 form-control w-full gap-1.5', !currentSecondaryCurrency && 'hidden']}
      >
        <label class="label px-0" for="secondary-currency">
          <span class="label-text font-medium text-base-content">Secondary currency</span>
        </label>
        <select
          id="secondary-currency"
          name="secondaryCurrency"
          class="select select-bordered w-full rounded-lg border border-base-300"
        >
          <option value="">— None —</option>
          {
            CURRENCY_OPTIONS.map((opt) => (
              <option value={opt.value} selected={opt.value === currentSecondaryCurrency}>
                {CURRENCY_META[opt.value].flagEmoji} {opt.label}
              </option>
            ))
          }
        </select>
      </div>
    </div>

    <div
      id="currency-error"
      class="alert alert-error hidden rounded-lg border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
      role="alert"
    >
    </div>

    <div class="flex justify-end pt-2">
      <button type="submit" class="btn btn-accent min-h-[44px] gap-2 rounded-lg px-6 sm:rounded-xl">
        Continue
        <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
      </button>
    </div>
  </form>
</div>

<script>
  import { csrfFetch } from '@/lib/csrf-client';

  function initStepCurrency() {
    const form = document.getElementById('onboarding-currency-form') as HTMLFormElement | null;
    const toggle = document.querySelector(
      '[data-onboarding-secondary-toggle]'
    ) as HTMLInputElement | null;
    const container = document.getElementById('secondary-currency-container');
    const errorDiv = document.getElementById('currency-error');

    if (!form || !toggle || !container) return;

    toggle.addEventListener('change', () => {
      container.classList.toggle('hidden', !toggle.checked);
      if (!toggle.checked) {
        const select = container.querySelector('select') as HTMLSelectElement;
        if (select) select.value = '';
      }
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }

      const formData = new FormData(form);
      const currency = formData.get('currency') as string;
      const secondaryCurrency = toggle.checked ? (formData.get('secondaryCurrency') as string) : '';

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.classList.add('loading');

      try {
        const res = await csrfFetch('/api/workspace/settings', {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ currency, secondaryCurrency: secondaryCurrency || null }),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error?.message || 'Failed to save currency');
        }

        // Navigate to next step (page reload picks up new state)
        window.location.href = '/onboarding';
      } catch (err) {
        if (errorDiv) {
          errorDiv.textContent = err instanceof Error ? err.message : 'An error occurred';
          errorDiv.classList.remove('hidden');
        }
      } finally {
        btn.disabled = false;
        btn.classList.remove('loading');
      }
    });
  }

  document.addEventListener('astro:page-load', initStepCurrency);
</script>
