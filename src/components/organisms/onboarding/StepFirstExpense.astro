---
/**
 * StepFirstExpense — Onboarding Step 5
 *
 * Record your first expense to complete the loop.
 * Shows how budgeting works in action.
 */

import { ArrowLeft, CircleCheckBig } from '@lucide/astro';
import AmountInput from '@/components/atoms/AmountInput.astro';
import type { Currency } from '@/lib/constants/currency';

export interface CategoryOption {
  id: string;
  name: string;
}

export interface AccountOption {
  id: string;
  name: string;
  currency: Currency;
}

export interface Props {
  categories: CategoryOption[];
  accounts: AccountOption[];
  currencies: Currency[];
}

const { categories, accounts, currencies } = Astro.props;
const primaryCurrency = currencies[0];
const today = new Date().toISOString().split('T')[0];

// Default to first account's currency
const defaultAccount = accounts[0];
---

<div class="space-y-6">
  <p class="max-w-2xl text-base leading-relaxed text-base-content/70">
    Record one real expense to close the loop. Any amount works, even a coffee, as long as it
    reflects what you spent today.
  </p>

  <form id="onboarding-expense-form" class="space-y-4" novalidate>
    <div class="rounded-xl border border-base-300 bg-base-200/50 p-4 sm:p-5">
      <div class="form-control gap-1.5">
        <label class="label px-0" for="expense-amount">
          <span class="label-text font-semibold text-base-content">Amount</span>
        </label>
        <AmountInput
          id="expense-amount"
          name="amount"
          currency={defaultAccount?.currency || primaryCurrency}
          required={true}
          placeholder="0"
          className="rounded-lg border border-base-300 input-bordered"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="form-control gap-1.5">
        <label class="label px-0" for="expense-category">
          <span class="label-text font-medium text-base-content">Category</span>
        </label>
        <select
          id="expense-category"
          name="categoryId"
          class="select select-bordered w-full rounded-lg border border-base-300"
          required
        >
          <option value="" disabled selected>Pick a category</option>
          {categories.map((cat) => <option value={cat.id}>{cat.name}</option>)}
        </select>
      </div>

      <div class="form-control gap-1.5">
        <label class="label px-0" for="expense-account">
          <span class="label-text font-medium text-base-content">Account</span>
        </label>
        <select
          id="expense-account"
          name="accountId"
          class="select select-bordered w-full rounded-lg border border-base-300"
          required
        >
          {
            accounts.map((acc) => (
              <option value={acc.id} data-currency={acc.currency}>
                {acc.name} ({acc.currency})
              </option>
            ))
          }
        </select>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-[minmax(0,1fr)_12rem]">
      <div class="form-control gap-1.5">
        <label class="label px-0" for="expense-description">
          <span class="label-text font-medium text-base-content">Description</span>
          <span class="label-text-alt text-base-content/50">Optional</span>
        </label>
        <input
          type="text"
          id="expense-description"
          name="description"
          class="input input-bordered w-full rounded-lg border border-base-300"
          placeholder="e.g., Morning coffee"
        />
      </div>

      <div class="form-control gap-1.5">
        <label class="label px-0" for="expense-date">
          <span class="label-text font-medium text-base-content">Date</span>
        </label>
        <input
          type="date"
          id="expense-date"
          name="transactionDate"
          class="input input-bordered w-full rounded-lg border border-base-300"
          value={today}
          required
        />
      </div>
    </div>

    <div
      id="expense-error"
      class="alert alert-error hidden rounded-lg border border-error/30 bg-error/10 px-3 py-2 text-sm text-error"
      role="alert"
    >
    </div>

    <div class="flex justify-between gap-3 pt-2">
      <a
        href="/onboarding?reset=allocation"
        class="btn btn-ghost min-h-[44px] gap-2 rounded-lg sm:rounded-xl"
      >
        <ArrowLeft size={16} class="stroke-current" aria-hidden="true" />
        Back
      </a>
      <button type="submit" class="btn btn-accent min-h-[44px] gap-2 rounded-lg px-6 sm:rounded-xl">
        Complete setup
        <CircleCheckBig size={16} class="stroke-current" aria-hidden="true" />
      </button>
    </div>
  </form>
</div>

<script>
  import { csrfFetch } from '@/lib/csrf-client';
  import { stripAmountFormatting } from '@/lib/formatting/amount-input';

  function initStepExpense() {
    const form = document.getElementById('onboarding-expense-form') as HTMLFormElement | null;
    const errorDiv = document.getElementById('expense-error');

    if (!form) return;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (errorDiv) {
        errorDiv.classList.add('hidden');
        errorDiv.textContent = '';
      }

      const formData = new FormData(form);
      const rawAmount = formData.get('amount') as string;
      const amount = stripAmountFormatting(rawAmount);
      const categoryId = formData.get('categoryId') as string;
      const accountId = formData.get('accountId') as string;
      const description = (formData.get('description') as string).trim();
      const transactionDate = formData.get('transactionDate') as string;

      // Get currency from the selected account option
      const accountSelect = document.getElementById('expense-account') as HTMLSelectElement;
      const selectedOption = accountSelect.selectedOptions[0];
      const currency = selectedOption?.dataset.currency || '';

      if (!amount || parseFloat(amount) <= 0) {
        if (errorDiv) {
          errorDiv.textContent = 'Please enter an amount';
          errorDiv.classList.remove('hidden');
        }
        return;
      }

      if (!categoryId) {
        if (errorDiv) {
          errorDiv.textContent = 'Please select a category';
          errorDiv.classList.remove('hidden');
        }
        return;
      }

      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      btn.disabled = true;
      btn.classList.add('loading');

      try {
        const res = await csrfFetch('/api/transactions', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            type: 'expense',
            amount,
            currency,
            category_id: categoryId,
            account_id: accountId,
            description: description || undefined,
            transaction_date: transactionDate,
          }),
        });

        if (!res.ok) {
          const data = await res.json();
          throw new Error(data.error || 'Failed to record expense');
        }

        // Onboarding complete! Go to dashboard
        window.location.href = '/dashboard';
      } catch (err) {
        if (errorDiv) {
          errorDiv.textContent = err instanceof Error ? err.message : 'An error occurred';
          errorDiv.classList.remove('hidden');
        }
      } finally {
        btn.disabled = false;
        btn.classList.remove('loading');
      }
    });
  }

  document.addEventListener('astro:page-load', initStepExpense);
</script>
