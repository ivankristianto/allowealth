---
import Drawer from '@/components/molecules/Drawer.astro';
import AmountInput from '@/components/atoms/AmountInput.astro';
import { CircleMinus, CirclePlus, CalendarClock, ChevronDown } from '@lucide/astro';
import type { Currency } from '@/lib/constants/currency';
import { isValidCurrency } from '@/lib/constants/currency';

interface CategoryOption {
  id: string;
  name: string;
  type: string;
}

interface AccountOption {
  id: string;
  name: string;
  type: string;
}

export interface Props {
  categories: CategoryOption[];
  accounts: AccountOption[];
  currencies?: string[];
}

const { categories = [], accounts = [], currencies = ['IDR'] } = Astro.props;
const defaultCurrency: Currency = isValidCurrency(currencies[0]) ? currencies[0] : 'IDR';
---

<Drawer id="recurring-template-drawer" title="New Recurring" width="w-full sm:max-w-md">
  <form id="recurring-template-form" class="flex flex-col gap-4 pb-20 sm:pb-4" novalidate>
    <input type="hidden" name="template_id" />

    <p class="text-sm font-medium text-base-content/60" data-drawer-subtitle>
      Set up an automatic bill or income.
    </p>

    <div role="alert" class="alert alert-error hidden rounded-xl text-sm" data-template-form-error>
    </div>

    <label class="form-control gap-1.5">
      <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50">Name</span>
      <input
        name="name"
        class="input input-bordered h-11 rounded-lg border border-base-300 bg-base-100 text-sm font-medium"
        required
        maxlength="200"
        placeholder="e.g., Rent, Netflix, Salary"
      />
    </label>

    <div
      class="grid grid-cols-2 gap-1 rounded-lg bg-base-200 p-1"
      role="radiogroup"
      aria-label="Recurring type"
      data-recurring-type-segmented
    >
      <label
        class="btn btn-sm h-9 cursor-pointer rounded-md border-none bg-white text-primary shadow-sm transition-all hover:bg-white"
        data-type-option="expense"
      >
        <input type="radio" class="sr-only" name="type" value="expense" checked />
        <CircleMinus size={15} class="stroke-current text-error" aria-hidden="true" />
        <span class="text-xs font-bold">Expense</span>
      </label>

      <label
        class="btn btn-sm h-9 cursor-pointer rounded-md border-none bg-transparent text-base-content/70 font-medium transition-all hover:bg-base-300"
        data-type-option="income"
      >
        <input type="radio" class="sr-only" name="type" value="income" />
        <CirclePlus size={15} class="stroke-current text-success" aria-hidden="true" />
        <span class="text-xs font-semibold">Income</span>
      </label>
    </div>

    <div class="space-y-3" data-recurring-schedule-block>
      <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50"
        >Schedule</span
      >
      <div class="flex flex-wrap gap-1.5" data-frequency-presets>
        <button
          type="button"
          class="btn btn-sm min-h-11 rounded-lg sm:rounded-xl"
          data-frequency-preset="weekly-1">Weekly</button
        >
        <button
          type="button"
          class="btn btn-sm min-h-11 rounded-lg sm:rounded-xl btn-active btn-accent"
          data-frequency-preset="monthly-1">Monthly</button
        >
        <button
          type="button"
          class="btn btn-sm min-h-11 rounded-lg sm:rounded-xl"
          data-frequency-preset="monthly-3">Quarterly</button
        >
        <button
          type="button"
          class="btn btn-sm min-h-11 rounded-lg sm:rounded-xl"
          data-frequency-preset="monthly-6">Semi-annual</button
        >
        <button
          type="button"
          class="btn btn-sm min-h-11 rounded-lg sm:rounded-xl"
          data-frequency-preset="monthly-12">Annual</button
        >
      </div>
      <div class="grid grid-cols-[1fr_auto_auto] items-end gap-2">
        <div class="form-control">
          <select
            name="frequency"
            aria-label="Frequency"
            class="select select-bordered select-sm h-9 rounded-lg border border-base-300 bg-base-100 text-sm font-medium"
          >
            <option value="monthly" selected>Monthly</option>
            <option value="weekly">Weekly</option>
          </select>
        </div>
        <label class="form-control gap-1">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/40"
            >Every</span
          >
          <input
            type="number"
            name="interval_count"
            min="1"
            max="52"
            value="1"
            class="input input-bordered input-sm h-9 w-16 rounded-lg border border-base-300 bg-base-100 text-center text-sm font-medium"
          />
        </label>
        <span
          class="flex h-9 items-center text-sm font-medium text-base-content/60"
          data-frequency-unit-label>month(s)</span
        >
      </div>
    </div>

    <div class="rounded-lg border border-base-300 bg-base-100 p-3" data-recurring-amount-field>
      <div class="grid grid-cols-[1fr_auto] items-end gap-3">
        <label class="form-control gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50"
            >Amount</span
          >
          <AmountInput
            id="recurring-template-amount"
            name="amount"
            currency={defaultCurrency}
            className="input-bordered h-16 rounded-lg border border-base-300 bg-base-100 text-center text-3xl font-bold tracking-tight placeholder:text-base-content/20"
            required
            placeholder="0"
          />
        </label>

        <label class="form-control min-w-[7.5rem] gap-1.5">
          <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50"
            >Currency</span
          >
          <select
            name="currency"
            class="select select-bordered h-10 rounded-lg border border-base-300 bg-base-100 text-sm font-medium"
            required
          >
            {currencies.map((currency) => <option value={currency}>{currency}</option>)}
          </select>
        </label>
      </div>
    </div>

    <div class="form-control" data-recurring-category-block>
      <label
        for="recurring-template-category"
        class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-base-content/50"
      >
        Category
      </label>
      <select
        id="recurring-template-category"
        name="category_id"
        class="select select-bordered h-10 w-full rounded-lg border border-base-300 bg-base-100 text-sm font-medium focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30"
        required
      >
        <option value="">Select category</option>
        {
          categories.map((category) => (
            <option value={category.id} data-type={category.type}>
              {category.name}
            </option>
          ))
        }
      </select>
    </div>

    <div class="form-control" data-recurring-account-block>
      <label
        for="recurring-template-account"
        class="mb-1.5 text-xs font-semibold uppercase tracking-wider text-base-content/50"
      >
        Account
      </label>
      <select
        id="recurring-template-account"
        name="account_id"
        class="select select-bordered h-10 w-full rounded-lg border border-base-300 bg-base-100 text-sm font-medium focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30"
        required
      >
        <option value="">Select account</option>
        {accounts.map((account) => <option value={account.id}>{account.name}</option>)}
      </select>
    </div>

    <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
      <label class="form-control gap-1.5" data-recurring-day-of-month-block>
        <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50"
          >Day of month</span
        >
        <select
          name="day_of_month"
          class="select select-bordered h-10 rounded-lg border border-base-300 bg-base-100 text-sm font-medium focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30"
          required
        >
          {
            Array.from({ length: 31 }).map((_, index) => (
              <option value={index + 1}>{index + 1}</option>
            ))
          }
        </select>
      </label>

      <label class="form-control gap-1.5" data-recurring-start-month-block>
        <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50"
          >Start month</span
        >
        <div class="relative">
          <input
            type="month"
            name="start_month"
            class="input input-bordered h-10 w-full rounded-lg border border-base-300 bg-base-100 pr-10 text-sm font-medium focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30"
            required
          />
          <CalendarClock
            size={16}
            class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-base-content/40"
            aria-hidden="true"
          />
        </div>
      </label>

      <label class="form-control hidden gap-1.5" data-recurring-start-date-block>
        <span class="text-xs font-semibold uppercase tracking-wider text-base-content/50"
          >Start date</span
        >
        <div class="relative">
          <input
            type="date"
            name="start_date_input"
            class="input input-bordered h-10 w-full rounded-lg border border-base-300 bg-base-100 pr-10 text-sm font-medium focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30"
          />
          <CalendarClock
            size={16}
            class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-base-content/40"
            aria-hidden="true"
          />
        </div>
      </label>
    </div>

    <section
      class="space-y-3 rounded-lg border border-base-300 bg-base-100 p-3.5"
      data-recurring-rules-card
    >
      <div>
        <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50">
          Schedule rules
        </p>
        <p class="mt-1 text-xs text-base-content/60">
          Set when this recurring ends and whether it should be tracked as an installment.
        </p>
      </div>

      <div
        class="space-y-3 rounded-lg border border-base-300 bg-base-100 p-3"
        data-recurring-end-group
      >
        <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50">End</p>

        <label class="label cursor-pointer justify-start gap-2.5 rounded-lg px-2 py-1.5">
          <input
            type="radio"
            class="radio radio-sm radio-accent"
            name="end_mode"
            value="none"
            data-end-mode="none"
            checked
          />
          <span class="label-text font-semibold">No end</span>
        </label>

        <label class="label cursor-pointer justify-start gap-2.5 rounded-lg px-2 py-1.5">
          <input
            type="radio"
            class="radio radio-sm radio-accent"
            name="end_mode"
            value="count"
            data-end-mode="count"
          />
          <span class="label-text font-semibold">End by count</span>
        </label>

        <div class="hidden pl-8" data-end-input="count">
          <input
            type="number"
            min="1"
            name="total_occurrences"
            class="input input-bordered h-11 w-full rounded-xl"
            placeholder="Total occurrences"
          />
        </div>

        <label class="label cursor-pointer justify-start gap-2.5 rounded-lg px-2 py-1.5">
          <input
            type="radio"
            class="radio radio-sm radio-accent"
            name="end_mode"
            value="date"
            data-end-mode="date"
          />
          <span class="label-text font-semibold">End by date</span>
        </label>

        <div class="hidden pl-8" data-end-input="date">
          <input type="date" name="end_date" class="input input-bordered h-11 w-full rounded-xl" />
        </div>

        <p class="text-xs font-medium text-base-content/60" data-end-validation-hint>
          Leave this on No end for ongoing bills, subscriptions, or salary.
        </p>
      </div>

      <div
        class="space-y-3 rounded-lg border border-base-300 bg-base-100 p-3"
        data-recurring-installment-group
      >
        <p class="text-xs font-semibold uppercase tracking-wider text-base-content/50">
          Installment
        </p>

        <label class="label cursor-pointer justify-start gap-2.5 rounded-lg px-2 py-1.5">
          <input
            type="checkbox"
            class="checkbox checkbox-sm checkbox-accent rounded-lg"
            name="is_installment"
            data-installment-toggle
            disabled
          />
          <span class="label-text font-semibold">Treat as installment</span>
        </label>

        <p class="pl-8 text-xs text-base-content/60">
          Best for loans or device payments with a known total number of cycles.
        </p>
        <p class="pl-8 text-xs text-base-content/55" data-installment-disabled-hint>
          Choose End by count and set occurrences to unlock installment mode.
        </p>

        <div class="hidden space-y-3 pl-8 pt-1" data-installment-fields>
          <label class="form-control gap-1.5">
            <span
              class="label-text text-xs font-semibold uppercase tracking-wider text-base-content/60"
              >Starting occurrence number</span
            >
            <input
              type="number"
              min="1"
              name="starting_occurrence_number"
              value="1"
              class="input input-bordered h-10 rounded-lg border border-base-300 bg-base-100 text-sm font-medium"
            />
          </label>

          <label class="form-control gap-1.5">
            <span
              class="label-text text-xs font-semibold uppercase tracking-wider text-base-content/60"
              >Installment label</span
            >
            <input
              name="installment_label"
              class="input input-bordered h-10 rounded-lg border border-base-300 bg-base-100 text-sm font-medium"
              maxlength="100"
              placeholder="Installment"
            />
          </label>
        </div>
      </div>
    </section>

    <details
      class="group rounded-lg border border-base-300 bg-base-100 p-3.5"
      data-recurring-description-details
    >
      <summary
        class="flex cursor-pointer list-none items-center justify-between text-sm font-semibold text-base-content/80"
        data-recurring-description-summary
      >
        <span>Description (optional)</span>
        <ChevronDown
          size={16}
          class="transition-transform group-open:rotate-180"
          aria-hidden="true"
        />
      </summary>
      <p class="pt-1 text-xs text-base-content/55">
        Add context for future edits, receipts, or reminders.
      </p>
      <div class="pt-2.5">
        <textarea
          name="description"
          class="textarea textarea-bordered min-h-24 w-full rounded-lg border border-base-300 bg-base-100 text-sm"
          maxlength="500"></textarea>
      </div>
    </details>

    <div
      class="-mx-1 mt-1 border-t border-base-200 bg-base-100 px-1 pb-1 pt-4 sm:sticky sm:bottom-0 sm:z-10"
      data-recurring-actions
    >
      <div class="flex gap-3">
        <button
          type="button"
          class="btn btn-ghost h-12 flex-1 rounded-lg text-sm font-bold sm:rounded-xl"
          data-template-form-cancel
        >
          Cancel
        </button>
        <button
          type="submit"
          class="btn btn-accent h-12 flex-[1.6] rounded-lg text-sm font-bold sm:rounded-xl"
          data-template-form-submit
          data-default-label="Save recurring"
        >
          Save recurring
        </button>
      </div>
    </div>
  </form>
</Drawer>

<script>
  import './RecurringTemplateForm.client';
</script>
