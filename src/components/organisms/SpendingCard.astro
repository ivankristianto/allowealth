---
/**
 * SpendingCard Component
 *
 * Monthly spending overview card with progress bar, income, and net savings.
 * Follows Oasis Finance v1.0.0 design system specifications.
 *
 * @param {number} spent - Amount spent (expenses)
 * @param {number} budget - Total budget amount
 * @param {number} income - Monthly income amount
 * @param {string} currency - Currency code (IDR or USD)
 * @param {string} remainingLabel - Label for remaining amount (e.g., "Remaining for Jan")
 * @param {string} alertMessage - Optional alert message to display
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} error - Error message to display
 * @param {string} className - Additional CSS classes
 */

import { Scale } from '@lucide/astro';
import {
  formatCurrency,
  getBudgetStatusClass,
  getStatusBadgeClasses,
  type BudgetStatusClassName,
} from '@/lib/tokens';
import ProgressBar from '@/components/atoms/ProgressBar.astro';
import IconBadge from '@/components/atoms/IconBadge.astro';
import StatLabel from '@/components/atoms/StatLabel.astro';
import BudgetAlertBanner from '@/components/molecules/BudgetAlertBanner.astro';
import Card from '@/components/atoms/Card.astro';

export interface Props {
  spent: number;
  budget: number;
  income?: number;
  currency?: 'IDR' | 'USD';
  remainingLabel?: string;
  alertMessage?: string;
  loading?: boolean;
  error?: string;
  className?: string;
}

const {
  spent: rawSpent,
  budget: rawBudget,
  income: rawIncome = 0,
  currency = 'IDR',
  remainingLabel = 'Budget Remaining',
  alertMessage,
  loading = false,
  error,
  className = '',
} = Astro.props;

// Validate numeric inputs to prevent NaN propagation
const spent = Number.isFinite(rawSpent) ? rawSpent : 0;
const budget = Number.isFinite(rawBudget) ? rawBudget : 0;
const income = Number.isFinite(rawIncome) ? rawIncome : 0;

// Calculate percentage and remaining
const percentage = budget > 0 ? (spent / budget) * 100 : 0;
const percentageRounded = Math.round(percentage);
const remaining = budget - spent;
const status = getBudgetStatusClass(percentage);

// Calculate net savings
const netSavings = income - spent;
const savingsPercentage = income > 0 ? (netSavings / income) * 100 : 0;

// Map status class to progress bar status
const getProgressBarStatus = (statusClass: BudgetStatusClassName): 'ok' | 'warning' | 'danger' => {
  if (statusClass === 'status-ok') return 'ok';
  if (statusClass === 'status-warning') return 'warning';
  return 'danger';
};

// Map status class to IconBadge variant
const getIconBadgeVariant = (
  statusClass: BudgetStatusClassName
): 'success' | 'warning' | 'error' => {
  if (statusClass === 'status-ok') return 'success';
  if (statusClass === 'status-warning') return 'warning';
  return 'error';
};

const progressBarStatus = getProgressBarStatus(status);
const iconBadgeVariant = getIconBadgeVariant(status);

const spentFormatted = formatCurrency(spent, currency);
const budgetFormatted = formatCurrency(budget, currency, true);
const remainingFormatted = formatCurrency(remaining, currency);
const incomeFormatted = formatCurrency(income, currency);
const netSavingsFormatted = formatCurrency(Math.abs(netSavings), currency);

// Generate unique ID to prevent conflicts when multiple SpendingCards on same page
const uniqueId = `spending-card-${Math.random().toString(36).slice(2, 11)}`;
---

<Card
  padding="lg"
  rounded="card-lg"
  className={className}
  role="status"
  aria-live="polite"
  aria-busy={loading}
  aria-label={loading ? 'Loading spending data...' : undefined}
  aria-labelledby={!loading && !error ? uniqueId : undefined}
  data-testid="dashboard-spending-card"
>
  <div class="flex flex-col gap-6">
    {/* Loading State */}
    {
      loading ? (
        <div aria-hidden="true">
          <div class="flex justify-between items-start">
            <div class="flex items-center gap-4">
              <div class="w-12 h-12 bg-base-300 rounded-2xl animate-pulse" />
              <div class="space-y-3">
                <div class="h-3 bg-base-300 rounded w-24 animate-pulse" />
                <div class="h-8 bg-base-300 rounded w-48 animate-pulse" />
              </div>
            </div>
            <div class="h-6 bg-base-300 rounded w-16 animate-pulse" />
          </div>

          {/* Progress bar skeleton */}
          <div class="space-y-2 mt-6">
            <div class="h-3 bg-base-300 rounded-full animate-pulse" />
            <div class="flex justify-between">
              <div class="h-4 bg-base-300 rounded w-28 animate-pulse" />
              <div class="h-4 bg-base-300 rounded w-10 animate-pulse" />
            </div>
          </div>

          <div class="h-4 bg-base-300 rounded w-40 animate-pulse mt-6" />

          {/* Income/Savings skeleton */}
          <div class="border-t border-base-300 pt-4 mt-6">
            <div class="grid grid-cols-2 gap-4">
              <div class="space-y-2">
                <div class="h-3 bg-base-300 rounded w-14 animate-pulse" />
                <div class="h-6 bg-base-300 rounded w-24 animate-pulse" />
              </div>
              <div class="space-y-2">
                <div class="h-3 bg-base-300 rounded w-20 animate-pulse" />
                <div class="h-6 bg-base-300 rounded w-28 animate-pulse" />
              </div>
            </div>
          </div>
        </div>
      ) : error ? (
        /* Error State */
        <div class="p-6 text-center">
          <p class="text-error font-medium">{error}</p>
        </div>
      ) : (
        /* Normal State */
        <>
          {/* Header: Responsive layout - stacks on mobile */}
          <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-3 sm:gap-4">
            <div class="flex items-center gap-3 sm:gap-4">
              <IconBadge variant={iconBadgeVariant} size="md">
                <Scale size={24} class="stroke-current" aria-hidden="true" />
              </IconBadge>
              <div class="min-w-0">
                <StatLabel size="md" color="neutral">
                  MONTHLY EXPENSES
                </StatLabel>
                <h3
                  id={uniqueId}
                  class="text-2xl sm:text-3xl font-bold mt-1.5 tracking-tight leading-none"
                  data-testid="dashboard-total-expenses"
                >
                  {spentFormatted}
                  <span class="text-sm sm:text-base text-base-content/60 font-medium tracking-normal">
                    / {budgetFormatted}
                  </span>
                </h3>
              </div>
            </div>

            <span class={`shrink-0 ${getStatusBadgeClasses(status)}`}>
              {percentageRounded}% used
            </span>
          </div>

          {/* Progress Bar with Monthly Allocation label */}
          <div class="space-y-2">
            <ProgressBar value={percentage} status={progressBarStatus} size="md" />
            <div class="flex justify-between items-center text-sm">
              <span class="text-base-content/60">Monthly Allocation</span>
              <span class="font-semibold text-base-content">{percentageRounded}%</span>
            </div>
          </div>

          <p class="text-base font-medium text-base-content/60">
            {remainingLabel}: <span class="font-bold text-base-content">{remainingFormatted}</span>
          </p>

          {alertMessage && (
            <BudgetAlertBanner
              title="Budget alert"
              message={alertMessage}
              variant={status === 'status-danger' ? 'error' : 'warning'}
            />
          )}

          {/* Income and Net Savings Section - Always at bottom */}
          <div class="border-t border-base-300 pt-4 mt-2">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <StatLabel size="sm" color="neutral">
                  INCOME
                </StatLabel>
                <p class="text-lg font-bold text-success mt-1" data-testid="dashboard-total-income">
                  {incomeFormatted}
                </p>
              </div>
              <div>
                <StatLabel size="sm" color="neutral">
                  NET SAVINGS
                </StatLabel>
                <p
                  class:list={[
                    'text-lg font-bold mt-1',
                    netSavings >= 0 ? 'text-success' : 'text-error',
                  ]}
                >
                  {netSavings < 0 ? '-' : ''}
                  {netSavingsFormatted}
                  <span class="text-xs font-medium text-base-content/60 ml-1">
                    ({netSavings >= 0 ? '+' : ''}
                    {Math.round(savingsPercentage)}%)
                  </span>
                </p>
              </div>
            </div>
          </div>
        </>
      )
    }
  </div>
</Card>
