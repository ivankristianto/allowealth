---
/**
 * AssetPortfolioSummary Component
 *
 * Portfolio overview split into independent visual sections:
 * 1. Metric cards grid (Assets, Debt, Net Worth) — each its own card
 * 2. Asset allocation card (stacked bar + legend) — separate card
 *
 * This avoids the visual tension of line dividers inside rounded cards.
 *
 * @param {number} totalIdr - Total asset value in IDR
 * @param {number} totalUsd - Total asset value in USD
 * @param {number} debtIdr - Total debt value in IDR
 * @param {number} debtUsd - Total debt value in USD
 * @param {Array} distribution - Asset type distribution for allocation chart
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} className - Additional CSS classes
 */

// External packages
import { Wallet, CreditCard, TrendingUp, Clock, Info } from '@lucide/astro';

// Internal aliases - lib
import { formatCurrency } from '@/lib/formatting';
import { sanitizeColor } from '@/lib/utils/budget';

// Internal aliases - components
import Skeleton from '@components/atoms/Skeleton.astro';
import AllocationBar from '@components/molecules/AllocationBar.astro';

export interface AllocationItem {
  type: string;
  percentage: number;
  color: string;
}

const MAX_LEGEND_ITEMS = 7;
const OTHERS_COLOR = '#9ca3af';

export interface Props {
  totalIdr: number;
  totalUsd: number;
  debtIdr?: number;
  debtUsd?: number;
  distribution: AllocationItem[];
  loading?: boolean;
  className?: string;
  latestUpdate?: Date | string | null;
  isHistoricalView?: boolean;
}

const {
  totalIdr,
  totalUsd,
  debtIdr = 0,
  debtUsd = 0,
  distribution,
  loading = false,
  className = '',
  latestUpdate,
  isHistoricalView = false,
} = Astro.props;

// Calculate net worth (assets - debt)
const netWorthIdr = totalIdr - debtIdr;
const netWorthUsd = totalUsd - debtUsd;
const hasDebt = debtIdr > 0 || debtUsd > 0;
const hasIdr = totalIdr > 0 || debtIdr > 0;
const hasUsd = totalUsd > 0 || debtUsd > 0;

// Format the latest update date if provided
const formattedLatestUpdate = latestUpdate
  ? new Date(latestUpdate).toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    })
  : null;

// Sort distribution by percentage (largest first)
const sortedDistribution = [...distribution].sort((a, b) => b.percentage - a.percentage);

// Take top N for legend display, combine rest as "Others"
const topTypes = sortedDistribution.slice(0, MAX_LEGEND_ITEMS);
const remainingTypes = sortedDistribution.slice(MAX_LEGEND_ITEMS);
const othersPercentage = remainingTypes.reduce((sum, item) => sum + item.percentage, 0);

const displayDistribution: AllocationItem[] =
  othersPercentage > 0
    ? [...topTypes, { type: 'Others', percentage: othersPercentage, color: OTHERS_COLOR }]
    : topTypes;

// Generate accessible description for screen readers
const allocationDescription = sortedDistribution
  .map((item) => `${item.type} ${item.percentage}%`)
  .join(', ');

// Badge class string
const badge =
  'inline-flex items-center px-1.5 py-0.5 rounded text-xs font-bold uppercase tracking-wider shrink-0';

// Determine grid columns: 2 if no debt, 3 if debt exists
const gridCols = hasDebt ? 'md:grid-cols-3' : 'md:grid-cols-2';

// Individual metric card classes
const metricCard =
  'bg-base-100 border border-base-300 rounded-card shadow-sm px-5 py-4 relative overflow-hidden';

// Allocation card classes
const allocationCard = 'bg-base-100 border border-base-300 rounded-card shadow-sm p-5 lg:p-6';

const wrapperClasses = ['space-y-4', className].filter(Boolean).join(' ');
---

{
  loading ? (
    <div class={wrapperClasses} aria-busy="true" aria-label="Loading portfolio summary">
      {/* Metric Cards Skeleton */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {Array(3)
          .fill(0)
          .map(() => (
            <div class={metricCard}>
              <div class="space-y-3">
                <Skeleton variant="text" width="100px" height="12px" />
                <Skeleton variant="text" width="100%" height="24px" />
                <Skeleton variant="text" width="80%" height="24px" />
              </div>
            </div>
          ))}
      </div>

      {/* Allocation Card Skeleton */}
      <div class={allocationCard}>
        <div class="space-y-4">
          <Skeleton variant="text" width="140px" height="16px" />
          <Skeleton variant="rectangular" width="100%" height="20px" className="rounded-full" />
          <div class="grid grid-cols-2 gap-2">
            {Array(4)
              .fill(0)
              .map(() => (
                <div class="flex items-center gap-2">
                  <Skeleton variant="circular" width="10px" height="10px" />
                  <Skeleton variant="text" width="80px" height="12px" />
                </div>
              ))}
          </div>
        </div>
      </div>
    </div>
  ) : (
    <div
      class={wrapperClasses}
      aria-label="Portfolio overview summary"
      data-testid="portfolio-total"
    >
      {/* Metric Cards Grid */}
      <div class={`grid grid-cols-1 ${gridCols} gap-4`}>
        {/* Total Assets */}
        <div
          class={`${metricCard} border-l-3 border-l-success`}
          data-testid="portfolio-total-assets"
        >
          <div class="flex items-center gap-2 mb-3">
            <Wallet size={16} class="stroke-current text-success" aria-hidden="true" />
            <span class="text-xs font-semibold uppercase tracking-widest text-base-content/50">
              Total Assets
            </span>
          </div>
          <div class="space-y-1.5">
            {totalIdr > 0 && (
              <div class="flex items-center gap-2">
                <span class={`${badge} bg-success/10 text-success`}>IDR</span>
                <p class="text-lg font-bold text-success tracking-tight leading-none truncate">
                  {formatCurrency(totalIdr, 'IDR')}
                </p>
              </div>
            )}
            {totalUsd > 0 && (
              <div class="flex items-center gap-2">
                <span class={`${badge} bg-info/10 text-info`}>USD</span>
                <p class="text-lg font-bold text-info tracking-tight leading-none truncate">
                  {formatCurrency(totalUsd, 'USD')}
                </p>
              </div>
            )}
          </div>
        </div>

        {/* Total Debt */}
        {hasDebt && (
          <div class={`${metricCard} border-l-3 border-l-error`} data-testid="portfolio-total-debt">
            <div class="flex items-center gap-2 mb-3">
              <CreditCard size={16} class="stroke-current text-error" aria-hidden="true" />
              <span class="text-xs font-semibold uppercase tracking-widest text-base-content/50">
                Total Debt
              </span>
            </div>
            <div class="space-y-1.5">
              {debtIdr > 0 && (
                <div class="flex items-center gap-2">
                  <span class={`${badge} bg-success/10 text-success`}>IDR</span>
                  <p class="text-lg font-bold text-error tracking-tight leading-none truncate">
                    {formatCurrency(debtIdr, 'IDR')}
                  </p>
                </div>
              )}
              {debtUsd > 0 && (
                <div class="flex items-center gap-2">
                  <span class={`${badge} bg-info/10 text-info`}>USD</span>
                  <p class="text-lg font-bold text-error tracking-tight leading-none truncate">
                    {formatCurrency(debtUsd, 'USD')}
                  </p>
                </div>
              )}
            </div>
          </div>
        )}

        {/* Net Worth */}
        <div class={`${metricCard} border-l-3 border-l-accent`} data-testid="portfolio-net-worth">
          <div class="flex items-center gap-2 mb-3">
            <TrendingUp size={16} class="stroke-current text-accent" aria-hidden="true" />
            <span class="text-xs font-semibold uppercase tracking-widest text-base-content/50">
              Net Worth
            </span>
            <div
              class="tooltip tooltip-bottom"
              data-tip="Total assets minus total debt. Positive means assets exceed liabilities."
            >
              <button
                type="button"
                class="inline-flex items-center justify-center rounded-full text-base-content/30 hover:text-base-content/60 transition-colors"
                aria-label="What is net worth? Total assets minus total debt."
              >
                <Info size={14} class="stroke-current" aria-hidden="true" />
              </button>
            </div>
          </div>
          <div class="space-y-1.5">
            {hasIdr && (
              <div class="flex items-center gap-2">
                <span class={`${badge} bg-success/10 text-success`}>IDR</span>
                <p
                  class={`text-lg font-bold tracking-tight leading-none truncate ${netWorthIdr >= 0 ? 'text-accent' : 'text-error'}`}
                >
                  {formatCurrency(netWorthIdr, 'IDR')}
                </p>
              </div>
            )}
            {hasUsd && (
              <div class="flex items-center gap-2">
                <span class={`${badge} bg-info/10 text-info`}>USD</span>
                <p
                  class={`text-lg font-bold tracking-tight leading-none truncate ${netWorthUsd >= 0 ? 'text-accent' : 'text-error'}`}
                >
                  {formatCurrency(netWorthUsd, 'USD')}
                </p>
              </div>
            )}
          </div>
        </div>
      </div>

      {/* Latest Update — floating metadata between sections */}
      {formattedLatestUpdate && (
        <div class="flex items-center gap-2 text-xs text-base-content/40 font-medium px-1">
          <Clock size={12} class="stroke-current shrink-0" aria-hidden="true" />
          <span>
            {isHistoricalView ? 'Latest update in this period' : 'Latest update'}:{' '}
            {formattedLatestUpdate}
          </span>
        </div>
      )}

      {/* Asset Allocation Card */}
      {displayDistribution.length > 0 && (
        <div class={allocationCard}>
          <h3 class="font-bold text-sm uppercase tracking-wider text-base-content mb-4">
            Asset Allocation
          </h3>

          {/* Allocation Bar */}
          <AllocationBar
            segments={displayDistribution.map((item) => ({
              label: item.type,
              percentage: item.percentage,
              color: item.color,
            }))}
            height="md"
            ariaLabel={`Asset allocation: ${allocationDescription}`}
          />

          {/* Legend */}
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-4 gap-y-2 mt-4">
            {displayDistribution.map((item) => {
              const safeColor = sanitizeColor(item.color);
              return (
                <div class="flex items-center gap-2 py-0.5">
                  <div
                    class="w-2.5 h-2.5 rounded-full shrink-0"
                    style={`background-color: ${safeColor};`}
                    aria-hidden="true"
                  />
                  <span class="text-xs text-base-content/60 font-medium truncate">{item.type}</span>
                  <span class="text-xs font-bold text-base-content tabular-nums ml-auto shrink-0">
                    {item.percentage}%
                  </span>
                </div>
              );
            })}
          </div>

          {/* Screen Reader Data Table */}
          <table class="sr-only" aria-label="Asset allocation data">
            <thead>
              <tr>
                <th>Type</th>
                <th>Percentage</th>
              </tr>
            </thead>
            <tbody>
              {displayDistribution.map((item) => (
                <tr>
                  <td>{item.type}</td>
                  <td>{item.percentage}%</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  )
}
