---
/**
 * AssetPortfolioSummary Component
 *
 * Overview section showing total portfolio value in both currencies
 * and asset allocation distribution bar.
 *
 * Part of the Global Portfolio page redesign.
 *
 * @param {number} totalIdr - Total value in IDR
 * @param {number} totalUsd - Total value in USD
 * @param {Array} distribution - Asset type distribution for allocation bar
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} className - Additional CSS classes
 */

// External packages
import { Wallet, Globe } from '@lucide/astro';

// Internal aliases - lib
import { formatCurrency } from '@/lib/formatting';
import { sanitizeColor } from '@/lib/utils/budget';

// Internal aliases - components
import StatLabel from '@components/atoms/StatLabel.astro';
import Skeleton from '@components/atoms/Skeleton.astro';

// P2: TODO - Consider importing AssetAllocationDistribution type from asset utils
export interface AllocationItem {
  type: string;
  percentage: number;
  color: string;
}

// Maximum number of individual asset types to show before grouping the rest as "Others"
const MAX_LEGEND_ITEMS = 7;
const OTHERS_COLOR = '#9ca3af'; // gray-400 for "Others" category

export interface Props {
  totalIdr: number;
  totalUsd: number;
  distribution: AllocationItem[];
  loading?: boolean;
  className?: string;
}

const { totalIdr, totalUsd, distribution, loading = false, className = '' } = Astro.props;

// Sort distribution by percentage (largest first)
const sortedDistribution = [...distribution].sort((a, b) => b.percentage - a.percentage);

// Take top N for legend display, combine rest as "Others"
const topTypes = sortedDistribution.slice(0, MAX_LEGEND_ITEMS);
const remainingTypes = sortedDistribution.slice(MAX_LEGEND_ITEMS);
const othersPercentage = remainingTypes.reduce((sum, item) => sum + item.percentage, 0);

// Build display distribution with "Others" if there are remaining types
const displayDistribution: AllocationItem[] =
  othersPercentage > 0
    ? [...topTypes, { type: 'Others', percentage: othersPercentage, color: OTHERS_COLOR }]
    : topTypes;

// Generate accessible description for screen readers (P1: Accessibility)
const allocationDescription = sortedDistribution
  .map((item) => `${item.type} ${item.percentage}%`)
  .join(', ');

const cardClasses = [
  // Base card styling
  'bg-base-100 rounded-card border border-base-300',
  // Premium shadow
  'shadow-sm',
  // Padding - responsive
  'p-6 lg:p-10',
  // Relative for overflow
  'relative overflow-hidden',
  // Additional classes
  className,
]
  .filter(Boolean)
  .join(' ');
---

{
  loading ? (
    <section class={cardClasses} aria-busy="true" aria-label="Loading portfolio summary">
      <div class="space-y-8">
        {/* Total Values Skeleton */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
          <div class="flex items-center justify-between">
            <div>
              <Skeleton variant="text" width="100px" height="12px" />
              <Skeleton variant="text" width="200px" height="36px" className="mt-3" />
            </div>
            <Skeleton variant="rectangular" width="56px" height="56px" className="rounded-2xl" />
          </div>
          <div class="flex items-center justify-between">
            <div>
              <Skeleton variant="text" width="100px" height="12px" />
              <Skeleton variant="text" width="160px" height="36px" className="mt-3" />
            </div>
            <Skeleton variant="rectangular" width="56px" height="56px" className="rounded-2xl" />
          </div>
        </div>

        {/* Asset Allocation Skeleton */}
        <div class="space-y-4 pt-6 border-t border-base-200">
          <div class="flex justify-between items-center">
            <Skeleton variant="text" width="140px" height="16px" />
            <div class="flex gap-4">
              {Array(3)
                .fill(0)
                .map(() => (
                  <div class="flex items-center gap-1.5">
                    <Skeleton variant="circular" width="8px" height="8px" />
                    <Skeleton variant="text" width="80px" height="10px" />
                  </div>
                ))}
            </div>
          </div>
          <Skeleton variant="rectangular" width="100%" height="16px" className="rounded-full" />
        </div>
      </div>
    </section>
  ) : (
    <section
      class={cardClasses}
      aria-label="Portfolio overview summary"
      data-testid="portfolio-total"
    >
      <div class="space-y-8">
        {/* Total Values */}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12">
          {/* Total Value (IDR) */}
          <div class="flex items-center justify-between" data-testid="portfolio-total-idr">
            <div>
              <StatLabel size="sm" className="uppercase tracking-widest">
                Total Value (IDR)
              </StatLabel>
              <p class="text-2xl lg:text-3xl font-bold mt-2 lg:mt-3 text-success tracking-tight leading-none">
                {formatCurrency(totalIdr, 'IDR')}
              </p>
            </div>
            <div class="w-12 h-12 lg:w-14 lg:h-14 bg-success/10 text-success rounded-2xl flex items-center justify-center shrink-0">
              <Wallet size={28} class="stroke-current" aria-hidden="true" />
            </div>
          </div>

          {/* Total Value (USD) */}
          <div class="flex items-center justify-between" data-testid="portfolio-total-usd">
            <div>
              <StatLabel size="sm" className="uppercase tracking-widest">
                Total Value (USD)
              </StatLabel>
              <p class="text-2xl lg:text-3xl font-bold mt-2 lg:mt-3 text-info tracking-tight leading-none">
                {formatCurrency(totalUsd, 'USD')}
              </p>
            </div>
            <div class="w-12 h-12 lg:w-14 lg:h-14 bg-info/10 text-info rounded-2xl flex items-center justify-center shrink-0">
              <Globe size={28} class="stroke-current" aria-hidden="true" />
            </div>
          </div>
        </div>

        {/* Asset Allocation */}
        {displayDistribution.length > 0 && (
          <div class="space-y-4 pt-6 border-t border-base-200">
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
              <h3 class="font-bold text-sm uppercase tracking-wider text-base-content">
                Asset Allocation
              </h3>

              {/* Legend - horizontal scrollable on mobile */}
              <div class="flex gap-4 lg:gap-6 overflow-x-auto hide-scrollbar pb-1 w-full sm:w-auto">
                {displayDistribution.map((item) => {
                  const safeColor = sanitizeColor(item.color);
                  return (
                    <div class="flex items-center gap-1.5 shrink-0">
                      <div
                        class="w-2 h-2 rounded-full"
                        style={`background-color: ${safeColor};`}
                        aria-hidden="true"
                      />
                      <span class="text-[10px] font-bold text-base-content/60 uppercase tracking-widest whitespace-nowrap">
                        {item.type} ({item.percentage}%)
                      </span>
                    </div>
                  );
                })}
              </div>
            </div>

            {/* Stacked Bar - P0: Colors sanitized, P1: Accessible description */}
            <div class="relative" data-allocation-bar>
              <div
                class="h-4 w-full bg-base-300 rounded-full overflow-hidden flex shadow-inner"
                role="img"
                aria-label={`Asset allocation: ${allocationDescription}`}
              >
                {displayDistribution.map((item) => {
                  const safeColor = sanitizeColor(item.color);
                  const safePercentage = Math.min(Math.max(item.percentage, 0), 100);
                  return (
                    <div
                      class="h-full transition-all duration-500 relative group/segment cursor-pointer"
                      style={`width: ${safePercentage}%; background-color: ${safeColor};`}
                      data-segment-type={item.type}
                      data-segment-percentage={item.percentage}
                    >
                      <div class="absolute inset-0 bg-white/10 opacity-0 group-hover/segment:opacity-100 transition-opacity" />
                    </div>
                  );
                })}
              </div>
              {/* Custom tooltip - positioned outside overflow-hidden */}
              <div
                class="absolute -top-10 left-1/2 -translate-x-1/2 px-3 py-1.5 bg-neutral text-neutral-content text-xs font-medium rounded-lg shadow-lg opacity-0 pointer-events-none transition-opacity z-50 whitespace-nowrap"
                data-allocation-tooltip
              >
                <span data-tooltip-text />
                <div class="absolute -bottom-1 left-1/2 -translate-x-1/2 w-2 h-2 bg-neutral rotate-45" />
              </div>
            </div>
          </div>
        )}
      </div>
    </section>
  )
}

<script>
  function initAllocationTooltips() {
    document.querySelectorAll('[data-allocation-bar]').forEach((bar) => {
      const tooltip = bar.querySelector('[data-allocation-tooltip]') as HTMLElement;
      const tooltipText = bar.querySelector('[data-tooltip-text]') as HTMLElement;
      if (!tooltip || !tooltipText) return;

      const segments = bar.querySelectorAll('[data-segment-type]');

      segments.forEach((segment) => {
        segment.addEventListener('mouseenter', (e: MouseEvent) => {
          const target = e.currentTarget as HTMLElement;
          const type = target.dataset.segmentType || '';
          const percentage = target.dataset.segmentPercentage || '0';
          tooltipText.textContent = `${type}: ${percentage}%`;

          // Position tooltip above the hovered segment
          const barRect = bar.getBoundingClientRect();
          const segmentRect = target.getBoundingClientRect();
          const segmentCenter = segmentRect.left + segmentRect.width / 2 - barRect.left;

          tooltip.style.left = `${segmentCenter}px`;
          tooltip.style.opacity = '1';
        });

        segment.addEventListener('mouseleave', () => {
          tooltip.style.opacity = '0';
        });
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllocationTooltips);
  } else {
    initAllocationTooltips();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAllocationTooltips);
</script>
