---
/**
 * AssetPortfolioSummary Component
 *
 * Overview section showing total portfolio value (assets, debt, net worth)
 * in both currencies and asset allocation distribution bar.
 *
 * Part of the Global Portfolio page redesign.
 *
 * @param {number} totalIdr - Total asset value in IDR
 * @param {number} totalUsd - Total asset value in USD
 * @param {number} debtIdr - Total debt value in IDR
 * @param {number} debtUsd - Total debt value in USD
 * @param {Array} distribution - Asset type distribution for allocation bar
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} className - Additional CSS classes
 */

// External packages
import { Wallet, CreditCard, TrendingUp, Clock } from '@lucide/astro';

// Internal aliases - lib
import { formatCurrency } from '@/lib/formatting';
import { sanitizeColor } from '@/lib/utils/budget';

// Internal aliases - components
import StatLabel from '@components/atoms/StatLabel.astro';
import Skeleton from '@components/atoms/Skeleton.astro';
import AllocationBar from '@components/molecules/AllocationBar.astro';

// P2: TODO - Consider importing AssetAllocationDistribution type from asset utils
export interface AllocationItem {
  type: string;
  percentage: number;
  color: string;
}

// Maximum number of individual asset types to show before grouping the rest as "Others"
const MAX_LEGEND_ITEMS = 7;
const OTHERS_COLOR = '#9ca3af'; // gray-400 for "Others" category

export interface Props {
  totalIdr: number;
  totalUsd: number;
  debtIdr?: number;
  debtUsd?: number;
  distribution: AllocationItem[];
  loading?: boolean;
  className?: string;
  latestUpdate?: Date | string | null;
  isHistoricalView?: boolean;
}

const {
  totalIdr,
  totalUsd,
  debtIdr = 0,
  debtUsd = 0,
  distribution,
  loading = false,
  className = '',
  latestUpdate,
  isHistoricalView = false,
} = Astro.props;

// Calculate net worth (assets - debt)
const netWorthIdr = totalIdr - debtIdr;
const netWorthUsd = totalUsd - debtUsd;
const hasDebt = debtIdr > 0 || debtUsd > 0;

// Format the latest update date if provided
const formattedLatestUpdate = latestUpdate
  ? new Date(latestUpdate).toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit',
    })
  : null;

// Sort distribution by percentage (largest first)
const sortedDistribution = [...distribution].sort((a, b) => b.percentage - a.percentage);

// Take top N for legend display, combine rest as "Others"
const topTypes = sortedDistribution.slice(0, MAX_LEGEND_ITEMS);
const remainingTypes = sortedDistribution.slice(MAX_LEGEND_ITEMS);
const othersPercentage = remainingTypes.reduce((sum, item) => sum + item.percentage, 0);

// Build display distribution with "Others" if there are remaining types
const displayDistribution: AllocationItem[] =
  othersPercentage > 0
    ? [...topTypes, { type: 'Others', percentage: othersPercentage, color: OTHERS_COLOR }]
    : topTypes;

// Generate accessible description for screen readers (P1: Accessibility)
const allocationDescription = sortedDistribution
  .map((item) => `${item.type} ${item.percentage}%`)
  .join(', ');

const cardClasses = [
  // Base card styling
  'bg-base-100 rounded-card border border-base-300',
  // Premium shadow
  'shadow-sm',
  // Padding - responsive
  'p-6 lg:p-10',
  // Relative for overflow
  'relative overflow-hidden',
  // Additional classes
  className,
]
  .filter(Boolean)
  .join(' ');
---

{
  loading ? (
    <section class={cardClasses} aria-busy="true" aria-label="Loading portfolio summary">
      <div class="space-y-8">
        {/* Total Values Skeleton */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
          <div class="flex items-center justify-between">
            <div>
              <Skeleton variant="text" width="100px" height="12px" />
              <Skeleton variant="text" width="200px" height="36px" className="mt-3" />
              <Skeleton variant="text" width="120px" height="14px" className="mt-2" />
            </div>
            <Skeleton variant="rectangular" width="56px" height="56px" className="rounded-2xl" />
          </div>
          <div class="flex items-center justify-between">
            <div>
              <Skeleton variant="text" width="100px" height="12px" />
              <Skeleton variant="text" width="160px" height="36px" className="mt-3" />
              <Skeleton variant="text" width="100px" height="14px" className="mt-2" />
            </div>
            <Skeleton variant="rectangular" width="56px" height="56px" className="rounded-2xl" />
          </div>
          <div class="flex items-center justify-between">
            <div>
              <Skeleton variant="text" width="100px" height="12px" />
              <Skeleton variant="text" width="180px" height="36px" className="mt-3" />
              <Skeleton variant="text" width="110px" height="14px" className="mt-2" />
            </div>
            <Skeleton variant="rectangular" width="56px" height="56px" className="rounded-2xl" />
          </div>
        </div>

        {/* Asset Allocation Skeleton */}
        <div class="space-y-4 pt-6 border-t border-base-200">
          <div class="flex justify-between items-center">
            <Skeleton variant="text" width="140px" height="16px" />
            <div class="flex gap-4">
              {Array(3)
                .fill(0)
                .map(() => (
                  <div class="flex items-center gap-1.5">
                    <Skeleton variant="circular" width="8px" height="8px" />
                    <Skeleton variant="text" width="80px" height="10px" />
                  </div>
                ))}
            </div>
          </div>
          <Skeleton variant="rectangular" width="100%" height="16px" className="rounded-full" />
        </div>
      </div>
    </section>
  ) : (
    <section
      class={cardClasses}
      aria-label="Portfolio overview summary"
      data-testid="portfolio-total"
    >
      <div class="space-y-8">
        {/* Total Values */}
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8 lg:gap-12">
          {/* Total Assets */}
          <div class="flex items-center justify-between" data-testid="portfolio-total-idr">
            <div>
              <StatLabel size="sm" className="uppercase tracking-widest">
                Total Assets
              </StatLabel>
              <p class="text-2xl lg:text-3xl font-bold mt-2 lg:mt-3 text-success tracking-tight leading-none">
                {formatCurrency(totalIdr, 'IDR')}
              </p>
              {totalUsd > 0 && (
                <p class="text-sm font-semibold mt-1.5 text-info">
                  {formatCurrency(totalUsd, 'USD')}
                </p>
              )}
            </div>
            <div class="w-12 h-12 lg:w-14 lg:h-14 bg-success/10 text-success rounded-2xl flex items-center justify-center shrink-0">
              <Wallet size={28} class="stroke-current" aria-hidden="true" />
            </div>
          </div>

          {/* Total Debt */}
          {hasDebt && (
            <div class="flex items-center justify-between" data-testid="portfolio-total-debt">
              <div>
                <StatLabel size="sm" className="uppercase tracking-widest">
                  Total Debt
                </StatLabel>
                <p class="text-2xl lg:text-3xl font-bold mt-2 lg:mt-3 text-error tracking-tight leading-none">
                  {formatCurrency(debtIdr, 'IDR')}
                </p>
                {debtUsd > 0 && (
                  <p class="text-sm font-semibold mt-1.5 text-error/70">
                    {formatCurrency(debtUsd, 'USD')}
                  </p>
                )}
              </div>
              <div class="w-12 h-12 lg:w-14 lg:h-14 bg-error/10 text-error rounded-2xl flex items-center justify-center shrink-0">
                <CreditCard size={28} class="stroke-current" aria-hidden="true" />
              </div>
            </div>
          )}

          {/* Net Worth */}
          <div class="flex items-center justify-between" data-testid="portfolio-net-worth">
            <div>
              <StatLabel size="sm" className="uppercase tracking-widest">
                Net Worth
              </StatLabel>
              <p
                class={`text-2xl lg:text-3xl font-bold mt-2 lg:mt-3 tracking-tight leading-none ${netWorthIdr >= 0 ? 'text-accent' : 'text-error'}`}
              >
                {formatCurrency(netWorthIdr, 'IDR')}
              </p>
              {netWorthUsd !== 0 && (
                <p
                  class={`text-sm font-semibold mt-1.5 ${netWorthUsd >= 0 ? 'text-accent/70' : 'text-error/70'}`}
                >
                  {formatCurrency(netWorthUsd, 'USD')}
                </p>
              )}
            </div>
            <div class="w-12 h-12 lg:w-14 lg:h-14 bg-accent/10 text-accent rounded-2xl flex items-center justify-center shrink-0">
              <TrendingUp size={28} class="stroke-current" aria-hidden="true" />
            </div>
          </div>
        </div>

        {/* Latest Update Info */}
        {formattedLatestUpdate && (
          <div class="flex items-center gap-2 text-xs text-base-content/50 font-medium pt-2">
            <Clock size={12} class="stroke-current shrink-0" aria-hidden="true" />
            <span>
              {isHistoricalView ? 'Latest update in this period' : 'Latest update'}:{' '}
              {formattedLatestUpdate}
            </span>
          </div>
        )}

        {/* Asset Allocation */}
        {displayDistribution.length > 0 && (
          <div class="space-y-4 pt-6 border-t border-base-200">
            <h3 class="font-bold text-sm uppercase tracking-wider text-base-content">
              Asset Allocation
            </h3>

            {/* Legend */}
            <div class="flex flex-wrap gap-3 lg:gap-4">
              {displayDistribution.map((item) => {
                const safeColor = sanitizeColor(item.color);
                return (
                  <div class="flex items-center gap-1.5">
                    <div
                      class="w-2 h-2 rounded-full"
                      style={`background-color: ${safeColor};`}
                      aria-hidden="true"
                    />
                    <span class="text-xs font-bold text-base-content/60 uppercase tracking-widest whitespace-nowrap">
                      {item.type} ({item.percentage}%)
                    </span>
                  </div>
                );
              })}
            </div>

            {/* Stacked Bar - P0: Colors sanitized, P1: Accessible description */}
            <AllocationBar
              segments={displayDistribution.map((item) => ({
                label: item.type,
                percentage: item.percentage,
                color: item.color,
              }))}
              height="sm"
              ariaLabel={`Asset allocation: ${allocationDescription}`}
            />
          </div>
        )}
      </div>
    </section>
  )
}
