---
/**
 * Category Delete Confirmation Dialog
 *
 * Confirmation dialog for deleting categories.
 * Features destructive action styling and category preview.
 *
 * @param {string} id - Dialog ID
 * @param {boolean} open - Whether dialog is open
 */

import ConfirmationModal from '../molecules/ConfirmationModal.astro';

export interface Props {
  id: string;
}

const { id } = Astro.props;
---

<div data-category-delete-dialog-container data-id={id} data-testid="category-delete-dialog">
  <ConfirmationModal
    id={id}
    title="Delete Category"
    description="This action cannot be undone."
    confirmLabel="Delete"
    confirmVariant="error"
    confirmLoadingLabel="Deleting..."
    iconVariant="error"
    confirmTestId="confirm-delete-btn"
  >
    <div
      slot="details"
      id="delete-category-info"
      class="p-4 bg-base-200/50 rounded-2xl border border-base-300"
      data-category-info
    >
      <div class="flex items-center gap-3">
        <div data-category-icon-container></div>
        <div>
          <p class="font-bold text-base-content" data-category-name></p>
        </div>
      </div>
    </div>

    <p slot="details" class="text-base-content/70 text-sm">
      Are you sure you want to delete this category? Existing transactions with this category will
      remain unchanged.
    </p>
  </ConfirmationModal>
</div>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { getCsrfHeaders } from '@/lib/csrf-client';
  import { navigate } from 'astro:transitions/client';
  import {
    clearConfirmError,
    closeConfirmationModal,
    getConfirmationModalElements,
    resetConfirmationModal,
    setConfirmLoading,
    showConfirmError,
  } from '@/components/molecules/ConfirmationModal.client';

  // Track which dialog containers have been initialized
  const initializedContainers = new WeakSet<Element>();

  // Store current category ID for deletion
  let currentCategoryId = '';

  // Initialize category delete dialog containers
  function initCategoryDeleteDialogs() {
    document.querySelectorAll('[data-category-delete-dialog-container]').forEach((container) => {
      // Skip if already initialized
      if (initializedContainers.has(container)) return;
      initializedContainers.add(container);

      const id = container.getAttribute('data-id');
      if (!id) return;

      const { modal, confirmButton, cancelButton, errorElement } = getConfirmationModalElements(
        container,
        id
      );
      const categoryNameEl = container.querySelector('[data-category-name]');
      const categoryIconContainer = container.querySelector('[data-category-icon-container]');

      if (!modal || !confirmButton) return;

      // Cancel button - close dialog
      cancelButton?.addEventListener('click', () => {
        resetConfirmationModal(confirmButton, errorElement);
        closeConfirmationModal(modal);
      });

      // Confirm delete button
      confirmButton.addEventListener('click', async () => {
        if (!currentCategoryId) return;

        // Clear errors
        clearConfirmError(errorElement);

        // Show loading state
        setConfirmLoading(confirmButton, true);

        try {
          const response = await fetch(`/api/categories/${currentCategoryId}`, {
            method: 'DELETE',
            headers: getCsrfHeaders(),
          });

          if (!response.ok) {
            const result = await response.json();
            throw new Error(result.error?.message || 'Failed to delete category');
          }

          // Success
          addToast('Category deleted successfully!', 'success');
          closeConfirmationModal(modal);

          // Reload page to show updated categories
          const url = new URL(window.location.href);
          navigate(url.pathname + url.search);
        } catch (err) {
          const message = err instanceof Error ? err.message : 'Failed to delete category';
          showConfirmError(errorElement, message);
        } finally {
          // Reset button state
          setConfirmLoading(confirmButton, false);
        }
      });

      // Expose function to open dialog with category info
      (window as any).openDeleteCategoryDialog = (
        categoryId: string,
        categoryName: string,
        _categoryIcon: string,
        categoryColor: string
      ) => {
        currentCategoryId = categoryId;
        clearConfirmError(errorElement);

        // Populate category info
        if (categoryNameEl) {
          categoryNameEl.textContent = categoryName;
        }

        if (categoryIconContainer instanceof HTMLElement) {
          const colorClass = categoryColor.replace('bg-', '');
          categoryIconContainer.textContent = '';

          const iconWrapper = document.createElement('div');
          iconWrapper.className = `w-10 h-10 rounded-xl ${categoryColor} text-${colorClass}-content flex items-center justify-center`;

          const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
          svg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
          svg.setAttribute('width', '20');
          svg.setAttribute('height', '20');
          svg.setAttribute('viewBox', '0 0 24 24');
          svg.setAttribute('fill', 'none');
          svg.setAttribute('stroke', 'currentColor');
          svg.setAttribute('stroke-width', '2');
          svg.setAttribute('stroke-linecap', 'round');
          svg.setAttribute('stroke-linejoin', 'round');
          svg.setAttribute('class', 'stroke-current');
          svg.setAttribute('aria-hidden', 'true');

          const pathPrimary = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          pathPrimary.setAttribute(
            'd',
            'M12 2H2v10l9.29 9.29c.94.94 2.48.94 3.42 0l6.58-6.58c.94-.94.94-2.48 0-3.42L12 2Z'
          );

          const pathDot = document.createElementNS('http://www.w3.org/2000/svg', 'path');
          pathDot.setAttribute('d', 'M7 7h.01');

          svg.append(pathPrimary, pathDot);
          iconWrapper.appendChild(svg);
          categoryIconContainer.appendChild(iconWrapper);
        }

        modal.showModal();
      };
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initCategoryDeleteDialogs);
  } else {
    initCategoryDeleteDialogs();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initCategoryDeleteDialogs);
</script>
