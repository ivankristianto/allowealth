---
/**
 * AccountGroupCard Component
 *
 * Collapsible card section for grouping accounts by type.
 * Shows count badge, totals by currency, and expand/collapse functionality.
 *
 * Part of the Global Accounts page redesign.
 *
 * @param {string} type - Account type name (e.g., "Bank Account", "Stock")
 * @param {number} count - Number of accounts in this group
 * @param {Array} totals - Group totals by currency
 * @param {boolean} defaultExpanded - Whether to start expanded
 * @param {string} groupId - Unique ID for this group (used for collapse state)
 * @param {string} className - Additional CSS classes
 */

import { ChevronUp, Info } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import type { AccountClass } from '@/lib/types/account';
import type { Currency } from '@/lib/constants/currency';

// Tooltip descriptions for each account class (shown on hover via Info icon)
const ACCOUNT_CLASS_DESCRIPTIONS: Record<AccountClass, string> = {
  liquid: 'Cash and equivalents available for immediate use',
  non_liquid: 'Investments and holdings with fluctuating value',
  debt: 'Liabilities shown as negative in net worth',
};

// Concise subtitles shown below the title
const ACCOUNT_CLASS_SUBTITLES: Record<AccountClass, string> = {
  liquid: 'Cash & equivalents',
  non_liquid: 'Investments & holdings',
  debt: 'Liabilities & loans',
};

export interface Props {
  type: string;
  accountClass?: AccountClass;
  count: number;
  totals?: Array<{ currency: Currency; amount: number }>;
  defaultExpanded?: boolean;
  groupId: string;
  isDebt?: boolean;
  className?: string;
}

const {
  type,
  accountClass,
  count,
  totals = [],
  defaultExpanded = true,
  groupId,
  isDebt = false,
  className = '',
} = Astro.props;

// Get tooltip description for this account class
const classDescription = accountClass ? ACCOUNT_CLASS_DESCRIPTIONS[accountClass] : null;

// Display title: append "Accounts" when we have an account class
const displayTitle = accountClass ? `${type} Accounts` : type;

const visibleTotals = totals.filter((row) => row.amount > 0);

// Generate subtitle: concise phrase for the card header
const subtitle = accountClass
  ? ACCOUNT_CLASS_SUBTITLES[accountClass]
  : `Managing your ${type.toLowerCase()} holdings`;

const cardClasses = [
  'bg-base-100 rounded-card border border-base-300 shadow-sm overflow-hidden transition-all duration-300',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div
  class={cardClasses}
  data-account-group={groupId}
  data-testid="account-group"
  data-account-type={groupId}
>
  {/* Collapsible Header Button */}
  <button
    type="button"
    class="w-full p-6 lg:px-8 lg:py-6 flex items-center justify-between text-left transition-colors hover:bg-base-100/80 group"
    data-group-toggle={groupId}
    aria-expanded={defaultExpanded}
    aria-controls={`group-content-${groupId}`}
  >
    <div>
      <div class="flex items-center gap-3">
        <h3 class="text-lg lg:text-xl font-bold text-base-content tracking-tight leading-none">
          {displayTitle}
        </h3>
        {
          classDescription && (
            <div class="tooltip tooltip-right" data-tip={classDescription}>
              <span
                class="inline-flex items-center justify-center rounded-full text-base-content/30 hover:text-base-content/60 transition-colors cursor-help"
                aria-label={`${displayTitle}: ${classDescription}`}
              >
                <Info size={14} class="stroke-current" aria-hidden="true" />
              </span>
            </div>
          )
        }
        <span
          class="px-2 py-0.5 bg-base-200 text-base-content/70 rounded-lg text-xs font-bold leading-none"
        >
          {count}
        </span>
      </div>
      <p class="text-xs font-medium text-base-content/50 mt-2">{subtitle}</p>
    </div>

    <div class="flex items-center gap-6 lg:gap-8">
      {/* Totals - hidden on mobile */}
      <div class="text-right hidden sm:block">
        {
          visibleTotals.map((row, index) => (
            <p
              class:list={[
                'text-sm font-bold leading-none',
                isDebt ? 'text-error' : index === 0 ? 'text-success' : 'text-info',
                index > 0 && 'mt-1.5',
              ]}
            >
              {formatCurrency(isDebt ? -row.amount : row.amount, row.currency)}
            </p>
          ))
        }
      </div>

      {/* Expand/Collapse Icon */}
      <ChevronUp
        size={20}
        class="stroke-current text-base-content/40 transition-transform duration-300 group-aria-expanded:rotate-0 -rotate-180"
        data-group-icon={groupId}
        aria-hidden="true"
      />
    </div>
  </button>

  {/* Collapsible Content */}
  <div
    id={`group-content-${groupId}`}
    class="divide-y divide-base-200 border-t border-base-200 transition-all duration-300 ease-in-out"
    data-group-content={groupId}
    data-expanded={defaultExpanded}
  >
    <slot />
  </div>
</div>

<script>
  // Track initialized elements to avoid duplicate listeners
  const initializedGroupToggles = new WeakSet<Element>();

  function initAccountGroupToggles() {
    document.querySelectorAll('[data-group-toggle]').forEach((button) => {
      // Skip if already initialized
      if (initializedGroupToggles.has(button)) return;
      initializedGroupToggles.add(button);

      const groupId = button.getAttribute('data-group-toggle');
      if (!groupId) return;

      const content = document.querySelector(
        `[data-group-content="${groupId}"]`
      ) as HTMLElement | null;
      const icon = document.querySelector(`[data-group-icon="${groupId}"]`) as HTMLElement | null;

      if (!content) return;

      // Set initial state based on data-expanded attribute
      const isExpanded = content.dataset.expanded === 'true';
      if (!isExpanded) {
        content.style.maxHeight = '0px';
        content.style.opacity = '0';
        content.style.overflow = 'hidden';
        button.setAttribute('aria-expanded', 'false');
        if (icon) {
          icon.classList.remove('rotate-0');
          icon.classList.add('-rotate-180');
        }
      } else {
        content.style.maxHeight = 'none';
        content.style.opacity = '1';
        button.setAttribute('aria-expanded', 'true');
        if (icon) {
          icon.classList.add('rotate-0');
          icon.classList.remove('-rotate-180');
        }
      }

      button.addEventListener('click', () => {
        const currentlyExpanded = button.getAttribute('aria-expanded') === 'true';

        if (currentlyExpanded) {
          // Collapse
          content.style.maxHeight = content.scrollHeight + 'px';
          // Force reflow
          content.offsetHeight;
          content.style.maxHeight = '0px';
          content.style.opacity = '0';
          content.style.overflow = 'hidden';
          button.setAttribute('aria-expanded', 'false');
          content.dataset.expanded = 'false';
          if (icon) {
            icon.classList.remove('rotate-0');
            icon.classList.add('-rotate-180');
          }
        } else {
          // Expand
          content.style.overflow = 'hidden';
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          button.setAttribute('aria-expanded', 'true');
          content.dataset.expanded = 'true';
          if (icon) {
            icon.classList.add('rotate-0');
            icon.classList.remove('-rotate-180');
          }

          // Remove max-height after transition to allow dynamic content
          setTimeout(() => {
            if (content.dataset.expanded === 'true') {
              content.style.maxHeight = 'none';
              content.style.overflow = 'visible';
            }
          }, 300);
        }
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAccountGroupToggles);
  } else {
    initAccountGroupToggles();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAccountGroupToggles);
</script>
