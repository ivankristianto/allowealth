---
/**
 * Transaction Filters Bar
 *
 * Unified filter bar with type toggle, category dropdown, and search input.
 * Matches POC design with pill-style buttons and clean rounded elements.
 *
 * @param {string} typeFilter - Current type filter (all/income/expense)
 * @param {string} searchValue - Current search query
 * @param {string} categoryId - Current category filter
 * @param {Array} categories - Available categories
 * @param {boolean} showCategoryFilter - Show category dropdown
 */

import { Search, ChevronLeft, ChevronRight, Calendar, Tag } from '@lucide/astro';

export interface Props {
  typeFilter?: 'all' | 'income' | 'expense';
  searchValue?: string;
  categoryId?: string;
  categories?: Array<{ id: string; name: string; type: string }>;
  showCategoryFilter?: boolean;
  monthSelector?: boolean;
  availableMonths?: string[];
  selectedMonth?: string;
  baseUrl?: string;
}

const {
  typeFilter = 'all',
  searchValue = '',
  categoryId = '',
  categories = [],
  showCategoryFilter = true,
  monthSelector = true,
  availableMonths = [],
  selectedMonth = '',
  baseUrl = '/transactions',
} = Astro.props;

// Build URL with current filters
const buildFilterUrl = (updates: Record<string, string>) => {
  const params = new URLSearchParams();

  // Add current filters
  if (typeFilter !== 'all') params.set('type', typeFilter);
  if (searchValue) params.set('search', searchValue);
  if (categoryId) params.set('category_id', categoryId);

  // Add updates
  Object.entries(updates).forEach(([key, value]) => {
    if (value && value !== 'all') {
      params.set(key, value);
    } else {
      params.delete(key);
    }
  });

  const queryString = params.toString();
  return queryString ? `${baseUrl}?${queryString}` : baseUrl;
};

// Get month index for navigation
const currentMonthIndex = availableMonths.indexOf(selectedMonth);
const hasPrevMonth = currentMonthIndex > 0;
const hasNextMonth = currentMonthIndex < availableMonths.length - 1;

// Build month navigation URL
const buildMonthUrl = (direction: 'prev' | 'next') => {
  const newIndex = direction === 'prev' ? currentMonthIndex - 1 : currentMonthIndex + 1;
  if (newIndex < 0 || newIndex >= availableMonths.length) return '#';
  return buildFilterUrl({ month: availableMonths[newIndex] });
};
---

<!-- Filter Bar Container -->
<form
  action={baseUrl}
  method="get"
  class="flex flex-col xl:flex-row items-center gap-4 xl:gap-6 justify-between"
  role="search"
  aria-label="Filter transactions"
>
  <div class="flex flex-wrap items-center gap-4 w-full xl:w-auto">
    <!-- Type Filter (Tab-style) -->
    <input type="hidden" name="type" value={typeFilter} data-filter-type />
    <div
      class="flex bg-base-200 p-1 rounded-2xl"
      role="group"
      aria-label="Filter by transaction type"
    >
      <a
        href={buildFilterUrl({ type: 'all' })}
        class={`px-6 py-2.5 text-xs font-bold rounded-xl transition-all focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 ${
          typeFilter === 'all'
            ? 'bg-base-100 shadow text-primary'
            : 'text-base-content/50 hover:text-base-content/70'
        }`}
        data-type="all"
        aria-pressed={typeFilter === 'all'}
        role="button"
      >
        All
      </a>
      <a
        href={buildFilterUrl({ type: 'expense' })}
        class={`px-6 py-2.5 text-xs font-bold rounded-xl transition-all focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 ${
          typeFilter === 'expense'
            ? 'bg-base-100 shadow text-primary'
            : 'text-base-content/50 hover:text-base-content/70'
        }`}
        data-type="expense"
        aria-pressed={typeFilter === 'expense'}
        role="button"
      >
        Expenses
      </a>
      <a
        href={buildFilterUrl({ type: 'income' })}
        class={`px-6 py-2.5 text-xs font-bold rounded-xl transition-all focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 ${
          typeFilter === 'income'
            ? 'bg-base-100 shadow text-primary'
            : 'text-base-content/50 hover:text-base-content/70'
        }`}
        data-type="income"
        aria-pressed={typeFilter === 'income'}
        role="button"
      >
        Income
      </a>
    </div>

    <!-- Category Filter -->
    {
      showCategoryFilter && categories.length > 0 && (
        <div class="relative min-w-[160px]">
          <select
            name="category_id"
            class="select w-full pl-10 pr-10 py-3 text-xs font-bold border border-base-300 bg-base-100 text-base-content rounded-2xl appearance-none cursor-pointer shadow-sm hover:border-base-content/30 transition-colors focus:outline-none focus:border-accent"
            aria-label="Filter by category"
          >
            <option value="">All Categories</option>
            {categories.map((cat) => (
              <option value={cat.id} selected={cat.id === categoryId}>
                {cat.name}
              </option>
            ))}
          </select>
          <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-base-content/40">
            <Tag size={18} class="stroke-current" aria-hidden="true" />
          </div>
        </div>
      )
    }

    <!-- Month Filter with Navigation -->
    {
      monthSelector && availableMonths.length > 0 && (
        <div class="flex items-center gap-1">
          <a
            href={buildMonthUrl('prev')}
            class={`btn btn-ghost btn-square border border-base-300 bg-base-100 rounded-2xl transition-all active:scale-95 shadow-sm ${
              !hasPrevMonth
                ? 'opacity-30 cursor-not-allowed pointer-events-none'
                : 'text-base-content/40 hover:text-primary hover:border-accent/30'
            }`}
            aria-label="Previous month"
            aria-disabled={!hasPrevMonth}
          >
            <ChevronLeft size={18} class="stroke-current" aria-hidden="true" />
          </a>

          <div class="relative min-w-[160px]">
            <select
              name="month"
              class="select w-full pl-10 pr-10 py-3 text-xs font-bold border border-base-300 bg-base-100 text-base-content rounded-2xl appearance-none cursor-pointer shadow-sm hover:border-base-content/30 transition-colors focus:outline-none focus:border-accent"
              aria-label="Select month"
            >
              {availableMonths.map((month) => (
                <option value={month} selected={month === selectedMonth}>
                  {month}
                </option>
              ))}
            </select>
            <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3.5 text-base-content/40">
              <Calendar size={18} class="stroke-current" aria-hidden="true" />
            </div>
          </div>

          <a
            href={buildMonthUrl('next')}
            class={`btn btn-ghost btn-square border border-base-300 bg-base-100 rounded-2xl transition-all active:scale-95 shadow-sm ${
              !hasNextMonth
                ? 'opacity-30 cursor-not-allowed pointer-events-none'
                : 'text-base-content/40 hover:text-primary hover:border-accent/30'
            }`}
            aria-label="Next month"
            aria-disabled={!hasNextMonth}
          >
            <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
          </a>
        </div>
      )
    }
  </div>

  <!-- Search Input -->
  <div class="relative w-full xl:max-w-xs">
    <Search
      size={18}
      class="absolute left-4 top-1/2 -translate-y-1/2 text-base-content/40 stroke-current pointer-events-none z-10"
      aria-hidden="true"
    />
    <label for="search-input" class="sr-only">Search activity</label>
    <input
      id="search-input"
      type="search"
      name="search"
      value={searchValue}
      placeholder="Search activity..."
      class="input w-full pl-11 pr-4 py-3 bg-base-100 border border-base-300 rounded-2xl text-sm font-medium shadow-sm placeholder:text-base-content/40 focus:outline-none focus:border-accent"
    />
  </div>
</form>

<script>
  // Handle keyboard navigation for type filter buttons
  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLElement && e.target.hasAttribute('data-filter-type')) {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        e.target.click();
      }
    }
  });

  // Sync select changes with URL
  const filterBar = document.querySelector('[role="search"]');
  if (filterBar) {
    const selects = filterBar.querySelectorAll('select');
    selects.forEach((select) => {
      select.addEventListener('change', () => {
        // Auto-submit form on select change
        (filterBar as HTMLFormElement).submit();
      });
    });
  }
</script>
