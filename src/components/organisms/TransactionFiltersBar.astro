---
/**
 * Transaction Filters Bar
 *
 * Unified filter bar with type toggle, category dropdown, account dropdown, and search input.
 * Matches POC design with pill-style buttons and clean rounded elements.
 */

import { ChevronDown, Tag, RotateCcw, Users, Wallet } from '@lucide/astro';
import { tokenClasses } from '@/lib/tokens';
import SearchInput from '@/components/atoms/SearchInput.astro';
import MultiSelectDropdown from '@/components/molecules/MultiSelectDropdown.astro';

export interface Props {
  typeFilter?: 'income' | 'expense';
  searchValue?: string;
  categoryIds?: string[];
  categories?: Array<{ id: string; name: string; type: string }>;
  showCategoryFilter?: boolean;
  accountIds?: string[];
  accounts?: Array<{ id: string; name: string; type: string }>;
  showAccountFilter?: boolean;
  userId?: string;
  members?: Array<{ id: string; name: string }>;
  showMemberFilter?: boolean;
  baseUrl?: string;
  currentMonth?: string;
  selectedMonth?: string;
}

const {
  typeFilter = 'expense',
  searchValue = '',
  categoryIds = [],
  categories = [],
  showCategoryFilter = true,
  accountIds = [],
  accounts = [],
  showAccountFilter = false,
  userId = '',
  members = [],
  showMemberFilter = false,
  baseUrl = '/transactions',
  currentMonth = '',
  selectedMonth = '',
} = Astro.props;

// Check if any filters are active (to show reset button)
const hasActiveFilters =
  typeFilter !== 'expense' ||
  searchValue !== '' ||
  categoryIds.length > 0 ||
  accountIds.length > 0 ||
  userId !== '' ||
  (selectedMonth !== '' && selectedMonth !== currentMonth);

// Build URL with current filters
const buildFilterUrl = (updates: Record<string, string>) => {
  const params = new URLSearchParams();

  // Add current filters
  params.set('type', typeFilter);
  if (searchValue) params.set('search', searchValue);
  if (categoryIds.length > 0) params.set('category_ids', categoryIds.join(','));
  if (accountIds.length > 0) params.set('account_ids', accountIds.join(','));
  if (userId) params.set('user_id', userId);
  if (selectedMonth) params.set('month', selectedMonth);

  // Add updates
  Object.entries(updates).forEach(([key, value]) => {
    if (value) {
      params.set(key, value);
    } else {
      params.delete(key);
    }
  });

  const queryString = params.toString();
  const basePath = baseUrl.split('?')[0] || '/transactions';
  return queryString ? `${basePath}?${queryString}` : basePath;
};

const mainSearchInputClass = [
  'input w-full rounded-lg font-medium shadow-sm',
  tokenClasses.inputSurfaceDefault,
  tokenClasses.inputFocusAccent,
  tokenClasses.inputPaddingSearchDefault,
  tokenClasses.textSm,
  tokenClasses.placeholderMuted,
].join(' ');
---

<!-- Filter Bar Container -->
<form
  action={baseUrl}
  method="get"
  class="flex flex-col gap-3 sm:gap-4"
  role="search"
  aria-label="Filter transactions"
  id="transaction-filters-form"
  data-filter-form
  data-selected-month={selectedMonth}
>
  {/* Row 1: Search + Reset */}
  <div class="flex items-center gap-2 sm:gap-3 w-full">
    <SearchInput
      id="search-input"
      name="search"
      label="Search activity"
      value={searchValue}
      placeholder="Search..."
      inputClass={mainSearchInputClass}
      class="flex-1"
      data-filter-search
    />

    <button
      type="button"
      class={`btn btn-ghost btn-sm gap-1 sm:gap-2 text-base-content/60 hover:text-primary hover:bg-primary/10 rounded-lg sm:rounded-xl transition-colors shrink-0 min-h-[44px] ${hasActiveFilters ? '' : 'hidden'}`}
      aria-label="Reset filters"
      data-reset-filters
      data-current-month={currentMonth}
    >
      <RotateCcw size={16} class="stroke-current" aria-hidden="true" />
      <span class="text-xs sm:text-sm">Reset</span>
    </button>
  </div>

  {/* Row 2: Type filter + Category + Account + Member */}
  <div class="flex flex-wrap items-center gap-2 sm:gap-4 w-full">
    <input type="hidden" name="type" value={typeFilter} id="type-filter-hidden" />
    <div
      class="flex bg-base-200 p-1 rounded-xl sm:rounded-2xl shrink-0"
      role="group"
      aria-label="Filter by transaction type"
      id="type-filter-group"
      data-filter-type-group
    >
      <button
        type="button"
        class={`px-3 sm:px-6 py-2 sm:py-2.5 min-h-[44px] min-w-[44px] text-xs font-bold rounded-lg sm:rounded-xl transition-all focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 ${
          typeFilter === 'expense'
            ? 'bg-base-100 shadow text-primary'
            : 'text-base-content/50 hover:text-base-content/70'
        }`}
        data-filter-type="expense"
        data-filter-url={buildFilterUrl({ type: 'expense' })}
        aria-pressed={typeFilter === 'expense'}
      >
        Expenses
      </button>
      <button
        type="button"
        class={`px-3 sm:px-6 py-2 sm:py-2.5 min-h-[44px] min-w-[44px] text-xs font-bold rounded-lg sm:rounded-xl transition-all focus-visible:outline-2 focus-visible:outline-accent focus-visible:outline-offset-2 ${
          typeFilter === 'income'
            ? 'bg-base-100 shadow text-primary'
            : 'text-base-content/50 hover:text-base-content/70'
        }`}
        data-filter-type="income"
        data-filter-url={buildFilterUrl({ type: 'income' })}
        aria-pressed={typeFilter === 'income'}
      >
        Income
      </button>
    </div>

    {
      showCategoryFilter && categories.length > 0 && (
        <MultiSelectDropdown
          id="category"
          label="All Categories"
          inputName="category_ids"
          selectedIds={categoryIds}
          items={categories.map((c) => ({ id: c.id, name: c.name, filterType: c.type }))}
          searchable={true}
          searchPlaceholder="Search categories..."
          filterEventType="category_ids"
        >
          <Tag
            size={16}
            class="stroke-current text-base-content/40"
            aria-hidden="true"
            slot="icon"
          />
        </MultiSelectDropdown>
      )
    }

    {
      showAccountFilter && accounts.length > 0 && (
        <MultiSelectDropdown
          id="account"
          label="All Accounts"
          inputName="account_ids"
          selectedIds={accountIds}
          items={accounts
            .map((a) => ({ id: a.id, name: a.name, group: a.type }))
            .sort((a, b) => {
              const liquidTypes = [
                'cash',
                'bank_account',
                'e_wallet',
                'credit_card',
                'Cash',
                'Bank Accounts',
                'E-Wallets',
                'Credit Cards',
              ];
              const aIsLiquid = liquidTypes.includes(a.group);
              const bIsLiquid = liquidTypes.includes(b.group);

              if (aIsLiquid && !bIsLiquid) return -1;
              if (!aIsLiquid && bIsLiquid) return 1;
              return a.name.localeCompare(b.name);
            })}
          searchable={true}
          searchPlaceholder="Search accounts..."
          filterEventType="account_ids"
        >
          <Wallet
            size={16}
            class="stroke-current text-base-content/40"
            aria-hidden="true"
            slot="icon"
          />
        </MultiSelectDropdown>
      )
    }

    {
      showMemberFilter && members.length > 0 && (
        <div class="dropdown dropdown-end" id="member-dropdown">
          <input type="hidden" name="user_id" id="member-filter" value={userId} />
          <button
            type="button"
            tabindex={0}
            class="flex items-center gap-2 px-4 py-3 text-xs font-bold border border-base-300 bg-base-100 text-base-content rounded-2xl shadow-sm hover:border-base-content/30 transition-colors min-w-[160px]"
            aria-label="Filter by member"
            aria-haspopup="listbox"
            data-member-trigger
          >
            <Users size={16} class="stroke-current text-base-content/40" aria-hidden="true" />
            <span class="flex-1 text-left truncate" data-member-label>
              {userId
                ? members.find((member) => member.id === userId)?.name || 'All Members'
                : 'All Members'}
            </span>
            <ChevronDown
              size={14}
              class="stroke-current text-base-content/40 shrink-0"
              aria-hidden="true"
            />
          </button>
          <ul
            tabindex={0}
            class="dropdown-content z-50 menu p-2 shadow-lg bg-base-100 rounded-2xl w-56 border border-base-300 mt-2"
            data-member-dropdown
          >
            <li>
              <a
                href={buildFilterUrl({ user_id: '' })}
                class={`${!userId ? 'active' : ''}`}
                data-member-option
                data-member-id=""
              >
                All Members
              </a>
            </li>
            {members.map((member) => (
              <li>
                <a
                  href={buildFilterUrl({ user_id: member.id })}
                  class={`${userId === member.id ? 'active' : ''}`}
                  data-member-option
                  data-member-id={member.id}
                >
                  {member.name}
                </a>
              </li>
            ))}
          </ul>
        </div>
      )
    }
  </div>
</form>

<script>
  import { PERIOD_CHANGE_EVENT, FILTERS_RESET_EVENT } from '@/lib/constants/events';

  let selectedPeriod = '';

  // Get current month from reset button
  function getCurrentMonth(): string {
    const resetBtn = document.querySelector('[data-reset-filters]') as HTMLElement;
    return resetBtn?.dataset.currentMonth || '';
  }

  function getInitialSelectedMonth(): string {
    const form = document.getElementById('transaction-filters-form') as HTMLElement | null;
    return form?.dataset.selectedMonth || '';
  }

  function getCurrentUserFilter(): string {
    const memberFilter = document.getElementById('member-filter') as HTMLInputElement | null;
    return memberFilter?.value || '';
  }

  function getCurrentTypeFilter(): string {
    let currentType = 'expense';
    document.querySelectorAll('[data-filter-type]').forEach((btn) => {
      if (btn.getAttribute('aria-pressed') === 'true') {
        currentType = btn.getAttribute('data-filter-type') || 'expense';
      }
    });
    return currentType;
  }

  // Check if filters are active and update reset button visibility
  function updateResetButtonVisibility() {
    const resetBtn = document.querySelector('[data-reset-filters]');
    if (!resetBtn) return;

    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const currentMonth = getCurrentMonth();
    const currentType = getCurrentTypeFilter();
    const categoryFilter = document.getElementById('category-filter') as HTMLInputElement | null;
    const hasCategories = categoryFilter ? categoryFilter.value.trim() !== '' : false;
    const accountFilter = document.getElementById('account-filter') as HTMLInputElement | null;
    const hasAccounts = accountFilter ? accountFilter.value.trim() !== '' : false;

    const hasFilters =
      currentType !== 'expense' ||
      (searchInput && searchInput.value.trim() !== '') ||
      hasCategories ||
      hasAccounts ||
      getCurrentUserFilter() !== '' ||
      (selectedPeriod !== '' && selectedPeriod !== currentMonth);

    resetBtn.classList.toggle('hidden', !hasFilters);
  }

  // Handle type filter button clicks
  document.querySelectorAll<HTMLButtonElement>('[data-filter-type]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const filterType = btn.dataset.filterType;
      const hiddenInput = document.getElementById('type-filter-hidden') as HTMLInputElement;

      // Update hidden input
      if (hiddenInput && filterType) {
        hiddenInput.value = filterType;
      }

      // Update aria-pressed states on all buttons
      document.querySelectorAll('[data-filter-type]').forEach((button) => {
        button.setAttribute(
          'aria-pressed',
          button.getAttribute('data-filter-type') === filterType ? 'true' : 'false'
        );

        // Update visual styles
        const isActive = button.getAttribute('data-filter-type') === filterType;
        button.classList.toggle('bg-base-100', isActive);
        button.classList.toggle('shadow', isActive);
        button.classList.toggle('text-primary', isActive);
        button.classList.toggle('text-base-content/50', !isActive);
      });

      if (filterType) {
        window.dispatchEvent(
          new CustomEvent('multiselect:filter', {
            detail: { id: 'category', filterType },
          })
        );
      }

      window.dispatchEvent(
        new CustomEvent('filterChange', {
          detail: { type: 'type', value: filterType },
        })
      );

      updateResetButtonVisibility();
    });
  });

  // Listen for period changes from PeriodNavigator component
  window.addEventListener(PERIOD_CHANGE_EVENT, (e: Event) => {
    const customEvent = e as CustomEvent;
    const { period } = customEvent.detail;
    selectedPeriod = period || '';

    // Update reset button visibility
    updateResetButtonVisibility();

    // Dispatch filterChange event for compatibility with existing page handlers
    window.dispatchEvent(
      new CustomEvent('filterChange', { detail: { type: 'month', value: period } })
    );
  });

  // Listen for search input changes to update reset button
  const searchInput = document.getElementById('search-input');
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      updateResetButtonVisibility();
    });
  }

  // Listen for generic filterChange events to keep reset visibility in sync
  window.addEventListener('filterChange', () => {
    updateResetButtonVisibility();
  });

  // Listen for filters reset to clear non-multiselect state/UI
  window.addEventListener(FILTERS_RESET_EVENT, () => {
    // Clear search input
    const searchEl = document.getElementById('search-input') as HTMLInputElement;
    if (searchEl) searchEl.value = '';

    const memberFilter = document.getElementById('member-filter') as HTMLInputElement | null;
    if (memberFilter) memberFilter.value = '';
    const memberLabel = document.querySelector('[data-member-label]');
    if (memberLabel) memberLabel.textContent = 'All Members';

    selectedPeriod = getCurrentMonth();

    updateResetButtonVisibility();
  });

  selectedPeriod = getInitialSelectedMonth();
  updateResetButtonVisibility();
</script>
