---
/**
 * Asset Update Todo List Component (Organism)
 *
 * @TODO: Maybe deprecate this component in favor of a more comprehensive Asset Management module.
 *
 * Displays a list of assets that need updating, sorted by priority.
 * Shows priority indicators (red/yellow/green) based on days since last update.
 *
 * @param {Array} assets - Array of asset items needing update
 * @param {boolean} loading - Show loading skeleton
 * @param {string} className - Additional CSS classes
 */

import Card from '../atoms/Card.astro';
import Badge from '../atoms/Badge.astro';
import EmptyState from '../atoms/EmptyState.astro';
import Skeleton from '../atoms/Skeleton.astro';
import { Calendar, Pencil, X, RefreshCw } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';

export interface AssetUpdateTodoItem {
  id: string;
  name: string;
  type: 'bank_account' | 'mutual_fund' | 'bond' | 'crypto' | 'stock' | 'other';
  balance: number;
  currency: string;
  daysSinceUpdate: number;
  lastUpdated: Date;
  priority: 'high' | 'medium' | 'low' | 'none';
}

export interface Props {
  assets?: AssetUpdateTodoItem[];
  loading?: boolean;
  className?: string;
}

const { assets = [], loading = false, className = '' } = Astro.props;

const getPriorityLabel = (days: number): string => {
  if (days === 1) return '1 day ago';
  return `${days} days ago`;
};

const getAssetTypeLabel = (type: string): string => {
  const labels: Record<string, string> = {
    bank_account: 'Bank Account',
    mutual_fund: 'Mutual Fund',
    bond: 'Bond',
    crypto: 'Crypto',
    stock: 'Stock',
    other: 'Other',
  };
  return labels[type] || type;
};

// Sort assets by priority (high -> medium -> low -> none)
const sortedAssets = [...assets].sort((a, b) => {
  const priorityOrder = { high: 0, medium: 1, low: 2, none: 3 };
  return priorityOrder[a.priority] - priorityOrder[b.priority];
});
---

<Card className={className} data-asset-update-todo-list>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold flex items-center gap-2">
      <Calendar size={20} class="stroke-current text-warning" aria-hidden="true" />
      Asset Updates Needed
    </h2>
    {
      !loading && assets.length > 0 && (
        <Badge variant="warning" size="sm">
          {assets.length}
        </Badge>
      )
    }
  </div>

  {
    loading ? (
      // Loading skeleton
      <div class="space-y-3" role="status" aria-live="polite" aria-label="Loading asset updates">
        {[1, 2, 3].map(() => (
          <div class="flex items-center gap-4 p-3 bg-base-200 rounded-lg">
            <Skeleton variant="circular" width="32px" height="32px" />
            <div class="flex-1 space-y-2">
              <Skeleton variant="rectangular" width="75%" height="16px" />
              <Skeleton variant="rectangular" width="50%" height="12px" />
            </div>
          </div>
        ))}
      </div>
    ) : sortedAssets.length === 0 ? (
      // Empty state - all assets up to date
      <EmptyState
        title="All assets up to date!"
        message="You don't have any assets that need updating right now. Great job staying on top of your finances!"
        iconName="check"
        variant="compact"
      />
    ) : (
      // Asset list
      <ul class="space-y-2" role="list" aria-label="Assets needing updates">
        {sortedAssets.map((asset) => (
          <li
            class={`flex items-center gap-4 p-3 rounded-lg border transition-all ${
              asset.priority === 'high'
                ? 'bg-error/10 border-error/20 hover:bg-error/20'
                : asset.priority === 'medium'
                  ? 'bg-warning/10 border-warning/20 hover:bg-warning/20'
                  : asset.priority === 'low'
                    ? 'bg-success/10 border-success/20 hover:bg-success/20'
                    : 'bg-base-200 border-base-300 hover:bg-base-100'
            }`}
          >
            {/* Priority badge */}
            <div class="shrink-0" role="status" aria-label={`Priority: ${asset.priority}`}>
              <Badge
                variant={
                  asset.priority === 'high'
                    ? 'error'
                    : asset.priority === 'medium'
                      ? 'warning'
                      : asset.priority === 'low'
                        ? 'success'
                        : 'neutral'
                }
                size="sm"
              >
                {asset.priority === 'high'
                  ? 'High'
                  : asset.priority === 'medium'
                    ? 'Medium'
                    : asset.priority === 'low'
                      ? 'Low'
                      : 'OK'}
              </Badge>
            </div>

            {/* Asset info */}
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1">
                <span class="font-medium truncate text-base-content">{asset.name}</span>
                <Badge variant="neutral" size="sm" outline>
                  {getAssetTypeLabel(asset.type)}
                </Badge>
              </div>
              <div class="flex items-center gap-3 text-sm text-base-content/60">
                <span class="font-mono font-medium">
                  {formatCurrency(asset.balance, asset.currency)}
                </span>
                <span aria-hidden="true">•</span>
                <span class={asset.priority === 'high' ? 'text-error font-medium' : ''}>
                  {getPriorityLabel(asset.daysSinceUpdate)}
                </span>
              </div>
            </div>

            {/* Quick update button */}
            <button
              class="shrink-0 btn btn-ghost btn-sm hover:bg-base-100"
              aria-label={`Update ${asset.name}`}
              data-asset-id={asset.id}
              data-update-asset
              type="button"
            >
              <Pencil size={16} class="stroke-current" aria-hidden="true" />
            </button>

            {/* Dismiss button */}
            <button
              class="flex-shrink-0 btn btn-ghost btn-sm text-base-content/60 hover:text-base-content hover:bg-base-100"
              aria-label={`Dismiss ${asset.name} reminder`}
              data-asset-id={asset.id}
              data-dismiss-reminder
              type="button"
            >
              <X size={16} class="stroke-current" aria-hidden="true" />
            </button>
          </li>
        ))}
      </ul>
    )
  }

  {/* Update all button */}
  {
    !loading && sortedAssets.length > 0 && (
      <div class="mt-4 pt-4 border-t border-base-300">
        <button
          class="btn btn-accent btn-sm w-full gap-2"
          aria-label="Update all assets"
          data-update-all-assets
        >
          <RefreshCw size={16} class="stroke-current" aria-hidden="true" />
          Update All Assets
        </button>
      </div>
    )
  }
</Card>

<script>
  import { addToast } from '@lib/stores/toastStore';

  // Handle update button clicks
  document.querySelectorAll('[data-update-asset]').forEach((button) => {
    button.addEventListener('click', () => {
      addToast('Asset editing coming soon!', 'info');
    });
  });

  // Handle dismiss button clicks
  document.querySelectorAll('[data-dismiss-reminder]').forEach((button) => {
    button.addEventListener('click', () => {
      addToast('Reminder dismissed', 'success');
      // Remove the list item with animation
      const listItem = button.closest('li');
      if (listItem) {
        listItem.style.opacity = '0';
        setTimeout(() => listItem.remove(), 300);
      }
    });
  });

  // Handle update all button
  const updateAllButton = document.querySelector('[data-update-all-assets]');
  if (updateAllButton) {
    updateAllButton.addEventListener('click', () => {
      addToast('Bulk update coming soon!', 'info');
    });
  }
</script>
