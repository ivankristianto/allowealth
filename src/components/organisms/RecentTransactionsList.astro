---
/**
 * Recent Transactions List Component (Organism)
 *
 * Displays the last 5 transactions with date, category, amount,
 * and payment method. Shows income in green and expenses in red.
 *
 * @param {Array} transactions - Array of recent transactions
 * @param {boolean} loading - Show loading skeleton
 * @param {string} viewAllUrl - URL for "View All" link
 * @param {string} className - Additional CSS classes
 */

import Card from '../atoms/Card.astro';
import EmptyState from '../atoms/EmptyState.astro';
import Currency from '../atoms/Currency.astro';
import IconBadge from '../atoms/IconBadge.astro';
import TransactionCard from '../molecules/TransactionCard.astro';
import { CreditCard } from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';
import { getCategoryMeta } from '@/lib/utils/categoryMeta';

export interface Props {
  transactions?: TransactionOutput[];
  loading?: boolean;
  viewAllUrl?: string;
  className?: string;
}

const {
  transactions = [],
  loading = false,
  viewAllUrl = '/transactions',
  className = '',
} = Astro.props;

const maxTransactions = 6;
const displayTransactions = transactions.slice(0, maxTransactions);

const primaryTextForTransaction = (transaction: TransactionOutput) =>
  transaction.description?.trim() || transaction.category.name;

// Format date for display with recent context
const formatActivityDate = (date: Date): string => {
  const now = new Date();
  const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const startOfDate = new Date(date.getFullYear(), date.getMonth(), date.getDate());
  const diffDays = Math.round((startOfToday.getTime() - startOfDate.getTime()) / 86400000);
  const time = date.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });

  if (diffDays === 0) {
    return `Today, ${time}`;
  }
  if (diffDays === 1) {
    return `Yesterday, ${time}`;
  }

  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};
---

<div class={`space-y-5 ${className}`} data-recent-transactions-list>
  <div class="flex items-center justify-between px-2">
    <h2 class="text-lg font-bold tracking-tight leading-none">Recent activity</h2>
    {
      !loading && transactions.length > 0 && (
        <a
          href={viewAllUrl}
          class="btn btn-outline btn-sm text-accent border-accent/20 hover:bg-accent/5 rounded-xl tracking-wide"
          aria-label="View all transactions"
        >
          View all
        </a>
      )
    }
  </div>

  <Card rounded="card-lg" padding="sm" className="p-0 overflow-hidden shadow-sm">
    {
      loading ? (
        // Loading skeleton
        <div
          class="divide-y divide-base-200"
          role="status"
          aria-live="polite"
          aria-label="Loading recent transactions"
        >
          {[1, 2, 3, 4, 5, 6].map(() => (
            <div class="flex items-center gap-5 p-5 animate-pulse">
              <div class="h-12 w-12 rounded-2xl bg-base-200" aria-hidden="true" />
              <div class="flex-1 space-y-2">
                <div class="h-4 bg-base-200 rounded w-3/4" aria-hidden="true" />
                <div class="h-3 bg-base-200 rounded w-1/2" aria-hidden="true" />
              </div>
              <div class="w-24 space-y-2">
                <div class="h-4 bg-base-200 rounded" aria-hidden="true" />
                <div class="h-3 bg-base-200 rounded" aria-hidden="true" />
              </div>
            </div>
          ))}
        </div>
      ) : displayTransactions.length === 0 ? (
        // Empty state
        <EmptyState
          title="No transactions yet"
          message="Start tracking by adding your first expense or income transaction."
          iconName="plus"
          actionLabel="Add Transaction"
          actionHref="/transactions/add"
          variant="compact"
        />
      ) : (
        // Transactions list - Mobile uses TransactionCard, Desktop uses inline layout
        <>
          {/* Mobile view: Stack layout with TransactionCard */}
          <ul
            class="md:hidden divide-y divide-base-200"
            role="list"
            aria-label="Recent transactions"
          >
            {displayTransactions.map((transaction) => (
              <li>
                <TransactionCard transaction={transaction} showActions={false} />
              </li>
            ))}
          </ul>

          {/* Desktop view: Inline layout */}
          <ul
            class="hidden md:block divide-y divide-base-200"
            role="list"
            aria-label="Recent transactions"
          >
            {displayTransactions.map((transaction) => {
              const amount = parseFloat(transaction.amount) || 0;
              const isExpense = transaction.type === 'expense';
              const date = new Date(transaction.transaction_date);
              const primaryText = primaryTextForTransaction(transaction);
              const categoryMeta = getCategoryMeta(transaction.category.name, transaction.type);
              const CategoryIcon = categoryMeta.icon;

              return (
                <li
                  class={`group flex items-center gap-5 p-5 transition-all cursor-pointer border-l-4 border-transparent ${
                    isExpense ? 'hover:border-error/30' : 'hover:border-success/30'
                  } hover:bg-base-200/40`}
                >
                  <IconBadge
                    variant={categoryMeta.variant}
                    size="sm"
                    className="rounded-2xl transition-transform group-hover:rotate-2"
                  >
                    <CategoryIcon size={18} class="stroke-current" aria-hidden="true" />
                  </IconBadge>

                  <div class="flex-1 min-w-0">
                    <div class="flex items-start justify-between gap-4">
                      <div class="min-w-0">
                        <div class="font-bold tracking-tight truncate text-base leading-none">
                          {primaryText}
                        </div>
                        <div class="mt-2 flex flex-wrap items-center gap-3 text-[11px] font-semibold text-base-content/60 tracking-wide leading-none">
                          <span class="text-[10px] font-bold tracking-widest uppercase text-base-content/60 bg-base-200 px-2 py-0.5 rounded">
                            {transaction.category.name}
                          </span>
                          <time datetime={date.toISOString()}>{formatActivityDate(date)}</time>
                        </div>
                      </div>

                      <div class="flex flex-col items-end gap-1 shrink-0">
                        <Currency
                          amount={amount}
                          currency={transaction.currency}
                          showSign={true}
                          variant={isExpense ? 'negative' : 'positive'}
                          size="md"
                          className="font-bold tracking-tight"
                        />
                        <div class="flex items-center gap-1.5 text-[10px] uppercase tracking-widest text-base-content/60">
                          <CreditCard size={12} class="stroke-current" aria-hidden="true" />
                          <span>{transaction.payment_method.name}</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </li>
              );
            })}
          </ul>
        </>
      )
    }
  </Card>
</div>
