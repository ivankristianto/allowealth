---
/**
 * Recent Transactions List Component (Organism)
 *
 * Displays the last 5 transactions with date, category, amount,
 * and payment method. Shows income in green and expenses in red.
 *
 * @param {Array} transactions - Array of recent transactions
 * @param {boolean} loading - Show loading skeleton
 * @param {string} viewAllUrl - URL for "View All" link
 * @param {string} className - Additional CSS classes
 */

import Card from '../atoms/Card.astro';
import Badge from '../atoms/Badge.astro';
import EmptyState from '../atoms/EmptyState.astro';
import Currency from '../atoms/Currency.astro';
import { Clock, ArrowRight, DollarSign, CreditCard, ArrowLeft, Wallet } from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';
import { formatCurrency } from '@/lib/tokens';

export interface Props {
  transactions?: TransactionOutput[];
  loading?: boolean;
  viewAllUrl?: string;
  className?: string;
}

const {
  transactions = [],
  loading = false,
  viewAllUrl = '/transactions',
  className = '',
} = Astro.props;

const maxTransactions = 5;
const displayTransactions = transactions.slice(0, maxTransactions);

// Format date for display
const formatDate = (date: Date): string => {
  return date.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric',
  });
};

// Type alias for payment method icon components
type PaymentIconComponent =
  | typeof DollarSign
  | typeof CreditCard
  | typeof ArrowLeft
  | typeof Wallet;

// Payment method icon mapping - returns Lucide component type
const getPaymentIconComponent = (type: string): PaymentIconComponent => {
  const icons: Record<string, PaymentIconComponent> = {
    cash: DollarSign,
    credit_card: CreditCard,
    debit_card: CreditCard,
    bank_transfer: ArrowLeft,
    e_wallet: Wallet,
  };
  return icons[type] || DollarSign;
};
---

<Card className={className} data-recent-transactions-list>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold flex items-center gap-2">
      <Clock size={20} class="stroke-current text-info" aria-hidden="true" />
      Recent Transactions
    </h2>
    {
      !loading && transactions.length > maxTransactions && (
        <a
          href={viewAllUrl}
          class="text-sm text-primary hover:text-primary-hover font-medium flex items-center gap-1 transition-colors"
        >
          View All
          <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
        </a>
      )
    }
  </div>

  {
    loading ? (
      // Loading skeleton
      <div
        class="space-y-3"
        role="status"
        aria-live="polite"
        aria-label="Loading recent transactions"
      >
        {[1, 2, 3, 4, 5].map(() => (
          <div class="flex items-center gap-4 p-4 bg-base-200 rounded-lg animate-pulse">
            <div class="w-20 h-4 bg-neutral-300 rounded" aria-hidden="true" />
            <div class="flex-1 space-y-2">
              <div class="h-4 bg-neutral-300 rounded w-3/4" aria-hidden="true" />
              <div class="h-3 bg-neutral-300 rounded w-1/2" aria-hidden="true" />
            </div>
            <div class="w-24 h-4 bg-neutral-300 rounded" aria-hidden="true" />
          </div>
        ))}
      </div>
    ) : displayTransactions.length === 0 ? (
      // Empty state
      <EmptyState
        title="No transactions yet"
        message="Start tracking by adding your first expense or income transaction."
        iconName="plus"
        actionLabel="Add Transaction"
        actionHref="/transactions/add"
        variant="compact"
      />
    ) : (
      // Transactions list
      <ul class="space-y-1" role="list" aria-label="Recent transactions">
        {displayTransactions.map((transaction) => {
          const amount = parseFloat(transaction.amount) || 0;
          const isExpense = transaction.type === 'expense';
          const date = new Date(transaction.transaction_date);

          return (
            <li class="flex items-center gap-4 p-4 hover:bg-base-200 rounded-lg transition-colors group">
              {/* Date */}
              <div class="flex-shrink-0 w-20 text-sm">
                <time class="font-medium" datetime={date.toISOString()}>
                  {formatDate(date)}
                </time>
              </div>

              {/* Category & Description */}
              <div class="flex-1 min-w-0">
                <div class="font-medium truncate group-hover:text-primary transition-colors">
                  {transaction.category.name}
                </div>
                {transaction.description && (
                  <div class="text-sm text-neutral-500 truncate">{transaction.description}</div>
                )}
              </div>

              {/* Payment Method */}
              <div class="flex-shrink-0 hidden sm:block">
                <Badge variant="neutral" size="sm" className="flex items-center gap-1">
                  {(() => {
                    const PaymentIcon = getPaymentIconComponent(transaction.payment_method.type);
                    return <PaymentIcon size={12} class="stroke-current" aria-hidden="true" />;
                  })()}
                  {transaction.payment_method.name}
                </Badge>
              </div>

              {/* Amount */}
              <div class="flex-shrink-0 text-right min-w-[100px]">
                <Currency
                  amount={amount}
                  currency={transaction.currency}
                  showSign={true}
                  variant={isExpense ? 'negative' : 'positive'}
                  size="md"
                />
              </div>

              {/* Quick action link */}
              <a
                href={`/transactions/${transaction.id}`}
                class="flex-shrink-0 opacity-0 group-hover:opacity-100 transition-opacity btn btn-ghost btn-sm"
                aria-label={`View ${transaction.category.name} transaction for ${formatCurrency(amount, transaction.currency)}`}
              >
                <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
              </a>
            </li>
          );
        })}
      </ul>
    )
  }

  {/* View all button */}
  {
    !loading && displayTransactions.length > 0 && (
      <div class="mt-4 pt-4 border-t border-base-300">
        <a
          href={viewAllUrl}
          class="flex items-center justify-center gap-2 w-full py-2 px-4 bg-base-200 hover:bg-base-300 rounded-lg transition-colors text-sm font-medium group"
        >
          View All Transactions
          <ArrowRight
            size={16}
            class="stroke-current group-hover:translate-x-1 transition-transform"
            aria-hidden="true"
          />
        </a>
      </div>
    )
  }
</Card>
