---
/**
 * BudgetCard Component
 *
 * Individual budget category card showing spending progress.
 * Part of the premium Budget page redesign (Task 15).
 *
 * @param {string} categoryId - Category ID for edit link
 * @param {string} categoryName - Display name for the category
 * @param {string} icon - Lucide icon name for the category
 * @param {number} spent - Amount spent in this category
 * @param {number} budget - Budget limit for this category
 * @param {number} percentageUsed - Percentage of budget used (0-100+)
 * @param {'ok' | 'warning' | 'exceeded'} status - Budget status
 * @param {string} currency - Currency code (IDR or USD)
 * @param {boolean} loading - Show loading skeleton state
 * @param {string} className - Additional CSS classes
 */

// External packages
import {
  Pencil,
  Eye,
  House,
  ShoppingCart,
  Utensils,
  Car,
  Film,
  Zap,
  Briefcase,
  Heart,
  GraduationCap,
  Shirt,
  Gift,
  Plane,
  CircleDollarSign,
  // Additional icons used by categories
  ShoppingBasket,
  Wallet,
  User,
  Users,
  Package,
  Smile,
  Hammer,
  Shield,
  Repeat,
  Banknote,
  TrendingUp,
  CircleDot,
  Tag,
} from '@lucide/astro';

// Internal aliases - lib
import { formatCurrency } from '@/lib/formatting';
import { getBudgetStatus } from '@/lib/utils/budget';
import { getIconForCategory } from '@/lib/utils/categoryIcons';

// Internal aliases - components
import Badge from '@components/atoms/Badge.astro';
import IconBadge from '@components/atoms/IconBadge.astro';
import ProgressBar from '@components/atoms/ProgressBar.astro';
import StatLabel from '@components/atoms/StatLabel.astro';
import Skeleton from '@components/atoms/Skeleton.astro';

export interface Props {
  categoryId?: string;
  categoryName: string;
  icon?: string;
  /** Category color (hex value) for the icon badge */
  color?: string;
  spent: number;
  budget: number;
  percentageUsed: number;
  status?: 'ok' | 'warning' | 'exceeded';
  currency?: 'IDR' | 'USD';
  /** Selected month (1-12) for transaction link context */
  month?: number;
  /** Selected year for transaction link context */
  year?: number;
  loading?: boolean;
  className?: string;
}

const {
  categoryId,
  categoryName,
  icon = 'CircleDollarSign',
  color,
  spent,
  budget,
  percentageUsed,
  currency = 'IDR',
  month,
  year,
  loading = false,
  className = '',
} = Astro.props;

// Build transaction link with optional period context
const transactionParams = new URLSearchParams({
  category_id: categoryId || '',
  type: 'expense',
});
if (month) transactionParams.set('month', String(month));
if (year) transactionParams.set('year', String(year));
const transactionUrl = `/transactions?${transactionParams.toString()}`;

// Calculate remaining amount
const remaining = budget - spent;

const budgetStatus = getBudgetStatus(percentageUsed);
const progressStatus = budgetStatus.status;
const iconBadgeVariant: 'success' | 'warning' | 'error' | 'neutral' = 'neutral';

// Get the icon component using the shared utility
// Resolve icon name from category name if not explicitly provided
const iconName = icon || getIconForCategory(categoryName, 'CircleDollarSign');

// Category icon component mapping (supports both PascalCase and kebab-case)
// IMPORTANT: Keep this map in sync with:
// - src/lib/utils/categoryIcons.ts (PascalCase names returned by getIconForCategory)
// - src/db/seed.ts CATEGORY_STYLES (kebab-case names stored in database)
// When adding new icons, update all three locations.
const iconMap: Record<string, typeof House> = {
  // PascalCase names (from categoryIcons utility)
  House,
  ShoppingCart,
  Utensils,
  Car,
  Film,
  Zap,
  Briefcase,
  Heart,
  GraduationCap,
  Shirt,
  Gift,
  Plane,
  CircleDollarSign,
  // Additional icons
  ShoppingBasket,
  Wallet,
  User,
  Users,
  Package,
  Smile,
  Hammer,
  Shield,
  Repeat,
  Banknote,
  TrendingUp,
  CircleDot,
  Tag,
  // kebab-case aliases (from database seed data)
  'shopping-basket': ShoppingBasket,
  'shopping-cart': ShoppingCart,
  'trending-up': TrendingUp,
  'circle-dot': CircleDot,
  home: House,
  plane: Plane,
  utensils: Utensils,
  briefcase: Briefcase,
  wallet: Wallet,
  heart: Heart,
  user: User,
  zap: Zap,
  package: Package,
  smile: Smile,
  users: Users,
  car: Car,
  hammer: Hammer,
  shield: Shield,
  repeat: Repeat,
  banknote: Banknote,
  tag: Tag,
};

// Get the icon component, fallback to CircleDollarSign
// P3 TODO: Consider logging missing icons in dev mode for easier debugging
const IconComponent = iconMap[iconName] || iconMap[iconName.toLowerCase()] || CircleDollarSign;

const cardClasses = [
  // Base card styling
  'bg-base-100 rounded-card border border-base-300',
  // Premium shadow and hover effect
  'shadow-sm hover:shadow-xl transition-all duration-300',
  // Responsive padding - compact on mobile, spacious on desktop
  'p-4 md:p-6 lg:p-8',
  // Full height with flex column for equal row heights
  'h-full flex flex-col',
  // Group for hover effects
  'group',
  // Additional classes
  className,
]
  .filter(Boolean)
  .join(' ');
---

{
  loading ? (
    <div class={cardClasses} aria-busy="true" aria-label="Loading budget card">
      <div class="flex justify-between items-start mb-6">
        <div class="flex items-center gap-4">
          <Skeleton variant="circular" size="lg" />
          <div class="space-y-2">
            <Skeleton variant="text" width="120px" />
            <Skeleton variant="text" width="80px" height="20px" />
          </div>
        </div>
        <Skeleton variant="circular" size="sm" />
      </div>
      <div class="space-y-4">
        <div class="flex justify-between">
          <div class="space-y-1">
            <Skeleton variant="text" width="40px" />
            <Skeleton variant="text" width="100px" />
          </div>
          <div class="space-y-1 text-right">
            <Skeleton variant="text" width="50px" />
            <Skeleton variant="text" width="90px" />
          </div>
        </div>
        <Skeleton variant="rectangular" width="100%" height="12px" className="rounded-full" />
        <Skeleton variant="rectangular" width="100%" height="48px" className="rounded-2xl" />
      </div>
    </div>
  ) : (
    <article
      class={cardClasses}
      aria-label={`Budget for ${categoryName}`}
      data-budget-card={categoryId}
      data-testid="budget-card"
      data-category-id={categoryId}
      data-spent={spent}
    >
      {/* Header: Icon, Name, Status Badge, Edit Button */}
      <div class="flex justify-between items-start mb-3 md:mb-6 lg:mb-8">
        <div class="flex items-center gap-2 md:gap-3 lg:gap-4">
          <IconBadge
            variant={iconBadgeVariant}
            size="sm"
            customColor={color}
            className="group-hover:scale-110 transition-transform !p-2 md:!p-3"
          >
            <IconComponent size={16} class="stroke-current md:hidden" aria-hidden="true" />
            <IconComponent size={20} class="stroke-current hidden md:block" aria-hidden="true" />
          </IconBadge>
          <div>
            <h3 class="font-bold text-sm md:text-base text-base-content tracking-tight leading-none">
              {categoryName}
            </h3>
            <span
              class="inline-block mt-1 md:mt-2"
              data-status-badge
              data-testid="budget-percentage"
            >
              <Badge
                variant={budgetStatus.badgeVariant}
                size="sm"
                className="text-[9px] md:text-[10px] uppercase tracking-wider"
              >
                {Math.round(percentageUsed)}% Used
              </Badge>
            </span>
          </div>
        </div>
        <div class="flex items-center gap-1">
          <a
            href={transactionUrl}
            class="inline-flex items-center gap-1 text-base-content/30 hover:text-base-content/60 transition-colors min-h-[44px] min-w-[44px] justify-center rounded-lg hover:bg-base-200 text-xs font-medium"
            aria-label={`View ${categoryName} transactions`}
          >
            <Eye size={16} class="stroke-current" aria-hidden="true" />
            <span class="hidden md:inline">View</span>
          </a>
          <button
            type="button"
            class="inline-flex items-center gap-1 text-base-content/30 hover:text-base-content/60 transition-colors min-h-[44px] min-w-[44px] justify-center rounded-lg hover:bg-base-200 text-xs font-medium"
            aria-label={`Edit ${categoryName} budget`}
            data-edit-budget={categoryId}
          >
            <Pencil size={16} class="stroke-current" aria-hidden="true" />
            <span class="hidden md:inline">Edit</span>
          </button>
        </div>
      </div>

      {/* Body: Spent/Budget amounts and Progress bar */}
      <div class="space-y-2 md:space-y-4 flex-grow flex flex-col">
        <div class="flex justify-between items-end">
          <div>
            <StatLabel size="sm" className="text-[10px] md:text-xs">
              Spent
            </StatLabel>
            <p
              class="text-base md:text-lg font-bold mt-0.5 md:mt-1 text-base-content leading-none"
              data-testid="budget-spent"
            >
              {formatCurrency(spent, currency)}
            </p>
          </div>
          <div class="text-right">
            <StatLabel size="sm" className="text-[10px] md:text-xs">
              Budget
            </StatLabel>
            <p
              class="text-xs md:text-sm font-bold mt-0.5 md:mt-1 text-base-content/60 leading-none"
              data-budget-amount
              data-testid="budget-amount"
            >
              {formatCurrency(budget, currency)}
            </p>
          </div>
        </div>

        <div data-progress-container>
          <ProgressBar
            value={Math.min(percentageUsed, 100)}
            status={progressStatus}
            size="sm"
            animate={true}
            className="md:h-3"
          />
        </div>

        {/* Footer: Only show warning when over budget or nearly exceeded */}
        {(budgetStatus.status === 'danger' || budgetStatus.status === 'warning') && (
          <div
            class={`mt-auto p-2.5 md:p-4 rounded-xl md:rounded-2xl border ${
              budgetStatus.status === 'danger'
                ? 'bg-error/5 border-error/10 text-error'
                : 'bg-warning/5 border-warning/10 text-warning'
            }`}
            data-footer
          >
            <div class="flex justify-between items-center text-[10px] md:text-xs font-bold leading-none">
              <span class="uppercase tracking-widest" data-footer-label>
                {budgetStatus.status === 'danger' ? 'Over budget' : 'Almost exceeded'}
              </span>
              <span
                class={budgetStatus.status === 'danger' ? 'text-error' : 'text-warning'}
                data-footer-amount
              >
                {budgetStatus.status === 'danger'
                  ? formatCurrency(Math.abs(remaining), currency)
                  : `${Math.round(percentageUsed)}%`}
              </span>
            </div>
          </div>
        )}
      </div>
    </article>
  )
}
