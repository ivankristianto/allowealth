---
/**
 * Header Component
 *
 * Premium glass-effect header with page title, subtitle, currency selector,
 * notifications, and new entry button. Displays user context when authenticated.
 *
 * @param title - Page title (required, defined by each page)
 * @param subtitle - Optional page subtitle
 * @param showMenuToggle - Show mobile menu toggle button
 * @param user - Authenticated user object
 */

import { Menu, Plus } from '@lucide/astro';
import CurrencySelector from '../molecules/CurrencySelector.astro';
import NotificationDropdown from '../molecules/NotificationDropdown.astro';
import ThemeToggle from '../atoms/ThemeToggle.astro';
import Button from '../atoms/Button.astro';
import type { User } from '@/lib/auth/lucia';

interface Props {
  /** Page title displayed in header (required) */
  title: string;
  /** Optional page subtitle */
  subtitle?: string;
  /** Show mobile menu toggle button */
  showMenuToggle?: boolean;
  /** Authenticated user object */
  user?: User | null;
}

const { title, subtitle, showMenuToggle = true, user } = Astro.props;
---

<header
  class="fixed top-0 left-0 right-0 lg:left-64 lg:group-data-[sidebar-collapsed=true]:left-20 z-40 bg-base-100/80 backdrop-blur-xl px-4 sm:px-6 lg:px-10 py-4 sm:py-5 min-h-16 sm:min-h-20 flex items-center justify-between gap-4 border-b border-base-300/50 transition-[left] duration-300 ease-out"
>
  <!-- Left side: Menu toggle + Page title + Subtitle -->
  <div class="flex items-center gap-3">
    {
      showMenuToggle && (
        <label
          for="drawer-toggle"
          class="btn btn-square btn-ghost btn-sm lg:hidden"
          aria-label="Toggle menu"
        >
          <Menu size={24} class="stroke-current" aria-hidden="true" />
        </label>
      )
    }
    <div>
      <h1 class="text-2xl lg:text-3xl font-bold tracking-tight text-primary leading-none">
        {title}
      </h1>
      {
        subtitle && (
          <p class="text-sm font-medium text-neutral hidden sm:block mt-1.5 leading-none">
            {subtitle}
          </p>
        )
      }
    </div>
  </div>

  <!-- Right side: Currency selector + Notifications + New Entry button -->
  <div class="flex items-center gap-3 sm:gap-5">
    {
      user && (
        <div class="hidden sm:block">
          <CurrencySelector />
        </div>
      )
    }

    <!-- Theme Toggle (mobile/tablet only - desktop has floating toggle) -->
    <ThemeToggle size="sm" className="lg:hidden" />

    <NotificationDropdown />

    {
      user && (
        <Button
          id="new-entry-button"
          variant="accent"
          size="md"
          className="px-4 sm:px-6 active:scale-95"
        >
          <Plus size={20} class="stroke-current" aria-hidden="true" />
          <span class="hidden sm:inline">New Entry</span>
        </Button>
      )
    }
  </div>
</header>

<script>
  // New Entry button - opens expense modal
  const newEntryButton = document.getElementById('new-entry-button');
  newEntryButton?.addEventListener('click', () => {
    // Try to open expense modal directly if it exists
    const modal = document.getElementById('expense-modal') as HTMLDialogElement | null;
    if (modal) {
      modal.showModal();
    } else {
      // Dispatch custom event for pages without embedded modal
      document.dispatchEvent(
        new CustomEvent('open-transaction-modal', {
          detail: { type: 'expense' },
          bubbles: true,
        })
      );
    }
  });
</script>
