---
/**
 * Header Component
 *
 * Premium glass-effect header with page title, subtitle,
 * notifications, and new entry button. Displays user context when authenticated.
 *
 * @param title - Page title (required, defined by each page)
 * @param subtitle - Optional page subtitle
 * @param showMenuToggle - Show mobile menu toggle button
 * @param user - Authenticated user object
 */

import { Menu, Plus } from '@lucide/astro';
// TODO: Re-enable when notification system is implemented
// import NotificationDropdown from '../molecules/NotificationDropdown.astro';
import Button from '../atoms/Button.astro';
import CurrencySwitcher from '../atoms/CurrencySwitcher.astro';
import GreetingHeader from '../molecules/GreetingHeader.astro';
import type { AuthUser as User } from '@/lib/auth/types';
import type { Currency } from '@/lib/constants/currency';

interface Props {
  /** Page title displayed in header (required) */
  title: string;
  /** Optional page subtitle */
  subtitle?: string;
  /** Show mobile menu toggle button */
  showMenuToggle?: boolean;
  /** Authenticated user object */
  user?: User | null;
  /** Current URL path (passed through from layout) */
  currentPath?: string;
  /** Workspace primary currency */
  primaryCurrency?: Currency;
  /** Workspace secondary currency */
  secondaryCurrency?: Currency | null;
  /** User name for warm greeting */
  userName?: string;
  /** Current date for greeting */
  currentDate?: Date;
}

const {
  title,
  subtitle,
  showMenuToggle = false,
  user,
  primaryCurrency,
  secondaryCurrency,
  userName,
  currentDate,
} = Astro.props;
const hasHeaderSlot = Astro.slots.has('header');
const showNewTransactionButton = user != null && user.role !== 'super_admin';
---

<header
  class="fixed top-0 left-0 right-0 lg:left-64 lg:group-data-[sidebar-collapsed=true]:left-20 z-40 bg-base-100/95 border-b border-base-300/50 transition-[left] duration-300 ease-out"
>
  <!-- Main header bar -->
  <div
    class="flex items-center justify-between gap-4 px-4 sm:px-6 lg:px-10 py-4 sm:py-5 min-h-16 sm:min-h-20"
  >
    <!-- Left side: Menu toggle + Page title + Subtitle -->
    <div class="flex items-center gap-3">
      {
        showMenuToggle && (
          <Button
            variant="ghost"
            shape="square"
            className="rounded-lg min-h-11 min-w-11 lg:hidden border-0"
            data-drawer-open
            aria-label="Open menu"
            aria-controls="drawer-toggle"
            aria-expanded="false"
          >
            <Menu size={24} class="stroke-current" aria-hidden="true" />
          </Button>
        )
      }
      <div>
        {
          userName ? (
            <>
              <h1 class="sr-only">{title}</h1>
              <GreetingHeader userName={userName} currentDate={currentDate} />
            </>
          ) : (
            <>
              <h1 class="text-2xl lg:text-3xl font-bold tracking-tight text-primary leading-none">
                {title}
              </h1>
              {subtitle && (
                <p
                  class="text-base font-medium text-base-content/70 mt-1 sm:mt-2 leading-tight"
                  data-header-subtitle
                >
                  {subtitle}
                </p>
              )}
            </>
          )
        }
      </div>
    </div>

    <!-- Right side: Header slot content (desktop) + New Entry button -->
    <div class="flex items-center gap-3 sm:gap-5">
      {/* Header slot content inline on desktop (e.g., PeriodNavigator) */}
      {
        hasHeaderSlot && (
          <div class="hidden lg:block" data-header-slot-desktop>
            <slot name="header" />
          </div>
        )
      }

      {/* Currency Switcher */}
      {
        primaryCurrency && (
          <CurrencySwitcher
            primaryCurrency={primaryCurrency}
            secondaryCurrency={secondaryCurrency ?? null}
          />
        )
      }

      {/* TODO: Re-enable when notification system is implemented */}
      {/* <NotificationDropdown /> */}

      {
        showNewTransactionButton && (
          <div class="hidden lg:block">
            <Button
              id="bulk-entry-button"
              data-open-transaction-drawer
              variant="accent"
              size="md"
              className="px-6 active:scale-95"
              aria-label="New Transaction"
            >
              <Plus size={20} class="stroke-current" aria-hidden="true" />
              <span class="text-sm">New Transaction</span>
            </Button>
          </div>
        )
      }
    </div>
  </div>

  {/* Header slot content below main bar on mobile/tablet */}
  {
    hasHeaderSlot && (
      <div
        class="flex flex-wrap items-center justify-start gap-3 px-4 sm:px-6 pb-3 lg:hidden"
        data-header-slot-mobile
      >
        <slot name="header" />
      </div>
    )
  }
</header>

<script>
  import './Header.client';
</script>
