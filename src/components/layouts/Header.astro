---
/**
 * Header Component
 *
 * Premium glass-effect header with page title, subtitle, currency selector,
 * notifications, and new entry button. Displays user context when authenticated.
 *
 * @param title - Page title (required, defined by each page)
 * @param subtitle - Optional page subtitle
 * @param showMenuToggle - Show mobile menu toggle button
 * @param user - Authenticated user object
 */

import { Menu, Plus } from '@lucide/astro';
import CurrencySelector from '../molecules/CurrencySelector.astro';
// TODO: Re-enable when notification system is implemented
// import NotificationDropdown from '../molecules/NotificationDropdown.astro';
import ThemeToggle from '../atoms/ThemeToggle.astro';
import Button from '../atoms/Button.astro';
import type { User } from '@/lib/auth/lucia';

interface Props {
  /** Page title displayed in header (required) */
  title: string;
  /** Optional page subtitle */
  subtitle?: string;
  /** Show mobile menu toggle button */
  showMenuToggle?: boolean;
  /** Authenticated user object */
  user?: User | null;
}

const { title, subtitle, showMenuToggle = true, user } = Astro.props;
const hasHeaderSlot = Astro.slots.has('header');
const headerSlotHtml = hasHeaderSlot ? await Astro.slots.render('header') : '';
---

<header
  class="fixed top-0 left-0 right-0 lg:left-64 lg:group-data-[sidebar-collapsed=true]:left-20 z-40 bg-base-100/80 backdrop-blur-xl border-b border-base-300/50 transition-[left] duration-300 ease-out"
>
  <!-- Main header bar -->
  <div
    class="flex items-center justify-between gap-4 px-4 sm:px-6 lg:px-10 py-4 sm:py-5 min-h-16 sm:min-h-20"
  >
    <!-- Left side: Menu toggle + Page title + Subtitle -->
    <div class="flex items-center gap-3">
      {
        showMenuToggle && (
          <label
            for="drawer-toggle"
            class="btn btn-square btn-ghost btn-sm lg:hidden"
            aria-label="Toggle menu"
          >
            <Menu size={24} class="stroke-current" aria-hidden="true" />
          </label>
        )
      }
      <div>
        <h1 class="text-2xl lg:text-3xl font-bold tracking-tight text-primary leading-none">
          {title}
        </h1>
        {
          subtitle && (
            <p
              class="text-sm font-medium text-neutral mt-0.5 sm:mt-1.5 leading-none"
              data-header-subtitle
            >
              {subtitle}
            </p>
          )
        }
      </div>
    </div>

    <!-- Right side: Header slot content (desktop) + Currency selector + New Entry button -->
    <div class="flex items-center gap-3 sm:gap-5">
      {/* Header slot content inline on desktop (e.g., PeriodNavigator beside CurrencySelector) */}
      {
        hasHeaderSlot && (
          <div class="hidden lg:block" data-header-slot-desktop>
            <Fragment set:html={headerSlotHtml} />
          </div>
        )
      }

      {
        user && (
          <div class="hidden sm:block">
            <CurrencySelector />
          </div>
        )
      }

      <!-- Theme Toggle (mobile/tablet only - desktop has floating toggle) -->
      <ThemeToggle size="sm" className="lg:hidden" />

      {/* TODO: Re-enable when notification system is implemented */}
      {/* <NotificationDropdown /> */}

      {
        user && (
          <div class="hidden lg:block">
            <Button
              id="bulk-entry-button"
              data-open-transaction-drawer
              variant="accent"
              size="md"
              className="px-6 active:scale-95"
              aria-label="New Transaction"
            >
              <Plus size={20} class="stroke-current" aria-hidden="true" />
              <span class="text-sm">New Transaction</span>
            </Button>
          </div>
        )
      }
    </div>
  </div>

  {/* Header slot content below main bar on mobile/tablet */}
  {
    hasHeaderSlot && (
      <div
        class="flex items-center justify-start gap-3 px-4 sm:px-6 pb-3 lg:hidden overflow-x-auto overflow-y-hidden"
        data-header-slot-mobile
      >
        <Fragment set:html={headerSlotHtml} />
      </div>
    )
  }
</header>

<script>
  import './Header.client';
</script>
