---
/**
 * Header Component
 *
 * Application header with mobile menu toggle, page title, and quick actions.
 */

import Icon from '../atoms/Icon.astro';

interface Props {
  title?: string;
  currentPath?: string;
  showMenuToggle?: boolean;
}

const { title = 'Finance Manager', currentPath = '/', showMenuToggle = true } = Astro.props;

// Get page title based on current path
const getPageTitle = (path: string) => {
  const titles: Record<string, string> = {
    '/': 'Dashboard',
    '/dashboard': 'Dashboard',
    '/transactions': 'Transactions',
    '/budget': 'Budget',
    '/assets': 'Assets',
    '/reports': 'Reports',
    '/forecast': 'Forecast',
    '/calculators': 'Calculators',
    '/settings': 'Settings',
  };

  // Check for exact match first
  if (titles[path]) return titles[path];

  // Check for partial matches (e.g., /transactions/add)
  for (const [key, value] of Object.entries(titles)) {
    if (path.startsWith(key + '/')) return value;
  }

  return title;
};
---

<header
  class="bg-base-100 border-b border-base-300 px-4 py-3 flex items-center justify-between gap-4"
>
  <!-- Left side: Menu toggle + Page title -->
  <div class="flex items-center gap-3">
    {
      showMenuToggle && (
        <label
          for="drawer-toggle"
          class="btn btn-square btn-ghost lg:hidden"
          aria-label="Toggle menu"
        >
          <Icon name="search" size="md" />
        </label>
      )
    }
    <h1 class="text-xl font-semibold">{getPageTitle(currentPath)}</h1>
  </div>

  <!-- Right side: Quick actions -->
  <div class="flex items-center gap-2">
    <!-- Add new button -->
    <button class="btn btn-primary btn-sm gap-2">
      <Icon name="plus" size="sm" />
      <span class="hidden sm:inline">Add New</span>
    </button>

    <!-- Notifications -->
    <div class="dropdown dropdown-end">
      <button tabindex={0} class="btn btn-square btn-ghost btn-sm" aria-label="Notifications">
        <Icon name="warning" size="md" />
        <span class="badge badge-xs badge-error absolute top-1 right-1">3</span>
      </button>
      <ul
        tabindex={0}
        class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-80"
      >
        <li class="menu-title">
          <span class="text-sm font-semibold">Notifications</span>
        </li>
        <li>
          <a href="#" class="flex flex-col items-start gap-1 p-2">
            <span class="text-sm font-medium">Budget exceeded</span>
            <span class="text-xs text-neutral-500">Dining out is 120% over budget</span>
            <span class="text-xs text-neutral-400">2 hours ago</span>
          </a>
        </li>
        <li>
          <a href="#" class="flex flex-col items-start gap-1 p-2">
            <span class="text-sm font-medium">Asset update reminder</span>
            <span class="text-xs text-neutral-500">Update your stock portfolio</span>
            <span class="text-xs text-neutral-400">1 day ago</span>
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>
