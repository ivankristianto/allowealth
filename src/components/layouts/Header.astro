---
/**
 * Header Component
 *
 * Premium glass-effect header with page title, subtitle, currency selector,
 * notifications, and new entry button. Displays user context when authenticated.
 */

import { Menu, Plus, Bell, Moon, Sun } from '@lucide/astro';
import UserContext from '../organisms/UserContext.astro';
import CurrencySelector from '../molecules/CurrencySelector.astro';
import { formatMonthYear } from '@/lib/utils';

interface Props {
  title?: string;
  currentPath?: string;
  showMenuToggle?: boolean;
  user?: any | null;
  subtitle?: string;
  // Optional data for dynamic subtitles
  transactionCount?: number;
  budgetSpent?: string;
  budgetTotal?: string;
  netWorth?: string;
  accountCount?: number;
}

const {
  title = 'Finance Manager',
  currentPath = '/',
  showMenuToggle = true,
  user,
  subtitle: subtitleProp,
  transactionCount,
  budgetSpent,
  budgetTotal,
  netWorth,
  accountCount,
} = Astro.props;

/**
 * Get dynamic subtitle based on current path and context
 * @param path - Current route path
 * @param data - Optional data for subtitle generation
 * @returns Subtitle string for the current page
 */
function getSubtitle(
  path: string,
  data: {
    transactionCount?: number;
    budgetSpent?: string;
    budgetTotal?: string;
    netWorth?: string;
    accountCount?: number;
  } = {}
): string {
  // Check for exact match first
  const pathMap: Record<string, string> = {
    '/dashboard': `Welcome back! ${formatMonthYear(new Date())}`,
    '/transactions': data.transactionCount
      ? `${data.transactionCount} transaction${data.transactionCount !== 1 ? 's' : ''} this month`
      : formatMonthYear(new Date()),
    '/budget':
      data.budgetSpent && data.budgetTotal
        ? `Spent ${data.budgetSpent} of ${data.budgetTotal}`
        : 'Monthly budget overview',
    '/assets': data.netWorth ? `Net worth: ${data.netWorth}` : formatMonthYear(new Date()),
    '/reports': formatMonthYear(new Date()),
    '/forecast': 'Based on your spending patterns',
    '/calculators': 'Financial planning tools',
    '/settings': 'Manage your preferences',
  };

  // Return exact match
  if (pathMap[path]) {
    return pathMap[path];
  }

  // Check for partial matches (e.g., /transactions/add)
  for (const [key, value] of Object.entries(pathMap)) {
    if (path.startsWith(key + '/')) {
      return value;
    }
  }

  // Default fallback
  return formatMonthYear(new Date());
}

const subtitle =
  subtitleProp ??
  getSubtitle(currentPath, {
    transactionCount,
    budgetSpent,
    budgetTotal,
    netWorth,
    accountCount,
  });

// Get page title based on current path
const getPageTitle = (path: string) => {
  const titles: Record<string, string> = {
    '/': 'Dashboard',
    '/dashboard': 'Dashboard',
    '/transactions': 'Transactions',
    '/budget': 'Budget',
    '/assets': 'Assets',
    '/reports': 'Reports',
    '/forecast': 'Forecast',
    '/calculators': 'Calculators',
    '/settings': 'Settings',
  };

  // Check for exact match first
  if (titles[path]) return titles[path];

  // Check for partial matches (e.g., /transactions/add)
  for (const [key, value] of Object.entries(titles)) {
    if (path.startsWith(key + '/')) return value;
  }

  return title;
};
---

<header
  class="fixed top-0 left-0 right-0 lg:left-64 lg:group-data-[sidebar-collapsed=true]:left-20 z-40 bg-base-100/80 backdrop-blur-xl px-4 sm:px-6 lg:px-10 py-4 sm:py-5 min-h-16 sm:min-h-20 flex items-center justify-between gap-4 border-b border-base-300/50 transition-[left] duration-300 ease-out"
>
  <!-- Left side: Menu toggle + Page title + Subtitle -->
  <div class="flex items-center gap-3">
    {
      showMenuToggle && (
        <label
          for="drawer-toggle"
          class="btn btn-square btn-ghost btn-sm lg:hidden"
          aria-label="Toggle menu"
        >
          <Menu size={24} class="stroke-current" aria-hidden="true" />
        </label>
      )
    }
    <div>
      <h1 class="text-2xl lg:text-3xl font-bold tracking-tight text-primary leading-none">
        {getPageTitle(currentPath)}
      </h1>
      <p class="text-sm font-medium text-neutral hidden sm:block mt-1.5 leading-none">{subtitle}</p>
    </div>
  </div>

  <!-- Right side: Currency selector + Notifications + New Entry button -->
  <div class="flex items-center gap-3 sm:gap-5">
    <!-- Currency Selector -->
    <div class="hidden sm:block">
      <CurrencySelector />
    </div>

    <!-- Theme Toggle (mobile only) -->
    <button
      type="button"
      id="header-theme-toggle"
      class="lg:hidden p-3 rounded-full transition-all text-neutral hover:bg-base-100 shadow-sm border border-base-300"
      aria-label="Toggle dark mode"
      title="Toggle dark mode"
    >
      <Moon size={20} class="stroke-current header-theme-icon-light" aria-hidden="true" />
      <Sun size={20} class="stroke-current header-theme-icon-dark hidden" aria-hidden="true" />
    </button>

    <!-- Notifications -->
    <div class="relative">
      <button
        id="notification-button"
        class="p-3 rounded-full transition-all relative text-neutral hover:bg-base-100 shadow-sm border border-base-300"
        aria-label="Notifications"
        aria-expanded="false"
        aria-haspopup="true"
      >
        <Bell size={20} class="stroke-current" aria-hidden="true" />
        <span
          class="absolute top-2 right-2 w-2.5 h-2.5 bg-error rounded-full border-2 border-base-100 animate-pulse"
          aria-hidden="true"></span>
      </button>

      <!-- Notification Dropdown Panel -->
      <div
        id="notification-dropdown"
        class="absolute right-0 mt-4 w-[calc(100vw-3rem)] sm:w-80 max-w-80 bg-base-100 rounded-2xl sm:rounded-3xl border border-base-300 shadow-premium z-50 overflow-hidden hidden"
        role="menu"
        aria-label="Notifications menu"
      >
        <!-- Header -->
        <div class="p-5 border-b border-base-300 flex justify-between items-center bg-base-200/50">
          <span class="font-bold text-base text-neutral">Notifications</span>
          <button
            id="close-notifications"
            class="text-sm font-bold text-accent hover:underline focus:outline-none focus:ring-2 focus:ring-accent focus:ring-offset-2 rounded"
            aria-label="Close notifications"
          >
            Close
          </button>
        </div>

        <!-- Notification List -->
        <div class="max-h-96 overflow-y-auto divide-y divide-base-300">
          <div class="p-5 hover:bg-base-200/50 transition-colors cursor-pointer flex gap-5">
            <div
              class="w-12 h-12 shrink-0 rounded-2xl flex items-center justify-center bg-warning/10 text-warning shadow-sm"
            >
              <Bell size={20} class="shrink-0" aria-hidden="true" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between items-start mb-1.5 leading-none">
                <p class="text-base font-bold text-base-content tracking-tight">Budget Alert</p>
                <span class="text-[10px] font-bold text-neutral uppercase tracking-widest"
                  >2m ago</span
                >
              </div>
              <p class="text-sm text-neutral leading-relaxed">
                Dining has reached 95% of its monthly limit.
              </p>
            </div>
          </div>
          <div class="p-5 hover:bg-base-200/50 transition-colors cursor-pointer flex gap-5">
            <div
              class="w-12 h-12 shrink-0 rounded-2xl flex items-center justify-center bg-success/10 text-success shadow-sm"
            >
              <Plus size={20} class="shrink-0" aria-hidden="true" />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex justify-between items-start mb-1.5 leading-none">
                <p class="text-base font-bold text-base-content tracking-tight">Salary Received</p>
                <span class="text-[10px] font-bold text-neutral uppercase tracking-widest"
                  >4h ago</span
                >
              </div>
              <p class="text-sm text-neutral leading-relaxed">Acme Corp deposited Rp51.025.000.</p>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <button
          class="w-full py-4 text-sm font-bold text-neutral hover:bg-base-200 transition-colors tracking-wide focus:outline-none focus:ring-2 focus:ring-accent focus:ring-inset"
          aria-label="View all notification history"
        >
          View all history
        </button>
      </div>
    </div>

    <!-- User Context (login/register or user menu) - hidden on mobile -->
    <div class="hidden lg:block">
      <UserContext user={user} />
    </div>

    <!-- New Entry Button -->
    <button
      id="new-entry-button"
      class="bg-accent hover:bg-accent-hover text-white px-4 sm:px-6 py-2.5 rounded-2xl flex items-center gap-2 font-bold shadow-xl shadow-accent/20 transition-all active:scale-95 text-base"
      aria-label="Add new expense"
      data-open-modal="expense"
    >
      <Plus size={20} class="stroke-current" aria-hidden="true" />
      <span class="hidden sm:inline">New Entry</span>
    </button>
  </div>
</header>

<script>
  // Client-side script to handle notification dropdown toggle
  const notificationButton = document.getElementById('notification-button');
  const notificationDropdown = document.getElementById('notification-dropdown');
  const closeNotificationsBtn = document.getElementById('close-notifications');

  function openNotifications() {
    if (notificationDropdown && notificationButton) {
      notificationDropdown.classList.remove('hidden');
      notificationButton.setAttribute('aria-expanded', 'true');
      // Move focus to first focusable element in dropdown for accessibility
      const firstFocusable = notificationDropdown.querySelector(
        'button, a, [tabindex]:not([tabindex="-1"])'
      ) as HTMLElement;
      setTimeout(() => firstFocusable?.focus(), 10);
    }
  }

  function closeNotifications() {
    if (notificationDropdown && notificationButton) {
      notificationDropdown.classList.add('hidden');
      notificationButton.setAttribute('aria-expanded', 'false');
      // Return focus to trigger button
      notificationButton.focus();
    }
  }

  function toggleNotifications() {
    if (notificationDropdown) {
      const isHidden = notificationDropdown.classList.contains('hidden');
      if (isHidden) {
        openNotifications();
      } else {
        closeNotifications();
      }
    }
  }

  notificationButton?.addEventListener('click', (e) => {
    e.stopPropagation();
    toggleNotifications();
  });

  closeNotificationsBtn?.addEventListener('click', () => {
    closeNotifications();
  });

  // Close on Escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeNotifications();
    }
  });

  // Close when clicking outside
  document.addEventListener('click', (e) => {
    if (
      notificationDropdown &&
      notificationButton &&
      !notificationDropdown.contains(e.target as Node) &&
      !notificationButton.contains(e.target as Node)
    ) {
      closeNotifications();
    }
  });

  // New Entry button - opens expense modal
  const newEntryButton = document.getElementById('new-entry-button');
  newEntryButton?.addEventListener('click', () => {
    const modalType = newEntryButton.getAttribute('data-open-modal') || 'expense';

    // Try to open modal directly if it exists
    const modal = document.getElementById(`${modalType}-modal`) as HTMLDialogElement | null;
    if (modal) {
      modal.showModal();
    } else {
      // Dispatch custom event for pages without embedded modal
      document.dispatchEvent(
        new CustomEvent('open-transaction-modal', {
          detail: { type: modalType },
          bubbles: true,
        })
      );
    }
  });

  // Header theme toggle (mobile)
  const headerThemeToggle = document.getElementById('header-theme-toggle');

  function updateHeaderThemeIcons() {
    const theme = document.documentElement.getAttribute('data-theme');
    const lightIcon = document.querySelector('.header-theme-icon-light');
    const darkIcon = document.querySelector('.header-theme-icon-dark');

    if (theme === 'dark') {
      lightIcon?.classList.add('hidden');
      darkIcon?.classList.remove('hidden');
      headerThemeToggle?.setAttribute('aria-label', 'Switch to light mode');
    } else {
      lightIcon?.classList.remove('hidden');
      darkIcon?.classList.add('hidden');
      headerThemeToggle?.setAttribute('aria-label', 'Switch to dark mode');
    }
  }

  headerThemeToggle?.addEventListener('click', () => {
    const current = document.documentElement.getAttribute('data-theme') as 'light' | 'dark';
    const next = current === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    localStorage.setItem('theme', next);
    updateHeaderThemeIcons();
  });

  // Initialize header theme icons
  updateHeaderThemeIcons();

  // Listen for theme changes from other toggles
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      if (mutation.attributeName === 'data-theme') {
        updateHeaderThemeIcons();
      }
    });
  });
  observer.observe(document.documentElement, { attributes: true });
</script>
