---
/**
 * Mobile Bottom Navigation Component
 *
 * Fixed bottom navigation bar for mobile viewports with:
 * - 5-slot layout: Activity, Assets, FAB center, Budgets, Reports
 * - Glass effect background with backdrop blur
 * - Elevated center FAB button for Dashboard
 * - Active state styling with accent color
 *
 * @design-system Oasis Finance v1.0.0
 * @see specs/ui-redesign_implementation_plan.md Task 5
 */

import { Receipt, Wallet, LayoutGrid, Donut, ChartBar } from '@lucide/astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

interface NavItem {
  href: string;
  label: string;
  icon: typeof Receipt;
}

const navItems: NavItem[] = [
  { href: '/transactions', label: 'Activity', icon: Receipt },
  { href: '/assets', label: 'Assets', icon: Wallet },
  // Center FAB is handled separately
  { href: '/budget', label: 'Budgets', icon: Donut },
  { href: '/reports', label: 'Reports', icon: ChartBar },
];

const isActive = (href: string) => {
  if (currentPath === href) return true;
  if (href === '/dashboard' && (currentPath === '/' || currentPath === '/dashboard')) return true;
  return currentPath.startsWith(href + '/');
};

const isDashboardActive = currentPath === '/' || currentPath === '/dashboard';
---

<nav
  class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-base-100/80 backdrop-blur-xl border-t border-base-300/50 px-4 pb-[max(1rem,env(safe-area-inset-bottom))] pt-3 shadow-[0_-10px_40px_rgba(0,0,0,0.05)]"
  role="navigation"
  aria-label="Mobile navigation"
>
  <div class="flex justify-between items-center max-w-md mx-auto relative h-14">
    <!-- Left nav items (Activity, Assets) -->
    {
      navItems.slice(0, 2).map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            class={`flex-1 flex flex-col items-center gap-1 py-1 transition-all active:scale-95 min-w-[44px] min-h-[44px] rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 ${
              active ? 'text-accent' : 'text-neutral hover:text-base-content'
            }`}
            aria-current={active ? 'page' : undefined}
            aria-label={item.label}
          >
            <div
              class={`relative flex items-center justify-center w-12 h-8 rounded-full transition-colors ${
                active ? 'bg-accent/10' : ''
              }`}
            >
              <item.icon
                size={24}
                class={`stroke-current transition-transform ${active ? 'scale-110' : ''}`}
                aria-hidden="true"
              />
              {active && (
                <span
                  class="absolute -bottom-1 w-1 h-1 rounded-full bg-accent"
                  aria-hidden="true"
                />
              )}
            </div>
            <span
              class={`text-xs font-bold tracking-tight uppercase leading-none mt-1 ${
                active ? 'opacity-100' : 'opacity-60'
              }`}
            >
              {item.label}
            </span>
          </a>
        );
      })
    }

    <!-- Center FAB (Dashboard) -->
    <div class="flex-1 flex justify-center -mt-10 pointer-events-none">
      <a
        href="/dashboard"
        class={`group mobile-fab w-16 h-16 rounded-2xl flex items-center justify-center transition-all duration-200 pointer-events-auto ring-8 ring-base-100 shadow-2xl min-w-[64px] min-h-[64px] focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-accent focus-visible:ring-offset-4 hover:scale-110 hover:-translate-y-1 active:scale-95 ${
          isDashboardActive
            ? 'bg-accent text-accent-content shadow-accent/40 hover:shadow-accent/60'
            : 'bg-primary text-primary-content hover:shadow-primary/40'
        }`}
        aria-label="Dashboard"
        aria-current={isDashboardActive ? 'page' : undefined}
      >
        <LayoutGrid
          size={28}
          class="stroke-current transition-transform duration-200 group-hover:rotate-12"
          aria-hidden="true"
        />
      </a>
    </div>

    <!-- Right nav items (Budgets, Reports) -->
    {
      navItems.slice(2).map((item) => {
        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            class={`flex-1 flex flex-col items-center gap-1 py-1 transition-all active:scale-95 min-w-[44px] min-h-[44px] rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 ${
              active ? 'text-accent' : 'text-neutral hover:text-base-content'
            }`}
            aria-current={active ? 'page' : undefined}
            aria-label={item.label}
          >
            <div
              class={`relative flex items-center justify-center w-12 h-8 rounded-full transition-colors ${
                active ? 'bg-accent/10' : ''
              }`}
            >
              <item.icon
                size={24}
                class={`stroke-current transition-transform ${active ? 'scale-110' : ''}`}
                aria-hidden="true"
              />
              {active && (
                <span
                  class="absolute -bottom-1 w-1 h-1 rounded-full bg-accent"
                  aria-hidden="true"
                />
              )}
            </div>
            <span
              class={`text-xs font-bold tracking-tight uppercase leading-none mt-1 ${
                active ? 'opacity-100' : 'opacity-60'
              }`}
            >
              {item.label}
            </span>
          </a>
        );
      })
    }
  </div>
</nav>
