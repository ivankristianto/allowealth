---
/**
 * Mobile Bottom Navigation Component
 *
 * Fixed bottom navigation bar for mobile viewports with:
 * - 5-slot layout: Transactions, Assets, FAB center, Budgets, Reports
 * - Glass effect background with backdrop blur
 * - Elevated center FAB button for Quick-Add Transaction
 * - Active state styling with accent color
 *
 * @design-system Oasis Finance v1.0.0
 * @see specs/ui-redesign_implementation_plan.md Task 5
 */

import { ArrowLeftRight, Wallet, Plus, Donut, ChartBar } from '@lucide/astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

interface NavItem {
  href: string;
  label: string;
  icon: typeof ArrowLeftRight;
}

const navItems: NavItem[] = [
  { href: '/transactions', label: 'Transactions', icon: ArrowLeftRight },
  { href: '/assets', label: 'Assets', icon: Wallet },
  // Center FAB is handled separately
  { href: '/budget', label: 'Budgets', icon: Donut },
  { href: '/reports', label: 'Reports', icon: ChartBar },
];
const navSlots: Array<NavItem | null> = [...navItems.slice(0, 2), null, ...navItems.slice(2)];

const isActive = (href: string) => {
  if (currentPath === href) return true;
  if (href === '/dashboard' && (currentPath === '/' || currentPath === '/dashboard')) return true;
  return currentPath.startsWith(href + '/');
};
---

<nav
  class="fixed inset-x-0 bottom-0 z-50 border-t border-base-300 bg-base-100/90 px-4 pt-2 pb-[max(1rem,env(safe-area-inset-bottom))] shadow-[0_-8px_24px_rgb(2_6_23_/_0.12)] backdrop-blur-xl lg:hidden"
  role="navigation"
  aria-label="Mobile navigation"
>
  <div class="relative mx-auto grid max-w-md grid-cols-5 items-end gap-0.5">
    {
      navSlots.map((item) => {
        if (!item) {
          return (
            <div class="-mt-9 flex justify-center pointer-events-none">
              <button
                type="button"
                data-open-transaction-drawer
                class="btn btn-accent btn-circle group pointer-events-auto size-16 border-[6px] border-base-100 shadow-accent-glow-lg transition-transform duration-200 hover:-translate-y-0.5 hover:scale-105 active:scale-95 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-4"
                aria-label="New Transaction"
              >
                <Plus
                  size={24}
                  class="stroke-current transition-transform duration-200 group-hover:rotate-12"
                  aria-hidden="true"
                />
              </button>
            </div>
          );
        }

        const active = isActive(item.href);
        return (
          <a
            href={item.href}
            class={`flex min-h-11 min-w-11 flex-col items-center justify-end gap-1 rounded-xl px-0.5 pt-1 text-neutral no-underline transition-[color,transform] duration-200 active:scale-95 hover:text-base-content focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 ${
              active ? 'text-accent' : ''
            }`}
            aria-current={active ? 'page' : undefined}
            aria-label={item.label}
          >
            <span
              class={`relative flex size-10 items-center justify-center rounded-full transition-colors duration-200 ${
                active ? 'bg-accent/15' : ''
              }`}
            >
              <item.icon
                size={22}
                class={`stroke-current transition-transform duration-200 ${active ? 'scale-110' : ''}`}
                aria-hidden="true"
              />
            </span>
            <span
              class={`mt-1 text-xs font-bold leading-none tracking-tight transition-opacity duration-200 ${
                active ? 'opacity-100' : 'opacity-70'
              }`}
            >
              {item.label}
            </span>
          </a>
        );
      })
    }
  </div>
</nav>
