---
/**
 * Mobile Command Center Navigation
 *
 * Accessible bottom sheet navigation for mobile with clear visual hierarchy.
 */

import {
  ArrowLeftRight,
  Wallet,
  Donut,
  BarChart2,
  Menu,
  X,
  User,
  Shield,
  LogOut,
  Settings,
  House,
  RefreshCw,
  TrendingUp,
  Calculator,
  ClipboardList,
  ExternalLink,
  ShieldCheck,
  Building2,
  Users,
  Activity,
} from '@lucide/astro';
import Button from '@/components/atoms/Button.astro';
import type { AuthUser as UserType } from '@/lib/auth/types';

interface Props {
  currentPath?: string;
  user?: UserType | null;
}

const { currentPath = '/', user = null } = Astro.props;

// Check if user is super admin
const isSuperAdmin = user?.role === 'super_admin';

const isActive = (href: string) => {
  if (currentPath === href) return true;
  if (href === '/dashboard' && (currentPath === '/' || currentPath === '/dashboard')) return true;
  return currentPath.startsWith(href + '/');
};
---

<nav
  class="mobile-command-center fixed inset-x-0 bottom-0 z-[var(--z-fixed)] lg:hidden"
  aria-label="Mobile navigation"
>
  {/* Collapsed Bar */}
  <div
    class="command-bar absolute bottom-4 inset-x-4 bg-linear-to-b from-base-100 to-base-200/90 backdrop-blur-xl rounded-2xl shadow-xl border border-base-300/60 p-2 flex items-center justify-between"
  >
    {/* Menu Button - More visible background */}
    <Button
      variant="ghost"
      className="command-menu-btn px-4 py-2.5 rounded-xl bg-base-300 text-base-content hover:bg-base-300/80 border-base-content/10"
      aria-label="Open navigation"
      aria-controls="command-sheet"
      aria-expanded="false"
      data-menu-toggle
    >
      <Menu size={20} aria-hidden="true" />
      <span class="font-semibold text-sm">Menu</span>
    </Button>

    {/* Quick Actions - Increased spacing and touch targets */}
    <div class="flex items-center gap-2">
      {
        !isSuperAdmin ? (
          <>
            <a
              href="/transactions"
              class={`flex items-center justify-center min-h-11 min-w-11 rounded-xl transition-all active:scale-95 ${isActive('/transactions') ? 'bg-accent/15 text-accent shadow-sm' : 'text-base-content/50 hover:text-base-content hover:bg-base-200'}`}
              aria-label="Transactions"
              aria-current={isActive('/transactions') ? 'page' : undefined}
            >
              <ArrowLeftRight size={20} aria-hidden="true" />
            </a>
            <a
              href="/accounts"
              class={`flex items-center justify-center min-h-11 min-w-11 rounded-xl transition-all active:scale-95 ${isActive('/accounts') ? 'bg-accent/15 text-accent shadow-sm' : 'text-base-content/50 hover:text-base-content hover:bg-base-200'}`}
              aria-label="Accounts"
              aria-current={isActive('/accounts') ? 'page' : undefined}
            >
              <Wallet size={20} aria-hidden="true" />
            </a>

            <Button
              variant="ghost"
              shape="circle"
              className="ml-2 w-11 h-11 rounded-full bg-base-100 shadow-lg shadow-base-content/20 hover:shadow-base-content/30 hover:scale-105 border-base-300"
              data-open-transaction-drawer
              aria-label="New transaction"
            >
              <img src="/favicon.svg" alt="" class="w-8 h-8 rounded-full" aria-hidden="true" />
            </Button>
          </>
        ) : (
          <a
            href="/admin"
            class={`flex items-center justify-center min-h-11 min-w-11 rounded-xl transition-all active:scale-95 ${isActive('/admin') ? 'bg-accent/15 text-accent shadow-sm' : 'text-base-content/50 hover:text-base-content hover:bg-base-200'}`}
            aria-label="Admin Dashboard"
            aria-current={isActive('/admin') ? 'page' : undefined}
          >
            <ShieldCheck size={20} aria-hidden="true" />
          </a>
        )
      }
    </div>
  </div>

  {/* Full Menu Sheet */}
  <div
    id="command-sheet"
    class="command-sheet fixed left-0 right-0 bottom-0 bg-base-100 rounded-t-4xl shadow-xl transform translate-y-full transition-transform duration-300 ease-out z-[var(--z-modal)] overflow-y-auto overscroll-contain max-h-[85vh] pb-[env(safe-area-inset-bottom)]"
    data-command-sheet
    role="dialog"
    aria-label="Navigation menu"
    aria-modal="true"
    aria-hidden="true"
    inert
  >
    {/* User Card Header */}
    <div class="flex items-center justify-between px-5 sm:px-6 py-4 border-b border-base-content/8">
      <div class="flex items-center gap-3">
        <div
          class="w-11 h-11 rounded-full bg-accent/20 text-accent flex items-center justify-center font-bold text-sm ring-2 ring-accent/10 shrink-0"
        >
          {user?.name ? user.name.substring(0, 2).toUpperCase() : '--'}
        </div>
        <div class="min-w-0">
          <p class="font-semibold text-base-content truncate leading-tight">
            {user?.name || 'User'}
          </p>
          <p class="text-xs text-base-content/50 truncate">{user?.email || ''}</p>
        </div>
      </div>
      <Button
        variant="ghost"
        className="command-close-btn p-3 rounded-xl border-0 bg-base-200 text-base-content/60 hover:text-base-content hover:bg-base-300"
        data-menu-close
        aria-label="Close navigation menu"
      >
        <X size={20} aria-hidden="true" />
      </Button>
    </div>

    {/* Main Navigation - grouped (user) */}
    {
      !isSuperAdmin && (
        <div class="p-4 sm:p-5 space-y-4">
          {/* Dashboard */}
          <div>
            <a
              href="/dashboard"
              class={`flex items-center gap-3 px-4 py-3 rounded-2xl transition-all active:scale-95 ${isActive('/dashboard') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
              aria-current={isActive('/dashboard') ? 'page' : undefined}
            >
              <House size={22} stroke-width={isActive('/dashboard') ? 2.5 : 2} aria-hidden="true" />
              <span class="text-sm font-semibold">Dashboard</span>
            </a>
          </div>

          {/* Track */}
          <div>
            <p
              class="text-[10px] font-semibold uppercase tracking-widest text-base-content/30 px-1 mb-2"
              aria-hidden="true"
            >
              Track
            </p>
            <div class="grid grid-cols-3 gap-3">
              <a
                href="/transactions"
                class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/transactions') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
                aria-current={isActive('/transactions') ? 'page' : undefined}
              >
                <ArrowLeftRight
                  size={22}
                  stroke-width={isActive('/transactions') ? 2.5 : 2}
                  aria-hidden="true"
                />
                <span class="text-xs font-semibold">Transactions</span>
              </a>
              <a
                href="/recurring"
                class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/recurring') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
                aria-current={isActive('/recurring') ? 'page' : undefined}
              >
                <RefreshCw
                  size={22}
                  stroke-width={isActive('/recurring') ? 2.5 : 2}
                  aria-hidden="true"
                />
                <span class="text-xs font-semibold">Recurring</span>
              </a>
              <a
                href="/accounts"
                class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/accounts') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
                aria-current={isActive('/accounts') ? 'page' : undefined}
              >
                <Wallet
                  size={22}
                  stroke-width={isActive('/accounts') ? 2.5 : 2}
                  aria-hidden="true"
                />
                <span class="text-xs font-semibold">Accounts</span>
              </a>
            </div>
          </div>

          {/* Plan */}
          <div>
            <p
              class="text-[10px] font-semibold uppercase tracking-widest text-base-content/30 px-1 mb-2"
              aria-hidden="true"
            >
              Plan
            </p>
            <div class="grid grid-cols-3 gap-3">
              <a
                href="/budget"
                class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/budget') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
                aria-current={isActive('/budget') ? 'page' : undefined}
              >
                <Donut size={22} stroke-width={isActive('/budget') ? 2.5 : 2} aria-hidden="true" />
                <span class="text-xs font-semibold">Budget</span>
              </a>
              <a
                href="/forecast"
                class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/forecast') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
                aria-current={isActive('/forecast') ? 'page' : undefined}
              >
                <TrendingUp
                  size={22}
                  stroke-width={isActive('/forecast') ? 2.5 : 2}
                  aria-hidden="true"
                />
                <span class="text-xs font-semibold">Forecast</span>
              </a>
            </div>
          </div>

          {/* Analyze */}
          <div>
            <p
              class="text-[10px] font-semibold uppercase tracking-widest text-base-content/30 px-1 mb-2"
              aria-hidden="true"
            >
              Analyze
            </p>
            <div class="grid grid-cols-3 gap-3">
              <a
                href="/reports"
                class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/reports') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
                aria-current={isActive('/reports') ? 'page' : undefined}
              >
                <BarChart2
                  size={22}
                  stroke-width={isActive('/reports') ? 2.5 : 2}
                  aria-hidden="true"
                />
                <span class="text-xs font-semibold">Reports</span>
              </a>
              <a
                href="/calculators"
                class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/calculators') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
                aria-current={isActive('/calculators') ? 'page' : undefined}
              >
                <Calculator
                  size={22}
                  stroke-width={isActive('/calculators') ? 2.5 : 2}
                  aria-hidden="true"
                />
                <span class="text-xs font-semibold">Calculators</span>
              </a>
            </div>
          </div>
        </div>
      )
    }

    {/* Admin navigation - unchanged, just wrapped in its own container */}
    {
      isSuperAdmin && (
        <div class="p-4 sm:p-5 grid grid-cols-3 gap-3">
          <a
            href="/admin"
            class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/admin') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
            aria-current={isActive('/admin') ? 'page' : undefined}
          >
            <ShieldCheck size={22} stroke-width={isActive('/admin') ? 2.5 : 2} aria-hidden="true" />
            <span class="text-xs font-semibold">Dashboard</span>
          </a>
          <a
            href="/admin/workspaces"
            class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/admin/workspaces') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
            aria-current={isActive('/admin/workspaces') ? 'page' : undefined}
          >
            <Building2
              size={22}
              stroke-width={isActive('/admin/workspaces') ? 2.5 : 2}
              aria-hidden="true"
            />
            <span class="text-xs font-semibold">Workspaces</span>
          </a>
          <a
            href="/admin/users"
            class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/admin/users') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
            aria-current={isActive('/admin/users') ? 'page' : undefined}
          >
            <Users size={22} stroke-width={isActive('/admin/users') ? 2.5 : 2} aria-hidden="true" />
            <span class="text-xs font-semibold">Users</span>
          </a>
          <a
            href="/admin/audit-logs"
            class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/admin/audit-logs') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
            aria-current={isActive('/admin/audit-logs') ? 'page' : undefined}
          >
            <ClipboardList
              size={22}
              stroke-width={isActive('/admin/audit-logs') ? 2.5 : 2}
              aria-hidden="true"
            />
            <span class="text-xs font-semibold">Audit Logs</span>
          </a>
          <a
            href="/admin/diagnostics"
            class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-all active:scale-95 ${isActive('/admin/diagnostics') ? 'bg-accent text-accent-content shadow-md shadow-accent/20' : 'bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content'}`}
            aria-current={isActive('/admin/diagnostics') ? 'page' : undefined}
          >
            <Activity
              size={22}
              stroke-width={isActive('/admin/diagnostics') ? 2.5 : 2}
              aria-hidden="true"
            />
            <span class="text-xs font-semibold">Diagnostics</span>
          </a>
        </div>
      )
    }

    {/* User links */}
    {
      !isSuperAdmin && (
        <div class="mx-4 sm:mx-5 mb-6 mt-2 border-t border-base-content/8 pt-3 space-y-1">
          <a
            href="/profile"
            class="flex items-center gap-3 px-4 py-3 min-h-11 rounded-xl text-base-content/70 hover:bg-base-200 hover:text-base-content transition-all active:scale-95 text-sm font-medium"
          >
            <User size={18} aria-hidden="true" />
            Profile
          </a>
          <a
            href="/security"
            class="flex items-center gap-3 px-4 py-3 min-h-11 rounded-xl text-base-content/70 hover:bg-base-200 hover:text-base-content transition-all active:scale-95 text-sm font-medium"
          >
            <Shield size={18} aria-hidden="true" />
            Security
          </a>
          <a
            href="/settings"
            class="flex items-center gap-3 px-4 py-3 min-h-11 rounded-xl text-base-content/70 hover:bg-base-200 hover:text-base-content transition-all active:scale-95 text-sm font-medium"
          >
            <Settings size={18} aria-hidden="true" />
            Settings
          </a>
          <hr class="border-base-content/8 mx-2" aria-hidden="true" />
          <a
            href="https://docs.allowealth.io"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-3 px-4 py-3 min-h-11 rounded-xl text-base-content/40 hover:text-base-content/60 hover:bg-base-200 transition-all active:scale-95 text-sm font-medium"
            aria-label="Documentation (opens in new tab)"
          >
            <ExternalLink size={18} aria-hidden="true" />
            Documentation
          </a>
          <hr class="border-base-content/8 mx-2" aria-hidden="true" />
          <Button
            variant="ghost"
            className="logout-btn w-full justify-start gap-3 px-4 py-3 min-h-11 rounded-xl border-0 text-error hover:bg-error/10 text-sm font-medium"
          >
            <LogOut size={18} aria-hidden="true" />
            Sign out
          </Button>
        </div>
      )
    }
  </div>

  {/* Backdrop Overlay */}
  <div
    class="command-backdrop fixed inset-0 bg-black/40 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300 z-[var(--z-modal-backdrop)]"
    data-command-backdrop
    aria-hidden="true"
  >
  </div>
</nav>

<script>
  import { performLogout } from '@/lib/utils/client';

  // Store abort controllers for cleanup
  const navControllers = new Map<HTMLElement, AbortController>();

  function initMobileNav() {
    const commandCenter = document.querySelector('.mobile-command-center');
    if (!(commandCenter instanceof HTMLElement)) return;

    // Cleanup existing listeners if re-initializing
    const existingController = navControllers.get(commandCenter);
    if (existingController) {
      existingController.abort();
    }

    // Create new abort controller for this instance
    const controller = new AbortController();
    const { signal } = controller;
    navControllers.set(commandCenter, controller);

    const menuToggle = commandCenter.querySelector('[data-menu-toggle]');
    const menuClose = commandCenter.querySelector('[data-menu-close]');
    const sheet = commandCenter.querySelector('[data-command-sheet]');
    const backdrop = commandCenter.querySelector('[data-command-backdrop]');
    const logoutBtn = commandCenter.querySelector('.logout-btn');

    if (!(sheet instanceof HTMLElement)) return;
    if (!(backdrop instanceof HTMLElement)) return;
    if (!(menuToggle instanceof HTMLElement)) return;

    // Store last focused element to restore focus on close
    let lastFocusedElement: HTMLElement | null = null;

    const getFocusableElements = () => {
      return Array.from(
        sheet.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), input:not([disabled]), textarea:not([disabled]), select:not([disabled]), [tabindex]:not([tabindex="-1"])'
        )
      ).filter((el) => !el.hasAttribute('inert'));
    };

    const openSheet = () => {
      // Store current focus
      lastFocusedElement = document.activeElement as HTMLElement;

      sheet.classList.remove('translate-y-full');
      sheet.classList.add('translate-y-0');
      sheet.removeAttribute('inert');
      sheet.removeAttribute('aria-hidden');
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = 'hidden';

      // Update aria-expanded on toggle
      menuToggle.setAttribute('aria-expanded', 'true');

      // Focus the close button after transition
      setTimeout(() => {
        const closeBtn = sheet.querySelector('[data-menu-close]') as HTMLElement | null;
        closeBtn?.focus();
      }, 100);
    };

    const closeSheet = () => {
      sheet.classList.add('translate-y-full');
      sheet.classList.remove('translate-y-0');
      sheet.setAttribute('inert', '');
      sheet.setAttribute('aria-hidden', 'true');
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      backdrop.classList.remove('opacity-100', 'pointer-events-auto');
      document.body.style.overflow = '';

      // Update aria-expanded on toggle
      menuToggle.setAttribute('aria-expanded', 'false');

      // Restore focus to the toggle button
      setTimeout(() => {
        lastFocusedElement?.focus();
        lastFocusedElement = null;
      }, 100);
    };

    menuToggle?.addEventListener('click', openSheet, { signal });
    menuClose?.addEventListener('click', closeSheet, { signal });
    backdrop?.addEventListener('click', closeSheet, { signal });

    // Focus trap within the sheet
    sheet.addEventListener(
      'keydown',
      (e) => {
        if (e.key !== 'Tab') return;

        const focusableElements = Array.from(getFocusableElements());
        if (focusableElements.length === 0) return;

        const firstElement = focusableElements[0];
        const lastElement = focusableElements[focusableElements.length - 1];
        const currentElement = document.activeElement as HTMLElement;

        if (e.shiftKey) {
          // Shift+Tab: moving backwards
          if (currentElement === firstElement) {
            e.preventDefault();
            lastElement.focus();
          }
        } else {
          // Tab: moving forwards
          if (currentElement === lastElement) {
            e.preventDefault();
            firstElement.focus();
          }
        }
      },
      { signal }
    );

    // Close sheet when clicking any link inside it (including external links)
    sheet.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeSheet, { signal });
    });

    // Logout handler
    logoutBtn?.addEventListener(
      'click',
      async (e: MouseEvent) => {
        e.preventDefault();
        await performLogout();
      },
      { signal }
    );

    // Close on escape key
    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') closeSheet();
      },
      { signal }
    );

    // Cleanup when element is removed from DOM
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        mutation.removedNodes.forEach((node) => {
          if (node === commandCenter || (node instanceof Element && node.contains(commandCenter))) {
            controller.abort();
            navControllers.delete(commandCenter);
            observer.disconnect();
          }
        });
      });
    });

    observer.observe(document.body, { childList: true, subtree: true });

    // Also cleanup on view transition
    document.addEventListener(
      'astro:before-swap',
      () => {
        // Reset scroll lock and sheet state before view transition
        document.body.style.overflow = '';
        controller.abort();
        navControllers.delete(commandCenter);
        observer.disconnect();
      },
      { signal }
    );
  }

  // Run on load and after view transitions
  initMobileNav();
  document.addEventListener('astro:page-load', initMobileNav);
</script>
