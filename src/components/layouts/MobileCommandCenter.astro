---
/**
 * Mobile Command Center Navigation
 *
 * Simplified bottom sheet navigation for mobile.
 */

import {
  ArrowLeftRight,
  Wallet,
  Donut,
  ChartBar,
  Menu,
  X,
  User,
  Shield,
  LogOut,
  Settings,
  House,
  RefreshCw,
  TrendingUp,
  Calculator,
  ClipboardList,
  ChevronDown,
} from '@lucide/astro';
import type { User as UserType } from '@/lib/auth/lucia';

interface Props {
  currentPath?: string;
  user?: UserType | null;
}

const { currentPath = '/', user = null } = Astro.props;

const isActive = (href: string) => {
  if (currentPath === href) return true;
  if (href === '/dashboard' && (currentPath === '/' || currentPath === '/dashboard')) return true;
  return currentPath.startsWith(href + '/');
};
---

<nav
  class="mobile-command-center fixed inset-x-0 bottom-0 z-50 lg:hidden"
  aria-label="Mobile navigation"
>
  {/* Collapsed Bar */}
  <div
    class="command-bar absolute bottom-4 inset-x-4 bg-base-100/95 backdrop-blur-xl rounded-2xl shadow-lg border border-base-300/50 p-2 flex items-center justify-between"
  >
    <button
      type="button"
      class="command-menu-btn flex items-center gap-2 px-4 py-2.5 rounded-xl bg-base-200 text-base-content hover:bg-base-300 transition-colors"
      aria-label="Open navigation"
      data-menu-toggle
    >
      <Menu size={20} aria-hidden="true" />
      <span class="font-semibold text-sm">Menu</span>
    </button>

    <div class="flex items-center gap-1">
      <a
        href="/transactions"
        class={`p-2.5 rounded-xl transition-colors ${isActive('/transactions') ? 'bg-accent/10 text-accent' : 'text-base-content/60 hover:bg-base-200'}`}
        aria-label="Transactions"
      >
        <ArrowLeftRight size={20} aria-hidden="true" />
      </a>
      <a
        href="/accounts"
        class={`p-2.5 rounded-xl transition-colors ${isActive('/accounts') ? 'bg-accent/10 text-accent' : 'text-base-content/60 hover:bg-base-200'}`}
        aria-label="Accounts"
      >
        <Wallet size={20} aria-hidden="true" />
      </a>

      <button
        type="button"
        class="ml-1 w-12 h-12 rounded-xl bg-accent text-accent-content flex items-center justify-center shadow-lg shadow-accent/30 hover:shadow-accent/50 hover:scale-105 active:scale-95 transition-all"
        data-open-transaction-drawer
        aria-label="New transaction"
      >
        <img src="/favicon.svg" alt="" class="w-7 h-7" aria-hidden="true" />
      </button>
    </div>
  </div>

  {/* Full Menu Sheet - Bleeds to edges */}
  <div
    class="command-sheet fixed left-0 right-0 bottom-0 bg-base-100 rounded-t-3xl shadow-2xl border-t border-base-300 transform translate-y-full transition-transform duration-300 z-50"
    data-command-sheet
    style="max-height: 80vh;"
  >
    {/* Header */}
    <div class="flex items-center justify-between px-6 py-4 border-b border-base-200">
      <span class="text-lg font-bold">Menu</span>
      <button
        type="button"
        class="command-close-btn p-2 rounded-xl bg-base-200 text-base-content/60 hover:text-base-content transition-colors"
        data-menu-close
        aria-label="Close navigation"
      >
        <X size={20} aria-hidden="true" />
      </button>
    </div>

    {/* Nav Links - Main 3x2 Grid */}
    <div class="p-6 grid grid-cols-3 gap-4">
      <a
        href="/dashboard"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/dashboard') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <House size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Dashboard</span>
      </a>
      <a
        href="/transactions"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/transactions') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <ArrowLeftRight size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Transactions</span>
      </a>
      <a
        href="/accounts"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/accounts') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <Wallet size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Accounts</span>
      </a>
      <a
        href="/budget"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/budget') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <Donut size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Budget</span>
      </a>
      <a
        href="/reports"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/reports') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <ChartBar size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Reports</span>
      </a>
      <a
        href="/recurring"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/recurring') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <RefreshCw size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Recurring</span>
      </a>
    </div>

    {/* More Menu Button - Expands to show additional items */}
    <div class="px-6 pb-4">
      <button
        type="button"
        class="more-menu-btn w-full flex items-center justify-center gap-2 px-4 py-3 rounded-xl bg-base-200 text-base-content/70 hover:bg-base-300 hover:text-base-content transition-all"
        data-more-menu-btn
        aria-expanded="false"
        aria-controls="more-menu-content"
      >
        <span class="text-sm font-medium">More</span>
        <ChevronDown size={18} class="transition-transform duration-300" data-chevron-icon />
      </button>
    </div>

    {/* Expanded More Menu - Hidden by default */}
    <div
      id="more-menu-content"
      class="more-menu-content hidden px-6 pb-6 grid grid-cols-3 gap-4"
      data-more-menu-content
    >
      <a
        href="/forecast"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/forecast') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <TrendingUp size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Forecast</span>
      </a>
      <a
        href="/calculators"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors ${isActive('/calculators') ? 'bg-accent/10 text-accent' : 'bg-base-200 text-base-content/70 hover:bg-base-300'}`}
      >
        <Calculator size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Calculators</span>
      </a>
      <a
        href="https://docs.allowealth.io"
        target="_blank"
        rel="noopener noreferrer"
        class={`flex flex-col items-center gap-2 p-4 rounded-2xl transition-colors bg-base-200 text-base-content/70 hover:bg-base-300`}
        aria-label="Documentation (opens in new tab)"
      >
        <ClipboardList size={24} aria-hidden="true" />
        <span class="text-xs font-semibold">Docs</span>
      </a>
    </div>

    {/* User Section */}
    <div class="px-6 pb-8 pt-2 border-t border-base-200">
      <div class="flex items-center gap-4 mb-4">
        <div
          class="w-12 h-12 rounded-full bg-accent/20 text-accent flex items-center justify-center font-bold"
        >
          {user?.name ? user.name.substring(0, 2).toUpperCase() : '--'}
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-bold text-base-content truncate">{user?.name || 'User'}</p>
          <p class="text-xs text-base-content/50 truncate">{user?.email || ''}</p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <a
          href="/profile"
          class="flex items-center gap-2 px-4 py-3 rounded-xl bg-base-200 text-base-content/80 hover:bg-base-300 transition-colors text-sm font-medium"
        >
          <User size={18} aria-hidden="true" />
          Profile
        </a>
        <a
          href="/security"
          class="flex items-center gap-2 px-4 py-3 rounded-xl bg-base-200 text-base-content/80 hover:bg-base-300 transition-colors text-sm font-medium"
        >
          <Shield size={18} aria-hidden="true" />
          Security
        </a>
        <a
          href="/settings"
          class="flex items-center gap-2 px-4 py-3 rounded-xl bg-base-200 text-base-content/80 hover:bg-base-300 transition-colors text-sm font-medium"
        >
          <Settings size={18} aria-hidden="true" />
          Settings
        </a>
        <button
          type="button"
          class="logout-btn flex items-center gap-2 px-4 py-3 rounded-xl bg-error/10 text-error/80 hover:bg-error/20 transition-colors text-sm font-medium"
        >
          <LogOut size={18} aria-hidden="true" />
          Sign out
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  import { performLogout } from '@/lib/utils/client';

  // Store abort controllers for cleanup
  const navControllers = new Map<HTMLElement, AbortController>();

  function initMobileNav() {
    const commandCenter = document.querySelector('.mobile-command-center');
    if (!(commandCenter instanceof HTMLElement)) return;

    // Cleanup existing listeners if re-initializing
    const existingController = navControllers.get(commandCenter);
    if (existingController) {
      existingController.abort();
    }

    // Create new abort controller for this instance
    const controller = new AbortController();
    const { signal } = controller;
    navControllers.set(commandCenter, controller);

    const menuToggle = commandCenter.querySelector('[data-menu-toggle]');
    const menuClose = commandCenter.querySelector('[data-menu-close]');
    const sheet = commandCenter.querySelector('[data-command-sheet]');
    const logoutBtn = commandCenter.querySelector('.logout-btn');
    const moreMenuBtn = commandCenter.querySelector('[data-more-menu-btn]');
    const moreMenuContent = commandCenter.querySelector('[data-more-menu-content]');
    const chevronIcon = commandCenter.querySelector('[data-chevron-icon]');

    if (!(sheet instanceof HTMLElement)) return;
    if (!(moreMenuBtn instanceof HTMLButtonElement)) return;

    const openSheet = () => {
      sheet.classList.remove('translate-y-full');
      sheet.classList.add('translate-y-0');
    };

    const closeSheet = () => {
      sheet.classList.add('translate-y-full');
      sheet.classList.remove('translate-y-0');
      // Reset more menu when closing sheet
      moreMenuContent?.classList.add('hidden');
      chevronIcon?.classList.remove('rotate-180');
      moreMenuBtn.setAttribute('aria-expanded', 'false');
    };

    menuToggle?.addEventListener('click', openSheet, { signal });
    menuClose?.addEventListener('click', closeSheet, { signal });

    // Toggle more menu
    moreMenuBtn.addEventListener(
      'click',
      () => {
        const isExpanded = moreMenuBtn.getAttribute('aria-expanded') === 'true';
        moreMenuContent?.classList.toggle('hidden');
        chevronIcon?.classList.toggle('rotate-180');
        moreMenuBtn.setAttribute('aria-expanded', String(!isExpanded));
      },
      { signal }
    );

    // Close sheet when clicking a link inside it (but not for external docs link)
    sheet.querySelectorAll('a[href^="/"]').forEach((link) => {
      link.addEventListener('click', closeSheet, { signal });
    });

    // Logout handler
    logoutBtn?.addEventListener(
      'click',
      async (e: MouseEvent) => {
        e.preventDefault();
        await performLogout();
      },
      { signal }
    );

    // Close on escape key
    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') closeSheet();
      },
      { signal }
    );

    // Cleanup when element is removed from DOM
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        mutation.removedNodes.forEach((node) => {
          if (node === commandCenter || (node instanceof Element && node.contains(commandCenter))) {
            controller.abort();
            navControllers.delete(commandCenter);
            observer.disconnect();
          }
        });
      });
    });

    observer.observe(document.body, { childList: true, subtree: true });

    // Also cleanup on view transition
    document.addEventListener(
      'astro:before-swap',
      () => {
        controller.abort();
        navControllers.delete(commandCenter);
        observer.disconnect();
      },
      { signal }
    );
  }

  // Run on load and after view transitions
  initMobileNav();
  document.addEventListener('astro:page-load', initMobileNav);
</script>
