---
/**
 * Page Container Component
 *
 * Wrapper component for page content with consistent spacing and max-width.
 * Uses tokenized max-width (1400px) and responsive padding from design system.
 */

interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

// Container uses tokenized max-width (1400px) from design system
// Responsive padding: mobile 1.5rem (px-6), desktop 3rem (lg:px-12)
const containerClass = `container-app mx-auto px-6 lg:px-12 w-full ${className}`;
---

<div class={containerClass}>
  <slot />
</div>
