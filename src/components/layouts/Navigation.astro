---
/**
 * Navigation Component
 *
 * Premium sidebar navigation with brand header, gradient active states,
 * and user profile section. Matches the premium UI redesign specifications.
 *
 * @design-system Oasis Finance v1.0.0
 * @see https://github.com/oasis-finance/design-system
 */

import {
  LayoutDashboard,
  Receipt,
  Donut,
  Wallet,
  ChartBar,
  TrendingUp,
  Calculator,
  Settings,
  X,
  ChevronLeft,
  ShieldCheck,
  Building2,
  ClipboardList,
  Activity,
} from '@lucide/astro';
import type { User } from '@/lib/auth/lucia';
import UserProfile from './UserProfile.astro';
import { APP_VERSION } from '@/lib/version';

interface Props {
  currentPath?: string;
  user?: User | null;
}

const { currentPath = '/', user = null } = Astro.props;

interface NavItem {
  href: string;
  label: string;
  icon: typeof LayoutDashboard;
  badge?: string;
}

// Updated icons per premium design spec - each nav item has unique icon
// Note: Categories is accessible via /budget/categories (linked from Budget page)
const navItems: NavItem[] = [
  { href: '/dashboard', label: 'Dashboard', icon: LayoutDashboard },
  { href: '/transactions', label: 'Transactions', icon: Receipt },
  { href: '/budget', label: 'Budget', icon: Donut },
  { href: '/assets', label: 'Assets', icon: Wallet },
  { href: '/reports', label: 'Reports', icon: ChartBar },
  { href: '/forecast', label: 'Forecast', icon: TrendingUp },
  { href: '/calculators', label: 'Calculators', icon: Calculator },
  { href: '/settings', label: 'Settings', icon: Settings },
];

// Check if user is super admin
const isSuperAdmin = user?.role === 'super_admin';

const isActive = (href: string) => {
  // Settings alias: treat /profile and /security as settings area
  if (href === '/settings') {
    return (
      currentPath === '/profile' ||
      currentPath === '/security' ||
      currentPath.startsWith('/settings')
    );
  }

  // Exact match for index routes
  if (currentPath === href) return true;
  // For nested routes (e.g., /assets/history), parent is active if path starts with href + '/'
  return currentPath.startsWith(href + '/');
};

// Oasis Finance v1.0.0 Design System - Sidebar specifications:
// - Width: 16rem (256px)
// - Brand section padding: p-8 (2rem) - matches PoC
// - Nav item padding: py-3 px-5 (0.75rem 1.25rem) - matches PoC
// - Icon size: 22px (md size from design system)
// - Icon-text gap: gap-4 (1rem) - matches PoC
// - Active state: solid bg-accent/10, rounded-xl, text-accent, no left border
// - Inactive state: text-base-content/60, transparent bg
---

<aside
  class="bg-base-100 w-64 min-w-64 h-full border-r border-base-300 flex flex-col transition-[width,min-width] duration-300 ease-out lg:group-data-[sidebar-collapsed=true]:w-20 lg:group-data-[sidebar-collapsed=true]:min-w-20 relative pb-20 lg:pb-0"
  role="navigation"
  aria-label="Main navigation"
>
  <!-- Skip link for keyboard users -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-accent-content focus:rounded font-medium"
  >
    Skip to main content
  </a>

  <!-- Mobile Header with Logo and Close button -->
  <div class="lg:hidden p-6 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3" aria-label="allowealth Home">
      <img src="/favicon.svg" alt="" class="w-8 h-8" aria-hidden="true" />
      <span class="text-xl font-bold tracking-tight text-base-content">allowealth</span>
    </a>
    <label for="drawer-toggle" class="btn btn-sm btn-circle btn-ghost" aria-label="Close menu">
      <X size={22} class="stroke-current" />
    </label>
  </div>

  <!-- Floating Collapse Toggle -->
  <button
    type="button"
    class="hidden lg:flex absolute -right-5 top-[55px] w-10 h-10 bg-base-100 border border-base-300 rounded-full items-center justify-center shadow-xl text-neutral hover:text-accent transition-all hover:scale-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 z-50"
    data-sidebar-toggle
    aria-pressed="false"
    aria-label="Collapse sidebar"
    title="Collapse sidebar"
  >
    <ChevronLeft
      size={20}
      class="stroke-current transition-transform duration-300 group-data-[sidebar-collapsed=true]:rotate-180"
      aria-hidden="true"
    />
  </button>

  <!-- Brand Logo Section (desktop only - mobile has it in the header above) -->
  <div
    class="hidden lg:flex pt-8 px-8 pb-4 items-center gap-3 group-data-[sidebar-collapsed=true]:p-4 group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:gap-0"
  >
    <a
      href="/"
      class="flex items-center gap-3 group-data-[sidebar-collapsed=true]:gap-0"
      aria-label="allowealth Home"
    >
      <img
        src="/favicon.svg"
        alt=""
        class="w-8 h-8 transition-transform duration-200 group-hover:scale-105"
        aria-hidden="true"
      />
      <span
        class="text-xl font-bold tracking-tight text-base-content group-data-[sidebar-collapsed=true]:hidden"
      >
        allowealth
      </span>
    </a>
  </div>

  <!-- Version Divider -->
  <div class="flex items-center gap-2 px-4 pb-4 group-data-[sidebar-collapsed=true]:hidden">
    <div class="flex-1 h-px bg-base-300"></div>
    <span class="text-xs text-base-content/40">v{APP_VERSION}</span>
    <div class="flex-1 h-px bg-base-300"></div>
  </div>

  <!-- Navigation -->
  <ul
    class="menu w-full flex-1 px-4 space-y-2 overflow-y-auto flex flex-col flex-nowrap group-data-[sidebar-collapsed=true]:px-2"
  >
    {
      navItems.map((item) => {
        const active = isActive(item.href);
        return (
          <li class="shrink-0">
            <a
              href={item.href}
              title={item.label}
              aria-label={item.label}
              class={`relative flex items-center gap-4 py-4 px-5 text-base rounded-xl transition-all duration-200 group border group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:px-0 group-data-[sidebar-collapsed=true]:gap-0 ${
                active
                  ? 'bg-accent/10 text-accent font-bold border-accent/20'
                  : 'text-base-content/60 hover:text-base-content font-medium border-transparent'
              } focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2`}
              aria-current={active ? 'page' : undefined}
            >
              <item.icon
                size={22}
                class={`shrink-0 transition-transform duration-200 group-hover:scale-110 ${
                  active ? 'text-accent' : ''
                }`}
                aria-hidden="true"
              />
              <span class="group-data-[sidebar-collapsed=true]:hidden">{item.label}</span>
              {active && (
                <span
                  class="ml-auto w-2 h-2 bg-accent rounded-full animate-pulse group-data-[sidebar-collapsed=true]:hidden"
                  aria-hidden="true"
                />
              )}
              {item.badge && (
                <span class="badge badge-sm badge-accent group-data-[sidebar-collapsed=true]:hidden">
                  {item.badge}
                </span>
              )}
            </a>
          </li>
        );
      })
    }

    {/* Admin Navigation - super_admin only */}
    {
      isSuperAdmin && (
        <>
          <li class="menu-title mt-4 group-data-[sidebar-collapsed=true]:hidden">
            <span>Admin</span>
          </li>
          <li class="shrink-0">
            <a
              href="/admin"
              title="Dashboard"
              aria-label="Admin Dashboard"
              class={`relative flex items-center gap-4 py-4 px-5 text-base rounded-xl transition-all duration-200 group border group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:px-0 group-data-[sidebar-collapsed=true]:gap-0 ${
                currentPath === '/admin'
                  ? 'bg-accent/10 text-accent font-bold border-accent/20'
                  : 'text-base-content/60 hover:text-base-content font-medium border-transparent'
              } focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2`}
              aria-current={currentPath === '/admin' ? 'page' : undefined}
            >
              <ShieldCheck
                size={22}
                class={`shrink-0 transition-transform duration-200 group-hover:scale-110 ${
                  currentPath === '/admin' ? 'text-accent' : ''
                }`}
                aria-hidden="true"
              />
              <span class="group-data-[sidebar-collapsed=true]:hidden">Dashboard</span>
              {currentPath === '/admin' && (
                <span
                  class="ml-auto w-2 h-2 bg-accent rounded-full animate-pulse group-data-[sidebar-collapsed=true]:hidden"
                  aria-hidden="true"
                />
              )}
            </a>
          </li>
          <li class="shrink-0">
            <a
              href="/admin/workspaces"
              title="Workspaces"
              aria-label="Workspaces"
              class={`relative flex items-center gap-4 py-4 px-5 text-base rounded-xl transition-all duration-200 group border group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:px-0 group-data-[sidebar-collapsed=true]:gap-0 ${
                currentPath?.startsWith('/admin/workspaces')
                  ? 'bg-accent/10 text-accent font-bold border-accent/20'
                  : 'text-base-content/60 hover:text-base-content font-medium border-transparent'
              } focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2`}
              aria-current={currentPath?.startsWith('/admin/workspaces') ? 'page' : undefined}
            >
              <Building2
                size={22}
                class={`shrink-0 transition-transform duration-200 group-hover:scale-110 ${
                  currentPath?.startsWith('/admin/workspaces') ? 'text-accent' : ''
                }`}
                aria-hidden="true"
              />
              <span class="group-data-[sidebar-collapsed=true]:hidden">Workspaces</span>
              {currentPath?.startsWith('/admin/workspaces') && (
                <span
                  class="ml-auto w-2 h-2 bg-accent rounded-full animate-pulse group-data-[sidebar-collapsed=true]:hidden"
                  aria-hidden="true"
                />
              )}
            </a>
          </li>
          <li class="shrink-0">
            <a
              href="/admin/audit-logs"
              title="Audit Logs"
              aria-label="Audit Logs"
              class={`relative flex items-center gap-4 py-4 px-5 text-base rounded-xl transition-all duration-200 group border group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:px-0 group-data-[sidebar-collapsed=true]:gap-0 ${
                currentPath?.startsWith('/admin/audit-logs')
                  ? 'bg-accent/10 text-accent font-bold border-accent/20'
                  : 'text-base-content/60 hover:text-base-content font-medium border-transparent'
              } focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2`}
              aria-current={currentPath?.startsWith('/admin/audit-logs') ? 'page' : undefined}
            >
              <ClipboardList
                size={22}
                class={`shrink-0 transition-transform duration-200 group-hover:scale-110 ${
                  currentPath?.startsWith('/admin/audit-logs') ? 'text-accent' : ''
                }`}
                aria-hidden="true"
              />
              <span class="group-data-[sidebar-collapsed=true]:hidden">Audit Logs</span>
              {currentPath?.startsWith('/admin/audit-logs') && (
                <span
                  class="ml-auto w-2 h-2 bg-accent rounded-full animate-pulse group-data-[sidebar-collapsed=true]:hidden"
                  aria-hidden="true"
                />
              )}
            </a>
          </li>
          <li class="shrink-0">
            <a
              href="/admin/diagnostics"
              title="Diagnostics"
              aria-label="Diagnostics"
              class={`relative flex items-center gap-4 py-4 px-5 text-base rounded-xl transition-all duration-200 group border group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:px-0 group-data-[sidebar-collapsed=true]:gap-0 ${
                currentPath?.startsWith('/admin/diagnostics')
                  ? 'bg-accent/10 text-accent font-bold border-accent/20'
                  : 'text-base-content/60 hover:text-base-content font-medium border-transparent'
              } focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2`}
              aria-current={currentPath?.startsWith('/admin/diagnostics') ? 'page' : undefined}
            >
              <Activity
                size={22}
                class={`shrink-0 transition-transform duration-200 group-hover:scale-110 ${
                  currentPath?.startsWith('/admin/diagnostics') ? 'text-accent' : ''
                }`}
                aria-hidden="true"
              />
              <span class="group-data-[sidebar-collapsed=true]:hidden">Diagnostics</span>
              {currentPath?.startsWith('/admin/diagnostics') && (
                <span
                  class="ml-auto w-2 h-2 bg-accent rounded-full animate-pulse group-data-[sidebar-collapsed=true]:hidden"
                  aria-hidden="true"
                />
              )}
            </a>
          </li>
        </>
      )
    }
  </ul>

  <!-- Bottom section - User info -->
  <UserProfile user={user} />
</aside>

<script>
  const STORAGE_KEY = 'ff.sidebar.collapsed';

  const initSidebarCollapse = () => {
    const root = document.querySelector('[data-sidebar-root]');
    if (!root) return;

    const toggles = document.querySelectorAll('[data-sidebar-toggle]');
    if (!toggles.length) return;

    let isCollapsed = root.getAttribute('data-sidebar-collapsed') === 'true';

    const applyCollapsedState = () => {
      root.setAttribute('data-sidebar-collapsed', isCollapsed ? 'true' : 'false');
      toggles.forEach((toggle) => {
        toggle.setAttribute('aria-pressed', isCollapsed ? 'true' : 'false');
        toggle.setAttribute('aria-label', isCollapsed ? 'Expand sidebar' : 'Collapse sidebar');
        toggle.setAttribute('title', isCollapsed ? 'Expand sidebar' : 'Collapse sidebar');
        toggle.setAttribute('aria-expanded', isCollapsed ? 'false' : 'true');
      });
    };

    try {
      const stored = localStorage.getItem(STORAGE_KEY);
      if (stored !== null) {
        isCollapsed = stored === 'true';
      }
    } catch (error) {
      console.warn('Sidebar state unavailable', error);
    }

    applyCollapsedState();

    toggles.forEach((toggle) => {
      if (!(toggle instanceof HTMLElement)) return;
      if (toggle.dataset.sidebarBound === 'true') return;
      toggle.dataset.sidebarBound = 'true';
      toggle.addEventListener('click', () => {
        isCollapsed = !isCollapsed;
        applyCollapsedState();
        try {
          localStorage.setItem(STORAGE_KEY, String(isCollapsed));
        } catch (error) {
          console.warn('Sidebar state save failed', error);
        }
      });
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSidebarCollapse, { once: true });
  } else {
    initSidebarCollapse();
  }

  document.addEventListener('astro:page-load', initSidebarCollapse);
</script>
