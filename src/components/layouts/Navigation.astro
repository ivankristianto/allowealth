---
/**
 * Navigation Component
 *
 * Premium sidebar navigation with brand header, gradient active states,
 * and user profile section. Matches the premium UI redesign specifications.
 *
 * @design-system Oasis Finance v1.0.0
 * @see https://github.com/oasis-finance/design-system
 */

import {
  LayoutDashboard,
  Receipt,
  Donut,
  Wallet,
  ChartBar,
  TrendingUp,
  Calculator,
  Settings,
  X,
} from '@lucide/astro';
import type { User } from '@/lib/auth/lucia';

interface Props {
  currentPath?: string;
  user?: User | null;
}

const { currentPath = '/', user = null } = Astro.props;

interface NavItem {
  href: string;
  label: string;
  icon: typeof LayoutDashboard;
  badge?: string;
}

// Updated icons per premium design spec - each nav item has unique icon
const navItems: NavItem[] = [
  { href: '/', label: 'Dashboard', icon: LayoutDashboard },
  { href: '/transactions', label: 'Transactions', icon: Receipt },
  { href: '/budget', label: 'Budget', icon: Donut },
  { href: '/assets', label: 'Assets', icon: Wallet },
  { href: '/reports', label: 'Reports', icon: ChartBar },
  { href: '/forecast', label: 'Forecast', icon: TrendingUp },
  { href: '/calculators', label: 'Calculators', icon: Calculator },
  { href: '/settings', label: 'Settings', icon: Settings },
];

const isActive = (href: string) => {
  // Exact match for index routes
  if (currentPath === href) return true;
  // For nested routes (e.g., /assets/add), parent is active if path starts with href + '/'
  return currentPath.startsWith(href + '/');
};

// Get user initials for avatar
const getUserInitials = () => {
  if (!user?.name) return '--';
  return user.name.substring(0, 2).toUpperCase();
};

// Oasis Finance v1.0.0 Design System - Sidebar specifications:
// - Width: 16rem (256px)
// - Nav item padding: py-2.5 px-4 (0.625rem 1rem)
// - Icon size: 22px (md size from design system)
// - Icon-text gap: gap-3 (0.75rem)
// - Active gradient: linear-gradient(90deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0) 100%)
// - Active left border: 2px solid #6366f1 (accent)
---

<aside
  class="bg-base-100 w-64 min-w-64 min-h-screen border-r border-base-300 hidden lg:block flex flex-col"
  role="navigation"
  aria-label="Main navigation"
>
  <!-- Skip link for keyboard users -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-accent-content focus:rounded font-medium"
  >
    Skip to main content
  </a>

  <!-- Close button for mobile -->
  <div class="lg:hidden p-4 border-b border-base-300 flex justify-between items-center">
    <span class="font-bold text-lg text-base-content">Menu</span>
    <label for="drawer-toggle" class="btn btn-sm btn-circle btn-ghost" aria-label="Close menu">
      <X size={22} class="stroke-current" />
    </label>
  </div>

  <!-- Brand Logo Section -->
  <div class="p-6 pb-4">
    <a href="/" class="flex items-center gap-3 group" aria-label="FamilyFinance Home">
      <div
        class="bg-accent text-accent-content rounded-xl p-2 transition-transform duration-200 group-hover:scale-110"
      >
        <Wallet size={24} class="stroke-current" aria-hidden="true" />
      </div>
      <span class="text-xl font-bold tracking-tight text-base-content"> FamilyFinance </span>
    </a>
  </div>

  <!-- Navigation -->
  <ul class="menu w-full flex-1 px-3">
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={[
              'relative py-2.5 px-4 gap-3 font-bold tracking-tight text-base-content rounded-lg transition-all duration-200',
              'hover:bg-base-200',
              'focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2',
              isActive(item.href) && 'nav-active',
            ]}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            <item.icon size={22} class="stroke-current shrink-0" aria-hidden="true" />
            <span>{item.label}</span>
            {isActive(item.href) && (
              <span
                class="absolute right-3 w-2 h-2 bg-accent rounded-full animate-pulse"
                aria-hidden="true"
              />
            )}
            {item.badge && <span class="badge badge-sm badge-accent">{item.badge}</span>}
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Bottom section - User info -->
  <div class="mt-auto p-4 border-t border-base-300 bg-base-100">
    <div class="flex items-center gap-3">
      <div class="avatar placeholder">
        <div class="bg-accent/10 text-accent rounded-full w-10 flex items-center justify-center">
          <span class="text-xs font-semibold">{getUserInitials()}</span>
        </div>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-base-content truncate">{user?.name || 'User Name'}</p>
        <p class="text-xs text-accent truncate">Pro Account</p>
      </div>
    </div>
  </div>
</aside>
