---
/**
 * Navigation Component
 *
 * Sidebar navigation with menu items for all main sections.
 * Active route is highlighted. Mobile-friendly with drawer toggle.
 *
 * @design-system Oasis Finance v1.0.0
 * @see https://github.com/oasis-finance/design-system
 */

import {
  LayoutDashboard,
  Search,
  Calendar,
  DollarSign,
  Info,
  TriangleAlert,
  Plus,
  Settings,
  X,
} from '@lucide/astro';
import type { User } from '@/lib/auth/lucia';

interface Props {
  currentPath?: string;
  user?: User | null;
}

const { currentPath = '/', user = null } = Astro.props;

interface NavItem {
  href: string;
  label: string;
  icon: typeof LayoutDashboard;
  badge?: string;
}

const navItems: NavItem[] = [
  { href: '/dashboard', label: 'Dashboard', icon: LayoutDashboard },
  { href: '/transactions', label: 'Transactions', icon: Search },
  { href: '/budget', label: 'Budget', icon: Calendar },
  { href: '/assets', label: 'Assets', icon: DollarSign },
  { href: '/reports', label: 'Reports', icon: Info },
  { href: '/forecast', label: 'Forecast', icon: TriangleAlert },
  { href: '/calculators', label: 'Calculators', icon: Plus },
  { href: '/settings', label: 'Settings', icon: Settings },
];

const isActive = (href: string) => {
  // Exact match for index routes
  if (currentPath === href) return true;
  // For nested routes (e.g., /assets/add), parent is active if path starts with href + '/'
  return currentPath.startsWith(href + '/');
};

// Oasis Finance v1.0.0 Design System - Sidebar specifications:
// - Width: 16rem (256px)
// - Nav item padding: py-2.5 px-4 (0.625rem 1rem)
// - Icon size: 22px (md size from design system)
// - Icon-text gap: gap-3 (0.75rem)
// - Active gradient: linear-gradient(90deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0) 100%)
// - Active left border: 2px solid #6366f1 (accent)
---

<aside
  class="bg-base-100 w-64 min-w-64 min-h-screen border-r border-base-300 hidden lg:block flex flex-col"
  role="navigation"
  aria-label="Main navigation"
>
  <!-- Close button for mobile -->
  <div class="lg:hidden p-4 border-b border-base-300 flex justify-between items-center">
    <span class="font-bold text-lg text-base-content">Menu</span>
    <label for="drawer-toggle" class="btn btn-sm btn-circle btn-ghost" aria-label="Close menu">
      <X size={22} class="stroke-current" />
    </label>
  </div>

  <!-- Navigation -->
  <ul class="menu w-full flex-1">
    {
      navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class:list={['py-2.5 px-4 gap-3', isActive(item.href) && 'nav-active']}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            <item.icon size={22} class="stroke-current" aria-hidden="true" />
            <span>{item.label}</span>
            {item.badge && <span class="badge badge-sm badge-accent">{item.badge}</span>}
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Bottom section - User info -->
  <div class="mt-auto p-4 border-t border-base-300 bg-base-100">
    <div class="flex items-center gap-3">
      <div class="avatar placeholder">
        <div
          class="bg-neutral text-neutral-content rounded-full w-10 flex items-center justify-center"
        >
          <span class="text-xs font-semibold">
            {user ? (user.name || 'User').substring(0, 2).toUpperCase() : '--'}
          </span>
        </div>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-base-content truncate">{user?.name || 'User Name'}</p>
        <p class="text-xs text-neutral truncate">{user?.email || 'user@example.com'}</p>
      </div>
    </div>
  </div>
</aside>
