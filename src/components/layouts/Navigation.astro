---
/**
 * Navigation Component
 *
 * Premium sidebar navigation with brand header, gradient active states,
 * and user profile section. Matches the premium UI redesign specifications.
 *
 * @design-system Allowealth v1.0.0
 * @see https://github.com/allowealth/design-system
 */

import { X, ChevronLeft, User as UserIcon, Shield, LogOut } from '@lucide/astro';
import type { User } from '@/lib/auth/lucia';
import UserProfile from './UserProfile.astro';
import UserNav from './UserNav.astro';
import AdminNav from './AdminNav.astro';
import { APP_VERSION } from '@/lib/version';

interface Props {
  currentPath?: string;
  user?: User | null;
}

const { currentPath = '/', user = null } = Astro.props;

// Check if user is super admin
const isSuperAdmin = user?.role === 'super_admin';

// Allowealth v1.0.0 Design System - Sidebar specifications:
// - Width: 16rem (256px)
// - Brand section padding: p-8 (2rem) - matches PoC
// - Nav item padding: py-3 px-5 (0.75rem 1.25rem) - matches PoC
// - Icon size: 22px (md size from design system)
// - Icon-text gap: gap-4 (1rem) - matches PoC
// - Active state: solid bg-accent/10, rounded-xl, text-accent, no left border
// - Inactive state: text-base-content/60, transparent bg
---

<aside
  class="bg-base-100 w-64 min-w-64 h-full border-r border-base-300 flex flex-col transition-[width,min-width] duration-300 ease-out lg:group-data-[sidebar-collapsed=true]:w-20 lg:group-data-[sidebar-collapsed=true]:min-w-20 relative lg:pb-0"
  role="navigation"
  aria-label="Main navigation"
  transition:persist="main-nav"
>
  <!-- Skip link for keyboard users -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:px-4 focus:py-2 focus:bg-accent focus:text-accent-content focus:rounded font-medium"
  >
    Skip to main content
  </a>

  <!-- Mobile Header with Logo and Close button -->
  <div class="lg:hidden p-6 flex justify-between items-center">
    <a href="/" class="flex items-center gap-3" aria-label="allowealth Home">
      <img src="/favicon.svg" alt="" class="w-8 h-8" aria-hidden="true" />
      <span class="text-xl font-bold tracking-tight text-base-content">allowealth</span>
    </a>
    <button
      type="button"
      class="btn btn-circle btn-ghost rounded-lg min-h-11 min-w-11"
      data-drawer-close
      aria-label="Close menu"
      aria-controls="drawer-toggle"
    >
      <X size={22} class="stroke-current" />
    </button>
  </div>

  <!-- Floating Collapse Toggle -->
  <button
    type="button"
    class="hidden lg:flex absolute -right-5 top-[55px] w-10 h-10 bg-base-100 border border-base-300 rounded-full items-center justify-center shadow-xl text-base-content/60 hover:text-accent transition-all hover:scale-110 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 z-50"
    data-sidebar-toggle
    aria-pressed="false"
    aria-label="Collapse sidebar"
    title="Collapse sidebar"
  >
    <ChevronLeft
      size={20}
      class="stroke-current transition-transform duration-300 group-data-[sidebar-collapsed=true]:rotate-180"
      aria-hidden="true"
    />
  </button>

  <!-- Brand Logo Section (desktop only - mobile has it in the header above) -->
  <div
    class="hidden lg:flex pt-8 px-8 pb-4 items-center gap-3 group-data-[sidebar-collapsed=true]:p-4 group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:gap-0"
  >
    <a
      href="/"
      class="flex items-center gap-3 group-data-[sidebar-collapsed=true]:gap-0"
      aria-label="allowealth Home"
    >
      <img
        src="/favicon.svg"
        alt=""
        class="w-8 h-8 transition-transform duration-200 group-hover:scale-105"
        aria-hidden="true"
      />
      <span
        class="text-xl font-bold tracking-tight text-base-content group-data-[sidebar-collapsed=true]:hidden"
      >
        allowealth
      </span>
    </a>
  </div>

  <!-- Version Divider -->
  <div class="flex items-center gap-2 px-4 pb-4 group-data-[sidebar-collapsed=true]:hidden">
    <div class="flex-1 h-px bg-base-300"></div>
    <span class="text-xs text-base-content/40">v{APP_VERSION}</span>
    <div class="flex-1 h-px bg-base-300"></div>
  </div>

  <!-- Navigation -->
  <ul
    class="menu w-full flex-1 px-4 space-y-1 overflow-y-auto flex flex-col flex-nowrap min-h-0 pb-24 lg:pb-4 group-data-[sidebar-collapsed=true]:px-2"
  >
    {isSuperAdmin ? <AdminNav currentPath={currentPath} /> : <UserNav currentPath={currentPath} />}

    <!-- Mobile User Section - Integrated into nav flow -->
    <li class="lg:hidden mt-4 pt-4 border-t border-base-300">
      <div class="px-4 py-2 mb-1">
        <p class="text-xs text-base-content/50 font-medium uppercase tracking-wide">Signed in as</p>
        <p class="text-sm font-bold text-base-content truncate">{user?.name || 'User'}</p>
      </div>
    </li>
    <li class="lg:hidden">
      <a
        href="/profile"
        class="flex items-center gap-3 py-3 px-5 rounded-xl hover:bg-base-200 transition-colors"
        data-drawer-close
      >
        <UserIcon size={20} class="stroke-current" aria-hidden="true" />
        <span class="font-medium">Profile</span>
      </a>
    </li>
    <li class="lg:hidden">
      <a
        href="/security"
        class="flex items-center gap-3 py-3 px-5 rounded-xl hover:bg-base-200 transition-colors"
        data-drawer-close
      >
        <Shield size={20} class="stroke-current" aria-hidden="true" />
        <span class="font-medium">Security</span>
      </a>
    </li>
    <li class="lg:hidden">
      <button
        type="button"
        class="w-full flex items-center gap-3 py-3 px-5 rounded-xl hover:bg-error/10 transition-colors text-error/70 hover:text-error text-left"
        data-mobile-logout-button
      >
        <LogOut size={20} class="stroke-current" aria-hidden="true" />
        <span class="font-medium">Sign out</span>
      </button>
    </li>
  </ul>

  <!-- Desktop User Profile -->
  <div class="hidden lg:block mt-auto">
    <UserProfile user={user} />
  </div>
</aside>

<script src="./Navigation.client.ts"></script>
