---
/**
 * UserProfile Component
 *
 * User profile section for the navigation sidebar.
 * Displays user avatar, name, account type, and a dropdown menu.
 *
 * @design-system Allowealth v1.0.0
 */

import { User, Shield, LogOut, ChevronDown, Sun, Moon, Monitor, Contrast } from '@lucide/astro';

import type { AuthUser as UserType } from '@/lib/auth/types';

interface Props {
  user?: UserType | null;
}

const { user = null } = Astro.props;

// Generate unique ID for menu (for aria-controls)
const menuId = 'user-profile-menu';

// Get user initials for avatar
const getUserInitials = () => {
  if (!user?.name) return '--';
  return user.name.substring(0, 2).toUpperCase();
};
---

<div
  class="p-5 border-t border-base-300 relative group-data-[sidebar-collapsed=true]:p-3 mt-auto shrink-0 bg-base-100"
  data-profile-dropdown
>
  <button
    type="button"
    class="w-full flex items-center gap-3 p-4 bg-base-200/80 dark:bg-base-200/50 rounded-2xl border border-base-300 dark:border-base-300/50 transition-all hover:bg-base-200 text-left group group-data-[sidebar-collapsed=true]:justify-center group-data-[sidebar-collapsed=true]:gap-0 group-data-[sidebar-collapsed=true]:p-2"
    data-profile-button
    aria-expanded="false"
    aria-haspopup="menu"
    aria-controls={menuId}
    aria-label="Open user menu"
  >
    <div class="avatar placeholder">
      <div
        class="bg-accent/20 text-accent rounded-full w-9 flex items-center justify-center shadow-inner group-hover:scale-105 transition-transform"
      >
        <span class="text-xs font-bold">{getUserInitials()}</span>
      </div>
    </div>
    <div class="flex-1 min-w-0 group-data-[sidebar-collapsed=true]:hidden">
      <p class="text-base font-bold text-base-content truncate">{user?.name || 'User'}</p>
    </div>
    <ChevronDown
      size={20}
      class="text-base-content/40 transition-transform duration-200 shrink-0 group-data-[sidebar-collapsed=true]:hidden"
      data-profile-chevron
      aria-hidden="true"
    />
  </button>

  <!-- User Menu Dropdown -->
  <div
    id={menuId}
    class="absolute bottom-full left-5 right-5 mb-2 bg-base-100 rounded-2xl border border-base-300 shadow-xl z-50 overflow-hidden opacity-0 translate-y-2 pointer-events-none transition-all duration-200 ease-out group-data-[sidebar-collapsed=true]:left-1 group-data-[sidebar-collapsed=true]:right-auto group-data-[sidebar-collapsed=true]:w-48"
    data-profile-menu
    role="menu"
    tabindex="-1"
    aria-label="User profile menu"
    style="opacity: 0; transform: translateY(8px);"
  >
    <div class="p-2 space-y-1">
      <a
        href="/profile"
        class="w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-base-200 text-left transition-colors"
        role="menuitem"
        tabindex="-1"
      >
        <User size={18} class="text-base-content/50" aria-hidden="true" />
        <span class="text-sm font-bold text-base-content">Manage account</span>
      </a>
      <a
        href="/security"
        class="w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-base-200 text-left transition-colors"
        role="menuitem"
        tabindex="-1"
      >
        <Shield size={18} class="text-base-content/50" aria-hidden="true" />
        <span class="text-sm font-bold text-base-content">Security</span>
      </a>
      <div class="px-2 pt-1 pb-2" data-theme-switcher>
        <p class="px-2 mb-1.5 text-xs font-semibold uppercase tracking-widest text-base-content/40">
          Theme
        </p>
        <div class="grid grid-cols-2 gap-1.5">
          {
            (
              [
                // Row 1: System, Mono
                { value: 'system', Icon: Monitor, label: 'System' },
                { value: 'monochrome', Icon: Contrast, label: 'Mono' },
                // Row 2: Light, Dark
                { value: 'light', Icon: Sun, label: 'Light' },
                { value: 'dark', Icon: Moon, label: 'Dark' },
              ] as const
            ).map(({ value, Icon, label }) => (
              <button
                type="button"
                class="flex items-center justify-center gap-2 rounded-xl px-3 py-2.5 text-base-content/50 transition-all hover:bg-base-200 hover:text-base-content hover:scale-[1.02] active:scale-[0.98]"
                data-theme-option={value}
                aria-label={`Switch to ${label} theme`}
                title={label}
                role="menuitem"
                tabindex="-1"
              >
                <Icon size={18} aria-hidden="true" />
                <span class="text-sm font-medium">{label}</span>
              </button>
            ))
          }
        </div>
      </div>
      <div class="h-px bg-base-300 my-1 mx-2" role="separator"></div>
      <button
        type="button"
        class="w-full flex items-center gap-3 px-4 py-3 rounded-xl hover:bg-error/10 text-left transition-colors text-error hover:text-error"
        role="menuitem"
        tabindex="-1"
        data-logout-button
      >
        <LogOut size={18} aria-hidden="true" />
        <span class="text-sm font-bold">Sign out</span>
      </button>
    </div>
  </div>
</div>

<script>
  import { performLogout } from '@/lib/utils/client';

  const initUserProfileDropdowns = () => {
    const profileDropdowns = document.querySelectorAll('[data-profile-dropdown]');

    profileDropdowns.forEach((container) => {
      if (!(container instanceof HTMLElement)) {
        return;
      }

      // Prevent duplicate listeners across Astro view transitions.
      if (container.dataset.profileDropdownBound === 'true') {
        return;
      }
      container.dataset.profileDropdownBound = 'true';

      const button = container.querySelector('[data-profile-button]');
      const menu = container.querySelector('[data-profile-menu]');
      const chevron = container.querySelector('[data-profile-chevron]');
      const logoutButton = container.querySelector('[data-logout-button]');

      const chevronElement =
        chevron instanceof HTMLElement || chevron instanceof SVGElement ? chevron : null;

      if (
        !(button instanceof HTMLButtonElement) ||
        !(menu instanceof HTMLElement) ||
        !chevronElement
      ) {
        return;
      }

      const controller = new AbortController();
      const { signal } = controller;
      let isOpen = false;

      const openMenu = () => {
        isOpen = true;
        button.setAttribute('aria-expanded', 'true');
        // Show menu with animation
        menu.style.opacity = '1';
        menu.style.transform = 'translateY(0)';
        menu.style.pointerEvents = 'auto';
        chevronElement.style.transform = 'rotate(180deg)';
      };

      const closeMenu = () => {
        isOpen = false;
        button.setAttribute('aria-expanded', 'false');
        // Hide menu with animation
        menu.style.opacity = '0';
        menu.style.transform = 'translateY(8px)';
        menu.style.pointerEvents = 'none';
        chevronElement.style.transform = 'rotate(0deg)';
      };

      const toggleMenu = () => {
        if (isOpen) {
          closeMenu();
        } else {
          openMenu();
        }
      };

      const handleClick = (e: MouseEvent) => {
        e.stopPropagation();
        toggleMenu();
      };

      const handleButtonKeydown = (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          toggleMenu();
        } else if (e.key === 'Escape') {
          closeMenu();
          button.focus();
        } else if (e.key === 'Tab') {
          // Close menu on Tab navigation (focus trap)
          if (isOpen) {
            closeMenu();
          }
        }
      };

      const handleDocumentClick = (e: MouseEvent) => {
        if (!(e.target instanceof Node) || !container.contains(e.target)) {
          closeMenu();
        }
      };

      const handleLogoutClick = async (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();
        await performLogout(() => closeMenu());
      };

      button.addEventListener('click', handleClick, { signal });
      button.addEventListener('keydown', handleButtonKeydown, { signal });
      document.addEventListener('click', handleDocumentClick, { signal });
      if (logoutButton instanceof HTMLButtonElement) {
        logoutButton.addEventListener('click', handleLogoutClick, { signal });
      }
      document.addEventListener('astro:before-swap', closeMenu, { signal });

      // Keyboard support for menu items
      const menuItems = menu.querySelectorAll('[role="menuitem"]');
      menuItems.forEach((item, index) => {
        if (!(item instanceof HTMLElement)) {
          return;
        }
        item.addEventListener(
          'keydown',
          (e: KeyboardEvent) => {
            if (e.key === 'ArrowDown') {
              e.preventDefault();
              const nextItem = menuItems[index + 1] || menuItems[0];
              if (nextItem instanceof HTMLElement) {
                nextItem.focus();
              }
            } else if (e.key === 'ArrowUp') {
              e.preventDefault();
              const prevItem = menuItems[index - 1] || menuItems[menuItems.length - 1];
              if (prevItem instanceof HTMLElement) {
                prevItem.focus();
              }
            } else if (e.key === 'Escape') {
              closeMenu();
              button.focus();
            } else if (e.key === 'Tab') {
              // Close menu on Tab (focus trap)
              closeMenu();
            }
          },
          { signal }
        );
      });

      // Cleanup when element is removed from DOM (prevents memory leaks)
      const removalObserver = new MutationObserver(() => {
        if (!document.contains(container)) {
          controller.abort();
          removalObserver.disconnect();
          delete container.dataset.profileDropdownBound;
        }
      });

      removalObserver.observe(document.body, { childList: true, subtree: true });
      signal.addEventListener(
        'abort',
        () => {
          removalObserver.disconnect();
          delete container.dataset.profileDropdownBound;
        },
        { once: true }
      );
    });
  };

  initUserProfileDropdowns();
  document.addEventListener('astro:page-load', initUserProfileDropdowns);
</script>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import {
    THEME_CHANGE_EVENT,
    type Theme,
    applyThemeToDom,
    getCurrentTheme,
    saveTheme,
  } from '@/lib/utils/theme-client';

  let themeSaveController: AbortController | null = null;
  let themeSaveRequestVersion = 0;

  function highlightActiveTheme(switcher: HTMLElement, activeTheme: Theme) {
    switcher.querySelectorAll<HTMLButtonElement>('[data-theme-option]').forEach((btn) => {
      const isActive = btn.dataset.themeOption === activeTheme;
      btn.classList.toggle('bg-accent/10', isActive);
      btn.classList.toggle('text-accent', isActive);
      btn.classList.toggle('text-base-content/50', !isActive);
    });
  }

  function initThemeSwitcher() {
    document.querySelectorAll<HTMLElement>('[data-theme-switcher]').forEach((switcher) => {
      if (switcher.dataset.themeSwitcherBound === 'true') return;
      switcher.dataset.themeSwitcherBound = 'true';

      const controller = new AbortController();
      const { signal } = controller;
      const form = document.getElementById('appearances-form');

      const syncThemeControls = (activeTheme: Theme) => {
        highlightActiveTheme(switcher, activeTheme);

        if (form instanceof HTMLElement) {
          form.dataset.currentTheme = activeTheme;
          form.querySelectorAll<HTMLInputElement>('input[name="theme"]').forEach((radio) => {
            radio.checked = radio.value === activeTheme;
          });
        }
      };

      syncThemeControls(getCurrentTheme());

      document.addEventListener(
        THEME_CHANGE_EVENT,
        (event: Event) => {
          const activeTheme = (event as CustomEvent<{ theme: Theme }>).detail.theme;
          syncThemeControls(activeTheme);
        },
        { signal }
      );

      document.addEventListener(
        'astro:before-swap',
        () => {
          controller.abort();
          // Reset binding flag so theme switcher re-initializes after view transitions
          switcher.removeAttribute('data-theme-switcher-bound');
        },
        { once: true }
      );

      switcher.querySelectorAll<HTMLButtonElement>('[data-theme-option]').forEach((btn) => {
        btn.addEventListener(
          'click',
          async (event) => {
            event.stopPropagation();
            const theme = btn.dataset.themeOption as Theme;
            if (!theme) return;

            const previousTheme = getCurrentTheme();
            themeSaveController?.abort();
            themeSaveController = new AbortController();
            const requestVersion = ++themeSaveRequestVersion;

            applyThemeToDom(theme);
            document.dispatchEvent(new CustomEvent(THEME_CHANGE_EVENT, { detail: { theme } }));

            try {
              await saveTheme(theme, themeSaveController.signal);
              if (requestVersion !== themeSaveRequestVersion) return;
              addToast('Theme updated', 'success');
            } catch (error) {
              if (error instanceof Error && error.name === 'AbortError') return;
              if (requestVersion !== themeSaveRequestVersion) return;
              applyThemeToDom(previousTheme);
              document.dispatchEvent(
                new CustomEvent(THEME_CHANGE_EVENT, { detail: { theme: previousTheme } })
              );
              addToast('Failed to save theme preference', 'error');
            }
          },
          { signal }
        );
      });
    });
  }

  initThemeSwitcher();
  document.addEventListener('astro:page-load', initThemeSwitcher);
</script>

<style>
  /* Additional transition styles for smooth dropdown animation */
  [data-profile-menu] {
    transition-property: opacity, transform;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>
