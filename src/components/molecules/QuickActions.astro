---
/**
 * Quick Actions Component (Molecule)
 *
 * Premium quick action buttons for common tasks:
 * - Add Expense (indigo theme)
 * - Log Income (emerald theme)
 *
 * Features:
 * - Premium card design with IconBadge
 * - Hover scale and shadow effects
 * - Active state with press feedback
 * - Responsive: vertical on mobile, horizontal on desktop
 * - Touch target: min-h-[44px] for accessibility
 *
 * @param {QuickAction[]} actions - Array of quick action objects (default: Add Expense, Log Income)
 * @param {string} className - Additional CSS classes
 * @param {Array} categories - Available categories for transaction modal
 * @param {Array} paymentMethods - Available payment methods for transaction modal
 *
 * TODO: Temporary modal integration - TransactionModal should be properly integrated
 * into the routing/navigation system instead of being embedded here. This is a
 * short-term solution to enable modal-based transaction creation from the dashboard.
 */

import { ShoppingCart, CircleDollarSign, Plus } from '@lucide/astro';
import IconBadge from '../atoms/IconBadge.astro';
import TransactionModal from '../organisms/TransactionModal.astro';

export interface QuickAction {
  label: string;
  url: string;
  icon: 'shopping-cart' | 'circle-dollar' | 'plus';
  variant: 'expense' | 'income';
  ariaLabel: string;
}

export interface Props {
  actions?: QuickAction[];
  className?: string;
  categories?: Array<{ id: string; name: string; type: string; currency?: string }>;
  paymentMethods?: Array<{ id: string; name: string; type: string }>;
}

// Icon mapping for Lucide Astro components
const iconComponents = {
  'shopping-cart': ShoppingCart,
  'circle-dollar': CircleDollarSign,
  plus: Plus,
};

// Color variant mapping for IconBadge
const variantColors: Record<string, 'accent' | 'success'> = {
  expense: 'accent', // indigo
  income: 'success', // emerald
};

// Default quick actions (Add Expense, Log Income)
const defaultActions: QuickAction[] = [
  {
    label: 'Add Expense',
    url: '/transactions/add?type=expense',
    icon: 'shopping-cart',
    variant: 'expense',
    ariaLabel: 'Add new expense transaction',
  },
  {
    label: 'Log Income',
    url: '/transactions/add?type=income',
    icon: 'circle-dollar',
    variant: 'income',
    ariaLabel: 'Add new income transaction',
  },
];

const {
  actions = defaultActions,
  className = '',
  categories = [],
  paymentMethods = [],
} = Astro.props;
---

<div
  class={`flex flex-col sm:flex-row gap-6 ${className}`}
  data-quick-actions
  role="group"
  aria-label="Quick actions"
>
  {
    actions.map((action) => {
      // Fallback to Plus icon for unknown icon names (runtime safety)
      const IconComponent = iconComponents[action.icon] || Plus;
      // Fallback to accent for unknown variants
      const badgeVariant = variantColors[action.variant] || 'accent';

      // Development warning for unknown icons
      if (import.meta.env.DEV && !iconComponents[action.icon]) {
        console.warn(`QuickActions: Unknown icon "${action.icon}", falling back to Plus`);
      }

      return (
        <button
          type="button"
          data-quick-action={action.variant}
          class="flex-1 px-8 py-7 min-h-[44px] bg-base-100 text-base-content font-bold rounded-card-lg border border-base-300 hover:bg-base-200 transition-all shadow-sm hover:shadow-md flex items-center justify-center gap-5 active:scale-95 hover:scale-[1.02] group relative overflow-hidden focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 cursor-pointer text-left"
          aria-label={action.ariaLabel}
        >
          <IconBadge
            variant={badgeVariant}
            size="md"
            className="group-hover:scale-110 transition-transform"
          >
            <IconComponent size={24} class="stroke-current" aria-hidden="true" />
          </IconBadge>
          <span class="text-lg tracking-tight font-bold leading-none">{action.label}</span>
        </button>
      );
    })
  }
</div>

<!-- Transaction Modals (TODO: Temporary integration - should be moved to proper routing) -->
<TransactionModal
  id="expense-modal"
  title="Add Expense"
  open={false}
  action="/api/transactions"
  method="POST"
  values={{ type: 'expense' }}
  categories={categories}
  paymentMethods={paymentMethods}
  submitLabel="Save Expense"
/>
<TransactionModal
  id="income-modal"
  title="Log Income"
  open={false}
  action="/api/transactions"
  method="POST"
  values={{ type: 'income' }}
  categories={categories}
  paymentMethods={paymentMethods}
  submitLabel="Save Income"
/>

<style>
  /* Ensure smooth transitions */
  [data-quick-actions] a {
    transition-property: transform, background-color, box-shadow, border-color;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 200ms;
  }

  [data-quick-actions] a:hover {
    transition-duration: 150ms;
  }

  [data-quick-actions] a:active {
    transition-duration: 75ms;
  }

  /* Ensure IconBadge hover doesn't cause layout shifts */
  [data-quick-actions] [class*='IconBadge'] {
    will-change: transform;
  }
</style>

<script>
  // TODO: Temporary modal integration - Open transaction modals when quick action buttons are clicked
  // This should be replaced with proper modal state management
  (function () {
    function initModalHandlers() {
      const quickActionsContainer = document.querySelector('[data-quick-actions]');
      if (!quickActionsContainer) return;

      /** @param {Event} e */
      quickActionsContainer.addEventListener('click', (e) => {
        const target = /** @type {Element} */ (e.target);
        const button = target.closest('[data-quick-action]');
        if (!button) return;

        const actionType = button.getAttribute('data-quick-action');
        const modalId = actionType === 'expense' ? 'expense-modal' : 'income-modal';
        const modal = /** @type {HTMLDialogElement|null} */ (document.getElementById(modalId));

        if (modal) {
          // @ts-expect-error - modal is HTMLDialogElement which has showModal method
          modal.showModal();
        }
      });
    }

    // Initialize on DOM ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initModalHandlers);
    } else {
      initModalHandlers();
    }
  })();
</script>
