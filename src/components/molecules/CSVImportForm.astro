---
/**
 * CSV Import Form Component
 *
 * Multi-step form for importing CSV files:
 * 1. File upload and parsing
 * 2. Preview validation
 * 3. Column mapping interface
 * 4. Import execution
 *
 * Features:
 * - File upload input for CSV files
 * - Client-side CSV parsing
 * - Preview table of parsed data
 * - Column mapping interface
 * - Error handling for invalid CSV files
 * - Validation feedback
 *
 * Security Features:
 * - All user data rendered via textContent (no innerHTML with user data)
 * - Strict ISO date validation (prevents rollover dates like 2025-99-99)
 * - Inline UI feedback (no alert() per constitution.md baseline)
 * - Full ARIA attributes for accessibility
 *
 * @param {string} action - Form action URL
 */

import Label from '../atoms/Label.astro';
import {
  Check,
  RefreshCw,
  ArrowRight,
  Info,
  ArrowLeft,
  Plus,
  List,
  CircleX,
  TriangleAlert,
  Upload,
} from '@lucide/astro';

export interface Props {
  action: string;
}

const { action } = Astro.props;
---

<!-- Hidden form for actual submission -->
<form
  id="csv-import-form"
  data-action={action}
  method="POST"
  enctype="multipart/form-data"
  class="hidden"
>
  <input type="file" name="csv_file" id="csv-file-hidden" />
  <input type="hidden" name="map_date" id="map-date-hidden" />
  <input type="hidden" name="map_type" id="map-type-hidden" />
  <input type="hidden" name="map_amount" id="map-amount-hidden" />
  <input type="hidden" name="map_currency" id="map-currency-hidden" />
  <input type="hidden" name="map_category" id="map-category-hidden" />
  <input type="hidden" name="map_account" id="map-account-hidden" />
  <input type="hidden" name="map_description" id="map-description-hidden" />
</form>

<!-- Hidden icon templates for client-side cloning -->
<div class="hidden" aria-hidden="true">
  <div id="icon-check-template"><Check size={24} class="stroke-current shrink-0" /></div>
  <div id="icon-error-template"><CircleX size={24} class="stroke-current shrink-0" /></div>
  <div id="icon-warning-template"><TriangleAlert size={24} class="stroke-current shrink-0" /></div>
</div>

<div class="csv-import-container space-y-6">
  <!-- Step 1: File Upload Section -->
  <div id="step-upload" class="space-y-4">
    <div class="form-control">
      <Label
        required
        htmlFor="csv-file-input"
        id="file-label"
        helpText="Select a CSV file to preview"
      >
        Upload CSV File
      </Label>
      <div
        id="csv-drop-zone"
        class="border-2 border-dashed border-base-300 rounded-2xl p-8 text-center hover:border-accent/50 focus-visible:outline-2 focus-visible:outline-accent transition-colors cursor-pointer"
        tabindex="0"
        role="button"
        aria-label="Upload CSV file. Drop a file or press Enter to browse"
        aria-describedby="file-error"
      >
        <Upload size={32} class="stroke-base-content/40 mx-auto mb-3" aria-hidden="true" />
        <p class="text-base-content/70 font-medium">
          Drop CSV file here or <span class="text-accent underline">browse</span>
        </p>
        <p class="text-xs text-base-content/40 mt-2">
          Expected columns: date, type, amount, currency, category, account, description
        </p>
        <input id="csv-file-input" name="csv_file" type="file" accept=".csv" class="hidden" />
      </div>
      <!-- Error message container -->
      <div id="file-error" class="text-error text-sm mt-2 hidden" role="alert"></div>
    </div>
  </div>

  <!-- Loading State -->
  <div id="loading-state" class="hidden" role="status" aria-live="polite">
    <div class="flex items-center gap-3">
      <span class="loading loading-spinner loading-primary"></span>
      <span class="text-base-content/70">Parsing CSV file...</span>
    </div>
  </div>

  <!-- Step 2: Preview Section (hidden until file is parsed) -->
  <div id="preview-section" class="hidden space-y-4">
    <!-- File Info -->
    <div id="file-info" class="alert alert-success" role="alert" aria-live="polite">
      <Check size={16} class="shrink-0" aria-hidden="true" />
      <div>
        <h4 class="font-bold">File Parsed Successfully</h4>
        <p id="file-info-text" class="text-sm"></p>
      </div>
    </div>

    <!-- Preview Table -->
    <div class="space-y-2">
      <h3 class="font-semibold text-base">Preview (First 10 rows)</h3>
      <div class="overflow-x-auto border rounded-lg">
        <table class="table table-sm table-zebra" aria-label="CSV preview table">
          <caption class="hidden">First 10 rows of CSV data</caption>
          <thead>
            <tr id="preview-header"></tr>
          </thead>
          <tbody id="preview-body"></tbody>
        </table>
      </div>
      <p id="row-count" class="text-sm text-base-content/60" aria-live="polite"></p>
    </div>

    <!-- Basic Validation Summary -->
    <div id="validation-section" class="space-y-3">
      <h3 class="font-semibold text-base">File Structure Check</h3>
      <div
        id="validation-results"
        role="region"
        aria-live="polite"
        aria-atomic="true"
        aria-label="Validation results"
      >
      </div>
    </div>

    <!-- Actions -->
    <div class="card-actions justify-end gap-2 pt-4 border-t border-base-300">
      <button
        id="reset-button"
        type="button"
        class="btn btn-ghost"
        aria-label="Choose different file"
      >
        <RefreshCw size={16} class="stroke-current" aria-hidden="true" />
        Choose Different File
      </button>
      <button
        id="proceed-to-mapping-button"
        type="button"
        class="btn btn-accent"
        aria-label="Proceed to column mapping"
      >
        <ArrowRight size={16} class="stroke-current" aria-hidden="true" />
        Map Columns
      </button>
    </div>
  </div>

  <!-- Step 3: Column Mapping Section (hidden initially) -->
  <div id="mapping-section" class="hidden space-y-4">
    <div class="alert alert-info">
      <Info size={16} class="shrink-0" aria-hidden="true" />
      <div>
        <h4 class="font-bold">Step 2: Map CSV Columns to Fields</h4>
        <p class="text-sm">
          Select which CSV column corresponds to each required field. We've suggested mappings based
          on your column names.
        </p>
      </div>
    </div>

    <!-- CSV Preview Reference -->
    <div class="space-y-2">
      <h3 class="font-semibold text-base">Your CSV Columns</h3>
      <div class="overflow-x-auto border rounded-lg">
        <table class="table table-sm table-zebra" aria-label="CSV column reference">
          <caption class="hidden">CSV column names from first row</caption>
          <thead>
            <tr id="mapping-header"></tr>
          </thead>
          <tbody>
            <tr id="mapping-preview-row"></tr>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mapping Form -->
    <div class="space-y-3">
      <h3 class="font-semibold text-base">Column Mapping</h3>

      <!-- Target Fields Mapping -->
      <div id="mapping-fields" class="space-y-3">
        <!-- Field mappings will be generated by JavaScript -->
      </div>
    </div>

    <!-- Mapping Actions -->
    <div class="card-actions justify-end gap-2 pt-4 border-t border-base-300">
      <button
        id="back-to-preview-button"
        type="button"
        class="btn btn-ghost"
        aria-label="Back to file preview"
      >
        <ArrowLeft size={16} class="stroke-current" aria-hidden="true" />
        Back to Preview
      </button>
      <button
        id="auto-map-button"
        type="button"
        class="btn btn-outline"
        aria-label="Auto-detect column mappings"
      >
        <RefreshCw size={16} class="stroke-current" aria-hidden="true" />
        Auto-Detect
      </button>
      <button
        id="confirm-import-button"
        type="button"
        class="btn btn-accent"
        aria-label="Confirm mapping and start import"
      >
        <Check size={16} class="stroke-current" aria-hidden="true" />
        Import Transactions
      </button>
    </div>

    <!-- Validation Message -->
    <div id="mapping-validation" class="hidden" role="alert" aria-live="polite"></div>
  </div>

  <!-- Step 4: Import Progress (hidden initially) -->
  <div id="import-progress-section" class="hidden space-y-4">
    <div class="alert alert-info" role="status" aria-live="polite">
      <span class="loading loading-spinner loading-primary"></span>
      <div>
        <h4 class="font-bold">Importing Transactions...</h4>
        <p class="text-sm">Please wait while we process your CSV file.</p>
      </div>
    </div>
  </div>

  <!-- Step 5: Import Results (hidden initially) -->
  <div id="import-results-section" class="hidden space-y-4">
    <!-- Success Summary -->
    <div id="result-summary" class="alert" role="alert" aria-live="polite"></div>

    <!-- Detailed Results -->
    <div class="card bg-base-100 shadow border border-base-300">
      <div class="card-body">
        <h3 class="card-title text-lg">Import Details</h3>

        <!-- Stats Grid -->
        <div id="result-stats" class="stats stats-vertical lg:stats-horizontal bg-base-200 w-full">
          <div class="stat">
            <div class="stat-title">Imported</div>
            <div id="stat-imported" class="stat-value text-success">0</div>
            <div class="stat-desc">Transactions created</div>
          </div>

          <div class="stat">
            <div class="stat-title">Skipped</div>
            <div id="stat-skipped" class="stat-value text-warning">0</div>
            <div class="stat-desc">Duplicates/Invalid</div>
          </div>

          <div class="stat">
            <div class="stat-title">Errors</div>
            <div id="stat-errors" class="stat-value text-error">0</div>
            <div class="stat-desc">Failed rows</div>
          </div>
        </div>

        <!-- Error Details (if any) -->
        <div id="error-details-section" class="hidden mt-4">
          <h4 class="font-semibold mb-2">Error Details</h4>
          <div class="overflow-x-auto border rounded-lg max-h-60">
            <table class="table table-sm table-zebra" aria-label="Import error details">
              <thead>
                <tr>
                  <th>Row #</th>
                  <th>Error Message</th>
                </tr>
              </thead>
              <tbody id="error-table-body"></tbody>
            </table>
          </div>
        </div>

        <!-- Actions -->
        <div class="card-actions justify-end mt-4 pt-4 border-t border-base-300">
          <button
            id="import-another-button"
            type="button"
            class="btn btn-accent"
            aria-label="Import another file"
          >
            <Plus size={16} class="stroke-current" aria-hidden="true" />
            Import Another File
          </button>
          <a href="/transactions" class="btn btn-outline">
            <List size={16} class="stroke-current" aria-hidden="true" />
            View All Transactions
          </a>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import './CSVImportForm.client';
</script>
