---
/**
 * CSV Import Form Component
 *
 * Form for uploading CSV files with client-side parsing and preview.
 * Features:
 * - File upload input for CSV files
 * - Client-side CSV parsing
 * - Preview table of parsed data
 * - Error handling for invalid CSV files
 * - Validation feedback
 *
 * Security Features:
 * - All user data rendered via textContent (no innerHTML with user data)
 * - Strict ISO date validation (prevents rollover dates like 2025-99-99)
 * - Inline UI feedback (no alert() per constitution.md baseline)
 * - Full ARIA attributes for accessibility
 *
 * @param {string} action - Form action URL
 */

import Label from '../atoms/Label.astro';
import Button from '../atoms/Button.astro';
import Icon from '../atoms/Icon.astro';

export interface Props {
  action: string;
}

const { action } = Astro.props;

// Get CSP nonce from middleware
const cspNonce = Astro.locals.cspNonce || '';
---

<div class="csv-import-container space-y-6">
  <!-- File Upload Section -->
  <div class="form-control">
    <Label
      required
      htmlFor="csv-file-input"
      id="file-label"
      helpText="Select a CSV file to preview"
    >
      Upload CSV File
    </Label>
    <input
      id="csv-file-input"
      name="csv_file"
      type="file"
      accept=".csv"
      class="file-input file-input-bordered w-full"
      aria-describedby="file-error"
    />
    <div class="text-sm text-neutral-500 mt-2">
      <p class="font-medium mb-1">Expected CSV format:</p>
      <ul class="list-disc list-inside space-y-0.5 text-xs">
        <li>date (YYYY-MM-DD format)</li>
        <li>type (expense or income)</li>
        <li>amount (numeric value)</li>
        <li>currency (IDR or USD)</li>
        <li>category (category name)</li>
        <li>payment_method (payment method name)</li>
        <li>description (optional notes)</li>
      </ul>
    </div>
    <!-- Error message container -->
    <div id="file-error" class="text-error text-sm mt-2 hidden" role="alert"></div>
  </div>

  <!-- Loading State -->
  <div id="loading-state" class="hidden" role="status" aria-live="polite">
    <div class="flex items-center gap-3">
      <span class="loading loading-spinner loading-primary"></span>
      <span class="text-neutral-600">Parsing CSV file...</span>
    </div>
  </div>

  <!-- Preview Section (hidden until file is parsed) -->
  <div id="preview-section" class="hidden space-y-4">
    <!-- File Info -->
    <div id="file-info" class="alert alert-success" role="alert" aria-live="polite">
      <Icon name="check" size="sm" />
      <div>
        <h4 class="font-bold">File Parsed Successfully</h4>
        <p id="file-info-text" class="text-sm"></p>
      </div>
    </div>

    <!-- Preview Table -->
    <div class="space-y-2">
      <h3 class="font-semibold text-base">Preview (First 10 rows)</h3>
      <div class="overflow-x-auto border rounded-lg">
        <table class="table table-sm table-zebra" aria-label="CSV preview table">
          <caption class="hidden">First 10 rows of CSV data</caption>
          <thead>
            <tr id="preview-header"></tr>
          </thead>
          <tbody id="preview-body"></tbody>
        </table>
      </div>
      <p id="row-count" class="text-sm text-neutral-500" aria-live="polite"></p>
    </div>

    <!-- Validation Summary -->
    <div id="validation-section" class="space-y-3">
      <h3 class="font-semibold text-base">Validation Summary</h3>
      <div
        id="validation-results"
        role="region"
        aria-live="polite"
        aria-atomic="true"
        aria-label="Validation results"
      >
      </div>
    </div>

    <!-- Actions -->
    <div class="card-actions justify-end gap-2 pt-4 border-t border-base-300">
      <button
        id="reset-button"
        type="button"
        class="btn btn-ghost"
        aria-label="Choose different file"
      >
        <Icon name="refresh" size="sm" />
        Choose Different File
      </button>
      <button
        id="confirm-import-button"
        type="button"
        class="btn btn-primary"
        aria-label="Proceed with CSV import"
      >
        <Icon name="check" size="sm" />
        Proceed with Import
      </button>
    </div>
  </div>
</div>

<script define:vars={{ cspNonce: Astro.locals.cspNonce || '' }} nonce={cspNonce}>
  (function () {
    'use strict';

    // DOM Elements
    const fileInput = document.getElementById('csv-file-input');
    const loadingState = document.getElementById('loading-state');
    const previewSection = document.getElementById('preview-section');
    const previewHeader = document.getElementById('preview-header');
    const previewBody = document.getElementById('preview-body');
    const fileInfo = document.getElementById('file-info');
    const fileInfoText = document.getElementById('file-info-text');
    const rowCount = document.getElementById('row-count');
    const validationResults = document.getElementById('validation-results');
    const resetButton = document.getElementById('reset-button');
    const confirmButton = document.getElementById('confirm-import-button');
    const fileError = document.getElementById('file-error');

    // Required columns for validation
    const REQUIRED_COLUMNS = ['date', 'type', 'amount', 'currency', 'category', 'payment_method'];
    const OPTIONAL_COLUMNS = ['description'];

    // HTML escaping utility to prevent XSS attacks
    const escapeHtml = (text) => {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    };

    // Validate ISO date strictly (no rollover dates like 2025-99-99)
    function isValidISODate(dateStr) {
      // First check regex pattern
      const isoPattern = /^\d{4}-(0[1-9]|1[0-2])-(0[1-9]|[12]\d|3[01])$/;
      if (!isoPattern.test(dateStr)) {
        return false;
      }

      // Then verify the date is valid (no rollover)
      const date = new Date(dateStr);
      const [year, month, day] = dateStr.split('-').map(Number);

      // Check if the date components match (prevents rollover)
      return (
        date.getFullYear() === year &&
        date.getMonth() === month - 1 && // JS months are 0-indexed
        date.getDate() === day
      );
    }

    // CSV Parser
    function parseCSV(text) {
      const lines = [];
      let currentLine = [];
      let currentField = '';
      let inQuotes = false;

      for (let i = 0; i < text.length; i++) {
        const char = text[i];
        const nextChar = text[i + 1];

        if (inQuotes) {
          if (char === '"') {
            if (nextChar === '"') {
              // Escaped quote
              currentField += '"';
              i++;
            } else {
              // End of quotes
              inQuotes = false;
            }
          } else {
            currentField += char;
          }
        } else {
          if (char === '"') {
            inQuotes = true;
          } else if (char === ',') {
            currentLine.push(currentField);
            currentField = '';
          } else if (char === '\n' || (char === '\r' && nextChar === '\n')) {
            currentLine.push(currentField);
            if (currentLine.some((field) => field.trim() !== '')) {
              lines.push(currentLine);
            }
            currentLine = [];
            currentField = '';
            if (char === '\r') i++;
          } else if (char !== '\r') {
            currentField += char;
          }
        }
      }

      // Don't forget the last line/field
      if (currentField || currentLine.length) {
        currentLine.push(currentField);
        if (currentLine.some((field) => field.trim() !== '')) {
          lines.push(currentLine);
        }
      }

      return lines;
    }

    // Validate CSV data
    function validateCSV(headers, rows) {
      const issues = {
        errors: [],
        warnings: [],
        rowErrors: [],
      };

      // Check for required columns
      const missingColumns = REQUIRED_COLUMNS.filter((col) => !headers.includes(col));
      if (missingColumns.length > 0) {
        issues.errors.push(`Missing required columns: ${missingColumns.join(', ')}`);
      }

      // Check for empty columns
      if (headers.length === 0) {
        issues.errors.push('No columns found in CSV file');
        return issues;
      }

      // Validate rows
      rows.forEach((row, rowIndex) => {
        const rowNum = rowIndex + 2; // +1 for header, +1 for 0-index
        const rowErrors = [];

        // Check row length
        if (row.length !== headers.length) {
          rowErrors.push(`Row has ${row.length} columns, expected ${headers.length}`);
        }

        // Validate required fields
        REQUIRED_COLUMNS.forEach((col) => {
          const colIndex = headers.indexOf(col);
          if (colIndex !== -1) {
            const value = row[colIndex]?.trim();

            if (!value) {
              rowErrors.push(`${col} is empty`);
            } else {
              // Type-specific validation
              switch (col) {
                case 'date':
                  if (!isValidISODate(value)) {
                    rowErrors.push(`${col}: "${value}" is not a valid date (YYYY-MM-DD)`);
                  }
                  break;
                case 'type':
                  if (!['expense', 'income'].includes(value.toLowerCase())) {
                    rowErrors.push(`${col}: "${value}" must be "expense" or "income"`);
                  }
                  break;
                case 'amount':
                  if (isNaN(parseFloat(value)) || parseFloat(value) < 0) {
                    rowErrors.push(`${col}: "${value}" must be a positive number`);
                  }
                  break;
                case 'currency':
                  if (!['IDR', 'USD'].includes(value.toUpperCase())) {
                    rowErrors.push(`${col}: "${value}" must be "IDR" or "USD"`);
                  }
                  break;
              }
            }
          }
        });

        if (rowErrors.length > 0) {
          issues.rowErrors.push({ row: rowNum, errors: rowErrors });
        }
      });

      // Warnings for unknown columns
      const knownColumns = [...REQUIRED_COLUMNS, ...OPTIONAL_COLUMNS];
      const unknownColumns = headers.filter((col) => !knownColumns.includes(col.toLowerCase()));
      if (unknownColumns.length > 0) {
        issues.warnings.push(`Unknown columns will be ignored: ${unknownColumns.join(', ')}`);
      }

      return issues;
    }

    // Show error message
    function showError(message) {
      fileError.textContent = message;
      fileError.classList.remove('hidden');
      fileInput.classList.add('input-error');
    }

    // Hide error message
    function hideError() {
      fileError.textContent = '';
      fileError.classList.add('hidden');
      fileInput.classList.remove('input-error');
    }

    // Render preview table
    function renderPreview(headers, rows) {
      // Render header
      previewHeader.innerHTML = '';
      headers.forEach((header) => {
        const th = document.createElement('th');
        th.textContent = header;

        // Mark required columns
        if (REQUIRED_COLUMNS.includes(header.toLowerCase())) {
          const badge = document.createElement('span');
          badge.className = 'badge badge-error badge-xs ml-1';
          badge.textContent = '*';
          th.appendChild(badge);
        }

        previewHeader.appendChild(th);
      });

      // Render body (first 10 rows)
      previewBody.innerHTML = '';
      const previewRows = rows.slice(0, 10);

      previewRows.forEach((row) => {
        const tr = document.createElement('tr');
        row.forEach((cell) => {
          const td = document.createElement('td');
          td.textContent = cell || '(empty)';
          tr.appendChild(td);
        });
        previewBody.appendChild(tr);
      });

      rowCount.textContent = `Showing first ${previewRows.length} of ${rows.length} total rows`;
    }

    // Render validation results
    function renderValidation(issues) {
      // Clear previous results
      while (validationResults.firstChild) {
        validationResults.removeChild(validationResults.firstChild);
      }

      if (
        issues.errors.length === 0 &&
        issues.warnings.length === 0 &&
        issues.rowErrors.length === 0
      ) {
        // Success message
        const successDiv = document.createElement('div');
        successDiv.className = 'alert alert-success';

        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'stroke-current shrink-0 h-6 w-6');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('viewBox', '0 0 24 24');
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('stroke-width', '2');
        path.setAttribute('d', 'M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z');
        svg.appendChild(path);

        const span = document.createElement('span');
        span.textContent = 'All rows validated successfully! Ready to import.';

        successDiv.appendChild(svg);
        successDiv.appendChild(span);
        validationResults.appendChild(successDiv);

        confirmButton.disabled = false;
        return;
      }

      // Errors
      if (issues.errors.length > 0) {
        const errorDiv = document.createElement('div');
        errorDiv.className = 'alert alert-error';

        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'stroke-current shrink-0 h-6 w-6');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('viewBox', '0 0 24 24');
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('stroke-width', '2');
        path.setAttribute(
          'd',
          'M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z'
        );
        svg.appendChild(path);

        const div = document.createElement('div');
        const h4 = document.createElement('h4');
        h4.className = 'font-bold';
        h4.textContent = 'Validation Errors';
        const ul = document.createElement('ul');
        ul.className = 'text-sm mt-1 list-disc list-inside';

        issues.errors.forEach((error) => {
          const li = document.createElement('li');
          li.textContent = error;
          ul.appendChild(li);
        });

        div.appendChild(h4);
        div.appendChild(ul);
        errorDiv.appendChild(svg);
        errorDiv.appendChild(div);
        validationResults.appendChild(errorDiv);

        confirmButton.disabled = true;
      }

      // Warnings
      if (issues.warnings.length > 0) {
        const warningDiv = document.createElement('div');
        warningDiv.className = 'alert alert-warning';

        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'stroke-current shrink-0 h-6 w-6');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('viewBox', '0 0 24 24');
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('stroke-width', '2');
        path.setAttribute(
          'd',
          'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z'
        );
        svg.appendChild(path);

        const div = document.createElement('div');
        const h4 = document.createElement('h4');
        h4.className = 'font-bold';
        h4.textContent = 'Warnings';
        const ul = document.createElement('ul');
        ul.className = 'text-sm mt-1 list-disc list-inside';

        issues.warnings.forEach((warning) => {
          const li = document.createElement('li');
          li.textContent = warning;
          ul.appendChild(li);
        });

        div.appendChild(h4);
        div.appendChild(ul);
        warningDiv.appendChild(svg);
        warningDiv.appendChild(div);
        validationResults.appendChild(warningDiv);
      }

      // Row errors
      if (issues.rowErrors.length > 0) {
        const rowErrorDiv = document.createElement('div');
        rowErrorDiv.className = 'alert alert-warning';

        const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
        svg.setAttribute('class', 'stroke-current shrink-0 h-6 w-6');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('viewBox', '0 0 24 24');
        const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
        path.setAttribute('stroke-linecap', 'round');
        path.setAttribute('stroke-linejoin', 'round');
        path.setAttribute('stroke-width', '2');
        path.setAttribute(
          'd',
          'M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z'
        );
        svg.appendChild(path);

        const div = document.createElement('div');
        const h4 = document.createElement('h4');
        h4.className = 'font-bold';
        h4.textContent = `Row Issues (${issues.rowErrors.length} rows affected)`;
        const errorListDiv = document.createElement('div');
        errorListDiv.className = 'text-sm mt-1 space-y-1';

        // Show first 5 row errors
        const displayErrors = issues.rowErrors.slice(0, 5);
        const remainingCount = issues.rowErrors.length - 5;

        displayErrors.forEach((re) => {
          const rowDiv = document.createElement('div');
          const strong = document.createElement('strong');
          strong.textContent = `Row ${re.row}: `;
          rowDiv.appendChild(strong);
          rowDiv.appendChild(document.createTextNode(re.errors.join(', ')));
          errorListDiv.appendChild(rowDiv);
        });

        if (remainingCount > 0) {
          const moreP = document.createElement('p');
          moreP.className = 'text-xs mt-2';
          moreP.textContent = `...and ${remainingCount} more rows with issues`;
          errorListDiv.appendChild(moreP);
        }

        div.appendChild(h4);
        div.appendChild(errorListDiv);
        rowErrorDiv.appendChild(svg);
        rowErrorDiv.appendChild(div);
        validationResults.appendChild(rowErrorDiv);

        if (issues.errors.length === 0) {
          confirmButton.disabled = false;
        }
      }
    }

    // Reset form
    function resetForm() {
      fileInput.value = '';
      previewSection.classList.add('hidden');
      hideError();
      // Clear validation results safely
      while (validationResults.firstChild) {
        validationResults.removeChild(validationResults.firstChild);
      }
      // Clear preview tables safely
      while (previewHeader.firstChild) {
        previewHeader.removeChild(previewHeader.firstChild);
      }
      while (previewBody.firstChild) {
        previewBody.removeChild(previewBody.firstChild);
      }
    }

    // Handle file selection
    fileInput.addEventListener('change', async function (e) {
      const file = e.target.files[0];

      if (!file) {
        resetForm();
        return;
      }

      hideError();
      loadingState.classList.remove('hidden');
      previewSection.classList.add('hidden');

      try {
        const text = await file.text();

        if (!text.trim()) {
          throw new Error('File is empty');
        }

        // Parse CSV
        const lines = parseCSV(text);

        if (lines.length < 2) {
          throw new Error('CSV file must contain at least a header row and one data row');
        }

        const headers = lines[0].map((h) => h.trim());
        const rows = lines.slice(1);

        // Validate
        const issues = validateCSV(headers, rows);

        // Update UI
        fileInfoText.textContent = `Found ${rows.length} rows with ${headers.length} columns`;
        renderPreview(headers, rows);
        renderValidation(issues);

        // Show preview section
        loadingState.classList.add('hidden');
        previewSection.classList.remove('hidden');
      } catch (err) {
        loadingState.classList.add('hidden');
        showError(err.message || 'Failed to parse CSV file');
      }
    });

    // Reset button
    resetButton.addEventListener('click', resetForm);

    // Confirm import button - navigate to import action (will be implemented in next phase)
    confirmButton.addEventListener('click', function () {
      // Replace alert() with inline UI feedback (constitution.md baseline requirement)
      // Create a temporary info message in the validation results area
      const infoDiv = document.createElement('div');
      infoDiv.className = 'alert alert-info';

      const svg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      svg.setAttribute('class', 'stroke-current shrink-0 h-6 w-6');
      svg.setAttribute('fill', 'none');
      svg.setAttribute('viewBox', '0 0 24 24');
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('stroke-linecap', 'round');
      path.setAttribute('stroke-linejoin', 'round');
      path.setAttribute('stroke-width', '2');
      path.setAttribute('d', 'M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z');
      svg.appendChild(path);

      const div = document.createElement('div');
      const h4 = document.createElement('h4');
      h4.className = 'font-bold';
      h4.textContent = 'Coming Soon';
      const p = document.createElement('p');
      p.className = 'text-sm';
      p.textContent =
        'Import functionality will be implemented in the next phase. The CSV has been validated and is ready for import.';

      div.appendChild(h4);
      div.appendChild(p);
      infoDiv.appendChild(svg);
      infoDiv.appendChild(div);

      // Add to validation results area
      validationResults.appendChild(infoDiv);

      // Auto-remove after 5 seconds
      setTimeout(() => {
        infoDiv.remove();
      }, 5000);
    });
  })();
</script>
