---
/**
 * PasswordChangeForm Component
 *
 * Password change form with old password verification, new password input with
 * strength meter, confirm password validation, and error/success message display.
 *
 * @param {string} formId - Unique identifier for the form (default: 'password-change-form')
 */

import PasswordField from '@/components/atoms/PasswordField.astro';
import Label from '@/components/atoms/Label.astro';
import Button from '@/components/atoms/Button.astro';
import {
  PASSWORD_MIN_LENGTH,
  PASSWORD_ERROR_MESSAGES,
  PASSWORD_REGEX_SOURCES,
} from '@/lib/validation';

export interface Props {
  formId?: string;
}

const { formId = 'password-change-form' } = Astro.props;

// Get CSP nonce from middleware
const cspNonce = Astro.locals.cspNonce || '';

// Password validation regex source strings (from centralized constants)
const HAS_LETTER_REGEX = PASSWORD_REGEX_SOURCES.hasLetter;
const HAS_NUMBER_OR_SPECIAL_REGEX = PASSWORD_REGEX_SOURCES.hasNumberOrSpecial;
---

<div class="card bg-base-100 shadow border border-base-300 max-w-2xl">
  <div class="card-body p-6">
    <h3 class="card-title text-lg mb-2">Change Password</h3>
    <p class="text-sm text-base-content/70 mb-6">
      Update your password. You'll need to enter your current password to make changes.
    </p>

    <form id={formId} class="space-y-5" novalidate>
      <!-- Old Password Field -->
      <div class="form-control">
        <Label htmlFor="old-password" required>Current Password</Label>
        <PasswordField
          id="old-password"
          name="oldPassword"
          placeholder="Enter your current password"
          required
        />
      </div>

      <!-- New Password Field -->
      <div class="form-control">
        <Label htmlFor="new-password" required>New Password</Label>
        <PasswordField
          id="new-password"
          name="newPassword"
          placeholder="Enter your new password"
          required
          showStrength={true}
          showRequirements={true}
        />
      </div>

      <!-- Confirm Password Field -->
      <div class="form-control">
        <Label htmlFor="confirm-password" required>Confirm New Password</Label>
        <PasswordField
          id="confirm-password"
          name="confirmPassword"
          placeholder="Confirm your new password"
          required
        />
      </div>

      <!-- Messages Container -->
      <div id="password-messages" class="space-y-2" aria-live="polite" aria-atomic="true"></div>

      <!-- Submit Button -->
      <div class="pt-2">
        <Button type="submit" variant="primary" className="min-w-[140px]">
          <span data-button-text>Change Password</span>
          <span data-loading-spinner class="hidden">
            <span class="loading loading-spinner"></span>
            Changing...
          </span>
        </Button>
      </div>
    </form>
  </div>
</div>

<script
  define:vars={{
    formId,
    apiPasswordUrl: '/api/user/password',
    PASSWORD_MIN_LENGTH,
    PASSWORD_ERROR_MESSAGES,
    HAS_LETTER_REGEX,
    HAS_NUMBER_OR_SPECIAL_REGEX,
  }}
  nonce={cspNonce}
  is:inline
>
  // HTML escaping utility to prevent XSS
  const escapeHtml = (text) => {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  };

  const form = document.getElementById(formId);
  const messagesContainer = document.getElementById('password-messages');
  const oldPasswordInput = document.getElementById('old-password');
  const newPasswordInput = document.getElementById('new-password');
  const confirmPasswordInput = document.getElementById('confirm-password');
  const submitButton = form?.querySelector('button[type="submit"]');
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  if (!form || !oldPasswordInput || !newPasswordInput || !confirmPasswordInput || !submitButton) {
    console.error('Password change form elements not found');
  } else {
    // Password validation requirements (from centralized constants)
    const passwordRequirements = {
      minLength: PASSWORD_MIN_LENGTH,
      hasLetter: new RegExp(HAS_LETTER_REGEX),
      hasNumberOrSpecial: new RegExp(HAS_NUMBER_OR_SPECIAL_REGEX),
    };

    // Validate password strength
    const isPasswordValid = (password) => {
      return (
        password.length >= passwordRequirements.minLength &&
        passwordRequirements.hasLetter.test(password) &&
        passwordRequirements.hasNumberOrSpecial.test(password)
      );
    };

    // Clear messages on input
    const inputs = form.querySelectorAll('input');
    inputs.forEach((input) => {
      input.addEventListener('input', () => {
        if (messagesContainer) {
          messagesContainer.innerHTML = '';
        }
      });
    });

    // Real-time confirm password validation
    confirmPasswordInput.addEventListener('input', () => {
      if (confirmPasswordInput.value && confirmPasswordInput.value !== newPasswordInput.value) {
        confirmPasswordInput.setCustomValidity('Passwords do not match');
      } else {
        confirmPasswordInput.setCustomValidity('');
      }
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous messages
      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      // Client-side validation
      const errors = [];

      if (!oldPasswordInput.value) {
        errors.push('Please enter your current password');
      }

      if (!newPasswordInput.value) {
        errors.push('Please enter a new password');
      } else if (!isPasswordValid(newPasswordInput.value)) {
        errors.push(PASSWORD_ERROR_MESSAGES.general);
      }

      if (!confirmPasswordInput.value) {
        errors.push('Please confirm your new password');
      } else if (newPasswordInput.value !== confirmPasswordInput.value) {
        errors.push('Passwords do not match');
      }

      if (oldPasswordInput.value === newPasswordInput.value) {
        errors.push('New password must be different from current password');
      }

      // Display validation errors
      if (errors.length > 0) {
        if (messagesContainer) {
          messagesContainer.innerHTML = `
            <div role="alert" class="alert alert-error">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>${escapeHtml(errors.join('. '))}</span>
            </div>
          `;
        }
        return;
      }

      // Show loading state
      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      if (submitButton) submitButton.disabled = true;

      try {
        const formData = new FormData(form);
        const data = {
          oldPassword: formData.get('oldPassword'),
          newPassword: formData.get('newPassword'),
        };

        const response = await fetch(apiPasswordUrl, {
          method: 'PUT',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Success - show success message and reset form
          if (messagesContainer) {
            messagesContainer.innerHTML = `
              <div role="alert" class="alert alert-success">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>Password changed successfully! You can continue using your current session.</span>
              </div>
            `;
          }
          form.reset();
        } else {
          // Error - show error message
          const errorMessage =
            result.error?.message || 'Failed to change password. Please try again.';
          if (messagesContainer) {
            messagesContainer.innerHTML = `
              <div role="alert" class="alert alert-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>${escapeHtml(errorMessage)}</span>
              </div>
            `;
          }
          // Keep form open so user can try again
        }
      } catch (error) {
        console.error('Password change error:', error);
        if (messagesContainer) {
          messagesContainer.innerHTML = `
            <div role="alert" class="alert alert-error">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>An error occurred. Please check your connection and try again.</span>
            </div>
          `;
        }
      } finally {
        // Reset loading state
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        if (submitButton) submitButton.disabled = false;
      }
    });
  }
</script>
