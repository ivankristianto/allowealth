---
import { History } from '@lucide/astro';
import PeriodNavigator, { type PeriodOption } from '@/components/molecules/PeriodNavigator.astro';

export interface Props {
  periodOptions: PeriodOption[];
  selectedPeriod: string;
  className?: string;
}

const { periodOptions, selectedPeriod, className = '' } = Astro.props;

const ghostButtonClass =
  'btn btn-sm min-h-[44px] gap-1 rounded-xl border border-base-300 bg-base-100 px-3 text-base-content/70 hover:border-accent/30 hover:text-accent';
---

<div
  class:list={['flex w-full flex-wrap items-center gap-1 py-1 sm:gap-2 lg:w-auto', className]}
  data-budget-header-controls
>
  <a href="/budget/history" class={ghostButtonClass} aria-label="Budget history">
    <History size={16} class="stroke-current" aria-hidden="true" />
    <span class="text-xs font-semibold">History</span>
  </a>

  <PeriodNavigator
    options={periodOptions}
    selected={selectedPeriod}
    ariaLabel="Select budget month"
    inputName="budget-period"
    className="shrink-0"
    newestFirst
  />
</div>
