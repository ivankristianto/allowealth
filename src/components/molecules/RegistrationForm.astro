---
/**
 * RegistrationForm Component (Molecule)
 *
 * User registration form with validation and loading states.
 * Includes email, name, password, and confirm password fields.
 *
 * @component
 * @description
 * This component follows the **Component/Page Enhancement Pattern**:
 *
 * 1. **Component Role (This File)**:
 *    - Provides UI structure, validation logic, and user interactions
 *    - Includes client-side validation for all fields
 *    - Displays loading states and error/success messages
 *    - Implements a SIMULATED submission as a placeholder (lines 269-297)
 *    - The simulated submission ensures the component works standalone (Storybook, prototypes)
 *
 * 2. **Page Role (Enhancement)**:
 *    - Pages that use this component should enhance it with real API calls
 *    - Use `e.stopImmediatePropagation()` to prevent the default handler
 *    - Implement the actual fetch API call to your registration endpoint
 *    - Keep the same validation and UI state management patterns
 *
 * 3. **Example Implementation**:
 *    See `/src/pages/register.astro` for the proper enhancement pattern:
 *    - Line 68: `e.stopImmediatePropagation()` prevents default handler
 *    - Lines 141-152: Real API call using fetch
 *    - Lines 156-184: Handle success/error responses with same UI patterns
 *
 * 4. **Why This Pattern?**:
 *    - Reusable: Component works in multiple contexts with different endpoints
 *    - Testable: Component can be tested independently (Storybook)
 *    - Flexible: Each page can customize API behavior without modifying the component
 *    - Progressive: Pages can start with simulated behavior, then add real API calls
 *
 * @example
 * ```astro
 * // In your page component:
 * <RegistrationForm />
 *
 * <script>
 *   document.addEventListener('DOMContentLoaded', () => {
 *     const form = document.querySelector('[data-registration-form]');
 *     form.addEventListener('submit', async (e) => {
 *       e.stopImmediatePropagation(); // Prevent default handler
 *       // Your API call logic here...
 *     });
 *   });
 * </script>
 * ```
 */

import Input from '../atoms/Input.astro';
import PasswordField from '../atoms/PasswordField.astro';
import Button from '../atoms/Button.astro';
import Label from '../atoms/Label.astro';
import { Eye, EyeOff } from '@lucide/astro';

interface Props {
  action?: string;
  method?: 'POST' | 'GET';
  submitText?: string;
  loginLink?: string;
  initialServerError?: string;
}

const {
  action = '/api/auth/register',
  method = 'POST',
  submitText = 'Create Account',
  loginLink = '/login',
  initialServerError = '',
} = Astro.props;

// Get CSP nonce from middleware
const cspNonce = Astro.locals.cspNonce || '';
---

<form
  id="registration-form"
  class="space-y-6"
  action={action}
  method={method}
  data-registration-form
  novalidate
>
  <div id="form-messages" class="space-y-2" aria-live="polite" tabindex="-1"></div>

  <div class="form-control">
    <Label htmlFor="name" required>Full Name</Label>
    <Input type="text" id="name" name="name" placeholder="Enter your full name" required />
  </div>

  <div class="form-control">
    <Label htmlFor="email" required>Email Address</Label>
    <Input type="email" id="email" name="email" placeholder="your.email@example.com" required />
  </div>

  <PasswordField
    id="password"
    name="password"
    label="Password"
    placeholder="Create a strong password"
    required={true}
    showStrength={true}
    showRequirements={true}
  />

  <div class="form-control">
    <Label htmlFor="confirm-password" required>Confirm Password</Label>
    <div class="relative">
      <Input
        type="password"
        id="confirm-password"
        name="confirm-password"
        placeholder="Re-enter your password"
        required
        className="pr-12"
      />
      <button
        type="button"
        class="absolute right-3 top-1/2 -translate-y-1/2 btn btn-ghost btn-circle btn-sm"
        aria-label="Toggle password visibility"
        data-toggle-password="confirm-password"
        tabindex="-1"
      >
        <Eye size={20} class="stroke-current" data-eye-icon />
        <EyeOff size={20} class="stroke-current hidden" data-eye-off-icon />
      </button>
    </div>
  </div>

  <Button type="submit" variant="accent" className="w-full" data-submit-button>
    <span data-button-text>{submitText}</span>
    <span data-loading-spinner class="hidden">
      <span class="loading loading-spinner"></span>
      Creating account...
    </span>
  </Button>

  <div class="text-center text-sm">
    <span class="text-base-content/60">Already have an account?</span>
    <a href={loginLink} class="link link-primary ml-1">Sign in</a>
  </div>
</form>

<style>
  /* Form styles */
  [data-registration-form] {
    max-width: 400px;
    margin: 0 auto;
  }

  /* Disabled state during submission */
  [data-registration-form].submitting input,
  [data-registration-form].submitting button {
    pointer-events: none;
    opacity: 0.7;
  }

  /* Focus styles for accessibility */
  input:focus-visible,
  button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
</style>

<script src="/scripts/registration-validation.js" nonce={cspNonce} is:inline></script>

<script
  define:vars={{
    loginLink,
    initialServerError,
  }}
  nonce={cspNonce}
  is:inline
>
  const form = document.querySelector('[data-registration-form]');
  const messagesContainer = document.getElementById('form-messages');
  const submitButton = form?.querySelector('[data-submit-button]');
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  if (form) {
    // Helper functions for dynamic aria-describedby management
    // This ensures screen readers announce form-level errors when they appear

    /**
     * Add aria-describedby="form-messages" to all form inputs
     * Associates inputs with the error message container for screen readers
     */
    const addFormMessagesAssociation = () => {
      const inputs = form.querySelectorAll('input');
      inputs.forEach((input) => {
        const currentDescribedBy = input.getAttribute('aria-describedby') || '';
        // Preserve existing aria-describedby values (like password requirements)
        const describedByIds = currentDescribedBy
          ? `${currentDescribedBy} form-messages`
          : 'form-messages';
        input.setAttribute('aria-describedby', describedByIds);
      });
    };

    /**
     * Remove aria-describedby="form-messages" from all form inputs
     * Removes association when error messages are cleared
     */
    const removeFormMessagesAssociation = () => {
      const inputs = form.querySelectorAll('input');
      inputs.forEach((input) => {
        const currentDescribedBy = input.getAttribute('aria-describedby') || '';
        // Remove form-messages while preserving other aria-describedby values
        const newDescribedBy = currentDescribedBy
          .split(' ')
          .filter((id) => id !== 'form-messages')
          .join(' ')
          .trim();
        if (newDescribedBy) {
          input.setAttribute('aria-describedby', newDescribedBy);
        } else {
          input.removeAttribute('aria-describedby');
        }
      });
    };

    // Display initial server error if provided
    if (initialServerError && messagesContainer) {
      messagesContainer.innerHTML = `
        <div role="alert" class="alert alert-error">
          <svg xmlns="http://www.w3.org/2000/svg" class="shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <circle cx="12" cy="12" r="10"></circle>
            <path d="m15 9-6 6"></path>
            <path d="m9 9 6 6"></path>
          </svg>
          <span>${window.RegistrationValidation.escapeHtml(initialServerError)}</span>
        </div>
      `;
      // Associate inputs with error messages for screen readers
      addFormMessagesAssociation();
    }
    // Handle password toggle for confirm password field
    const toggleButtons = form.querySelectorAll('[data-toggle-password]');
    toggleButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const targetId = button.getAttribute('data-toggle-password');
        const input = document.getElementById(targetId);
        const eyeIcon = button.querySelector('[data-eye-icon]');
        const eyeOffIcon = button.querySelector('[data-eye-off-icon]');

        if (input && eyeIcon && eyeOffIcon) {
          const isPassword = input.type === 'password';
          input.type = isPassword ? 'text' : 'password';
          eyeIcon.classList.toggle('hidden', !isPassword);
          eyeOffIcon.classList.toggle('hidden', isPassword);
          button.setAttribute('aria-label', isPassword ? 'Hide password' : 'Show password');
        }
      });
    });

    // Clear messages on input
    const inputs = form.querySelectorAll('input');
    inputs.forEach((input) => {
      input.addEventListener('input', () => {
        if (messagesContainer) {
          messagesContainer.innerHTML = '';
          // Remove association when messages are cleared
          removeFormMessagesAssociation();
        }
      });
    });

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      // Use shared validation from RegistrationValidation module
      const emailInput = document.getElementById('email');
      const validationResult = window.RegistrationValidation.validateRegistrationForm(
        data,
        emailInput
      );

      // Display validation errors
      if (!validationResult.isValid) {
        if (messagesContainer) {
          messagesContainer.innerHTML = window.RegistrationValidation.renderValidationErrors(
            validationResult.errors
          );
          // Associate inputs with error messages for screen readers
          addFormMessagesAssociation();
          // Move focus to first invalid input or message container for accessibility
          const firstInvalidInput = form.querySelector('input[aria-invalid="true"]');
          if (firstInvalidInput) {
            firstInvalidInput.focus();
          } else {
            messagesContainer.focus();
          }
        }
        return;
      }

      // Show loading state
      form.classList.add('submitting');
      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      if (submitButton) submitButton.disabled = true;

      try {
        // PLACEHOLDER SIMULATION: This component provides a simulated submission
        // so it works standalone in Storybook, prototypes, or pages that don't
        // require real registration. Pages that need real API behavior should
        // enhance this component by overriding the submit handler (see below).
        //
        // HOW TO OVERRIDE (page-level enhancement pattern):
        // 1. In your page's <script> tag, use DOMContentLoaded listener
        // 2. Get the form: document.querySelector('[data-registration-form]')
        // 3. Add submit listener with e.stopImmediatePropagation() to block this handler
        // 4. Implement your fetch() API call
        // 5. Use the same UI state management (submitting class, loading spinner, etc.)
        //
        // EXAMPLE: See /src/pages/register.astro lines 56-204 for full implementation

        await new Promise((resolve) => setTimeout(resolve, 2000));

        // Show success message
        if (messagesContainer) {
          messagesContainer.innerHTML = `
						<div role="alert" class="alert alert-success">
							<svg xmlns="http://www.w3.org/2000/svg" class="shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" aria-hidden="true">
								<circle cx="12" cy="12" r="10"></circle>
								<path d="m9 12 2 2 4-4"></path>
							</svg>
							<span>Account created successfully! Redirecting to login...</span>
						</div>
					`;
          // Associate inputs with success message for screen readers
          addFormMessagesAssociation();
          // Move focus to message container for accessibility
          messagesContainer.focus();
        }

        // Reset form
        form.reset();

        // Redirect to login after delay
        setTimeout(() => {
          window.location.href = loginLink;
        }, 2000);
      } catch (error) {
        // Show error message
        if (messagesContainer) {
          messagesContainer.innerHTML = `
						<div role="alert" class="alert alert-error">
							<svg xmlns="http://www.w3.org/2000/svg" class="shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" aria-hidden="true">
								<circle cx="12" cy="12" r="10"></circle>
								<path d="m15 9-6 6"></path>
								<path d="m9 9 6 6"></path>
							</svg>
							<span>An error occurred. Please try again.</span>
						</div>
					`;
          // Associate inputs with error message for screen readers
          addFormMessagesAssociation();
          // Move focus to message container for accessibility
          messagesContainer.focus();
        }
      } finally {
        // Reset loading state
        form.classList.remove('submitting');
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        if (submitButton) submitButton.disabled = false;
      }
    });
  }
</script>
