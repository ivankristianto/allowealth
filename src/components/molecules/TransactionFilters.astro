---
/**
 * Transaction Filters Component
 *
 * Filter controls for transaction list.
 *
 * @param {string} action - Form action URL
 * @param {Array} categories - Available categories
 * @param {Array} assets - Available assets
 * @param {Object} values - Current filter values
 * @param {number} count - Number of results
 */

import Input from '../atoms/Input.astro';
import CategorySelect from '../atoms/CategorySelect.astro';
import AssetSelect from '../atoms/AssetSelect.astro';
import DatePicker from '../atoms/DatePicker.astro';
import Button from '../atoms/Button.astro';
import FormField from '../molecules/FormField.astro';
import { Search } from '@lucide/astro';

export interface Props {
  action: string;
  categories?: Array<{ id: string; name: string; type: string }>;
  assets?: Array<{ id: string; name: string; type: string }>;
  values?: {
    search?: string;
    type?: 'expense' | 'income' | '';
    category_id?: string;
    asset_id?: string;
    currency?: 'IDR' | 'USD' | '';
    start_date?: string;
    end_date?: string;
  };
  count?: number;
}

const { action, categories = [], assets = [], values = {}, count = 0 } = Astro.props;
---

<form action={action} method="GET" class="space-y-4">
  <!-- Search -->
  <FormField label="Search" htmlFor="search">
    <div class="join">
      <Input
        id="search"
        name="search"
        type="text"
        value={values.search || ''}
        placeholder="Search by description..."
        className="join-item"
      />
      <Button type="submit" variant="secondary" size="md" className="join-item" aria-label="Search">
        <Search size={16} class="stroke-current" aria-hidden="true" />
      </Button>
    </div>
  </FormField>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <!-- Type -->
    <FormField label="Type" htmlFor="type">
      <select id="type" name="type" class="select select-bordered">
        <option value="">All Types</option>
        <option value="expense" selected={values.type === 'expense'}>Expense</option>
        <option value="income" selected={values.type === 'income'}>Income</option>
      </select>
    </FormField>

    <!-- Currency -->
    <FormField label="Currency" htmlFor="currency">
      <select id="currency" name="currency" class="select select-bordered">
        <option value="">All Currencies</option>
        <option value="IDR" selected={values.currency === 'IDR'}>IDR</option>
        <option value="USD" selected={values.currency === 'USD'}>USD</option>
      </select>
    </FormField>

    <!-- Category -->
    <CategorySelect
      id="category_id"
      categories={categories}
      value={values.category_id || ''}
      required={false}
      label="Category"
    />

    <!-- Asset -->
    <AssetSelect
      id="asset_id"
      assets={assets}
      value={values.asset_id || ''}
      required={false}
      label="Account"
    />

    <!-- Start Date -->
    <FormField label="From Date" htmlFor="start_date">
      <DatePicker id="start_date" name="start_date" value={values.start_date || ''} />
    </FormField>

    <!-- End Date -->
    <FormField label="To Date" htmlFor="end_date">
      <DatePicker id="end_date" name="end_date" value={values.end_date || ''} />
    </FormField>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between gap-4">
    <span class="text-sm text-base-content/60">{count} transactions found</span>
    <div class="flex gap-2">
      <a href={action} class="btn btn-ghost">Clear Filters</a>
      <Button type="submit" variant="accent">Apply Filters</Button>
    </div>
  </div>
</form>
