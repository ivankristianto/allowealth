---
/**
 * LoginForm Component
 *
 * Reusable login form component with email/password inputs, remember me checkbox,
 * forgot password link, and sign up link.
 *
 * @param {string} action - Form action URL
 * @param {string} method - Form method (default: POST)
 * @param {string} errorMessage - Error message to display
 * @param {string} email - Pre-filled email value
 */

import Input from '../atoms/Input.astro';
import PasswordField from '../atoms/PasswordField.astro';
import Checkbox from '../atoms/Checkbox.astro';
import Label from '../atoms/Label.astro';
import Button from '../atoms/Button.astro';
import ErrorMessage from '../atoms/ErrorMessage.astro';

export interface Props {
  action?: string;
  method?: string;
  errorMessage?: string;
  email?: string;
}

const { action = '/api/auth/login', method = 'POST', errorMessage = '', email = '' } = Astro.props;
---

<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <h2 class="card-title text-2xl font-bold mb-4">Sign In</h2>

    {errorMessage && <ErrorMessage message={errorMessage} />}

    <form action={action} method={method} class="space-y-4">
      <!-- TODO: Add CSRF token when backend auth is implemented -->
      <!-- <input type="hidden" name="csrf_token" value={csrfToken} /> -->

      <!-- Email Field -->
      <div class="form-control">
        <Label htmlFor="email" required>Email</Label>
        <Input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          value={email}
          className="w-full"
        />
      </div>

      <!-- Password Field -->
      <div class="form-control">
        <Label htmlFor="password" required>Password</Label>
        <PasswordField id="password" name="password" placeholder="Enter your password" />
      </div>

      <!-- Remember Me and Forgot Password -->
      <div class="flex items-center justify-between">
        <Checkbox id="remember" name="remember" value="true">Remember me</Checkbox>
        <a href="/forgot-password" class="text-sm text-primary hover:underline">
          Forgot password?
        </a>
      </div>

      <!-- Submit Button -->
      <Button type="submit" variant="primary" className="w-full">Sign In</Button>

      <!-- Sign Up Link -->
      <div class="text-center text-sm">
        Don't have an account?
        <a href="/signup" class="text-primary hover:underline font-medium ml-1">Sign up</a>
      </div>
    </form>
  </div>
</div>

<!-- Client-side validation and security enhancements -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.querySelector('form');
    const emailInput = document.getElementById('email') as HTMLInputElement;
    const passwordInput = document.querySelector(
      '[data-password-input][name="password"]'
    ) as HTMLInputElement;
    const submitButton = document.querySelector('button[type="submit"]') as HTMLButtonElement;

    if (!form || !emailInput || !passwordInput || !submitButton) return;

    // Add autocomplete attributes for security and UX
    emailInput.setAttribute('autocomplete', 'email');
    passwordInput.setAttribute('autocomplete', 'current-password');

    // Add required attributes
    emailInput.required = true;
    passwordInput.required = true;

    // Email validation pattern
    emailInput.pattern = '[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$';
    emailInput.title = 'Please enter a valid email address';

    // Form submission with loading state
    form.addEventListener('submit', () => {
      submitButton.disabled = true;
      submitButton.setAttribute('aria-busy', 'true');
      submitButton.textContent = 'Signing In...';
    });
  });
</script>
