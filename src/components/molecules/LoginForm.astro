---
/**
 * LoginForm Component
 *
 * Reusable login form component with email/password inputs, remember me checkbox,
 * forgot password link, and sign up link. Uses JSON API for login.
 *
 * @param {string} errorMessage - Error message to display
 * @param {string} email - Pre-filled email value
 */

import Input from '../atoms/Input.astro';
import PasswordField from '../atoms/PasswordField.astro';
import Checkbox from '../atoms/Checkbox.astro';
import Label from '../atoms/Label.astro';
import Button from '../atoms/Button.astro';
import ErrorMessage from '../atoms/ErrorMessage.astro';

export interface Props {
  errorMessage?: string;
  email?: string;
  redirectTo?: string;
}

const { errorMessage = '', email = '', redirectTo = '' } = Astro.props;
---

<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <h2 class="card-title text-2xl font-bold mb-4">Sign In</h2>

    <div id="login-messages" aria-live="polite" aria-atomic="true">
      {errorMessage && <ErrorMessage message={errorMessage} />}
    </div>

    <form id="login-form" class="space-y-4" novalidate>
      <!-- Email Field -->
      <div class="form-control">
        <Label htmlFor="email" required>Email</Label>
        <Input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          value={email}
          className="w-full"
        />
      </div>

      <!-- Password Field -->
      <div class="form-control">
        <Label htmlFor="password" required>Password</Label>
        <PasswordField id="password" name="password" placeholder="Enter your password" />
      </div>

      <!-- Remember Me and Forgot Password -->
      <div class="flex items-center justify-between">
        <Checkbox id="remember" name="remember" value="true">Remember me</Checkbox>
        <a href="/forgot-password" class="text-sm text-primary hover:underline">
          Forgot password?
        </a>
      </div>

      <!-- Submit Button -->
      <Button type="submit" variant="primary" className="w-full" data-login-submit-button>
        <span data-button-text>Sign In</span>
        <span data-loading-spinner class="hidden">
          <span class="loading loading-spinner"></span>
          Signing In...
        </span>
      </Button>

      <!-- Sign Up Link -->
      <div class="text-center text-sm">
        Don't have an account?
        <a href="/register" class="text-primary hover:underline font-medium ml-1">Sign up</a>
      </div>
    </form>
  </div>
</div>

<script define:vars={{ redirectTo, apiLoginUrl: '/api/auth/login' }}>
  // HTML escaping utility to prevent XSS
  const escapeHtml = (text) => {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  };

  const form = document.getElementById('login-form');
  const messagesContainer = document.getElementById('login-messages');
  const emailInput = document.getElementById('email');
  const passwordInput = document.querySelector('[data-password-input][name="password"]');
  const submitButton = document.querySelector('[data-login-submit-button]');
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  if (!form || !emailInput || !passwordInput || !submitButton) {
    console.error('Login form elements not found');
  } else {
    // Add autocomplete attributes for security and UX
    emailInput.setAttribute('autocomplete', 'email');
    passwordInput.setAttribute('autocomplete', 'current-password');

    // Add required attributes
    emailInput.required = true;
    passwordInput.required = true;

    // Email validation pattern
    emailInput.pattern = '[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$';
    emailInput.title = 'Please enter a valid email address';

    // Clear messages on input
    const inputs = form.querySelectorAll('input');
    inputs.forEach((input) => {
      input.addEventListener('input', () => {
        if (messagesContainer) {
          const existingError = messagesContainer.querySelector('[role="alert"]');
          if (existingError) {
            existingError.remove();
          }
        }
      });
    });

    // Form submission with fetch API
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous messages
      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      // Client-side validation
      const errors = [];

      if (!emailInput.value || !emailInput.checkValidity()) {
        errors.push('Please enter a valid email address');
      }

      if (!passwordInput.value) {
        errors.push('Please enter your password');
      }

      // Display validation errors
      if (errors.length > 0) {
        if (messagesContainer) {
          messagesContainer.innerHTML = `
            <div role="alert" class="alert alert-error">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>${escapeHtml(errors.join(', '))}</span>
            </div>
          `;
        }
        return;
      }

      // Show loading state
      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      if (submitButton) submitButton.disabled = true;

      try {
        const formData = new FormData(form);
        const data = {
          email: formData.get('email'),
          password: formData.get('password'),
        };

        const response = await fetch(apiLoginUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Login successful - redirect to dashboard or return URL
          const returnUrl = redirectTo || '/dashboard';
          window.location.href = returnUrl;
        } else {
          // Login failed - show error message
          if (messagesContainer) {
            messagesContainer.innerHTML = `
              <div role="alert" class="alert alert-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>${escapeHtml(result.error?.message || 'Login failed. Please try again.')}</span>
              </div>
            `;
          }
        }
      } catch (error) {
        console.error('Login error:', error);
        // Show error message
        if (messagesContainer) {
          messagesContainer.innerHTML = `
            <div role="alert" class="alert alert-error">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>An error occurred. Please try again.</span>
            </div>
          `;
        }
      } finally {
        // Reset loading state
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        if (submitButton) submitButton.disabled = false;
      }
    });
  }
</script>
