---
/**
 * LoginForm Component
 *
 * Reusable login form component with email/password inputs, remember me checkbox,
 * forgot password link, and sign up link. Uses JSON API for login.
 *
 * @param {string} errorMessage - Error message to display
 * @param {string} email - Pre-filled email value
 */

import Input from '../atoms/Input.astro';
import PasswordField from '../atoms/PasswordField.astro';
import Checkbox from '../atoms/Checkbox.astro';
import Button from '../atoms/Button.astro';
import ErrorMessage from '../atoms/ErrorMessage.astro';
import FormField from '../molecules/FormField.astro';
import { CircleX, CircleCheck, Info } from '@lucide/astro';

export interface Props {
  errorMessage?: string;
  email?: string;
  redirectTo?: string;
  bannerMessage?: string;
  bannerType?: 'info' | 'success' | 'error';
  resendEmail?: string;
}

const {
  errorMessage = '',
  email = '',
  redirectTo = '',
  bannerMessage = '',
  bannerType = 'info',
  resendEmail = '',
} = Astro.props;

// Get CSP nonce from middleware
const cspNonce = Astro.locals.cspNonce || '';
---

<div class="card bg-base-100 shadow-2xl border border-base-300">
  <div class="card-body p-8">
    <h2 class="text-2xl font-bold mb-6 text-center">Welcome Back</h2>

    {
      bannerMessage && (
        <div
          role="alert"
          class={`alert mb-4 ${bannerType === 'success' ? 'alert-success' : bannerType === 'error' ? 'alert-error' : 'alert-info'}`}
        >
          {bannerType === 'success' && <CircleCheck size={20} class="stroke-current shrink-0" />}
          {bannerType === 'info' && <Info size={20} class="stroke-current shrink-0" />}
          {bannerType === 'error' && <CircleX size={20} class="stroke-current shrink-0" />}
          <span>{bannerMessage}</span>
          {resendEmail && (
            <button type="button" class="btn btn-ghost" data-resend-email={resendEmail}>
              Resend
            </button>
          )}
        </div>
      )
    }

    <div id="login-messages" data-testid="login-error" aria-live="polite" aria-atomic="true">
      {errorMessage && <ErrorMessage message={errorMessage} />}
    </div>

    <form
      id="login-form"
      data-testid="login-form"
      class="space-y-5"
      novalidate
      data-redirect={redirectTo}
      data-api-login="/api/auth/login"
      data-resend-api="/api/auth/resend-verification"
    >
      <!-- Email Field -->
      <FormField label="Email" htmlFor="email" required>
        <Input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          value={email}
          className="w-full rounded-lg py-4 px-6 h-14 text-base font-bold border border-base-300"
          data-testid="email-input"
        />
      </FormField>

      <!-- Password Field -->
      <PasswordField
        id="password"
        name="password"
        placeholder="Enter your password"
        required
        inputClassName="rounded-lg py-4 pl-6 h-14 text-base font-bold border border-base-300"
        data-testid="password-input"
      />

      <!-- Remember Me and Forgot Password -->
      <div class="flex items-center justify-between">
        <Checkbox id="remember" name="remember" value="true" data-testid="remember-me"
          >Remember me</Checkbox
        >
        <a
          href="/forgot-password"
          class="text-sm text-primary hover:underline"
          data-testid="forgot-password-link"
        >
          Forgot password?
        </a>
      </div>

      <!-- Submit Button -->
      <div class="pt-2">
        <Button
          id="login-submit-button"
          type="submit"
          variant="accent"
          className="w-full h-14 rounded-2xl"
          data-testid="login-btn"
        >
          <span data-button-text>Sign In</span>
          <span data-loading-spinner class="hidden">
            <span class="loading loading-spinner"></span>
            Signing In...
          </span>
        </Button>
      </div>

      <!-- Sign Up Link -->
      <div class="text-center text-sm pt-4 border-t border-base-300">
        Don't have an account?
        <a href="/register" class="link link-primary font-semibold ml-1" data-testid="signup-link"
          >Sign up</a
        >
      </div>
    </form>
  </div>
</div>

<!-- Hidden icon templates for client-side messages -->
<div class="hidden" aria-hidden="true">
  <div id="icon-error-template">
    <CircleX size={24} class="stroke-current shrink-0" />
  </div>
</div>

<script nonce={cspNonce} is:inline>
  // Read server values from data attributes
  const loginForm = document.getElementById('login-form');
  const redirectTo = loginForm?.dataset.redirect || '';
  const apiLoginUrl = loginForm?.dataset.apiLogin || '/api/auth/login';
  const resendApiUrl = loginForm?.dataset.resendApi || '/api/auth/resend-verification';

  // Helper function to clone icon from template
  const getErrorIcon = () => {
    const template = document.getElementById('icon-error-template');
    if (!template?.firstElementChild) {
      console.warn('Error icon template not found or empty');
      return null;
    }
    const clone = template.firstElementChild.cloneNode(true);
    clone.removeAttribute('id'); // Remove ID to avoid duplicates
    return clone;
  };

  // Helper function to show alert messages
  const showErrorAlert = (message) => {
    if (!messagesContainer) return;

    messagesContainer.innerHTML = '';

    const alertDiv = document.createElement('div');
    alertDiv.setAttribute('role', 'alert');
    alertDiv.className = 'alert alert-error';

    const icon = getErrorIcon();
    if (icon) {
      alertDiv.appendChild(icon);
    }

    const textSpan = document.createElement('span');
    // Safe: textContent prevents XSS
    textSpan.textContent = message;
    alertDiv.appendChild(textSpan);

    messagesContainer.appendChild(alertDiv);
  };

  // Show verification error with resend button
  const showVerificationError = (email) => {
    if (!messagesContainer) return;
    messagesContainer.innerHTML = '';

    const alertDiv = document.createElement('div');
    alertDiv.setAttribute('role', 'alert');
    alertDiv.className = 'alert alert-error';

    const icon = getErrorIcon();
    if (icon) alertDiv.appendChild(icon);

    const textSpan = document.createElement('span');
    textSpan.textContent = 'Please verify your email before signing in. ';
    alertDiv.appendChild(textSpan);

    const resendBtn = document.createElement('button');
    resendBtn.type = 'button';
    resendBtn.className = 'btn btn-ghost';
    resendBtn.textContent = 'Resend verification email';
    resendBtn.dataset.resendEmail = email;
    alertDiv.appendChild(resendBtn);

    messagesContainer.appendChild(alertDiv);
  };

  // Handle resend verification email clicks (event delegation)
  document.addEventListener('click', async (e) => {
    const target = e.target;
    if (!target || !target.dataset || !target.dataset.resendEmail) return;

    const email = target.dataset.resendEmail;
    if (!email) return;

    target.disabled = true;
    target.textContent = 'Sending...';

    try {
      const res = await fetch(resendApiUrl, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });

      if (res.ok) {
        target.textContent = 'Sent! Check your inbox';
        target.className = 'btn btn-ghost btn-disabled';
      } else {
        const data = await res.json();
        target.textContent = data.error?.message || 'Failed to send';
        target.disabled = false;
      }
    } catch {
      target.textContent = 'Failed to send. Try again.';
      target.disabled = false;
    }
  });

  const form = loginForm;
  const messagesContainer = document.getElementById('login-messages');
  const emailInput = document.getElementById('email');
  const passwordInput = document.getElementById('password');
  const submitButton = document.getElementById('login-submit-button');
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  if (!form || !emailInput || !passwordInput || !submitButton) {
    console.error('Login form elements not found');
  } else {
    // Add autocomplete attributes for security and UX
    emailInput.setAttribute('autocomplete', 'email');
    passwordInput.setAttribute('autocomplete', 'current-password');

    // Add required attributes
    emailInput.required = true;
    passwordInput.required = true;

    // Email validation pattern
    emailInput.pattern = '[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$';
    emailInput.title = 'Please enter a valid email address';

    // Clear messages on input
    const inputs = form.querySelectorAll('input');
    inputs.forEach((input) => {
      input.addEventListener('input', () => {
        if (messagesContainer) {
          const existingError = messagesContainer.querySelector('[role="alert"]');
          if (existingError) {
            existingError.remove();
          }
        }
      });
    });

    // Form submission with fetch API
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous messages
      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      // Client-side validation
      const errors = [];

      if (!emailInput.value || !emailInput.checkValidity()) {
        errors.push('Please enter a valid email address');
      }

      if (!passwordInput.value) {
        errors.push('Please enter your password');
      }

      // Display validation errors
      if (errors.length > 0) {
        showErrorAlert(errors.join(', '));
        return;
      }

      // Show loading state
      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      if (submitButton) submitButton.disabled = true;

      try {
        const formData = new FormData(form);
        const data = {
          email: formData.get('email'),
          password: formData.get('password'),
          remember: formData.get('remember') === 'true',
        };

        const response = await fetch(apiLoginUrl, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          credentials: 'include',
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Login successful - redirect to dashboard or return URL
          const returnUrl = redirectTo || '/dashboard';
          window.location.href = returnUrl;
        } else if (result.code === 'EMAIL_NOT_VERIFIED') {
          // Show verification error with resend option
          showVerificationError(result.email || emailInput.value);
        } else {
          // Login failed - show error message
          showErrorAlert(
            result.error?.message || result.error || 'Login failed. Please try again.'
          );
        }
      } catch (error) {
        console.error('Login error:', error);
        // Show error message
        showErrorAlert('An error occurred. Please try again.');
      } finally {
        // Reset loading state
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        if (submitButton) submitButton.disabled = false;
      }
    });
  }
</script>
