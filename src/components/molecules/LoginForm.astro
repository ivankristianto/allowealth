---
/**
 * LoginForm Component
 *
 * Reusable login form component with email/password inputs, remember me checkbox,
 * forgot password link, and sign up link. Uses JSON API for login.
 *
 * @param {string} errorMessage - Error message to display
 * @param {string} email - Pre-filled email value
 */

import Input from '../atoms/Input.astro';
import PasswordField from '../atoms/PasswordField.astro';
import Checkbox from '../atoms/Checkbox.astro';
import Button from '../atoms/Button.astro';
import ErrorMessage from '../atoms/ErrorMessage.astro';
import FormField from '../molecules/FormField.astro';
import GoogleButton from '../atoms/GoogleButton.astro';
import { CircleX, CircleCheck, Info } from '@lucide/astro';
import Turnstile from '../atoms/Turnstile.astro';

export interface Props {
  errorMessage?: string;
  email?: string;
  redirectTo?: string;
  bannerMessage?: string;
  bannerType?: 'info' | 'success' | 'error';
  oauthError?: string;
}

const {
  errorMessage = '',
  email = '',
  redirectTo = '',
  bannerMessage = '',
  bannerType = 'info',
  oauthError = '',
} = Astro.props;

const oauthErrorMessages: Record<string, string> = {
  oauth_error: 'Google sign-in failed. Please try again.',
  link_expired: 'Account linking session expired. Please try again.',
  link_failed: 'Failed to link account. Please try again.',
  rate_limited: 'Too many attempts. Please try again later.',
};
const oauthMessage = oauthError ? oauthErrorMessages[oauthError] || 'An error occurred.' : '';
---

<div class="card bg-base-100 shadow-2xl border border-base-300">
  <div class="card-body p-8">
    <h2 class="text-2xl font-bold mb-6 text-center">Welcome Back</h2>

    {
      bannerMessage && (
        <div
          role="alert"
          class={`alert mb-4 ${bannerType === 'success' ? 'alert-success' : bannerType === 'error' ? 'alert-error' : 'alert-info'}`}
        >
          {bannerType === 'success' && <CircleCheck size={20} class="stroke-current shrink-0" />}
          {bannerType === 'info' && <Info size={20} class="stroke-current shrink-0" />}
          {bannerType === 'error' && <CircleX size={20} class="stroke-current shrink-0" />}
          <span>{bannerMessage}</span>
        </div>
      )
    }

    {
      oauthMessage && (
        <div role="alert" class="alert alert-error mb-4">
          <CircleX size={20} class="stroke-current shrink-0" />
          <span>{oauthMessage}</span>
        </div>
      )
    }

    <div id="login-messages" data-testid="login-error" aria-live="polite" aria-atomic="true">
      {errorMessage && <ErrorMessage message={errorMessage} />}
    </div>

    <form
      id="login-form"
      data-testid="login-form"
      data-redirect={redirectTo}
      data-api-login="/api/auth/login"
      class="space-y-5"
      novalidate
    >
      <!-- Email Field -->
      <FormField label="Email" htmlFor="email" required>
        <Input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          value={email}
          className="w-full rounded-lg py-4 px-6 h-14 text-base font-bold border border-base-300"
          data-testid="email-input"
        />
      </FormField>

      <!-- Password Field -->
      <PasswordField
        id="password"
        name="password"
        placeholder="Enter your password"
        required
        inputClassName="rounded-lg py-4 pl-6 h-14 text-base font-bold border border-base-300"
        data-testid="password-input"
      />

      <!-- Remember Me and Forgot Password -->
      <div class="flex items-center justify-between">
        <Checkbox id="remember" name="remember" value="true" data-testid="remember-me"
          >Remember me</Checkbox
        >
        <a
          href="/forgot-password"
          class="text-sm text-primary hover:underline"
          data-testid="forgot-password-link"
        >
          Forgot password?
        </a>
      </div>

      <!-- Bot Protection -->
      <Turnstile />

      <!-- Submit Button -->
      <div class="pt-2">
        <Button
          id="login-submit-button"
          type="submit"
          variant="accent"
          className="w-full h-14 rounded-2xl"
          data-testid="login-btn"
        >
          <span data-button-text>Sign In</span>
          <span data-loading-spinner class="hidden">
            <span class="loading loading-spinner"></span>
            Signing In...
          </span>
        </Button>
      </div>

      <!-- Sign Up Link -->
      <div class="text-center text-sm pt-4 border-t border-base-300">
        Don't have an account?
        <a
          href="/signup"
          class="link link-primary font-semibold ml-1"
          data-testid="signup-link"
          data-astro-reload
        >
          Sign up
        </a>
      </div>
    </form>

    <div class="divider text-base-content/40 text-xs uppercase tracking-widest my-6">or</div>
    <div class="flex flex-col gap-3">
      <button
        id="passkey-signin-btn"
        type="button"
        class="btn btn-outline border-base-300 bg-base-100 hover:bg-base-200 gap-3 h-14 rounded-2xl text-base font-semibold w-full"
        data-testid="passkey-btn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          class="shrink-0"
        >
          <path
            d="M12.4 2.7a2.5 2.5 0 0 1 3.4 0l5.5 5.5a2.5 2.5 0 0 1 0 3.4l-3.7 3.7a2.5 2.5 0 0 1-3.4 0L8.7 9.8a2.5 2.5 0 0 1 0-3.4z"
          ></path>
          <path d="m14 7 3 3"></path>
          <path
            d="m9.4 10.6-6.814 6.814A2 2 0 0 0 2 18.828V21a1 1 0 0 0 1 1h3a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h1a1 1 0 0 0 1-1v-1a1 1 0 0 1 1-1h.172a2 2 0 0 0 1.414-.586l.814-.814"
          ></path>
        </svg>
        <span>Sign in with Passkey</span>
      </button>
      <GoogleButton action="Sign in" />
    </div>
  </div>
</div>

<!-- Hidden icon templates for client-side messages -->
<div class="hidden" aria-hidden="true">
  <div id="icon-error-template">
    <CircleX size={24} class="stroke-current shrink-0" />
  </div>
</div>

<script>
  import { authClient } from '@/lib/auth/client';
  import {
    buildCaptchaHeaders,
    hasCaptchaWidget,
    resetCaptchaWidget,
  } from '@/lib/auth/captcha-client';
  import {
    sanitizeClientAuthNavigationTarget,
    sanitizePostAuthRedirect,
  } from '@/lib/auth/redirect';

  // Read server values from data attributes
  const loginForm = document.getElementById('login-form');
  const redirectTo = sanitizePostAuthRedirect(loginForm?.dataset.redirect);

  // Helper function to clone icon from template
  const getErrorIcon = () => {
    const template = document.getElementById('icon-error-template');
    if (!template?.firstElementChild) {
      console.warn('Error icon template not found or empty');
      return null;
    }
    const clone = template.firstElementChild.cloneNode(true) as Element;
    clone.removeAttribute('id'); // Remove ID to avoid duplicates
    return clone;
  };

  // Helper function to show alert messages
  const showErrorAlert = (message: string) => {
    if (!messagesContainer) return;

    messagesContainer.innerHTML = '';

    const alertDiv = document.createElement('div');
    alertDiv.setAttribute('role', 'alert');
    alertDiv.className = 'alert alert-error';

    const icon = getErrorIcon();
    if (icon) {
      alertDiv.appendChild(icon);
    }

    const textSpan = document.createElement('span');
    // Safe: textContent prevents XSS
    textSpan.textContent = message;
    alertDiv.appendChild(textSpan);

    messagesContainer.appendChild(alertDiv);
  };

  const form = loginForm as HTMLFormElement | null;
  const messagesContainer = document.getElementById('login-messages');
  const emailInput = document.getElementById('email') as HTMLInputElement | null;
  const passwordInput = document.getElementById('password') as HTMLInputElement | null;
  const submitButton = document.getElementById('login-submit-button') as HTMLButtonElement | null;
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  if (!form || !emailInput || !passwordInput || !submitButton) {
    console.error('Login form elements not found');
  } else {
    // Add autocomplete attributes for security, UX, and WebAuthn conditional UI
    emailInput.setAttribute('autocomplete', 'username webauthn');
    passwordInput.setAttribute('autocomplete', 'current-password');

    // Add required attributes
    emailInput.required = true;
    passwordInput.required = true;

    // Email validation pattern
    emailInput.pattern = '[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$';
    emailInput.title = 'Please enter a valid email address';

    // Clear messages on input
    const inputs = form.querySelectorAll('input');
    inputs.forEach((input) => {
      input.addEventListener('input', () => {
        if (messagesContainer) {
          const existingError = messagesContainer.querySelector('[role="alert"]');
          if (existingError) {
            existingError.remove();
          }
        }
      });
    });

    // Passkey conditional UI autofill (browser shows passkey suggestions in email field)
    if (
      typeof PublicKeyCredential !== 'undefined' &&
      PublicKeyCredential.isConditionalMediationAvailable
    ) {
      PublicKeyCredential.isConditionalMediationAvailable()
        .then((available) => {
          if (available) {
            authClient.signIn
              .passkey({ autoFill: true })
              .then((result) => {
                if (!result?.error) {
                  window.location.href = redirectTo || '/dashboard';
                }
              })
              .catch(() => {
                // Conditional UI silently fails if user cancels or no passkeys
              });
          }
        })
        .catch(() => {});
    }

    // Form submission with fetch API
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous messages
      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      // Client-side validation
      const errors = [];

      if (!emailInput.value || !emailInput.checkValidity()) {
        errors.push('Please enter a valid email address');
      }

      if (!passwordInput.value) {
        errors.push('Please enter your password');
      }

      const captchaHeaders = buildCaptchaHeaders(form);
      if (hasCaptchaWidget(form) && !captchaHeaders['x-captcha-response']) {
        errors.push('Please complete the bot protection check');
      }

      // Display validation errors
      if (errors.length > 0) {
        showErrorAlert(errors.join(', '));
        return;
      }

      // Show loading state
      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      if (submitButton) submitButton.disabled = true;

      try {
        let shouldRedirectToTwoFactor = false;
        const result = await authClient.signIn.email({
          email: emailInput.value.trim(),
          password: passwordInput.value,
          rememberMe: (form.querySelector('[name="remember"]') as HTMLInputElement | null)?.checked,
          callbackURL: redirectTo || '/dashboard',
          fetchOptions: {
            headers: captchaHeaders,
            onSuccess(context) {
              shouldRedirectToTwoFactor = context.data?.twoFactorRedirect === true;
            },
          },
        });

        if (result.error) {
          showErrorAlert(result.error.message || 'Login failed. Please try again.');
          return;
        }

        if (shouldRedirectToTwoFactor) {
          const mfaUrl = `/login/verify-mfa${redirectTo ? `?redirect=${encodeURIComponent(redirectTo)}` : ''}`;
          window.location.href = mfaUrl;
          return;
        }

        if (typeof result.data?.url === 'string' && result.data.url.length > 0) {
          const safeTarget = sanitizeClientAuthNavigationTarget(result.data.url, {
            currentOrigin: window.location.origin,
          });

          if (safeTarget) {
            window.location.href = safeTarget;
            return;
          }

          showErrorAlert(
            'Received an invalid redirect target. Sending you to a safe page instead.'
          );
        }

        window.location.href = redirectTo || '/dashboard';
      } catch (error) {
        console.error('Login error:', error);
        // Show error message
        showErrorAlert('An error occurred. Please try again.');
      } finally {
        // Reset loading state
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        if (submitButton) submitButton.disabled = false;
        resetCaptchaWidget();
      }
    });
  }

  // Helper: show an info-level alert (non-error feedback)
  const showInfoAlert = (message: string) => {
    if (!messagesContainer) return;
    messagesContainer.innerHTML = '';
    const alertDiv = document.createElement('div');
    alertDiv.setAttribute('role', 'alert');
    alertDiv.className = 'alert alert-info';
    const textSpan = document.createElement('span');
    textSpan.textContent = message;
    alertDiv.appendChild(textSpan);
    messagesContainer.appendChild(alertDiv);
  };

  // Helper: detect if the passkey operation was cancelled by the user
  const isPasskeyCancellation = (err: unknown): boolean => {
    // DOMException: NotAllowedError is thrown when user cancels the WebAuthn ceremony
    if (err instanceof DOMException && err.name === 'NotAllowedError') return true;
    const msg = (err instanceof Error ? err.message : String(err)).toLowerCase();
    return msg.includes('cancel') || msg.includes('abort') || msg.includes('not allowed');
  };

  // Passkey sign-in button handler
  const passkeyBtn = document.getElementById('passkey-signin-btn') as HTMLButtonElement | null;
  if (passkeyBtn) {
    passkeyBtn.addEventListener('click', async () => {
      passkeyBtn.disabled = true;
      const originalContent = passkeyBtn.innerHTML;
      passkeyBtn.innerHTML =
        '<span class="loading loading-spinner loading-sm"></span><span>Signing In...</span>';

      try {
        const result = await authClient.signIn.passkey();

        if (result?.error) {
          const code = (result.error as { code?: string }).code || '';
          const msg = result.error.message || '';

          if (
            code === 'PASSKEY_NOT_FOUND' ||
            (code === 'AUTHENTICATION_FAILED' && msg.toLowerCase().includes('no passkey'))
          ) {
            showInfoAlert('No passkeys registered yet. Sign in with your password first.');
          } else if (isPasskeyCancellation(msg)) {
            showInfoAlert('Passkey sign-in was cancelled.');
          } else {
            showErrorAlert(msg || 'Passkey sign-in failed. Please try again.');
          }
          return;
        }

        window.location.href = redirectTo || '/dashboard';
      } catch (err) {
        if (isPasskeyCancellation(err)) {
          showInfoAlert('Passkey sign-in was cancelled.');
        } else {
          showErrorAlert('Passkey sign-in failed. Please try again.');
        }
      } finally {
        passkeyBtn.disabled = false;
        passkeyBtn.innerHTML = originalContent;
      }
    });
  }
</script>
