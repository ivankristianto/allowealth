---
/**
 * MfaEnableBanner Component
 *
 * Dismissible info banner encouraging users to enable MFA.
 * Shown on dashboard when MFA is not enabled.
 * Dismissal persisted in localStorage to avoid re-showing.
 */

import { ShieldCheck, X } from '@lucide/astro';
---

<div
  class="p-6 rounded-card border bg-info/10 border-info/20"
  role="alert"
  aria-live="polite"
  data-mfa-enable-banner
  id="mfa-enable-banner"
>
  <div class="flex items-start gap-3">
    <div class="text-info shrink-0 mt-0.5">
      <ShieldCheck size={20} class="stroke-current" aria-hidden="true" />
    </div>

    <div class="flex-1 min-w-0">
      <p class="text-sm font-bold tracking-wide text-info leading-none mb-1.5">
        Secure your account with two-factor authentication
      </p>
      <p class="text-base font-medium leading-relaxed text-info/80">
        Add extra protection.
        <a href="/security" class="link link-info font-semibold ml-1">Enable now</a>
      </p>
    </div>

    <button
      type="button"
      class="btn btn-ghost btn-xs btn-circle rounded-lg h-11 min-h-11 w-11 min-w-11 -mr-2 -mt-2 shrink-0 text-base-content/60 hover:text-base-content"
      aria-label="Dismiss MFA banner"
      data-dismiss-mfa-banner
    >
      <X size={16} class="stroke-current" aria-hidden="true" />
    </button>
  </div>
</div>

<script>
  function initMfaBanner() {
    const banner = document.getElementById('mfa-enable-banner');
    if (!banner) return;

    if (localStorage.getItem('mfa-banner-dismissed') === 'true') {
      banner.style.display = 'none';
      return;
    }

    const dismissButton = banner.querySelector('[data-dismiss-mfa-banner]');
    dismissButton?.addEventListener('click', () => {
      localStorage.setItem('mfa-banner-dismissed', 'true');
      banner.style.display = 'none';
    });
  }

  initMfaBanner();
  document.addEventListener('astro:page-load', initMfaBanner);
</script>
