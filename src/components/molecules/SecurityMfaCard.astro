---
/**
 * SecurityMfaCard Component
 *
 * Displays MFA status and provides enable/disable/manage actions.
 */

import IconBadge from '@/components/atoms/IconBadge.astro';
import Button from '@/components/atoms/Button.astro';
import { ShieldCheck, ShieldOff } from '@lucide/astro';

export interface Props {
  enabled: boolean;
  backupCodesRemaining: number;
}

const { enabled, backupCodesRemaining } = Astro.props;
const hasLowBackupCodes = backupCodesRemaining <= 2 && backupCodesRemaining > 0;
const hasNoBackupCodes = backupCodesRemaining === 0;
---

<section class="card bg-base-100 shadow border border-base-300" data-mfa-card>
  <div class="card-body p-6 space-y-6">
    <div class="flex items-center justify-between">
      <div class="flex items-center gap-4">
        <IconBadge variant={enabled ? 'success' : 'warning'} size="sm">
          {
            enabled ? (
              <ShieldCheck size={20} class="stroke-current" aria-hidden="true" />
            ) : (
              <ShieldOff size={20} class="stroke-current" aria-hidden="true" />
            )
          }
        </IconBadge>
        <div>
          <h3 class="text-lg font-bold">Multi-Factor Authentication</h3>
          <p class="text-xs uppercase tracking-widest text-base-content/50">
            {enabled ? 'Enabled' : 'Not configured'}
          </p>
        </div>
      </div>
      {enabled && <span class="badge badge-success badge-sm gap-1">Active</span>}
    </div>

    {
      enabled ? (
        <div class="space-y-4">
          <div class="rounded-2xl border border-base-300 bg-base-200/60 p-4">
            <div class="flex items-center justify-between">
              <div>
                <p class="text-sm font-semibold">Authenticator App</p>
                <p class="text-xs text-base-content/60">
                  {backupCodesRemaining} backup {backupCodesRemaining === 1 ? 'code' : 'codes'}{' '}
                  remaining
                </p>
              </div>
              <div class="flex gap-2">
                <button
                  type="button"
                  class="btn btn-outline btn-sm rounded-xl"
                  data-action="regenerate-backup-codes"
                  data-testid="regenerate-backup-btn"
                >
                  Regenerate Codes
                </button>
                <button
                  type="button"
                  class="btn btn-outline btn-error btn-sm rounded-xl"
                  data-action="disable-mfa"
                  data-testid="disable-mfa-btn"
                >
                  Disable
                </button>
              </div>
            </div>
          </div>

          {hasLowBackupCodes && (
            <div class="alert alert-warning text-sm">
              <span>You have few backup codes remaining. Consider regenerating them.</span>
            </div>
          )}

          {hasNoBackupCodes && (
            <div class="alert alert-error text-sm">
              <span>
                No backup codes remaining. Regenerate codes to maintain account recovery access.
              </span>
            </div>
          )}
        </div>
      ) : (
        <div class="space-y-4">
          <p class="text-sm text-base-content/60">
            Add an extra layer of security by requiring a verification code from your authenticator
            app when signing in. You will confirm your account password before setup starts.
          </p>
          <Button
            variant="accent"
            className="w-full"
            data-action="enable-mfa"
            data-testid="enable-mfa-btn"
          >
            Enable MFA
          </Button>
        </div>
      )
    }
  </div>
</section>
