---
/**
 * CurrencySelector Component
 *
 * Dropdown for selecting display currency (IDR/USD).
 * Displays current selection with chevron icon.
 */

import { ChevronDown } from '@lucide/astro';

export interface Props {
  selectedCurrency?: 'IDR' | 'USD';
  currencies?: Array<'IDR' | 'USD'>;
}

const { selectedCurrency = 'IDR', currencies = ['IDR', 'USD'] } = Astro.props;

const currencyLabels: Record<string, string> = {
  IDR: 'IDR (Default)',
  USD: 'USD',
};
---

<div class="relative inline-block text-left">
  <label for="currency-select" class="sr-only">Select currency</label>
  <select
    id="currency-select"
    name="currency"
    class="block w-full pl-4 pr-10 py-2 text-base font-medium border-base-300 focus:outline-none focus:ring-2 focus:ring-accent focus:border-accent rounded-xl bg-base-100 text-base-content appearance-none cursor-pointer shadow-sm hover:bg-base-200 transition-colors"
    aria-label="Currency selector"
  >
    {
      currencies.map((currency) => (
        <option value={currency} selected={currency === selectedCurrency}>
          {currencyLabels[currency]}
        </option>
      ))
    }
  </select>
  <div
    class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-neutral"
    aria-hidden="true"
  >
    <ChevronDown size={20} class="stroke-current" />
  </div>
</div>

<script>
  // Client-side script to handle currency selection
  const select = document.getElementById('currency-select') as HTMLSelectElement;
  select?.addEventListener('change', (e) => {
    const selected = (e.target as HTMLSelectElement).value;
    // Store in localStorage for persistence
    localStorage.setItem('selectedCurrency', selected);
    // Dispatch custom event for other components to listen
    window.dispatchEvent(new CustomEvent('currencyChange', { detail: { currency: selected } }));
  });

  // Restore from localStorage on load
  const savedCurrency = localStorage.getItem('selectedCurrency');
  if (savedCurrency && select) {
    select.value = savedCurrency;
  }
</script>
