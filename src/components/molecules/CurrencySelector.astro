---
/**
 * CurrencySelector Component
 *
 * Simple dropdown button for selecting display currency (IDR/USD).
 * Clean minimalist design with light border and chevron indicator.
 */

import { ChevronDown } from '@lucide/astro';

export interface Props {
  selectedCurrency?: 'IDR' | 'USD';
  currencies?: Array<'IDR' | 'USD'>;
}

const { selectedCurrency = 'IDR', currencies = ['IDR', 'USD'] } = Astro.props;

const currencyLabels: Record<string, string> = {
  IDR: 'IDR (Default)',
  USD: 'USD',
};
---

<div class="dropdown dropdown-end">
  <button
    tabindex={0}
    class="px-4 py-2 text-sm font-medium border border-base-300 bg-base-100 text-base-content rounded-xl hover:bg-base-200 transition-colors shadow-sm flex items-center gap-2"
    aria-label="Currency selector"
  >
    <span class="text-base-content">{currencyLabels[selectedCurrency]}</span>
    <ChevronDown size={14} class="stroke-current text-neutral shrink-0" aria-hidden="true" />
  </button>

  <ul
    tabindex={0}
    class="dropdown-content z-[1] menu p-2 shadow-lg bg-base-100 rounded-box w-52 border border-base-300"
  >
    {
      currencies.map((currency) => (
        <li>
          <button
            class="flex items-center gap-2 w-full text-left hover:bg-base-200 rounded-btn"
            data-currency-selector={currency}
            type="button"
          >
            <span class="text-base-content">{currencyLabels[currency]}</span>
            {currency === selectedCurrency && <span class="ml-auto text-accent text-xs">✓</span>}
          </button>
        </li>
      ))
    }
  </ul>
</div>

<script>
  // Client-side script to handle currency selection
  const currencyButtons = document.querySelectorAll('[data-currency-selector]');

  currencyButtons.forEach((button) => {
    button.addEventListener('click', (e: Event) => {
      const selected = (e.currentTarget as HTMLElement).dataset.currencySelector;
      if (selected) {
        // Store in localStorage for persistence
        localStorage.setItem('selectedCurrency', selected);
        // Dispatch custom event for other components to listen
        window.dispatchEvent(new CustomEvent('currencyChange', { detail: { currency: selected } }));
        // Reload page to apply change (or you could update UI without reload)
        window.location.reload();
      }
    });
  });

  // Restore from localStorage on load and update button label
  const savedCurrency = localStorage.getItem('selectedCurrency') || 'IDR';
  const buttonText = document.querySelector('[aria-label="Currency selector"] span');
  if (buttonText) {
    buttonText.textContent = savedCurrency === 'IDR' ? 'IDR (Default)' : 'USD';
  }

  // Update checkmark visibility based on saved currency
  const allButtons = document.querySelectorAll('[data-currency-selector]');
  allButtons.forEach((btn) => {
    const currency = btn.getAttribute('data-currency-selector');
    const checkmark = btn.querySelector('.text-accent');
    if (currency === savedCurrency && checkmark) {
      checkmark.classList.remove('hidden');
    } else if (checkmark) {
      checkmark.classList.add('hidden');
    }
  });
</script>
