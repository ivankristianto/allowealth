---
/**
 * Asset Form Component (Molecule)
 *
 * Form for adding/editing assets with validation.
 *
 * @param {string} action - Form action URL (API endpoint)
 * @param {string} method - Form method (POST or PUT)
 * @param {Object} values - Default form values
 * @param {string} submitLabel - Submit button label
 * @param {string} cancelUrl - URL to cancel and go back
 */

import Input from '../atoms/Input.astro';
import Button from '../atoms/Button.astro';
import Label from '../atoms/Label.astro';
import FormField from '../molecules/FormField.astro';
import { Wallet } from '@lucide/astro';
import type { Currency } from '@/lib/types/asset';
import { DEFAULT_ASSET_CATEGORIES } from '@/lib/constants';

export interface Props {
  action: string;
  method?: 'POST' | 'PUT';
  values?: {
    name?: string;
    categoryId?: string;
    balance?: string;
    currency?: Currency;
  };
  categories?: Array<{
    id: string;
    name: string;
    is_liability: boolean;
    is_system: boolean;
    sort_order: number;
  }>;
  errors?: Record<string, string>;
  submitLabel?: string;
  cancelUrl?: string;
  assetId?: string;
}

const {
  action,
  method = 'POST',
  values = {},
  categories = [],
  errors = {},
  submitLabel = 'Save Asset',
  cancelUrl = '/assets',
  assetId = '',
} = Astro.props;

const categoryOptions = categories.length
  ? categories.map((category) => ({
      value: category.id,
      label: category.name,
    }))
  : DEFAULT_ASSET_CATEGORIES.map((category) => ({
      value: category.legacyType,
      label: category.name,
    }));

const currencyOptions: Array<{ value: Currency; label: string }> = [
  { value: 'IDR', label: 'IDR - Indonesian Rupiah' },
  { value: 'USD', label: 'USD - US Dollar' },
];
---

<!-- Global error message container -->
<div id="asset-form-error" class="hidden alert alert-error" role="alert"></div>

<form
  id="asset-form"
  data-action={action}
  data-method={method}
  data-asset-id={assetId}
  data-cancel-url={cancelUrl}
  class="space-y-4"
  novalidate
>
  <!-- Asset Name -->
  <FormField label="Asset Name" htmlFor="name" required>
    <Input
      id="name"
      name="name"
      type="text"
      value={values.name || ''}
      placeholder="e.g., Savings Account, Mutual Fund ABC"
      required={true}
      error={!!errors.name}
      errorMessage={errors.name}
    />
  </FormField>

  <!-- Asset Category -->
  <FormField
    label="Asset Category"
    htmlFor="categoryId"
    required
    error={!!errors.categoryId}
    errorMessage={errors.categoryId}
    errorId="categoryId-error"
  >
    <div slot="label" class="flex items-center justify-between">
      <Label required htmlFor="categoryId" id="type-label">Asset Category</Label>
      <a href="/assets/categories" class="text-xs text-accent font-semibold hover:underline">
        Manage categories
      </a>
    </div>
    <select
      id="categoryId"
      name="categoryId"
      class="select select-bordered"
      required={true}
      class:list={['select', 'select-bordered', errors.categoryId && 'select-error']}
      aria-describedby={errors.categoryId ? 'categoryId-error' : undefined}
    >
      <option value="">Select category...</option>
      {
        categoryOptions.map((option) => (
          <option value={option.value} selected={values.categoryId === option.value}>
            {option.label}
          </option>
        ))
      }
    </select>
  </FormField>

  <!-- Currency -->
  <FormField
    label="Currency"
    htmlFor="currency"
    required
    error={!!errors.currency}
    errorMessage={errors.currency}
    errorId="currency-error"
  >
    <select
      id="currency"
      name="currency"
      class="select select-bordered"
      required={true}
      class:list={['select', 'select-bordered', errors.currency && 'select-error']}
      aria-describedby={errors.currency ? 'currency-error' : undefined}
    >
      {
        currencyOptions.map((curr) => (
          <option value={curr.value} selected={values.currency === curr.value}>
            {curr.label}
          </option>
        ))
      }
    </select>
  </FormField>

  <!-- Current Balance -->
  <FormField label="Current Balance" htmlFor="balance" required>
    <div class="join">
      <select
        id="currency-select"
        class="select select-bordered select-sm join-item"
        aria-label="Currency"
      >
        {
          currencyOptions.map((curr) => (
            <option value={curr.value} selected={values.currency === curr.value}>
              {curr.value}
            </option>
          ))
        }
      </select>
      <Input
        id="balance"
        name="balance"
        type="text"
        value={values.balance || ''}
        placeholder="Enter current balance"
        required={true}
        error={!!errors.balance}
        errorMessage={errors.balance}
        className="join-item flex-1"
      />
    </div>
  </FormField>

  <!-- Actions -->
  <div class="card-actions justify-end mt-6 gap-2">
    <a href={cancelUrl} class="btn btn-ghost">Cancel</a>
    <Button type="submit" variant="primary" className="gap-2">
      <Wallet size={16} class="stroke-current" aria-hidden="true" />
      {submitLabel}
    </Button>
  </div>
</form>

<script>
  import { getCsrfHeaders } from '@/lib/csrf-client';
  import { attachAmountFormatter, stripAmountFormatting } from '@/lib/formatting/amount-input';
  import type { AmountFormatterHandle } from '@/lib/formatting/amount-input';
  import type { Currency } from '@/lib/constants/currency';

  // Asset Form Client-side script
  // Handles form validation and submission

  interface AssetFormValues {
    name: string;
    categoryId: string;
    balance: string;
    currency: string;
  }

  interface CreateAssetResponse {
    success: boolean;
    data?: any;
    error?: {
      message: string;
      code?: string;
      details?: Array<{ message: string; path: string[] }>;
    };
  }

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('asset-form') as HTMLFormElement;
    if (!form) return;

    const action = form.getAttribute('data-action') || '';
    const method = form.getAttribute('data-method') || 'POST';
    const assetId = form.getAttribute('data-asset-id') || '';
    const cancelUrl = form.getAttribute('data-cancel-url') || '/assets';
    const formError = document.getElementById('asset-form-error') as HTMLElement;
    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    // Currency select sync with balance currency prefix
    const currencySelect = document.getElementById('currency') as HTMLSelectElement;
    const balanceCurrencySelect = document.getElementById('currency-select') as HTMLSelectElement;

    // Attach amount formatter for thousand separators on balance input
    const balanceInput = document.getElementById('balance') as HTMLInputElement;
    let balanceFormatter: AmountFormatterHandle | null = null;
    if (balanceInput) {
      balanceInput.inputMode = 'decimal';
      const initialCurrency = (currencySelect?.value || 'IDR') as Currency;
      balanceFormatter = attachAmountFormatter(balanceInput, initialCurrency);
    }

    // Sync currency selects
    if (currencySelect && balanceCurrencySelect) {
      currencySelect.addEventListener('change', () => {
        balanceCurrencySelect.value = currencySelect.value;
        balanceFormatter?.updateCurrency(currencySelect.value as Currency);
      });

      balanceCurrencySelect.addEventListener('change', () => {
        currencySelect.value = balanceCurrencySelect.value;
        balanceFormatter?.updateCurrency(balanceCurrencySelect.value as Currency);
      });
    }

    // Show form error
    function showFormError(message: string) {
      if (formError) {
        formError.textContent = message;
        formError.classList.remove('hidden');
        formError.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    }

    // Clear form error
    function clearFormError() {
      if (formError) {
        formError.textContent = '';
        formError.classList.add('hidden');
      }
    }

    // Clear field errors
    function clearFieldErrors() {
      form.querySelectorAll('.text-error').forEach((el) => {
        if (el.id !== 'asset-form-error') {
          el.remove();
        }
      });
      form.querySelectorAll('.select-error, .input-error').forEach((el) => {
        el.classList.remove('select-error', 'input-error');
      });
    }

    // Show field error
    function showFieldError(field: string, message: string) {
      const input = form.querySelector(`[name="${field}"]`) as HTMLElement;
      if (input) {
        input.classList.add(input.tagName === 'SELECT' ? 'select-error' : 'input-error');

        // Check if error span already exists
        let errorSpan = input.parentElement?.querySelector(`[id="${field}-error"]`) as HTMLElement;
        if (!errorSpan) {
          errorSpan = document.createElement('span');
          errorSpan.id = `${field}-error`;
          errorSpan.className = 'text-error text-sm mt-1';
          input.parentElement?.appendChild(errorSpan);
        }
        errorSpan.textContent = message;
        errorSpan.setAttribute('role', 'alert');
      }
    }

    // Show loading state
    function setLoading(isLoading: boolean) {
      if (submitButton) {
        submitButton.disabled = isLoading;
        if (isLoading) {
          submitButton.innerHTML =
            '<span class="loading loading-spinner loading-sm"></span> Saving...';
        } else {
          submitButton.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="m9 12 2 2 4-4"/></svg> ${assetId ? 'Update Asset' : 'Save Asset'}`;
        }
      }
    }

    // Validate form
    function validateForm(values: AssetFormValues): string[] {
      const errors: string[] = [];

      if (!values.name || values.name.trim().length === 0) {
        errors.push('Asset name is required');
      } else if (values.name.length > 255) {
        errors.push('Asset name must be less than 255 characters');
      }

      if (!values.categoryId) {
        errors.push('Asset category is required');
      }

      if (!values.currency) {
        errors.push('Currency is required');
      }

      if (!values.balance) {
        errors.push('Balance is required');
      } else {
        const stripped = stripAmountFormatting(
          values.balance,
          (values.currency || 'IDR') as Currency
        );
        const balance = Number(stripped);
        if (isNaN(balance) || balance < 0) {
          errors.push('Balance must be a valid positive number');
        }
      }

      return errors;
    }

    // Show toast notification
    function showToast(message: string, type: 'success' | 'error' = 'success') {
      const toast = document.createElement('div');
      toast.className = `alert alert-${type} shadow-lg fixed top-4 right-4 z-50 max-w-sm`;
      toast.setAttribute('role', 'alert');

      const iconSvg =
        type === 'success'
          ? '<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="m9 12 2 2 4-4"/></svg>'
          : '<svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="m15 9-6 6"/><path stroke-linecap="round" stroke-linejoin="round" d="m9 9 6 6"/></svg>';

      toast.innerHTML = `${iconSvg}<span>${message}</span>`;
      document.body.appendChild(toast);

      setTimeout(() => {
        toast.remove();
      }, 3000);
    }

    // Form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      clearFormError();
      clearFieldErrors();

      const formData = new FormData(form);
      const values: AssetFormValues = {
        name: formData.get('name') as string,
        categoryId: formData.get('categoryId') as string,
        balance: formData.get('balance') as string,
        currency: formData.get('currency') as string,
      };

      // Client-side validation
      const validationErrors = validateForm(values);
      if (validationErrors.length > 0) {
        showFormError(validationErrors.join('. '));
        return;
      }

      setLoading(true);

      try {
        const payload: Record<string, string> = {
          name: values.name,
          balance: stripAmountFormatting(values.balance, (values.currency || 'IDR') as Currency),
          currency: values.currency,
        };

        const nanoidPattern = /^[A-Za-z0-9_-]{21}$/;
        if (nanoidPattern.test(values.categoryId)) {
          payload.categoryId = values.categoryId;
        } else {
          payload.type = values.categoryId;
        }

        const url = assetId ? `/api/assets/${assetId}` : action;
        const response = await fetch(url, {
          method: assetId ? 'PUT' : method,
          headers: getCsrfHeaders({ 'Content-Type': 'application/json' }),
          body: JSON.stringify(payload),
        });

        const result = (await response.json()) as CreateAssetResponse;

        if (!response.ok || !result.success) {
          // Handle field-specific errors
          if (result.error?.details) {
            result.error.details.forEach((detail) => {
              const field = detail.path[detail.path.length - 1];
              showFieldError(field, detail.message);
            });
          } else {
            showFormError(result.error?.message || 'Failed to save asset');
          }
        } else {
          showToast(
            assetId ? 'Asset updated successfully' : 'Asset created successfully',
            'success'
          );

          // Redirect to assets list after brief delay
          setTimeout(() => {
            window.location.href = cancelUrl;
          }, 500);
        }
      } catch (err) {
        showFormError('Network error. Please try again.');
      } finally {
        setLoading(false);
      }
    });
  });
</script>
