---
/**
 * Modal Component
 *
 * Dialog modal for focused user interactions.
 * Can be used for forms, confirmations, or detailed views.
 *
 * Uses Motion library for smooth enter/exit animations per styles.json specification.
 * Respects prefers-reduced-motion for accessibility.
 *
 * @param {string} id - Unique ID for the modal (required for dialog functionality)
 * @param {string} title - Modal title
 * @param {boolean} open - Whether the modal is open
 * @param {string} size - Modal size: sm, md, lg, xl
 * @param {boolean} closable - Show close button
 * @param {boolean} backdropClose - Close when clicking backdrop
 * @param {string} className - Additional CSS classes
 */

import { X } from '@lucide/astro';

interface Props {
  id: string;
  title?: string;
  open?: boolean;
  size?: 'sm' | 'md' | 'lg' | 'xl';
  closable?: boolean;
  backdropClose?: boolean;
  className?: string;
}

const {
  id,
  title = '',
  open = false,
  size = 'md',
  closable = true,
  backdropClose = true,
  className = '',
} = Astro.props;

const sizeClasses: Record<string, string> = {
  sm: 'max-w-md',
  md: 'max-w-lg',
  lg: 'max-w-2xl',
  xl: 'max-w-4xl',
};

// Generate unique ID for title element to link with aria-labelledby
const titleId = title ? `${id}-title` : undefined;
---

<!-- Modal -->
<dialog
  id={id}
  aria-labelledby={titleId}
  class:list={['modal', open && 'modal-open', className]}
  data-modal
  data-backdrop-close={backdropClose ? 'true' : 'false'}
>
  <!-- Backdrop with blur effect -->
  {
    backdropClose && (
      <form
        method="dialog"
        class="modal-backdrop backdrop-blur-md bg-base-content/20"
        data-modal-backdrop
      >
        <button>Close</button>
      </form>
    )
  }

  <!-- Modal content -->
  <div
    class:list={['modal-box', sizeClasses[size], 'rounded-3xl', 'shadow-premium']}
    data-modal-content
  >
    {/* Header */}
    {
      (title || closable) && (
        <div class="flex items-center justify-between mb-4">
          {title && (
            <h3 id={titleId} class="font-bold text-lg">
              {title}
            </h3>
          )}
          {closable && (
            <form method="dialog">
              <button
                class="btn btn-sm btn-circle btn-ghost hover:bg-accent/10 hover:text-accent"
                aria-label="Close modal"
              >
                <X size={16} class="stroke-current" aria-hidden="true" />
              </button>
            </form>
          )}
        </div>
      )
    }

    {/* Content */}
    <div class="py-4">
      <slot />
    </div>

    {/* Actions (if provided) */}
    <slot name="actions" />
  </div>
</dialog>

<script>
  import { animate } from 'motion';
  import {
    MODAL_ANIMATION_CONFIG,
    MODAL_INITIAL_SCALE,
    MODAL_INITIAL_Y_OFFSET,
  } from '@/lib/animations';

  // Track which modals have been initialized to avoid duplicate handlers
  const initializedModals = new WeakSet<Element>();

  function initModal(modal: HTMLDialogElement) {
    // Skip if already initialized
    if (initializedModals.has(modal)) return;
    initializedModals.add(modal);

    const backdropClose = modal.dataset.backdropClose === 'true';

    // Check if user prefers reduced motion for accessibility
    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let prefersReducedMotion = motionQuery.matches;

    // Listen for runtime motion preference changes
    const handleMotionPreferenceChange = (e: MediaQueryListEvent) => {
      prefersReducedMotion = e.matches;
    };
    motionQuery.addEventListener('change', handleMotionPreferenceChange);

    // Get backdrop and content elements
    const getBackdrop = () => modal.querySelector('[data-modal-backdrop]') as HTMLElement | null;
    const getContent = () => modal.querySelector('[data-modal-content]') as HTMLElement | null;

    // Track animation state to prevent overlapping animations
    let isAnimating = false;

    // Animate backdrop enter
    const animateBackdropIn = async () => {
      const backdrop = getBackdrop();
      if (!backdrop) return;

      if (prefersReducedMotion) {
        backdrop.style.opacity = '1';
      } else {
        await animate(backdrop, { opacity: [0, 1] }, MODAL_ANIMATION_CONFIG.backdrop.options);
      }
    };

    // Animate content enter
    const animateContentIn = async () => {
      const content = getContent();
      if (!content) return;

      if (prefersReducedMotion) {
        content.style.opacity = '1';
        content.style.transform = '';
      } else {
        // Cast keyframes to satisfy motion library types
        const keyframes = MODAL_ANIMATION_CONFIG.content.enter.keyframes as Parameters<
          typeof animate
        >[1];
        await animate(content, keyframes, MODAL_ANIMATION_CONFIG.content.enter.options);
      }
    };

    // Animate content exit
    const animateContentOut = async () => {
      const content = getContent();
      if (!content) return;

      if (prefersReducedMotion) {
        content.style.opacity = '0';
        content.style.transform = `scale(${MODAL_INITIAL_SCALE}) translateY(${MODAL_INITIAL_Y_OFFSET}px)`;
      } else {
        // Cast keyframes to satisfy motion library types
        const keyframes = MODAL_ANIMATION_CONFIG.content.exit.keyframes as Parameters<
          typeof animate
        >[1];
        await animate(content, keyframes, MODAL_ANIMATION_CONFIG.content.exit.options);
      }
    };

    // Handle modal show (when modal opens)
    const handleShow = async () => {
      if (isAnimating) return;
      isAnimating = true;

      // Set initial states before animation
      const backdrop = getBackdrop();
      const content = getContent();

      if (prefersReducedMotion) {
        // Show immediately without animation
        if (backdrop) backdrop.style.opacity = '1';
        if (content) {
          content.style.opacity = '1';
          content.style.transform = '';
        }
      } else {
        if (backdrop) backdrop.style.opacity = '0';
        if (content) {
          content.style.opacity = '0';
          content.style.transform = `scale(${MODAL_INITIAL_SCALE}) translateY(${MODAL_INITIAL_Y_OFFSET}px)`;
        }

        // Run both animations (they start simultaneously)
        await Promise.all([animateBackdropIn(), animateContentIn()]);
      }

      isAnimating = false;
    };

    // Handle modal close (when modal closes)
    const handleClose = async (event: Event) => {
      if (isAnimating) return;
      isAnimating = true;

      // Prevent default to allow animation to complete
      event.preventDefault();

      if (prefersReducedMotion) {
        // Close immediately without animation
        modal.close();
      } else {
        // Only animate content exit, backdrop closes instantly (no blur transition)
        await animateContentOut();

        // Close the modal after animation completes
        modal.close();
      }

      isAnimating = false;
    };

    // Listen for close event to reset modal state
    modal.addEventListener('close', () => {
      const backdrop = getBackdrop();
      const content = getContent();

      if (backdrop) backdrop.style.opacity = '';
      if (content) {
        content.style.opacity = '';
        content.style.transform = '';
      }
    });

    // Listen for click events on the dialog to trigger show animation
    // (using a mutation observer to detect when modal-open class is added)
    const observer = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.type === 'attributes' && mutation.attributeName === 'class') {
          const isOpen = modal.classList.contains('modal-open');

          if (isOpen && !isAnimating) {
            // Modal is opening (modal-open class is the source of truth)
            requestAnimationFrame(() => handleShow());
          }
        }
      });
    });

    observer.observe(modal, { attributes: true });

    // Handle backdrop click to close with animation
    if (backdropClose) {
      modal.addEventListener('click', (e) => {
        const rect = modal.getBoundingClientRect();
        const isInDialog =
          rect.top <= e.clientY &&
          e.clientY <= rect.top + rect.height &&
          rect.left <= e.clientX &&
          e.clientX <= rect.left + rect.width;

        if (!isInDialog && modal.open && !isAnimating) {
          handleClose(e);
        }
      });
    }

    // Intercept form submissions (close button clicks)
    const closeForms = modal.querySelectorAll('form[method="dialog"]');
    closeForms.forEach((closeForm) => {
      closeForm.addEventListener('submit', (e: Event) => {
        if (modal.open && !isAnimating) {
          handleClose(e);
        }
      });
    });

    // Cleanup
    const cleanup = () => {
      observer.disconnect();
      motionQuery.removeEventListener('change', handleMotionPreferenceChange);
    };

    // Cleanup when modal is removed from DOM
    const removalObserver = new MutationObserver(() => {
      if (!document.contains(modal)) {
        cleanup();
        removalObserver.disconnect();
      }
    });

    removalObserver.observe(document.body, { childList: true, subtree: true });
  }

  // Initialize all modals on the page
  function initAllModals() {
    document.querySelectorAll<HTMLDialogElement>('dialog[data-modal]').forEach(initModal);
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllModals);
  } else {
    initAllModals();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAllModals);
</script>
