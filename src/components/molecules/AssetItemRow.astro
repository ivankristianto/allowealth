---
/**
 * AssetItemRow Component
 *
 * Individual asset row within an AssetGroupCard.
 * Shows asset name, currency badge, updated date, balance, and action buttons.
 *
 * Part of the Global Portfolio page redesign.
 * Uses modals for edit, delete, and history actions.
 *
 * @param {string} id - Asset ID
 * @param {string} name - Asset name
 * @param {string} type - Asset type (bank_account, stock, etc.)
 * @param {string} categoryId - Asset category ID
 * @param {string} categoryName - Asset category name
 * @param {string} currency - Currency code (IDR or USD)
 * @param {number} balance - Asset balance
 * @param {Date} lastUpdated - Last updated date
 * @param {string} className - Additional CSS classes
 */

import { TrendingUp, Pencil, Trash2, Clock, RefreshCw, History } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import { ASSET_TYPE_LABELS, type AssetType } from '@/lib/types/asset';

export interface Props {
  id: string;
  name: string;
  type: AssetType;
  categoryId?: string | null;
  categoryName?: string | null;
  currency: 'IDR' | 'USD';
  balance: number;
  initialBalance?: number;
  lastUpdated: Date;
  className?: string;
  isHistoricalView?: boolean;
}

const {
  id,
  name,
  type,
  categoryId = null,
  categoryName = null,
  currency,
  balance,
  initialBalance,
  lastUpdated,
  className = '',
  isHistoricalView = false,
} = Astro.props;

// Get display label for type
const typeLabel = ASSET_TYPE_LABELS[type] || type;
const categoryLabel = categoryName || typeLabel;

// Format date for display
const lastUpdateDate = new Date(lastUpdated);
const formattedDate = lastUpdateDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

// Calculate relative time for "last updated" display
const now = new Date();
const diffMs = now.getTime() - lastUpdateDate.getTime();
const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));
const relativeTime =
  diffDays === 0
    ? 'Today'
    : diffDays === 1
      ? 'Yesterday'
      : diffDays < 7
        ? `${diffDays}d ago`
        : diffDays < 30
          ? `${Math.floor(diffDays / 7)}w ago`
          : formattedDate;

// Currency-specific classes
const currencyBadgeClasses =
  currency === 'IDR' ? 'bg-success/10 text-success' : 'bg-info/10 text-info';

const currencyValueClasses = currency === 'IDR' ? 'text-success' : 'text-info';

const rowClasses = [
  'p-4 lg:px-8 lg:py-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4',
  'hover:bg-base-100/50 transition-all group',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={rowClasses} data-asset-row={id} data-testid="asset-item" data-asset-id={id}>
  {/* Asset Info */}
  <div class="flex-1 min-w-0">
    <h4
      class="text-base lg:text-lg font-bold text-base-content leading-none tracking-tight truncate"
      data-testid="asset-name"
    >
      {name}
    </h4>
    <div class="flex items-center gap-3 mt-2 lg:mt-3">
      <span
        class:list={[
          'px-2 py-0.5 rounded-md text-[10px] font-bold tracking-wider uppercase',
          currencyBadgeClasses,
        ]}
      >
        {currency}
      </span>
      <span
        class="inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-[10px] font-bold tracking-wider uppercase bg-base-200 text-base-content/50"
        title={`Last balance input: ${formattedDate}`}
      >
        <Clock size={10} class="stroke-current" aria-hidden="true" />
        {relativeTime}
      </span>
    </div>
  </div>

  {/* Balance and Actions */}
  <div class="flex items-center gap-6 lg:gap-10">
    {/* Balance */}
    <div class="text-right sm:min-w-[140px]">
      <p
        class:list={[
          'text-lg lg:text-xl font-bold tracking-tight leading-none',
          currencyValueClasses,
        ]}
        data-testid="asset-balance"
      >
        {formatCurrency(balance, currency)}
      </p>
      {
        initialBalance !== undefined && initialBalance !== balance && (
          <p
            class="text-[10px] font-medium text-base-content/40 mt-1"
            data-testid="asset-initial-balance"
          >
            Initial: {formatCurrency(initialBalance, currency)}
          </p>
        )
      }
    </div>

    {/* Action Buttons - hidden for historical views */}
    {
      !isHistoricalView && (
        <div class="flex items-center gap-1 opacity-40 group-hover:opacity-100 transition-opacity">
          {/* Inline History Toggle */}
          <div class="tooltip tooltip-bottom" data-tip="Quick history">
            <button
              type="button"
              class="p-2 min-h-11 min-w-11 flex items-center justify-center text-base-content/50 hover:text-info transition-all rounded-xl hover:bg-info/10"
              aria-label={`Toggle ${name} inline history`}
              data-toggle-history
              data-asset-id={id}
              data-testid="asset-inline-history-btn"
            >
              <History size={18} class="stroke-current" aria-hidden="true" />
            </button>
          </div>

          {/* View History / Timeline */}
          <div class="tooltip tooltip-bottom" data-tip="View timeline">
            <button
              type="button"
              class="p-2 min-h-11 min-w-11 flex items-center justify-center text-base-content/50 hover:text-accent transition-all rounded-xl hover:bg-accent/10"
              aria-label={`View ${name} history`}
              data-history-asset={id}
              data-asset-name={name}
              data-asset-type={categoryLabel}
              data-asset-currency={currency}
              data-asset-balance={balance}
              data-testid="asset-history-btn"
            >
              <TrendingUp size={18} class="stroke-current" aria-hidden="true" />
            </button>
          </div>

          {/* Update Value */}
          <div class="tooltip tooltip-bottom" data-tip="Update value">
            <button
              type="button"
              class="p-2 min-h-11 min-w-11 flex items-center justify-center text-base-content/50 hover:text-warning transition-all rounded-xl hover:bg-warning/10"
              aria-label={`Update ${name} value`}
              data-update-value-asset={id}
              data-asset-name={name}
              data-asset-currency={currency}
              data-asset-balance={balance}
              data-testid="asset-update-value-btn"
            >
              <RefreshCw size={18} class="stroke-current" aria-hidden="true" />
            </button>
          </div>

          {/* Edit Asset */}
          <div class="tooltip tooltip-bottom" data-tip="Edit asset">
            <button
              type="button"
              class="p-2 min-h-11 min-w-11 flex items-center justify-center text-base-content/50 hover:text-success transition-all rounded-xl hover:bg-success/10"
              aria-label={`Edit ${name}`}
              data-edit-asset={id}
              data-asset-name={name}
              data-asset-type={type}
              data-asset-category-id={categoryId || ''}
              data-asset-category-name={categoryLabel}
              data-asset-currency={currency}
              data-asset-balance={balance}
              data-testid="asset-edit-btn"
            >
              <Pencil size={18} class="stroke-current" aria-hidden="true" />
            </button>
          </div>

          {/* Delete Asset */}
          <div class="tooltip tooltip-bottom" data-tip="Delete asset">
            <button
              type="button"
              class="p-2 min-h-11 min-w-11 flex items-center justify-center text-base-content/50 hover:text-error transition-all rounded-xl hover:bg-error/10"
              aria-label={`Delete ${name}`}
              data-delete-asset={id}
              data-asset-name={name}
              data-asset-type={categoryLabel}
              data-asset-currency={currency}
              data-asset-balance={balance}
              data-testid="asset-delete-btn"
            >
              <Trash2 size={18} class="stroke-current" aria-hidden="true" />
            </button>
          </div>
        </div>
      )
    }
  </div>
</div>

{/* Inline History Container (populated by client script) */}
{
  !isHistoricalView && (
    <div
      data-history-container
      data-asset-id={id}
      class="hidden bg-base-200/50 rounded-xl p-4 mt-2 mb-2 mx-4 lg:mx-8"
    />
  )
}

<script>
  // Track initialized elements to avoid duplicate listeners
  const initializedHistoryButtons = new WeakSet<Element>();
  const initializedUpdateValueButtons = new WeakSet<Element>();
  const initializedEditButtons = new WeakSet<Element>();
  const initializedDeleteButtons = new WeakSet<Element>();

  function initAssetRowButtons() {
    // Initialize History buttons
    document.querySelectorAll('[data-history-asset]').forEach((button) => {
      if (initializedHistoryButtons.has(button)) return;
      initializedHistoryButtons.add(button);

      button.addEventListener('click', (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();

        const btn = button as HTMLElement;
        const assetId = btn.getAttribute('data-history-asset');
        const assetName = btn.getAttribute('data-asset-name') || 'Asset';
        const assetType = btn.getAttribute('data-asset-type') || 'Unknown';
        const assetCurrency = (btn.getAttribute('data-asset-currency') || 'IDR') as 'IDR' | 'USD';
        const assetBalance = parseFloat(btn.getAttribute('data-asset-balance') || '0');

        if (!assetId) return;

        // Dispatch event to open history modal
        document.dispatchEvent(
          new CustomEvent('open-asset-history', {
            detail: {
              id: assetId,
              name: assetName,
              type: assetType,
              currency: assetCurrency,
              balance: assetBalance,
            },
          })
        );
      });
    });

    // Initialize Update Value buttons
    document.querySelectorAll('[data-update-value-asset]').forEach((button) => {
      if (initializedUpdateValueButtons.has(button)) return;
      initializedUpdateValueButtons.add(button);

      button.addEventListener('click', (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();

        const btn = button as HTMLElement;
        const assetId = btn.getAttribute('data-update-value-asset');
        const assetName = btn.getAttribute('data-asset-name') || 'Asset';
        const assetCurrency = (btn.getAttribute('data-asset-currency') || 'IDR') as 'IDR' | 'USD';
        const assetBalance = parseFloat(btn.getAttribute('data-asset-balance') || '0');

        if (!assetId) return;

        document.dispatchEvent(
          new CustomEvent('open-asset-update-value', {
            detail: {
              id: assetId,
              name: assetName,
              currency: assetCurrency,
              balance: assetBalance,
            },
          })
        );
      });
    });

    // Initialize Edit buttons
    document.querySelectorAll('[data-edit-asset]').forEach((button) => {
      if (initializedEditButtons.has(button)) return;
      initializedEditButtons.add(button);

      button.addEventListener('click', (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();

        const btn = button as HTMLElement;
        const assetId = btn.getAttribute('data-edit-asset');
        const assetName = btn.getAttribute('data-asset-name') || '';
        const assetType = btn.getAttribute('data-asset-type') || 'bank_account';
        const assetCategoryId = btn.getAttribute('data-asset-category-id') || '';
        const assetCategoryName = btn.getAttribute('data-asset-category-name') || '';
        const assetCurrency = (btn.getAttribute('data-asset-currency') || 'IDR') as 'IDR' | 'USD';
        const assetBalance = btn.getAttribute('data-asset-balance') || '0';

        if (!assetId) return;

        // Dispatch event to open edit modal
        document.dispatchEvent(
          new CustomEvent('open-asset-form', {
            detail: {
              id: assetId,
              name: assetName,
              type: assetType,
              categoryId: assetCategoryId,
              categoryName: assetCategoryName,
              currency: assetCurrency,
              balance: assetBalance,
            },
          })
        );
      });
    });

    // Initialize Delete buttons
    document.querySelectorAll('[data-delete-asset]').forEach((button) => {
      if (initializedDeleteButtons.has(button)) return;
      initializedDeleteButtons.add(button);

      button.addEventListener('click', (e: MouseEvent) => {
        e.preventDefault();
        e.stopPropagation();

        const btn = button as HTMLElement;
        const assetId = btn.getAttribute('data-delete-asset');
        const assetName = btn.getAttribute('data-asset-name') || 'this asset';
        const assetType = btn.getAttribute('data-asset-type') || 'Asset';
        const assetCurrency = (btn.getAttribute('data-asset-currency') || 'IDR') as 'IDR' | 'USD';
        const assetBalance = parseFloat(btn.getAttribute('data-asset-balance') || '0');

        if (!assetId) return;

        // Dispatch event to open delete confirmation modal
        document.dispatchEvent(
          new CustomEvent('open-asset-delete', {
            detail: {
              id: assetId,
              name: assetName,
              type: assetType,
              currency: assetCurrency,
              balance: assetBalance,
            },
          })
        );
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAssetRowButtons);
  } else {
    initAssetRowButtons();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initAssetRowButtons);
</script>
