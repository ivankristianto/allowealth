---
/**
 * Admin Workspace Member List
 *
 * Read-only member list showing name, email, role, and join date.
 */
import { User, Crown } from '@lucide/astro';

interface Member {
  id: string;
  name: string;
  email: string;
  role: string;
  createdAt: Date;
}

interface Props {
  members: Member[];
}

const { members } = Astro.props;
---

<div class="card bg-base-100 shadow-sm">
  <div class="card-body">
    <h3 class="card-title text-lg">Members ({members.length})</h3>
    {
      members.length === 0 ? (
        <p class="text-base-content/60">No members</p>
      ) : (
        <div class="overflow-x-auto">
          <table class="table table-sm">
            <thead>
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
              </tr>
            </thead>
            <tbody>
              {members.map((member) => (
                <tr>
                  <td class="font-semibold">{member.name}</td>
                  <td class="text-base-content/70">{member.email}</td>
                  <td>
                    {member.role === 'admin' ? (
                      <span class="badge badge-accent badge-sm gap-1">
                        <Crown size={12} /> Admin
                      </span>
                    ) : (
                      <span class="badge badge-ghost badge-sm gap-1">
                        <User size={12} /> Member
                      </span>
                    )}
                  </td>
                  <td class="text-base-content/70 text-sm">
                    {new Date(member.createdAt).toLocaleDateString()}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </div>
</div>
