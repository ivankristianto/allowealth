---
/**
 * Admin Workspace Member List
 *
 * Read-only member list showing name, email, role, and join date.
 * Uses the Card atom component for design system consistency.
 */
import Card from '@/components/atoms/Card.astro';
import { User, Crown } from '@lucide/astro';

interface Member {
  id: string;
  name: string;
  email: string;
  role: 'admin' | 'member' | 'super_admin';
  createdAt: Date;
}

interface Props {
  members: Member[];
}

const { members } = Astro.props;
---

<section aria-label="Workspace members">
  <Card padding="md">
    <div class="flex items-center justify-between gap-3 mb-4">
      <h3 class="text-lg font-bold">Members</h3>
      <span class="badge badge-outline">{members.length}</span>
    </div>
    {
      members.length === 0 ? (
        <p class="text-base-content/60 py-2">No members in this workspace.</p>
      ) : (
        <div class="overflow-x-auto rounded-2xl border border-base-300/80 bg-base-100">
          <table class="table table-sm">
            <thead class="bg-base-200/70 text-xs uppercase tracking-wide text-base-content/70">
              <tr>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Joined</th>
              </tr>
            </thead>
            <tbody>
              {members.map((member) => (
                <tr class="border-b border-base-200/80 last:border-b-0">
                  <td class="font-semibold text-base-content">{member.name}</td>
                  <td class="text-base-content/70">{member.email}</td>
                  <td>
                    {member.role === 'super_admin' ? (
                      <span class="badge badge-error badge-sm gap-1">
                        <Crown size={12} aria-hidden="true" /> Super Admin
                      </span>
                    ) : member.role === 'admin' ? (
                      <span class="badge badge-accent badge-sm gap-1">
                        <Crown size={12} aria-hidden="true" /> Admin
                      </span>
                    ) : (
                      <span class="badge badge-ghost badge-sm gap-1">
                        <User size={12} aria-hidden="true" /> Member
                      </span>
                    )}
                  </td>
                  <td class="text-base-content/70 text-sm">
                    {new Date(member.createdAt).toLocaleDateString()}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )
    }
  </Card>
</section>
