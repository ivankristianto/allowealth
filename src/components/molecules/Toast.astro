---
/**
 * Toast Notification Component
 *
 * Dismissible notification messages for user feedback.
 * Uses Motion library for smooth enter/exit animations.
 * Respects prefers-reduced-motion for accessibility.
 *
 * Uses shared animation config from @/lib/animations/toast.ts for consistency.
 *
 * @param {string} id - Unique ID for the toast
 * @param {string} message - Toast message
 * @param {string} type - Toast type: success, error, warning, info
 * @param {number} duration - Auto-dismiss duration in ms (0 to disable)
 * @param {string} position - Position: top-right, top-left, bottom-right, bottom-left
 */

import { X } from '@lucide/astro';

interface Props {
  id: string;
  message: string;
  type?: 'success' | 'error' | 'warning' | 'info';
  duration?: number;
  position?: 'top-right' | 'top-left' | 'bottom-right' | 'bottom-left';
}

const { id, message, type = 'info', duration = 5000, position = 'top-right' } = Astro.props;

const typeClasses: Record<string, string> = {
  success: 'alert-success',
  error: 'alert-error',
  warning: 'alert-warning',
  info: 'alert-info',
};

const positionClasses: Record<string, string> = {
  'top-right': 'toast-top toast-end',
  'top-left': 'toast-top toast-start',
  'bottom-right': 'toast-bottom toast-end',
  'bottom-left': 'toast-bottom toast-start',
};
---

<toast-message
  id={id}
  data-type={type}
  data-duration={duration.toString()}
  data-testid={`toast-${type}`}
  class:list={['alert shadow-lg', typeClasses[type], positionClasses[position]]}
>
  <span>{message}</span>
  <button class="btn btn-sm btn-ghost" aria-label="Dismiss notification" data-dismiss>
    <X size={16} class="stroke-current" aria-hidden="true" />
  </button>
</toast-message>

<script>
  import { animate } from 'motion';
  import { TOAST_ANIMATION_CONFIG, TOAST_INITIAL_STYLES } from '@/lib/animations';

  /**
   * Initialize a toast element with animations and auto-dismiss
   * Uses data attributes to pass configuration from server to client
   */
  function initToast(toast: HTMLElement) {
    // Get configuration from data attributes
    const duration = parseInt(toast.dataset.duration || '5000', 10);

    // Check if user prefers reduced motion
    const motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    let prefersReducedMotion = motionQuery.matches;

    // Listen for runtime motion preference changes
    const handleMotionPreferenceChange = (e: MediaQueryListEvent) => {
      prefersReducedMotion = e.matches;
    };
    motionQuery.addEventListener('change', handleMotionPreferenceChange);

    // Track whether toast has been dismissed to prevent race conditions
    let isDismissed = false;
    // Store timeout ID to cancel on manual dismiss
    let autoDismissTimeout: ReturnType<typeof setTimeout> | undefined = undefined;

    // Enter animation (using shared config from @/lib/animations/toast.ts)
    // Skip animation if user prefers reduced motion - show toast immediately
    if (prefersReducedMotion) {
      toast.style.opacity = '1';
    } else {
      // Set initial state for enter animation
      Object.assign(toast.style, TOAST_INITIAL_STYLES);

      animate(toast, TOAST_ANIMATION_CONFIG.enter.keyframes, TOAST_ANIMATION_CONFIG.enter.options);
    }

    // Dismiss toast with exit animation
    const dismiss = () => {
      if (isDismissed) return;
      isDismissed = true;

      // Cancel auto-dismiss timeout if running
      if (autoDismissTimeout !== undefined) {
        clearTimeout(autoDismissTimeout);
        autoDismissTimeout = undefined;
      }

      // Cleanup motion preference listener
      motionQuery.removeEventListener('change', handleMotionPreferenceChange);

      // Exit animation (using shared config from @/lib/animations/toast.ts)
      // Skip animation if user prefers reduced motion - remove immediately
      if (prefersReducedMotion) {
        toast.remove();
      } else {
        animate(
          toast,
          TOAST_ANIMATION_CONFIG.exit.keyframes,
          TOAST_ANIMATION_CONFIG.exit.options
        ).then(() => {
          if (document.contains(toast)) {
            toast.remove();
          }
        });
      }
    };

    // Dismiss button handler
    const dismissBtn = toast.querySelector('[data-dismiss]');
    if (dismissBtn) {
      dismissBtn.addEventListener('click', dismiss);
    }

    // Auto-dismiss after duration
    if (duration > 0) {
      autoDismissTimeout = setTimeout(() => {
        dismiss();
      }, duration);
    }
  }

  // Initialize all toast-message elements on page load
  function initAllToasts() {
    document.querySelectorAll<HTMLElement>('toast-message').forEach((toast) => {
      // Only initialize if not already initialized
      if (!toast.dataset.initialized) {
        toast.dataset.initialized = 'true';
        initToast(toast);
      }
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAllToasts);
  } else {
    initAllToasts();
  }

  // Use MutationObserver to handle dynamically added toasts
  const observer = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
      mutation.addedNodes.forEach((node) => {
        if (node instanceof HTMLElement) {
          if (node.tagName === 'TOAST-MESSAGE' && !node.dataset.initialized) {
            node.dataset.initialized = 'true';
            initToast(node);
          }
          // Also check for toasts added as children
          node
            .querySelectorAll<HTMLElement>('toast-message:not([data-initialized])')
            .forEach((toast) => {
              toast.dataset.initialized = 'true';
              initToast(toast);
            });
        }
      });
    });
  });

  observer.observe(document.body, { childList: true, subtree: true });
</script>
