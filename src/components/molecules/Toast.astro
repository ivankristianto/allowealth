---
/**
 * Toast Notification Component
 *
 * Dismissible notification messages for user feedback.
 * Uses Motion library for smooth enter/exit animations.
 * Respects prefers-reduced-motion for accessibility.
 *
 * @param {string} id - Unique ID for the toast
 * @param {string} message - Toast message
 * @param {string} type - Toast type: success, error, warning, info
 * @param {number} duration - Auto-dismiss duration in ms (0 to disable)
 * @param {string} position - Position: top-right, top-left, bottom-right, bottom-left
 */

import { X } from '@lucide/astro';

interface Props {
  id: string;
  message: string;
  type?: 'success' | 'error' | 'warning' | 'info';
  duration?: number;
  position?: 'top-right' | 'top-left' | 'bottom-right' | 'bottom-left';
}

const { id, message, type = 'info', duration = 5000, position = 'top-right' } = Astro.props;

const typeClasses: Record<string, string> = {
  success: 'alert-success',
  error: 'alert-error',
  warning: 'alert-warning',
  info: 'alert-info',
};

const positionClasses: Record<string, string> = {
  'top-right': 'toast-top toast-end',
  'top-left': 'toast-top toast-start',
  'bottom-right': 'toast-bottom toast-end',
  'bottom-left': 'toast-bottom toast-start',
};
---

<toast-message
  id={id}
  data-type={type}
  data-duration={duration}
  class:list={['alert shadow-lg', typeClasses[type], positionClasses[position]]}
>
  <span>{message}</span>
  <button class="btn btn-sm btn-ghost" aria-label="Dismiss notification" data-dismiss>
    <X size={16} class="stroke-current" aria-hidden="true" />
  </button>
</toast-message>

<script define:vars={{ id, duration }}>
  import { animate } from 'motion';

  const toast = document.getElementById(id);
  if (!toast) {
    console.error('Toast element not found');
    throw new Error('Toast element not found');
  }

  // Check if user prefers reduced motion
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  // Track whether toast has been dismissed to prevent race conditions
  let isDismissed = false;
  // Store timeout ID to cancel on manual dismiss (explicitly initialized to undefined)
  let autoDismissTimeout = undefined;

  // Enter animation (matches styles.json toast preset)
  // Skip animation if user prefers reduced motion - show toast immediately
  if (prefersReducedMotion) {
    toast.style.opacity = '1';
  } else {
    // Set initial state for enter animation
    toast.style.opacity = '0';
    toast.style.transform = 'translateY(-10px) scale(0.95)';

    animate(
      toast,
      { opacity: [0, 1], y: [-10, 0], scale: [0.95, 1] },
      { duration: 0.2, easing: [0.4, 0, 0.2, 1] }
    );
  }

  // Dismiss toast with exit animation
  const dismiss = () => {
    if (isDismissed) return;
    isDismissed = true;

    // Cancel auto-dismiss timeout if running
    if (autoDismissTimeout !== undefined) {
      clearTimeout(autoDismissTimeout);
      autoDismissTimeout = undefined;
    }

    // Exit animation (matches styles.json toast preset)
    // Skip animation if user prefers reduced motion - remove immediately
    if (prefersReducedMotion) {
      toast.remove();
    } else {
      animate(
        toast,
        { opacity: [1, 0], scale: [1, 0.95] },
        { duration: 0.2, easing: [0.4, 0, 0.2, 1] }
      ).then(() => {
        if (document.contains(toast)) {
          toast.remove();
        }
      });
    }
  };

  // Dismiss button handler
  const dismissBtn = toast.querySelector('[data-dismiss]');
  if (dismissBtn) {
    dismissBtn.addEventListener('click', dismiss);
  }

  // Auto-dismiss after duration
  if (duration > 0) {
    autoDismissTimeout = setTimeout(() => {
      dismiss();
    }, duration);
  }
</script>
