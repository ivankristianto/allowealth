---
/**
 * Tab Switcher Component
 *
 * Tab navigation for switching between different calculator views.
 * Supports mobile-first responsive design with icons.
 *
 * @param {string} activeTab - Currently active tab ID
 * @param {Array<Tab>} tabs - Array of tab objects with id, label, and icon
 * @param {string} className - Additional CSS classes
 */

import { TrendingUp, House, PiggyBank } from '@lucide/astro';

// Icon mapping for tab icons
const iconMap: Record<string, typeof TrendingUp> = {
  trending_up: TrendingUp,
  home: House,
  piggy_bank: PiggyBank,
};

export interface Tab {
  id: string;
  label: string;
  icon: keyof typeof iconMap;
}

export interface Props {
  activeTab: string;
  tabs: Tab[];
  className?: string;
}

const { activeTab, tabs, className = '' } = Astro.props;

// Function to get icon component
function getIcon(iconName: keyof typeof iconMap) {
  return iconMap[iconName] || TrendingUp;
}
---

<div
  class={['tabs bg-base-200 p-1.5 rounded-2xl max-w-2xl', className].join(' ')}
  role="tablist"
  data-tabs
>
  {
    tabs.map((tab) => {
      const IconComponent = getIcon(tab.icon);
      const isActive = activeTab === tab.id;
      return (
        <button
          type="button"
          role="tab"
          aria-selected={isActive ? 'true' : 'false'}
          aria-controls={`${tab.id}-panel`}
          id={`${tab.id}-tab`}
          tabindex={isActive ? 0 : -1}
          class={[
            'tab flex-1 flex items-center justify-center gap-2 py-3 text-xs font-bold rounded-xl transition-all',
            isActive
              ? 'bg-base-100 shadow-md text-primary tab-active'
              : 'text-base-content/60 hover:text-primary',
          ].join(' ')}
          data-tab-id={tab.id}
        >
          <IconComponent size={18} class="stroke-current shrink-0" aria-hidden="true" />
          <span class="text-sm sm:text-xs">{tab.label}</span>
        </button>
      );
    })
  }
</div>

<script>
  // Tab switching logic with roving tabindex for WCAG 2.1 AA keyboard navigation
  function initTabSwitcher(tabsContainer: Element): void {
    const tabs = Array.from(tabsContainer.querySelectorAll<HTMLElement>('[data-tab-id]'));
    if (tabs.length === 0) return;

    function setActiveTab(activeTab: HTMLElement): void {
      tabs.forEach((tab) => {
        const isActive = tab === activeTab;
        tab.setAttribute('aria-selected', isActive ? 'true' : 'false');
        tab.setAttribute('tabindex', isActive ? '0' : '-1');
        if (isActive) {
          tab.classList.add('bg-base-100', 'shadow-md', 'text-primary', 'tab-active');
          tab.classList.remove('text-base-content/60', 'hover:text-primary');
        } else {
          tab.classList.remove('bg-base-100', 'shadow-md', 'text-primary', 'tab-active');
          tab.classList.add('text-base-content/60', 'hover:text-primary');
        }
      });
    }

    tabsContainer.addEventListener('click', (e: Event) => {
      const target = (e.target as Element).closest<HTMLElement>('[data-tab-id]');
      if (!target) return;

      const tabId = target.getAttribute('data-tab-id');
      if (!tabId) return;

      setActiveTab(target);
      target.focus();

      tabsContainer.dispatchEvent(
        new CustomEvent('tab-change', {
          detail: { tabId },
          bubbles: true,
        })
      );
    });

    // Roving tabindex: arrow key navigation between tabs
    tabsContainer.addEventListener('keydown', (e: Event) => {
      const keyEvent = e as KeyboardEvent;
      if (!['ArrowLeft', 'ArrowRight', 'Home', 'End'].includes(keyEvent.key)) return;

      const currentIndex = tabs.findIndex(
        (tab) => tab.getAttribute('tabindex') === '0' || tab === document.activeElement
      );
      if (currentIndex === -1) return;

      let nextIndex: number;
      if (keyEvent.key === 'ArrowRight') {
        nextIndex = (currentIndex + 1) % tabs.length;
      } else if (keyEvent.key === 'ArrowLeft') {
        nextIndex = (currentIndex - 1 + tabs.length) % tabs.length;
      } else if (keyEvent.key === 'Home') {
        nextIndex = 0;
      } else {
        nextIndex = tabs.length - 1;
      }

      const nextTab = tabs[nextIndex];
      if (!nextTab) return;

      keyEvent.preventDefault();
      setActiveTab(nextTab);
      nextTab.focus();

      const tabId = nextTab.getAttribute('data-tab-id');
      if (tabId) {
        tabsContainer.dispatchEvent(
          new CustomEvent('tab-change', {
            detail: { tabId },
            bubbles: true,
          })
        );
      }
    });
  }

  // Initialize on page load and after Astro view transitions
  function setupTabSwitchers(): void {
    document.querySelectorAll('[data-tabs]').forEach((container) => {
      // Skip already initialized containers to prevent duplicate listeners
      if (container.hasAttribute('data-tabs-initialized')) return;
      container.setAttribute('data-tabs-initialized', '');
      initTabSwitcher(container);
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setupTabSwitchers, { once: true });
  } else {
    setupTabSwitchers();
  }
  document.addEventListener('astro:page-load', setupTabSwitchers);
</script>

<style>
  /* Active tab indicator styles */
  .tab-active {
    font-weight: 700;
  }
</style>
