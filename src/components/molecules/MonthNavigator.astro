---
/**
 * Month Navigator Component
 *
 * Reusable month filter with navigation buttons and dropdown selector.
 * Used in TransactionFiltersBar and ReportSelector for consistent month navigation.
 *
 * @param {Array} availableMonths - Array of month options with key and label
 * @param {string} selectedMonth - Currently selected month key (e.g., "2024-02")
 * @param {string} currentMonth - Current month key (optional, for highlighting)
 * @param {string} className - Additional CSS classes
 */

import { ChevronLeft, ChevronRight, Calendar, ChevronDown } from '@lucide/astro';

export interface MonthOption {
  key: string;
  label: string;
}

export interface Props {
  availableMonths?: MonthOption[];
  selectedMonth?: string;
  className?: string;
}

const { availableMonths = [], selectedMonth = '', className = '' } = Astro.props;

// Get month index for navigation
const currentMonthIndex = availableMonths.findIndex((m) => m.key === selectedMonth);
const hasPrevMonth = currentMonthIndex > 0;
const hasNextMonth = currentMonthIndex < availableMonths.length - 1;

// Get display label for selected month
const selectedMonthData = availableMonths.find((m) => m.key === selectedMonth);
const currentMonthLabel =
  selectedMonthData?.label ||
  availableMonths[availableMonths.length - 1]?.label ||
  new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
---

{
  availableMonths.length > 0 && (
    <div
      class={`flex items-center gap-1 ${className}`}
      data-month-navigator
      data-available-months={JSON.stringify(availableMonths)}
    >
      <button
        type="button"
        class={`btn btn-ghost btn-square border border-base-300 bg-base-100 rounded-2xl transition-all active:scale-95 shadow-sm ${
          !hasPrevMonth
            ? 'opacity-30 cursor-not-allowed pointer-events-none'
            : 'text-base-content/40 hover:text-primary hover:border-accent/30'
        }`}
        aria-label="Previous month"
        aria-disabled={!hasPrevMonth}
        data-month-nav="prev"
        data-has-prev={hasPrevMonth ? 'true' : 'false'}
      >
        <ChevronLeft size={18} class="stroke-current" aria-hidden="true" />
      </button>

      <div class="dropdown" data-month-dropdown>
        <input type="hidden" name="month" data-month-input value={selectedMonth} />
        <button
          type="button"
          tabindex={0}
          class="flex items-center gap-2 px-4 py-3 text-xs font-bold border border-base-300 bg-base-100 text-base-content rounded-2xl shadow-sm hover:border-base-content/30 transition-colors min-w-[120px]"
          aria-label="Select month"
          data-month-trigger
        >
          <Calendar size={16} class="stroke-current text-base-content/40" aria-hidden="true" />
          <span class="flex-1 text-left" data-month-label>
            {currentMonthLabel}
          </span>
          <ChevronDown size={14} class="stroke-current text-base-content/40" aria-hidden="true" />
        </button>
        <ul
          tabindex={0}
          class="dropdown-content z-50 menu p-2 shadow-lg bg-base-100 rounded-2xl w-52 border border-base-300 mt-2 max-h-64 overflow-y-auto"
        >
          {availableMonths.map((month) => (
            <li>
              <button
                type="button"
                class={`text-xs font-medium ${month.key === selectedMonth ? 'bg-primary/10 text-primary' : ''}`}
                data-month-option={month.key}
                data-month-label={month.label}
              >
                {month.label}
              </button>
            </li>
          ))}
        </ul>
      </div>

      <button
        type="button"
        class={`btn btn-ghost btn-square border border-base-300 bg-base-100 rounded-2xl transition-all active:scale-95 shadow-sm ${
          !hasNextMonth
            ? 'opacity-30 cursor-not-allowed pointer-events-none'
            : 'text-base-content/40 hover:text-primary hover:border-accent/30'
        }`}
        aria-label="Next month"
        aria-disabled={!hasNextMonth}
        data-month-nav="next"
        data-has-next={hasNextMonth ? 'true' : 'false'}
      >
        <ChevronRight size={18} class="stroke-current" aria-hidden="true" />
      </button>
    </div>
  )
}

<script>
  // Import external initialization script
  import '@/components/molecules/MonthNavigator.client';
</script>
