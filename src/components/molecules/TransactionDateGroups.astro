---
/**
 * Transaction Date Groups Component
 *
 * Renders date-grouped transaction cards with sticky date headers.
 * Reusable across dashboard, transaction list, search results, and modals.
 *
 * @param {DateGroup[]} groups - Date-grouped transactions from groupTransactionsByDate()
 * @param {boolean} showActions - Pass through to TransactionCard for edit/delete actions
 * @param {boolean} showCount - Show transaction count in date headers
 * @param {'default' | 'compact'} variant - Size variant (compact for modal contexts)
 */

import TransactionCard from './TransactionCard.astro';
import type { DateGroup } from '@/lib/utils/transaction-grouping';

export interface Props {
  groups: DateGroup[];
  showActions?: boolean;
  showBulkSelection?: boolean;
  showCount?: boolean;
  variant?: 'default' | 'compact';
  inCard?: boolean;
}

const {
  groups,
  showActions = false,
  showBulkSelection = false,
  showCount = true,
  variant = 'default',
  inCard = false,
} = Astro.props;

const isCompact = variant === 'compact';
---

{
  (
    <>
      {showBulkSelection && (
        <div
          class:list={[
            'flex items-center gap-3 px-4 md:px-6 py-3 border-b border-base-300/50 bg-base-100',
            inCard && 'rounded-t-[var(--radius-card)]',
          ]}
          id="bulk-select-all-bar"
        >
          <label class="flex items-center cursor-pointer shrink-0">
            <input
              type="checkbox"
              class="checkbox checkbox-sm checkbox-primary"
              data-bulk-select-all
              aria-label="Select all transactions on this page"
            />
          </label>
          <span class="text-xs font-medium text-base-content/60" data-bulk-select-count>
            Select all
          </span>
        </div>
      )}
      {groups.map((group, index) => (
        <div
          role="group"
          aria-label={`Transactions from ${group.label}`}
          class:list={[index > 0 && 'mt-3']}
        >
          {/* Date header */}
          <div
            class:list={[
              'flex items-center justify-between bg-base-200 border-base-300/50 border-b',
              index === 0 && !showBulkSelection && 'border-t',
              inCard && index === 0 && !showBulkSelection && 'rounded-t-[var(--radius-card)]',
              isCompact ? 'py-2 px-3' : 'py-4 px-4 md:px-6',
            ]}
          >
            <div class="flex items-baseline gap-1.5">
              {group.relativeLabel ? (
                <>
                  <span
                    class:list={[
                      'font-bold text-base-content tracking-wide',
                      isCompact ? 'text-xs' : 'text-xs',
                    ]}
                  >
                    {group.relativeLabel}
                  </span>
                  <span
                    class:list={[
                      'text-base-content/50 font-medium',
                      isCompact ? 'text-xs' : 'text-xs',
                    ]}
                  >
                    {group.fullDate}
                  </span>
                </>
              ) : (
                <span
                  class:list={[
                    'font-bold text-base-content tracking-wide',
                    isCompact ? 'text-xs' : 'text-xs',
                  ]}
                >
                  {group.fullDate}
                </span>
              )}
            </div>
            {showCount && group.transactions.length > 0 && (
              <span
                class:list={[
                  'font-medium text-base-content/40 tabular-nums',
                  isCompact ? 'text-xs' : 'text-xs',
                ]}
              >
                {group.transactions.length}{' '}
                {group.transactions.length === 1 ? 'transaction' : 'transactions'}
              </span>
            )}
          </div>
          {/* Transaction cards */}
          <div class="divide-y divide-base-200">
            {group.transactions.map((transaction) => (
              <TransactionCard
                transaction={transaction}
                showActions={showActions}
                showBulkSelection={showBulkSelection}
              />
            ))}
          </div>
        </div>
      ))}
    </>
  )
}
