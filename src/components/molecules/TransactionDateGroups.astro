---
/**
 * Transaction Date Groups Component
 *
 * Renders date-grouped transaction cards with sticky date headers.
 * Reusable across dashboard, transaction list, search results, and modals.
 *
 * @param {DateGroup[]} groups - Date-grouped transactions from groupTransactionsByDate()
 * @param {boolean} showActions - Pass through to TransactionCard for edit/delete actions
 * @param {boolean} showCount - Show transaction count in date headers
 * @param {'default' | 'compact'} variant - Size variant (compact for modal contexts)
 */

import TransactionCard from './TransactionCard.astro';
import type { DateGroup } from '@/lib/utils/transaction-grouping';

export interface Props {
  groups: DateGroup[];
  showActions?: boolean;
  showCount?: boolean;
  variant?: 'default' | 'compact';
}

const { groups, showActions = false, showCount = true, variant = 'default' } = Astro.props;

const isCompact = variant === 'compact';
---

{
  groups.map((group) => (
    <div role="group" aria-label={`Transactions from ${group.label}`}>
      {/* Date header */}
      <div
        class:list={[
          'flex items-center justify-between bg-base-200/30 border-b border-base-200',
          isCompact ? 'py-2 px-3' : 'py-2.5 px-4',
        ]}
      >
        <div class="flex items-baseline gap-1.5">
          {group.relativeLabel ? (
            <>
              <span
                class:list={[
                  'font-bold text-base-content/70 tracking-wide',
                  isCompact ? 'text-[11px]' : 'text-xs',
                ]}
              >
                {group.relativeLabel}
              </span>
              <span
                class:list={[
                  'text-base-content/40 font-medium',
                  isCompact ? 'text-[11px]' : 'text-xs',
                ]}
              >
                {group.fullDate}
              </span>
            </>
          ) : (
            <span
              class:list={[
                'font-bold text-base-content/70 tracking-wide',
                isCompact ? 'text-[11px]' : 'text-xs',
              ]}
            >
              {group.fullDate}
            </span>
          )}
        </div>
        {showCount && group.transactions.length > 0 && (
          <span
            class:list={[
              'font-medium text-base-content/30 tabular-nums',
              isCompact ? 'text-[10px]' : 'text-[11px]',
            ]}
          >
            {group.transactions.length}{' '}
            {group.transactions.length === 1 ? 'transaction' : 'transactions'}
          </span>
        )}
      </div>
      {/* Transaction cards */}
      <div class="divide-y divide-base-200">
        {group.transactions.map((transaction) => (
          <TransactionCard transaction={transaction} showActions={showActions} />
        ))}
      </div>
    </div>
  ))
}
