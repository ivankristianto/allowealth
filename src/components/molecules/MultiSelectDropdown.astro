---
import Button from '@/components/atoms/Button.astro';
import { Check, ChevronDown, Search } from '@lucide/astro';

interface MultiSelectItem {
  id: string;
  name: string;
  group?: string;
  filterType?: string;
}

interface Props {
  id: string;
  label: string;
  inputName: string;
  selectedIds?: string[];
  items: MultiSelectItem[];
  searchable?: boolean;
  searchPlaceholder?: string;
  filterEventType: string;
  class?: string;
}

const {
  id,
  label,
  inputName,
  selectedIds = [],
  items = [],
  searchable = true,
  searchPlaceholder = 'Search...',
  filterEventType,
  class: className = '',
} = Astro.props;

const groupedItems = items.reduce<
  Array<{ key: string; label: string | null; items: MultiSelectItem[] }>
>((groups, item) => {
  const groupKey = item.group || '__ungrouped__';
  const existing = groups.find((group) => group.key === groupKey);
  if (existing) {
    existing.items.push(item);
    return groups;
  }

  groups.push({
    key: groupKey,
    label: item.group || null,
    items: [item],
  });
  return groups;
}, []);
---

<div class={`dropdown ${className}`} data-multiselect-id={id}>
  <input
    type="hidden"
    name={inputName}
    id={`${id}-filter`}
    value={selectedIds.join(',')}
    data-ms-hidden
    data-ms-default-label={label}
    data-ms-filter-event-type={filterEventType}
  />

  <Button
    type="button"
    variant="ghost"
    tabindex={0}
    className="min-w-[160px] gap-2 rounded-2xl border border-base-300 bg-base-100 px-4 py-3 text-xs font-bold text-base-content shadow-sm hover:border-base-content/30 hover:bg-base-100"
    aria-label={`Filter by ${label.toLowerCase()}`}
    aria-haspopup="listbox"
    aria-expanded="false"
    data-ms-trigger
  >
    <slot name="icon" />
    <span class="flex-1 text-left truncate" data-ms-label>{label}</span>
    <ChevronDown
      size={14}
      class="stroke-current text-base-content/40 shrink-0"
      aria-hidden="true"
    />
  </Button>

  <div
    tabindex={0}
    class="dropdown-content z-50 p-3 shadow-lg bg-base-100 rounded-2xl w-72 border border-base-300 mt-2"
    role="listbox"
    aria-multiselectable="true"
    aria-label={label}
  >
    {
      searchable && (
        <div class="mb-2">
          <label for={`${id}-search`} class="mb-1 block text-base-content/70 text-xs">
            Search
          </label>
          <div class="relative">
            <Search
              size={14}
              class="absolute left-3 top-1/2 -translate-y-1/2 text-base-content/40 stroke-current pointer-events-none"
              aria-hidden="true"
            />
            <input
              id={`${id}-search`}
              type="text"
              placeholder={searchPlaceholder}
              class="input w-full rounded-lg border border-base-300 bg-base-100 focus:border-accent focus:outline-none pl-9 pr-3 py-2 text-xs placeholder:text-base-content/40"
              data-ms-search
            />
          </div>
        </div>
      )
    }

    <div class="flex items-center justify-between pb-2 mb-2 border-b border-base-200">
      <Button
        type="button"
        variant="ghost"
        className="min-h-0 border-0 bg-transparent px-0 py-0 text-xs font-medium text-accent hover:bg-transparent hover:text-accent/80"
        data-ms-clear-all
      >
        Clear all
      </Button>
      <span class="text-xs text-base-content/50" data-ms-count>
        {selectedIds.length} selected
      </span>
    </div>

    <div class="space-y-2 max-h-52 overflow-y-auto" data-ms-list>
      {
        groupedItems.map((group) => (
          <div class="space-y-1" data-ms-group={group.key}>
            {group.label && (
              <div class="px-3 py-1.5 text-xs font-semibold text-base-content/40 tracking-wider">
                {group.label}
              </div>
            )}
            {group.items.map((item) => {
              const isSelected = selectedIds.includes(item.id);
              return (
                <label
                  class={`flex items-center gap-3 px-3 py-2.5 rounded-xl cursor-pointer transition-colors hover:bg-base-200 ${isSelected ? 'bg-accent/10' : ''}`}
                  data-ms-item={item.id}
                  data-ms-name={item.name.toLowerCase()}
                  data-ms-filter-type={item.filterType}
                >
                  <div
                    class={`w-5 h-5 rounded-md border-2 flex items-center justify-center shrink-0 transition-colors ${isSelected ? 'bg-accent border-accent' : 'border-base-300'}`}
                    data-ms-checkbox={item.id}
                  >
                    <Check
                      size={12}
                      class={`stroke-white stroke-3 ${isSelected ? '' : 'hidden'}`}
                      aria-hidden="true"
                    />
                  </div>
                  <span class="text-sm font-medium text-base-content truncate">{item.name}</span>
                </label>
              );
            })}
          </div>
        ))
      }
    </div>
  </div>
</div>

<script>
  import { FILTERS_RESET_EVENT } from '@/lib/constants/events';

  type MultiSelectFilterEvent = {
    id: string;
    filterType?: string;
  };

  type MultiSelectSyncEvent = {
    id: string;
    selectedIds?: string[];
  };

  function initMultiSelectDropdowns(): void {
    const containers = document.querySelectorAll<HTMLElement>('[data-multiselect-id]');

    containers.forEach((container) => {
      if (container.dataset.msInitialized === 'true') return;
      container.dataset.msInitialized = 'true';

      const multiselectId = container.dataset.multiselectId || '';
      const hiddenInput = container.querySelector('[data-ms-hidden]') as HTMLInputElement | null;
      const labelEl = container.querySelector('[data-ms-label]') as HTMLElement | null;
      const countEl = container.querySelector('[data-ms-count]') as HTMLElement | null;
      const clearAllBtn = container.querySelector(
        '[data-ms-clear-all]'
      ) as HTMLButtonElement | null;
      const searchInput = container.querySelector('[data-ms-search]') as HTMLInputElement | null;

      if (!hiddenInput || !labelEl || !countEl) return;

      const triggerBtn = container.querySelector('[data-ms-trigger]') as HTMLButtonElement | null;
      const dropdownPanel = container.querySelector('.dropdown-content') as HTMLElement | null;

      // TODO: Replace with CSS Anchor Positioning API by 2027.
      // https://developer.chrome.com/docs/css-ui/anchor-positioning-api
      // As of Feb 2026, browser support is ~77% (no iOS Safari <26).
      // Once support reaches ~95%, use anchor-name + position-area +
      // position-try-fallbacks for pure-CSS auto-positioning.
      function autoPositionDropdown(): void {
        if (!triggerBtn || !dropdownPanel) return;
        const rect = triggerBtn.getBoundingClientRect();
        const panelWidth = dropdownPanel.offsetWidth || 288;
        const overflowsRight = rect.left + panelWidth > window.innerWidth;
        container.classList.toggle('dropdown-end', overflowsRight);
      }

      if (triggerBtn) {
        triggerBtn.addEventListener('click', autoPositionDropdown);
      }

      const defaultLabel = hiddenInput.dataset.msDefaultLabel || 'All';
      const filterEventType = hiddenInput.dataset.msFilterEventType || '';
      const itemEls = Array.from(container.querySelectorAll<HTMLElement>('[data-ms-item]'));
      const groupEls = Array.from(container.querySelectorAll<HTMLElement>('[data-ms-group]'));

      let selectedIds = hiddenInput.value ? hiddenInput.value.split(',').filter(Boolean) : [];
      let searchQuery = '';
      let activeFilterType: string | null = null;

      function dispatchChangeEvent(): void {
        if (!filterEventType) return;
        window.dispatchEvent(
          new CustomEvent('filterChange', {
            detail: { type: filterEventType, value: [...selectedIds] },
          })
        );
      }

      function updateGroupVisibility(): void {
        groupEls.forEach((groupEl) => {
          const visibleItems = Array.from(
            groupEl.querySelectorAll<HTMLElement>('[data-ms-item]')
          ).filter((item) => item.style.display !== 'none');
          groupEl.style.display = visibleItems.length > 0 ? '' : 'none';
        });
      }

      function applyVisibilityFilters(): void {
        itemEls.forEach((itemEl) => {
          const itemFilterType = itemEl.dataset.msFilterType || '';
          const itemName = itemEl.dataset.msName || '';
          const matchesType =
            !activeFilterType || !itemFilterType || itemFilterType === activeFilterType;
          const matchesSearch = searchQuery === '' || itemName.includes(searchQuery);
          itemEl.style.display = matchesType && matchesSearch ? '' : 'none';
        });
        updateGroupVisibility();
      }

      function pruneSelectionsOutsideTypeFilter(): boolean {
        if (!activeFilterType) return false;

        const typeVisibleIds = new Set(
          itemEls
            .filter((itemEl) => {
              const itemFilterType = itemEl.dataset.msFilterType || '';
              return itemFilterType === '' || itemFilterType === activeFilterType;
            })
            .map((itemEl) => itemEl.dataset.msItem || '')
            .filter(Boolean)
        );

        const nextSelectedIds = selectedIds.filter((selectedId) => typeVisibleIds.has(selectedId));
        if (nextSelectedIds.length === selectedIds.length) return false;

        selectedIds = nextSelectedIds;
        return true;
      }

      function updateUI(emitChange = false): void {
        hiddenInput.value = selectedIds.join(',');

        if (selectedIds.length === 0) {
          labelEl.textContent = defaultLabel;
        } else if (selectedIds.length === 1) {
          const selectedItem = itemEls.find((itemEl) => itemEl.dataset.msItem === selectedIds[0]);
          labelEl.textContent =
            selectedItem?.querySelector('span')?.textContent?.trim() || defaultLabel;
        } else {
          labelEl.textContent = `${selectedIds.length} selected`;
        }

        countEl.textContent = `${selectedIds.length} selected`;

        itemEls.forEach((itemEl) => {
          const itemId = itemEl.dataset.msItem || '';
          const isSelected = selectedIds.includes(itemId);
          itemEl.classList.toggle('bg-accent/10', isSelected);

          const checkbox = itemEl.querySelector(`[data-ms-checkbox="${itemId}"]`);
          const checkIcon = checkbox?.querySelector('svg');
          checkbox?.classList.toggle('bg-accent', isSelected);
          checkbox?.classList.toggle('border-accent', isSelected);
          checkbox?.classList.toggle('border-base-300', !isSelected);
          checkIcon?.classList.toggle('hidden', !isSelected);
        });

        if (emitChange) {
          dispatchChangeEvent();
        }
      }

      function toggleSelection(itemId: string): void {
        if (!itemId) return;

        if (selectedIds.includes(itemId)) {
          selectedIds = selectedIds.filter((selectedId) => selectedId !== itemId);
        } else {
          selectedIds = [...selectedIds, itemId];
        }

        updateUI(true);
      }

      function clearAllSelections(emitChange = true): void {
        if (selectedIds.length === 0) return;
        selectedIds = [];
        updateUI(emitChange);
      }

      function filterBySearch(query: string): void {
        searchQuery = query.trim().toLowerCase();
        applyVisibilityFilters();
      }

      function filterByType(filterType?: string): void {
        activeFilterType = filterType || null;
        applyVisibilityFilters();
        const didPrune = pruneSelectionsOutsideTypeFilter();
        updateUI(didPrune);
      }

      itemEls.forEach((itemEl) => {
        itemEl.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          toggleSelection(itemEl.dataset.msItem || '');
        });
      });

      if (clearAllBtn) {
        clearAllBtn.addEventListener('click', (event) => {
          event.preventDefault();
          event.stopPropagation();
          clearAllSelections(true);
        });
      }

      if (searchInput) {
        searchInput.addEventListener('input', () => {
          filterBySearch(searchInput.value);
        });

        searchInput.addEventListener('click', (event) => {
          event.stopPropagation();
        });
      }

      window.addEventListener(FILTERS_RESET_EVENT, () => {
        if (searchInput) {
          searchInput.value = '';
        }
        searchQuery = '';
        clearAllSelections(true);
        applyVisibilityFilters();
      });

      window.addEventListener('multiselect:filter', (event: Event) => {
        const customEvent = event as CustomEvent<MultiSelectFilterEvent>;
        if (customEvent.detail?.id !== multiselectId) return;
        filterByType(customEvent.detail?.filterType);
      });

      window.addEventListener('multiselect:sync', (event: Event) => {
        const customEvent = event as CustomEvent<MultiSelectSyncEvent>;
        if (customEvent.detail?.id !== multiselectId) return;

        selectedIds = Array.isArray(customEvent.detail?.selectedIds)
          ? customEvent.detail.selectedIds.filter(Boolean)
          : [];
        searchQuery = '';
        if (searchInput) {
          searchInput.value = '';
        }

        applyVisibilityFilters();
        updateUI(false);
      });

      const hasFilterTypedItems = itemEls.some((itemEl) => Boolean(itemEl.dataset.msFilterType));
      if (hasFilterTypedItems) {
        const activeTypeButton = document.querySelector<HTMLElement>(
          '[data-filter-type][aria-pressed="true"]'
        );
        const currentType = activeTypeButton?.dataset.filterType || '';
        filterByType(currentType);
      } else {
        applyVisibilityFilters();
        updateUI(false);
      }
    });
  }

  // Initialize on first load
  initMultiSelectDropdowns();

  // Re-initialize after Astro view transitions swap the DOM
  document.addEventListener('astro:page-load', initMultiSelectDropdowns);
</script>
