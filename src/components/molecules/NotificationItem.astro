---
/**
 * NotificationItem Component
 *
 * Individual notification row with icon, title, description, and time.
 * Used in the notification dropdown panel.
 */

import { TriangleAlert, DollarSign, CircleAlert, Info } from '@lucide/astro';
import type { Notification } from '@/lib/stores/notificationStore';

export interface Props {
  notification: Notification;
}

const { notification } = Astro.props;

// Icon mapping for notification types - use non-deprecated icons
const iconMap = {
  warning: TriangleAlert,
  success: DollarSign,
  alert: CircleAlert,
  info: Info,
};

// Icon background color mapping - using DaisyUI semantic classes with opacity
// Note: Using bg-{color}/10 for 10% opacity tint, text-{color} for icon color
const bgMap = {
  warning: 'bg-warning/10 text-warning dark:bg-warning/20',
  success: 'bg-success/10 text-success dark:bg-success/20',
  alert: 'bg-error/10 text-error dark:bg-error/20',
  info: 'bg-info/10 text-info dark:bg-info/20',
};

const IconComponent = iconMap[notification.type];
const iconBgClass = bgMap[notification.type];
---

<div
  class="p-5 hover:bg-base-200/50 dark:hover:bg-base-200/20 transition-colors cursor-pointer flex gap-5"
>
  <div
    class={`w-12 h-12 shrink-0 rounded-2xl flex items-center justify-center shadow-sm ${iconBgClass}`}
  >
    <IconComponent size={24} class="shrink-0" aria-hidden="true" />
  </div>
  <div class="flex-1 min-w-0">
    <div class="flex justify-between items-start mb-1.5 leading-none">
      <p class="text-base font-bold text-base-content tracking-tight">{notification.title}</p>
      <span class="text-[10px] font-bold text-neutral uppercase tracking-widest"
        >{notification.time}</span
      >
    </div>
    <p class="text-sm text-neutral leading-relaxed line-clamp-2">{notification.description}</p>
  </div>
</div>
