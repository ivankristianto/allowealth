---
/**
 * Budget Health Widget Component (Molecule)
 *
 * Displays budget alert status with:
 * - Alert badge count
 * - Color-coded status indicator
 * - List of categories needing attention
 * - Link to view full budget
 *
 * @param {Object} data - Budget health data
 * @param {string} viewBudgetUrl - URL for "View Budget" link
 * @param {string} className - Additional CSS classes
 */

import Badge from '../atoms/Badge.astro';
import { Check, TriangleAlert, ArrowRight } from '@lucide/astro';
import { formatCurrency, formatPercentage } from '@/lib/formatting';

export interface BudgetAlertItem {
  categoryId: string;
  categoryName: string;
  budgetAmount: number;
  spentAmount: number;
  remaining: number;
  percentage: number;
  status: 'ok' | 'warning' | 'exceeded';
}

export interface BudgetHealthData {
  alertCount: number;
  status: 'healthy' | 'warning' | 'exceeded';
  alerts: BudgetAlertItem[];
}

export interface Props {
  data: BudgetHealthData;
  viewBudgetUrl?: string;
  className?: string;
}

const { data, viewBudgetUrl = '/budget', className = '' } = Astro.props;

// Status styling helpers
const getStatusColor = (status: string): string => {
  switch (status) {
    case 'healthy':
      return 'text-success';
    case 'warning':
      return 'text-warning';
    case 'exceeded':
      return 'text-error';
    default:
      return 'text-base-content/60';
  }
};

const getStatusBadge = (status: string): 'success' | 'warning' | 'error' | 'neutral' => {
  switch (status) {
    case 'healthy':
      return 'success';
    case 'warning':
      return 'warning';
    case 'exceeded':
      return 'error';
    default:
      return 'neutral';
  }
};

const getStatusBg = (status: string): string => {
  switch (status) {
    case 'healthy':
      return 'bg-success/10';
    case 'warning':
      return 'bg-warning/10';
    case 'exceeded':
      return 'bg-error/10';
    default:
      return 'bg-base-200';
  }
};

const getProgressBarColor = (percentage: number): string => {
  if (percentage >= 100) return 'bg-error';
  if (percentage >= 80) return 'bg-warning';
  return 'bg-success';
};
---

<div
  class={`p-4 rounded-lg border ${getStatusBg(data.status)} border-current/20 ${className}`}
  data-budget-health-widget
>
  {/* Header with alert count and status */}
  <div
    class="flex items-center justify-between mb-4"
    role="group"
    aria-label="Budget health status"
  >
    <div class="flex items-center gap-3">
      <div class={`p-2 rounded-full ${getStatusBg(data.status)}`}>
        {
          data.status === 'healthy' ? (
            <Check
              size={22}
              class={`stroke-current ${getStatusColor(data.status)}`}
              aria-hidden="true"
            />
          ) : (
            <TriangleAlert
              size={22}
              class={`stroke-current ${getStatusColor(data.status)}`}
              aria-hidden="true"
            />
          )
        }
      </div>
      <div>
        <div class={`text-2xl font-bold ${getStatusColor(data.status)}`}>
          {data.alertCount}
        </div>
        <div class="text-sm text-neutral">
          alert{data.alertCount !== 1 ? 's' : ''}
        </div>
      </div>
    </div>

    <Badge variant={getStatusBadge(data.status)} size="lg">
      {
        data.status === 'healthy'
          ? 'All Good'
          : data.status === 'warning'
            ? 'Review'
            : 'Action Needed'
      }
    </Badge>
  </div>

  {/* Alert details */}
  {
    data.alerts.length > 0 ? (
      <div class="mb-4">
        <h3 class="text-sm font-medium text-neutral mb-2">Categories needing attention:</h3>
        <ul class="space-y-3" role="list">
          {data.alerts.map((alert) => (
            <li class="p-3 bg-base-100/80 rounded-lg border border-base-300 hover:border-current/30 transition-colors">
              <div class="flex items-center justify-between mb-2">
                <span class="font-medium">{alert.categoryName}</span>
                <Badge
                  variant={
                    alert.status === 'exceeded'
                      ? 'error'
                      : alert.status === 'warning'
                        ? 'warning'
                        : 'success'
                  }
                  size="sm"
                >
                  {formatPercentage(alert.percentage)}
                </Badge>
              </div>

              <div class="flex items-center justify-between text-sm mb-2">
                <span class="text-neutral">
                  {formatCurrency(alert.spentAmount, 'IDR')} of{' '}
                  {formatCurrency(alert.budgetAmount, 'IDR')}
                </span>
                <span class={`font-medium ${alert.remaining < 0 ? 'text-error' : 'text-success'}`}>
                  {alert.remaining < 0 ? '-' : '+'}
                  {formatCurrency(Math.abs(alert.remaining), 'IDR')}
                </span>
              </div>

              {/* Progress bar */}
              <div class="w-full bg-base-300 rounded-full h-2 overflow-hidden">
                <div
                  class={`h-full ${getProgressBarColor(alert.percentage)} transition-all duration-300`}
                  style={`width: ${Math.min(alert.percentage, 100)}%`}
                  role="progressbar"
                  aria-valuenow={alert.percentage}
                  aria-valuemin={0}
                  aria-valuemax={100}
                  aria-label={`${alert.categoryName}: ${formatPercentage(alert.percentage)} used`}
                />
              </div>
            </li>
          ))}
        </ul>
      </div>
    ) : (
      // No alerts state
      <div class="mb-4 p-4 bg-base-100/80 rounded-lg text-center">
        <Check size={24} class="stroke-current text-success mx-auto mb-2" aria-hidden="true" />
        <p class="text-sm font-medium text-success">All budgets healthy!</p>
        <p class="text-xs text-neutral mt-1">You're on track with all your spending categories.</p>
      </div>
    )
  }

  {/* View Budget link */}
  <a
    href={viewBudgetUrl}
    class="flex items-center justify-center gap-2 w-full py-2 px-4 bg-base-100 hover:bg-base-200 rounded-lg transition-colors text-sm font-medium group"
    aria-label="View detailed budget breakdown"
  >
    View Budget
    <ArrowRight
      size={16}
      class="group-hover:translate-x-1 transition-transform stroke-current"
      aria-hidden="true"
    />
  </a>
</div>
