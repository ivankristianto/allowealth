---
/**
 * AuthValidationMessages Component
 *
 * Molecule component for displaying authentication-related validation messages
 * Uses DaisyUI alert component for consistent styling
 * Uses Lucide icons from @lucide/astro for consistent, accessible icons
 */

import Button from '@/components/atoms/Button.astro';
import { TriangleAlert, CircleX, Lock, CircleOff, CircleCheck, X } from '@lucide/astro';

interface Props {
  type?:
    | 'email-format'
    | 'password-mismatch'
    | 'password-requirements'
    | 'email-exists'
    | 'invalid-credentials'
    | 'network-error'
    | 'success';
  message?: string;
  dismissible?: boolean;
}

const { type = 'success', message, dismissible = false } = Astro.props;

// Icon component mapping for each message type
const iconMap = {
  'email-format': TriangleAlert,
  'password-mismatch': CircleX,
  'password-requirements': TriangleAlert,
  'email-exists': CircleX,
  'invalid-credentials': Lock,
  'network-error': CircleOff,
  success: CircleCheck,
};

// Alert configuration without SVG strings (security improvement: no set:html)
const alertConfig = {
  'email-format': {
    alertClass: 'alert-warning',
    defaultMessage: 'Please enter a valid email address',
  },
  'password-mismatch': {
    alertClass: 'alert-error',
    defaultMessage: 'Passwords do not match',
  },
  'password-requirements': {
    alertClass: 'alert-warning',
    defaultMessage: 'Password does not meet requirements',
  },
  'email-exists': {
    alertClass: 'alert-error',
    defaultMessage: 'An account with this email already exists',
  },
  'invalid-credentials': {
    alertClass: 'alert-error',
    defaultMessage: 'Invalid email or password',
  },
  'network-error': {
    alertClass: 'alert-error',
    defaultMessage: 'Network error. Please check your connection and try again',
  },
  success: {
    alertClass: 'alert-success',
    defaultMessage: 'Success!',
  },
};

const config = alertConfig[type];
const displayMessage = message || config.defaultMessage;
const IconComponent = iconMap[type] || CircleCheck;
---

<div role="alert" class:list={['alert', config.alertClass]}>
  <IconComponent size={24} class="shrink-0" aria-hidden="true" />
  <span>{displayMessage}</span>
  {
    dismissible && (
      <Button
        variant="ghost"
        size="sm"
        shape="circle"
        className="border-0"
        aria-label="Dismiss message"
      >
        <X size={16} class="stroke-current" aria-hidden="true" />
      </Button>
    )
  }
</div>

<style>
  /* Ensure alert is accessible and properly styled */
  [role='alert'] {
    min-height: 3rem;
  }

  /* Focus styles for dismiss button */
  button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }
</style>
