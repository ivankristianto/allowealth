---
/**
 * SecurityConnectedAccountsCard Component
 *
 * Displays connected SSO providers for account security.
 */
import SecurityCard from '@/components/molecules/SecurityCard.astro';
import Button from '@/components/atoms/Button.astro';
import { Key, Globe } from '@lucide/astro';

interface ConnectedAccount {
  id: string;
  provider: string;
  email?: string;
  accountId?: string;
  connected: boolean;
  canUnlink: boolean;
}

export interface Props {
  accounts: ConnectedAccount[];
}

const { accounts } = Astro.props;
---

<SecurityCard title="Connected Accounts" subtitle="Single Sign-On (SSO)" iconVariant="accent">
  <Key slot="icon" size={20} class="stroke-current" aria-hidden="true" />

  <div class="space-y-4">
    {
      accounts.map((account) => (
        <div class="flex flex-col gap-4 rounded-2xl border border-base-300 bg-base-200/60 p-4 sm:flex-row sm:items-center sm:justify-between">
          <div class="flex items-center gap-4">
            <div class="rounded-xl bg-base-100 p-3 text-base-content/60">
              <Globe size={20} class="stroke-current" aria-hidden="true" />
            </div>
            <div>
              <p class="text-sm font-semibold">{account.provider} SSO</p>
              <p class="text-xs text-base-content/60">
                {account.connected
                  ? `Connected as ${account.email || 'primary account'}`
                  : `Sign in using your ${account.provider} account`}
              </p>
            </div>
          </div>
          {account.connected ? (
            account.canUnlink ? (
              <Button
                type="button"
                variant="outline"
                size="sm"
                data-provider-id={account.id}
                data-account-id={account.accountId}
                data-unlink-provider
                data-testid="disconnect-google-btn"
              >
                Disconnect
              </Button>
            ) : (
              <div class="text-right text-xs text-base-content/60">
                Google is currently your only linked sign-in method.
              </div>
            )
          ) : (
            <Button
              type="button"
              variant="primary"
              size="sm"
              data-link-provider={account.id}
              data-testid="connect-google-btn"
            >
              Connect Account
            </Button>
          )}
        </div>
      ))
    }
  </div>
</SecurityCard>

<script>
  import { authClient } from '@/lib/auth/client';
  import { addToast } from '@/lib/stores/toastStore';

  const initializedCards = new WeakSet<Element>();

  function getAuthErrorMessage(error: unknown, fallbackMessage: string): string {
    if (
      error &&
      typeof error === 'object' &&
      'message' in error &&
      typeof error.message === 'string'
    ) {
      return error.message;
    }

    return fallbackMessage;
  }

  function setPendingState(button: HTMLButtonElement, isPending: boolean) {
    button.disabled = isPending;
    button.setAttribute('aria-busy', isPending ? 'true' : 'false');
  }

  function initConnectedAccountCards() {
    document
      .querySelectorAll<HTMLElement>('[data-link-provider], [data-unlink-provider]')
      .forEach((control) => {
        if (initializedCards.has(control)) {
          return;
        }

        initializedCards.add(control);

        control.addEventListener('click', async (event) => {
          const button = event.currentTarget;
          if (!(button instanceof HTMLButtonElement)) {
            return;
          }

          const providerId = button.dataset.linkProvider ?? button.dataset.providerId;
          if (!providerId) {
            return;
          }

          try {
            setPendingState(button, true);

            if (button.dataset.linkProvider) {
              const result = await authClient.linkSocial({
                provider: providerId,
                callbackURL: '/security',
              });

              if (result.error) {
                throw result.error;
              }

              return;
            }

            const result = await authClient.unlinkAccount({
              providerId,
              accountId: button.dataset.accountId || undefined,
            });

            if (result.error) {
              throw result.error;
            }

            addToast(`${providerId} disconnected successfully.`, 'success');
            window.location.reload();
          } catch (error) {
            addToast(getAuthErrorMessage(error, 'Unable to update linked accounts.'), 'error');
            setPendingState(button, false);
          }
        });
      });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initConnectedAccountCards);
  } else {
    initConnectedAccountCards();
  }

  document.addEventListener('astro:page-load', initConnectedAccountCards);
</script>
