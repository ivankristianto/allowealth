---
/**
 * BudgetActions Component
 *
 * Action buttons row for the Budget page.
 * Left: Categories, Import, Export, Initialize All, AI Rebalancer
 * Right: New Budget (accent ghost)
 * Uses ActionBar for consistent layout.
 *
 * Note: History and Copy buttons are in BudgetPageHeader (left of month picker).
 *
 * @param {boolean} showAiRebalancer - Show AI Rebalancer button
 * @param {number} uninitializedCount - Number of categories without budgets
 * @param {string} className - Additional CSS classes
 */

import { Sparkles, Plus, Tags, Download, Upload, Zap } from '@lucide/astro';
import Modal from '@components/molecules/Modal.astro';
import ActionBar from './ActionBar.astro';

export interface Props {
  showAiRebalancer?: boolean;
  uninitializedCount?: number;
  className?: string;
}

const { showAiRebalancer = true, uninitializedCount = 0, className = '' } = Astro.props;

const ghostBtn =
  'btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4';

const accentGhostBtn =
  'btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-accent hover:text-accent hover:bg-accent/10 px-2 md:px-4 font-semibold';
---

<ActionBar className={className} ariaLabel="Budget actions">
  {/* Categories */}
  <div class="tooltip tooltip-bottom" data-tip="Manage categories">
    <a href="/budget/categories" class={ghostBtn} aria-label="Manage categories">
      <Tags size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Tags size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="text-xs md:text-sm">Categories</span>
    </a>
  </div>

  {/* Import */}
  <div class="tooltip tooltip-bottom" data-tip="Import budgets from CSV">
    <button
      type="button"
      class={ghostBtn}
      aria-label="Import budgets from CSV"
      data-budget-import-btn
      data-testid="budget-import-btn"
    >
      <Upload size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Upload size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span>Import</span>
    </button>
  </div>

  {/* Export */}
  <div class="tooltip tooltip-bottom" data-tip="Export budgets to CSV">
    <button
      type="button"
      class={ghostBtn}
      aria-label="Export budgets to CSV"
      data-budget-export-btn
      data-testid="budget-export-btn"
    >
      <Download size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Download size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span>Export</span>
    </button>
  </div>

  {/* Initialize All Budgets */}
  {
    uninitializedCount > 0 ? (
      <div class="tooltip tooltip-bottom" data-tip="Initialize all uninitialized budgets">
        <button
          type="button"
          class={ghostBtn}
          id="initialize-budgets-btn"
          data-target-modal="initialize-budgets-modal"
          aria-label="Initialize all budgets"
          data-testid="initialize-budgets-btn"
        >
          <Zap size={16} class="stroke-current md:hidden" aria-hidden="true" />
          <Zap size={18} class="stroke-current hidden md:block" aria-hidden="true" />
          <span class="text-xs sm:text-sm">Initialize All</span>
        </button>
      </div>
    ) : (
      <div class="tooltip tooltip-bottom" data-tip="All categories already have budgets">
        <button
          type="button"
          class={ghostBtn + ' opacity-30 cursor-not-allowed'}
          disabled
          aria-label="Initialize all budgets (all categories already have budgets)"
          aria-disabled="true"
          data-testid="initialize-budgets-btn"
        >
          <Zap size={16} class="stroke-current md:hidden" aria-hidden="true" />
          <Zap size={18} class="stroke-current hidden md:block" aria-hidden="true" />
          <span class="text-xs sm:text-sm">Initialize All</span>
        </button>
      </div>
    )
  }

  {/* AI Rebalancer */}
  {
    showAiRebalancer && (
      <div class="tooltip tooltip-bottom" data-tip="AI budget rebalancer">
        <button
          type="button"
          class="btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-accent hover:text-accent hover:bg-accent/10 px-2 md:px-4"
          id="ai-rebalancer-btn"
          data-target-modal="ai-rebalancer-modal"
          aria-label="AI budget rebalancer"
        >
          <Sparkles size={16} class="stroke-current md:hidden" aria-hidden="true" />
          <Sparkles size={18} class="stroke-current hidden md:block" aria-hidden="true" />
          <span class="text-xs md:text-sm md:hidden">AI</span>
          <span class="text-sm hidden md:inline">AI Rebalancer</span>
        </button>
      </div>
    )
  }

  {/* Primary Action - New Budget */}
  <div slot="primary" class="tooltip tooltip-bottom" data-tip="Set new budget">
    <button
      type="button"
      class={accentGhostBtn}
      id="set-new-budget-btn"
      data-testid="set-new-budget-btn"
      data-target-modal="set-new-budget-modal"
      aria-label="Set new budget"
    >
      <Plus size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Plus size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden sm:inline">New Budget</span>
      <span class="sm:hidden">New</span>
    </button>
  </div>
</ActionBar>

{/* AI Rebalancer Coming Soon Modal */}
{
  showAiRebalancer && (
    <Modal
      id="ai-rebalancer-modal"
      title="AI Rebalancer"
      size="sm"
      closable={true}
      backdropClose={true}
    >
      <div class="text-center">
        <div class="flex justify-center mb-4">
          <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center">
            <Sparkles size={32} class="text-accent" aria-hidden="true" />
          </div>
        </div>
        <p class="text-base-content/70 mb-4">
          Smart budget optimization powered by AI is coming soon. This feature will analyze your
          spending patterns and suggest optimal budget allocations.
        </p>
        <div class="badge badge-accent badge-outline">Coming Soon</div>
      </div>
      <div slot="actions" class="modal-action justify-center">
        <form method="dialog">
          <button class="btn btn-ghost rounded-xl">Close</button>
        </form>
      </div>
    </Modal>
  )
}

<script>
  const handlerMap = new WeakMap<HTMLElement, (e: Event) => void>();

  function initModalTriggerButton(buttonId: string) {
    const btn = document.getElementById(buttonId);
    if (!btn) return;

    if (handlerMap.has(btn)) return;

    const handler = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      const targetId = btn.getAttribute('data-target-modal');
      if (!targetId) return;
      const modal = document.getElementById(targetId) as HTMLDialogElement;
      if (modal) {
        modal.showModal();
      }
    };

    handlerMap.set(btn, handler);
    btn.addEventListener('click', handler);
  }

  function cleanupBudgetActionButtons() {
    ['set-new-budget-btn', 'ai-rebalancer-btn', 'initialize-budgets-btn'].forEach((buttonId) => {
      const btn = document.getElementById(buttonId);
      if (btn) {
        const handler = handlerMap.get(btn);
        if (handler) {
          btn.removeEventListener('click', handler);
          handlerMap.delete(btn);
        }
      }
    });
  }

  function initBudgetActionButtons() {
    initModalTriggerButton('set-new-budget-btn');
    initModalTriggerButton('ai-rebalancer-btn');
    initModalTriggerButton('initialize-budgets-btn');
  }

  function registerCleanup() {
    document.addEventListener('astro:before-swap', cleanupBudgetActionButtons, { once: true });
  }

  initBudgetActionButtons();
  registerCleanup();

  document.addEventListener('astro:page-load', () => {
    initBudgetActionButtons();
    registerCleanup();
  });
</script>
