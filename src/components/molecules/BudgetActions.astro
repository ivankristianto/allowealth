---
/**
 * BudgetActions Component
 *
 * Action buttons row for the Budget page.
 * Mobile order: New Budget, Categories, Import, Export, Copy, Initialize All, AI Rebalancer.
 * (AI Rebalancer is intentionally disabled for now.)
 * Uses ActionBar for consistent layout.
 *
 * Note: History is in BudgetHeaderControls (header slot).
 *
 * @param {boolean} showAiRebalancer - Feature flag input (currently ignored; AI is disabled)
 * @param {number} uninitializedCount - Number of categories without budgets
 * @param {boolean} showCopyAction - Whether copy action should be rendered
 * @param {boolean} disableCopyAction - Whether copy action is disabled
 * @param {string} copyActionTooltip - Disabled state tooltip text for copy action
 * @param {string} className - Additional CSS classes
 */

import { Plus, Tags, Download, Upload } from '@lucide/astro';
import ActionBar from './ActionBar.astro';
import ActionOverflowMenu from './ActionOverflowMenu.astro';
import type { OverflowAction } from './ActionOverflowMenu.astro';
import {
  BUDGET_ACTIONS_DESKTOP_CARD_CLASS,
  BUDGET_ACTIONS_MOBILE_SCROLL_CLASS,
} from './budget-actions.config';

export interface Props {
  showAiRebalancer?: boolean;
  uninitializedCount?: number;
  showCopyAction?: boolean;
  disableCopyAction?: boolean;
  copyActionTooltip?: string;
  className?: string;
}

const {
  showAiRebalancer: _showAiRebalancer = true,
  uninitializedCount = 0,
  showCopyAction = false,
  disableCopyAction = false,
  copyActionTooltip = '',
  className = '',
} = Astro.props;

const ghostBtn =
  'btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4';

const accentGhostBtn =
  'btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-accent hover:text-accent hover:bg-accent/10 px-2 md:px-4 font-semibold';

// Build overflow actions for Copy and Initialize All
const overflowActions: OverflowAction[] = [];
if (showCopyAction) {
  overflowActions.push({
    id: 'copy-budget',
    label: 'Copy Budget',
    disabled: disableCopyAction,
    title: disableCopyAction && copyActionTooltip ? copyActionTooltip : undefined,
    dataTestId: 'copy-budget-btn',
  });
}
if (uninitializedCount > 0) {
  overflowActions.push({
    id: 'initialize-budgets',
    label: 'Initialize All',
    dataTestId: 'initialize-budgets-btn',
  });
}
---

<ActionBar
  className={[BUDGET_ACTIONS_MOBILE_SCROLL_CLASS, BUDGET_ACTIONS_DESKTOP_CARD_CLASS, className]
    .filter(Boolean)
    .join(' ')}
  ariaLabel="Budget actions"
  edgeBleed
>
  <div slot="secondary-visible" class="flex items-center gap-1 md:gap-2">
    {/* Categories */}
    <div class="tooltip tooltip-bottom" data-tip="Manage categories">
      <a href="/budget/categories" class={ghostBtn} aria-label="Manage categories">
        <Tags size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <Tags size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="text-xs md:text-sm">Categories</span>
      </a>
    </div>

    {/* Import */}
    <div class="tooltip tooltip-bottom" data-tip="Import budgets from CSV">
      <button
        type="button"
        class={ghostBtn}
        aria-label="Import budgets from CSV"
        data-budget-import-btn
        data-testid="budget-import-btn"
      >
        <Upload size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <Upload size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span>Import</span>
      </button>
    </div>

    {/* Export */}
    <div class="tooltip tooltip-bottom" data-tip="Export budgets to CSV">
      <button
        type="button"
        class={ghostBtn}
        aria-label="Export budgets to CSV"
        data-budget-export-btn
        data-testid="budget-export-btn"
      >
        <Download size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <Download size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span>Export</span>
      </button>
    </div>
  </div>

  {/* Overflow: Copy Budget + Initialize All */}
  {overflowActions.length > 0 && <ActionOverflowMenu slot="overflow" actions={overflowActions} />}

  {/* Primary Action - New Budget */}
  <div slot="primary" class="tooltip tooltip-bottom" data-tip="Set new budget">
    <button
      type="button"
      class={accentGhostBtn}
      id="set-new-budget-btn"
      data-testid="set-new-budget-btn"
      data-target-modal="set-new-budget-modal"
      aria-label="Set new budget"
    >
      <Plus size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Plus size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden sm:inline">New Budget</span>
      <span class="sm:hidden">New</span>
    </button>
  </div>
</ActionBar>

<script>
  const handlerMap = new WeakMap<HTMLElement, (e: Event) => void>();

  function initModalTriggerButton(buttonId: string) {
    const btn = document.getElementById(buttonId);
    if (!btn) return;

    if (handlerMap.has(btn)) return;

    const handler = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      const targetId = btn.getAttribute('data-target-modal');
      if (!targetId) return;
      const modal = document.getElementById(targetId) as HTMLDialogElement;
      if (modal) {
        modal.showModal();
      }
    };

    handlerMap.set(btn, handler);
    btn.addEventListener('click', handler);
  }

  function initOverflowAction(actionId: string, modalId: string) {
    const btn = document.querySelector(`[data-action-id="${actionId}"]`) as HTMLElement | null;
    if (!btn || handlerMap.has(btn)) return;

    const handler = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      const modal = document.getElementById(modalId) as HTMLDialogElement;
      if (modal) modal.showModal();
    };

    handlerMap.set(btn, handler);
    btn.addEventListener('click', handler);
  }

  function cleanupBudgetActionButtons() {
    ['set-new-budget-btn'].forEach((buttonId) => {
      const btn = document.getElementById(buttonId);
      if (btn) {
        const handler = handlerMap.get(btn);
        if (handler) {
          btn.removeEventListener('click', handler);
          handlerMap.delete(btn);
        }
      }
    });
    ['copy-budget', 'initialize-budgets'].forEach((actionId) => {
      const btn = document.querySelector(`[data-action-id="${actionId}"]`) as HTMLElement | null;
      if (btn) {
        const handler = handlerMap.get(btn);
        if (handler) {
          btn.removeEventListener('click', handler);
          handlerMap.delete(btn);
        }
      }
    });
  }

  function initBudgetActionButtons() {
    initModalTriggerButton('set-new-budget-btn');
    initOverflowAction('copy-budget', 'copy-budget-modal');
    initOverflowAction('initialize-budgets', 'initialize-budgets-modal');
    document.removeEventListener('budget-content-updated', handleBudgetContentUpdated);
    document.addEventListener('budget-content-updated', handleBudgetContentUpdated);
  }

  function handleBudgetContentUpdated() {
    initBudgetActionButtons();
  }

  function registerCleanup() {
    document.addEventListener(
      'astro:before-swap',
      () => {
        cleanupBudgetActionButtons();
        document.removeEventListener('budget-content-updated', handleBudgetContentUpdated);
      },
      { once: true }
    );
  }

  initBudgetActionButtons();
  registerCleanup();

  document.addEventListener('astro:page-load', () => {
    initBudgetActionButtons();
    registerCleanup();
  });
</script>
