---
/**
 * BudgetActions Component
 *
 * Action buttons row for the Budget page containing View History,
 * AI Rebalancer, Copy to Next Month, and Set New Budget buttons.
 * Extracted from BudgetPageHeader for better separation of concerns.
 *
 * @param {boolean} showAiRebalancer - Show AI Rebalancer button
 * @param {boolean} showCopyButton - Show Copy to Next Month button
 * @param {string} className - Additional CSS classes
 */

import { Sparkles, History, Plus, Copy, Tags, Download, Upload } from '@lucide/astro';
import Modal from '@components/molecules/Modal.astro';

export interface Props {
  showAiRebalancer?: boolean;
  showCopyButton?: boolean;
  className?: string;
}

const { showAiRebalancer = true, showCopyButton = false, className = '' } = Astro.props;

const containerClasses = [
  // Card styling
  'bg-base-100 rounded-card border border-base-300 shadow-sm',
  // Responsive padding - compact on mobile
  'p-2 md:p-4 lg:p-6',
  // Layout - nowrap on mobile for single row, wrap on larger screens
  'flex items-center gap-1 md:gap-3 md:flex-wrap',
  // Additional classes
  className,
]
  .filter(Boolean)
  .join(' ');
---

{/* P2 TODO: Consider using <nav aria-label="Budget actions"> for better semantics */}
<div class={containerClasses}>
  {/* Secondary Actions - Ghost style, icon-only on mobile */}
  <div class="flex items-center gap-1 md:gap-2">
    {/* View History */}
    <a
      href="/budget/history"
      class="btn btn-ghost btn-sm md:btn-md gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4"
      aria-label="View budget history"
      title="History"
    >
      <History size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <History size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden md:inline">History</span>
    </a>

    {/* Categories */}
    <a
      href="/budget/categories"
      class="btn btn-ghost btn-sm md:btn-md gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4"
      aria-label="Manage categories"
      title="Categories"
    >
      <Tags size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Tags size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden md:inline">Categories</span>
    </a>

    {/* AI Rebalancer */}
    {
      showAiRebalancer && (
        <button
          type="button"
          class="btn btn-ghost btn-sm md:btn-md gap-1 md:gap-2 rounded-lg md:rounded-xl text-accent hover:text-accent hover:bg-accent/10 px-2 md:px-4"
          id="ai-rebalancer-btn"
          data-target-modal="ai-rebalancer-modal"
          aria-label="AI budget rebalancer"
          title="AI Rebalancer"
        >
          <Sparkles size={16} class="stroke-current md:hidden" aria-hidden="true" />
          <Sparkles size={18} class="stroke-current hidden md:block" aria-hidden="true" />
          <span class="hidden md:inline">AI Rebalancer</span>
        </button>
      )
    }

    {/* Copy to Next Month */}
    {
      showCopyButton && (
        <button
          type="button"
          class="btn btn-ghost btn-sm md:btn-md gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4"
          id="copy-budgets-btn"
          data-target-modal="copy-budget-modal"
          aria-label="Copy budgets to next month"
          title="Copy to Next Month"
        >
          <Copy size={16} class="stroke-current md:hidden" aria-hidden="true" />
          <Copy size={18} class="stroke-current hidden md:block" aria-hidden="true" />
          <span class="hidden md:inline">Copy</span>
        </button>
      )
    }

    {/* Export */}
    <button
      type="button"
      class="btn btn-ghost btn-sm md:btn-md gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4"
      aria-label="Export budgets to CSV"
      title="Export"
      data-budget-export-btn
      data-testid="budget-export-btn"
    >
      <Download size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Download size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span>Export</span>
    </button>

    {/* Import */}
    <button
      type="button"
      class="btn btn-ghost btn-sm md:btn-md gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4"
      aria-label="Import budgets from CSV"
      title="Import"
      data-budget-import-btn
      data-testid="budget-import-btn"
    >
      <Upload size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Upload size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span>Import</span>
    </button>
  </div>

  {/* Primary Action - Pushed to right */}
  <button
    type="button"
    class="btn btn-accent btn-sm md:btn-md ml-auto gap-1 md:gap-2 rounded-lg md:rounded-xl font-semibold px-3 md:px-4"
    id="set-new-budget-btn"
    data-testid="set-new-budget-btn"
    data-target-modal="set-new-budget-modal"
    aria-label="Set new budget"
  >
    <Plus size={16} class="stroke-current md:hidden" aria-hidden="true" />
    <Plus size={18} class="stroke-current hidden md:block" aria-hidden="true" />
    <span class="hidden sm:inline">New Budget</span>
    <span class="sm:hidden">New</span>
  </button>
</div>

{/* AI Rebalancer Coming Soon Modal - Using Modal Component */}
{
  showAiRebalancer && (
    <Modal
      id="ai-rebalancer-modal"
      title="AI Rebalancer"
      size="sm"
      closable={true}
      backdropClose={true}
    >
      <div class="text-center">
        <div class="flex justify-center mb-4">
          <div class="w-16 h-16 rounded-full bg-accent/10 flex items-center justify-center">
            <Sparkles size={32} class="text-accent" aria-hidden="true" />
          </div>
        </div>
        <p class="text-base-content/70 mb-4">
          Smart budget optimization powered by AI is coming soon. This feature will analyze your
          spending patterns and suggest optimal budget allocations.
        </p>
        <div class="badge badge-accent badge-outline">Coming Soon</div>
      </div>
      <div slot="actions" class="modal-action justify-center">
        <form method="dialog">
          <button class="btn btn-ghost rounded-xl">Close</button>
        </form>
      </div>
    </Modal>
  )
}

<script>
  // P3 TODO: Consider moving this script to a separate .client.ts file for better TypeScript support
  // P1: Use data-target-modal attribute to decouple from hardcoded modal IDs
  // Store handler references for cleanup to prevent memory leaks
  const handlerMap = new WeakMap<HTMLElement, (e: Event) => void>();

  function initModalTriggerButton(buttonId: string) {
    const btn = document.getElementById(buttonId);
    if (!btn) return;

    // Skip if already initialized
    if (handlerMap.has(btn)) return;

    const handler = (e: Event) => {
      e.preventDefault();
      e.stopPropagation();
      const targetId = btn.getAttribute('data-target-modal');
      if (!targetId) return;
      const modal = document.getElementById(targetId) as HTMLDialogElement;
      if (modal) {
        modal.showModal();
      }
    };

    handlerMap.set(btn, handler);
    btn.addEventListener('click', handler);
  }

  function cleanupBudgetActionButtons() {
    ['set-new-budget-btn', 'copy-budgets-btn', 'ai-rebalancer-btn'].forEach((buttonId) => {
      const btn = document.getElementById(buttonId);
      if (btn) {
        const handler = handlerMap.get(btn);
        if (handler) {
          btn.removeEventListener('click', handler);
          handlerMap.delete(btn);
        }
      }
    });
  }

  function initBudgetActionButtons() {
    initModalTriggerButton('set-new-budget-btn');
    initModalTriggerButton('copy-budgets-btn');
    initModalTriggerButton('ai-rebalancer-btn');
  }

  // Register cleanup handler (must re-register after each page load since it's once)
  function registerCleanup() {
    document.addEventListener('astro:before-swap', cleanupBudgetActionButtons, { once: true });
  }

  // Initialize
  initBudgetActionButtons();
  registerCleanup();

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', () => {
    initBudgetActionButtons();
    registerCleanup();
  });
</script>
