---
/**
 * ToastContainer Component
 *
 * Global toast notification system using Nano Stores for state management
 * and Motion library for smooth animations per styles.json specifications.
 * Respects prefers-reduced-motion for accessibility.
 *
 * Uses shared animation config from @/lib/animations/toast.ts for consistency.
 *
 * Automatically included in BaseLayout. Use addToast() from client scripts.
 *
 * @example
 * ```typescript
 * import { addToast } from '@/lib/stores/toastStore';
 * addToast('Success!', 'success');
 * ```
 */
---

<div
  id="toast-container"
  class="toast toast-top toast-end z-[100]"
  role="region"
  aria-label="Notifications"
  transition:persist="toast-container"
>
  <!-- Separate aria-live regions for polite and assertive announcements -->
  <div
    id="toast-announcer-polite"
    role="status"
    aria-live="polite"
    aria-atomic="true"
    class="sr-only"
  >
  </div>
  <div
    id="toast-announcer-assertive"
    role="alert"
    aria-live="assertive"
    aria-atomic="true"
    class="sr-only"
  >
  </div>
</div>

<script>
  import { animate } from 'motion/mini';
  import { TOAST_ANIMATION_CONFIG, TOAST_INITIAL_STYLES } from '@/lib/animations';
  import { toasts, removeToast, type ToastMessage } from '@/lib/stores/toastStore';

  // Track rendered toasts for efficient DOM updates
  let renderedToasts = new Map<string, HTMLElement>();

  // Track focused elements for restoration - only restore on MANUAL dismiss
  // Map toast ID to focused element so we can clean up on auto-dismiss
  let focusRestoreMap = new Map<string, HTMLElement>();

  // Store unsubscribe function for cleanup
  let unsubscribeFromToasts: (() => void) | null = null;

  // Store document event listener abort controllers for cleanup
  let afterSwapAbortController: AbortController | null = null;
  let beforeSwapAbortController: AbortController | null = null;

  // Check if user prefers reduced motion for accessibility
  // Use MediaQueryList object to enable dynamic preference changes
  let motionQuery: MediaQueryList | null = null;
  let prefersReducedMotion = false;

  // Get DaisyUI alert class for toast type
  function getAlertClass(type: string): string {
    const typeClasses: Record<string, string> = {
      success: 'alert-success',
      error: 'alert-error',
      warning: 'alert-warning',
      info: 'alert-info',
    };
    return typeClasses[type] || 'alert-info';
  }

  // Announce toast to screen readers via separate aria-live regions
  function announceToast(message: string, type: string): void {
    const container = document.getElementById('toast-container');
    const announcerId = type === 'error' ? '#toast-announcer-assertive' : '#toast-announcer-polite';
    const announcer = container?.querySelector(announcerId) as HTMLElement;
    if (!announcer) return;

    announcer.textContent = message;

    // Clear after announcement to prevent re-announcement
    setTimeout(() => {
      announcer.textContent = '';
    }, 1000);
  }

  // Listen for runtime motion preference changes
  function handleMotionPreferenceChange(): void {
    prefersReducedMotion = motionQuery?.matches ?? false;
  }

  // Create toast element with Motion enter animation (using shared config from @/lib/animations/toast.ts)
  function createToastElement(toast: ToastMessage): HTMLElement {
    const container = document.getElementById('toast-container');

    // Capture currently focused element BEFORE toast appears
    // Only if it's not already focused on a toast element
    const currentFocus = document.activeElement as HTMLElement;
    if (
      currentFocus &&
      currentFocus !== document.body &&
      !currentFocus.closest('#toast-container')
    ) {
      focusRestoreMap.set(toast.id, currentFocus);
    }

    const toastEl = document.createElement('div');
    toastEl.className = `alert shadow-lg ${getAlertClass(toast.type)}`;
    toastEl.id = `toast-${toast.id}`;
    toastEl.setAttribute('role', 'alert');
    toastEl.setAttribute('data-testid', `toast-${toast.type}`);

    // Set initial state for enter animation (using shared config from @/lib/animations/toast.ts)
    // Skip animation if user prefers reduced motion - show toast immediately
    if (prefersReducedMotion) {
      toastEl.style.opacity = '1';
    } else {
      Object.assign(toastEl.style, TOAST_INITIAL_STYLES);
    }

    // Message span
    const messageSpan = document.createElement('span');
    messageSpan.textContent = toast.message;
    toastEl.appendChild(messageSpan);

    // Dismiss button (using Lucide X icon)
    const closeButton = document.createElement('button');
    closeButton.className = 'btn btn-ghost btn-xs';
    closeButton.setAttribute('aria-label', 'Dismiss notification');
    // Create Lucide X icon using DOM methods
    const xIcon = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
    xIcon.setAttribute('width', '16');
    xIcon.setAttribute('height', '16');
    xIcon.setAttribute('viewBox', '0 0 24 24');
    xIcon.setAttribute('fill', 'none');
    xIcon.setAttribute('stroke', 'currentColor');
    xIcon.setAttribute('stroke-width', '2');
    xIcon.setAttribute('stroke-linecap', 'round');
    xIcon.setAttribute('stroke-linejoin', 'round');
    xIcon.setAttribute('aria-hidden', 'true');
    const path1 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path1.setAttribute('d', 'M18 6 6 18');
    const path2 = document.createElementNS('http://www.w3.org/2000/svg', 'path');
    path2.setAttribute('d', 'm6 6 12 12');
    xIcon.appendChild(path1);
    xIcon.appendChild(path2);
    closeButton.appendChild(xIcon);

    // Handle dismiss click with exit animation and focus restoration (manual)
    closeButton.addEventListener('click', () => {
      dismissToast(toast.id, toastEl, true);
    });

    toastEl.appendChild(closeButton);

    // Announce toast to screen readers
    announceToast(toast.message, toast.type);

    // Append to DOM first, then trigger enter animation
    if (container) {
      container.appendChild(toastEl);
    }

    // Enter animation (using shared config from @/lib/animations/toast.ts)
    // Skip animation if user prefers reduced motion
    if (!prefersReducedMotion) {
      animate(
        toastEl,
        TOAST_ANIMATION_CONFIG.enter.keyframes,
        TOAST_ANIMATION_CONFIG.enter.options
      );
    }

    return toastEl;
  }

  // Dismiss toast with Motion exit animation and optional focus restoration (using shared config from @/lib/animations/toast.ts)
  function dismissToast(id: string, element: HTMLElement, manual: boolean = false): void {
    // Exit animation (using shared config from @/lib/animations/toast.ts)
    // Skip animation if user prefers reduced motion - remove immediately
    if (prefersReducedMotion) {
      element.remove();
      renderedToasts.delete(id);
      removeToast(id);

      // Only restore focus for manually dismissed toasts
      if (manual) {
        const restoreFocus = focusRestoreMap.get(id);
        focusRestoreMap.delete(id);
        if (restoreFocus && document.contains(restoreFocus)) {
          restoreFocus.focus();
        }
      } else {
        // Auto-dismiss: clean up the focus map entry
        focusRestoreMap.delete(id);
      }
    } else {
      animate(
        element,
        TOAST_ANIMATION_CONFIG.exit.keyframes,
        TOAST_ANIMATION_CONFIG.exit.options
      ).then(() => {
        element.remove();
        renderedToasts.delete(id);
        removeToast(id);

        // Only restore focus for manually dismissed toasts
        if (manual) {
          const restoreFocus = focusRestoreMap.get(id);
          focusRestoreMap.delete(id);
          if (restoreFocus && document.contains(restoreFocus)) {
            restoreFocus.focus();
          }
        } else {
          // Auto-dismiss: clean up the focus map entry
          focusRestoreMap.delete(id);
        }
      });
    }
  }

  // Reconcile DOM based on store state
  function reconcileDOM(currentToasts: readonly ToastMessage[]): void {
    const currentIds = new Set(currentToasts.map((t) => t.id));
    const renderedIds = new Set(renderedToasts.keys());

    // Remove toasts that are no longer in store
    for (const id of renderedIds) {
      if (!currentIds.has(id)) {
        const element = renderedToasts.get(id);
        if (element) {
          element.remove();
          renderedToasts.delete(id);
          // Clean up focus map entry for auto-dismissed toasts
          focusRestoreMap.delete(id);
        }
      }
    }

    // Add new toasts
    for (const toast of currentToasts) {
      if (!renderedToasts.has(toast.id)) {
        const element = createToastElement(toast);
        renderedToasts.set(toast.id, element);
      }
    }
  }

  // Track if after-swap listener is registered (persist across cleanups)
  let isAfterSwapListenerRegistered = false;

  // Initialize toast system
  function initToastSystem(): void {
    // Clean up any existing subscription first (but keep after-swap listener)
    cleanupToastSystem();

    // Reset state maps
    renderedToasts = new Map<string, HTMLElement>();
    focusRestoreMap = new Map<string, HTMLElement>();

    // Initialize motion preference
    motionQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    prefersReducedMotion = motionQuery.matches;
    motionQuery.addEventListener('change', handleMotionPreferenceChange);

    // Subscribe to toast store changes
    unsubscribeFromToasts = toasts.subscribe((currentToasts) => {
      reconcileDOM(currentToasts);
    });

    // Register after-swap listener once (persist for session lifetime)
    if (!isAfterSwapListenerRegistered) {
      afterSwapAbortController = new AbortController();
      document.addEventListener('astro:after-swap', initToastSystem, {
        signal: afterSwapAbortController.signal,
      });
      isAfterSwapListenerRegistered = true;
    }

    // Register before-swap listener (cleaned up and re-registered each time)
    beforeSwapAbortController = new AbortController();
    document.addEventListener('astro:before-swap', cleanupToastSystem, {
      signal: beforeSwapAbortController.signal,
    });
  }

  // Cleanup toast system (for view transitions)
  function cleanupToastSystem(): void {
    if (unsubscribeFromToasts) {
      unsubscribeFromToasts();
      unsubscribeFromToasts = null;
    }

    if (motionQuery) {
      motionQuery.removeEventListener('change', handleMotionPreferenceChange);
      motionQuery = null;
    }

    // Abort only the before-swap listener (after-swap persists)
    if (beforeSwapAbortController) {
      beforeSwapAbortController.abort();
      beforeSwapAbortController = null;
    }

    // Clear all rendered toasts from DOM
    for (const element of renderedToasts.values()) {
      element.remove();
    }
    renderedToasts.clear();
    focusRestoreMap.clear();
  }

  // Initialize on first load
  initToastSystem();
</script>
