---
import ActionBar from '@/components/molecules/ActionBar.astro';
import Button from '@/components/atoms/Button.astro';
import { CalendarDays, Info, List, Plus } from '@lucide/astro';

export interface Props {
  view: 'list' | 'calendar';
  total: number;
}

const { view, total } = Astro.props;

const viewButtonClass =
  'h-10 min-h-[44px] gap-1.5 px-3 rounded-lg sm:rounded-xl text-sm font-semibold border-0';
---

<div class="flex w-full flex-wrap items-center gap-3">
  <h2 class="text-xs font-bold uppercase tracking-widest text-neutral">
    All Recurring
    <span id="recurring-count-badge" class="ml-1 badge badge-sm badge-ghost font-bold">{total}</span
    >
  </h2>

  <div class="ml-auto flex w-full justify-end sm:w-auto">
    <ActionBar
      ariaLabel="Recurring section actions"
      edgeBleed={false}
      className="!border-0 !bg-transparent !shadow-none !p-0"
    >
      <div slot="primary" class="flex flex-wrap items-center justify-end gap-2 sm:gap-3">
        <div
          class="flex items-center gap-1 rounded-xl border border-base-300 bg-base-100 p-1.5"
          role="group"
          aria-label="View toggle"
        >
          <span class="hidden sm:inline px-2 text-xs font-semibold text-base-content/60">View</span>

          <Button
            type="button"
            variant="ghost"
            size="sm"
            className={[viewButtonClass, view === 'list' && 'btn-active'].filter(Boolean).join(' ')}
            data-recurring-view="list"
            aria-label="List view"
            aria-pressed={view === 'list'}
          >
            <List size={16} class="stroke-current" aria-hidden="true" />
            <span class="text-xs sm:text-sm">List</span>
          </Button>

          <Button
            type="button"
            variant="ghost"
            size="sm"
            className={[viewButtonClass, view === 'calendar' && 'btn-active']
              .filter(Boolean)
              .join(' ')}
            data-recurring-view="calendar"
            aria-label="Calendar view"
            aria-pressed={view === 'calendar'}
          >
            <CalendarDays size={16} class="stroke-current" aria-hidden="true" />
            <span class="text-xs sm:text-sm">Calendar</span>
          </Button>

          <div class="dropdown dropdown-end">
            <Button
              type="button"
              variant="ghost"
              size="sm"
              shape="square"
              tabindex={0}
              className="h-10 min-h-[44px] min-w-[44px] rounded-lg border-0 text-base-content/60"
              aria-label="View mode information"
            >
              <Info size={14} class="stroke-current" aria-hidden="true" />
            </Button>
            <div
              tabindex={0}
              class="dropdown-content z-40 w-60 rounded-xl border border-base-300 bg-base-100 p-3 text-xs text-base-content/70 shadow-lg"
            >
              <p class="font-semibold text-base-content">View Modes</p>
              <p class="mt-1">
                List view is best for quick actions. Calendar view helps scan dates.
              </p>
            </div>
          </div>
        </div>

        <Button
          type="button"
          variant="primary"
          size="sm"
          className="h-10 min-h-[44px] gap-1.5 rounded-lg sm:rounded-xl px-3 font-semibold"
          data-open-recurring-template
          aria-label="Create new recurring transaction"
        >
          <Plus size={16} class="stroke-current" aria-hidden="true" />
          <span class="text-xs sm:text-sm">New Recurring</span>
        </Button>
      </div>
    </ActionBar>
  </div>
</div>
