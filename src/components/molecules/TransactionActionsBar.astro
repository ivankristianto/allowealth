---
/**
 * Transaction Actions Bar Component
 *
 * Action bar with Import CSV, Export CSV as visible secondary actions.
 * Scan Receipt as primary action (right side). Add Expense/Income removed
 * (handled by FAB / transaction drawer triggers elsewhere).
 */

import { Upload, Download, Camera } from '@lucide/astro';
import ActionBar from './ActionBar.astro';
import { accentGhostBtn, ghostBtn } from '@/lib/ui/action-button-classes';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;
---

<ActionBar className={className} ariaLabel="Transaction actions" edgeBleed>
  <div slot="secondary-visible" class="flex items-center gap-1 md:gap-2">
    {/* Import CSV */}
    <div class="tooltip tooltip-bottom" data-tip="Import transactions from CSV">
      <button
        type="button"
        class={ghostBtn}
        data-import-csv-button
        aria-label="Import CSV"
        data-transaction-actions-bar
      >
        <Upload size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <Upload size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="text-xs md:text-sm">Import</span>
      </button>
    </div>

    {/* Export CSV */}
    <div class="tooltip tooltip-bottom" data-tip="Export transactions to CSV">
      <button type="button" class={ghostBtn} data-export-csv-button aria-label="Export CSV">
        <Download size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <Download size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="text-xs md:text-sm">Export</span>
      </button>
    </div>
  </div>

  {/* Primary Action - Scan Receipt */}
  <div slot="primary" class="tooltip tooltip-bottom" data-tip="Scan receipt">
    <button
      type="button"
      class={accentGhostBtn}
      data-scan-receipt-button
      aria-label="Scan receipt"
      data-testid="scan-receipt-btn"
    >
      <Camera size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Camera size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden sm:inline">Scan Receipt</span>
      <span class="sm:hidden">Scan</span>
    </button>
  </div>
</ActionBar>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { navigate } from 'astro:transitions/client';

  function initTransactionActionsBar() {
    const actionsBar = document.querySelector(
      '[data-transaction-actions-bar]'
    ) as HTMLElement | null;
    if (!actionsBar) return;

    // Use closest ActionBar container for scoped queries
    const container = actionsBar.closest('[role="toolbar"]');
    if (!container) return;

    // Prevent duplicate initialization
    if ((container as HTMLElement).dataset.initialized === 'true') return;
    (container as HTMLElement).dataset.initialized = 'true';

    // Scan Receipt button (primary action)
    const scanBtn = container.querySelector('[data-scan-receipt-button]');
    scanBtn?.addEventListener('click', () => {
      addToast('Receipt scanning coming soon!', 'info');
    });

    // Import CSV button
    const importBtn = container.querySelector('[data-import-csv-button]');
    importBtn?.addEventListener('click', () => {
      navigate('/transactions/import');
    });

    // Export CSV button
    const exportBtn = container.querySelector('[data-export-csv-button]');
    exportBtn?.addEventListener('click', async () => {
      try {
        // Get current filters from URL
        const url = new URL(window.location.href);
        const params = new URLSearchParams(url.search);

        // Build export URL with filters
        const exportUrl = `/api/transactions/export?${params.toString()}`;

        // Trigger download
        const response = await fetch(exportUrl);
        if (!response.ok) {
          throw new Error('Failed to export transactions');
        }

        const blob = await response.blob();
        const downloadUrl = window.URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = downloadUrl;
        link.download = `transactions-${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        window.URL.revokeObjectURL(downloadUrl);

        addToast('Transactions exported successfully!', 'success');
      } catch (err) {
        console.error('Export failed:', err);
        addToast('Failed to export transactions. Please try again.', 'error');
      }
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionActionsBar);
  } else {
    initTransactionActionsBar();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initTransactionActionsBar);
</script>
