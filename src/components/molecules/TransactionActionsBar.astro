---
/**
 * Transaction Actions Bar Component
 *
 * Action bar with Add Expense, Add Income, Scan Receipt, Import CSV,
 * and Export CSV buttons. Uses ActionBar for consistent layout.
 */

import { Sparkles, Upload, Download, CircleMinus, CirclePlus } from '@lucide/astro';
import ActionBar from './ActionBar.astro';

export interface Props {
  className?: string;
}

const { className = '' } = Astro.props;

const ghostBtn =
  'btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-base-content/70 hover:text-base-content hover:bg-base-200 px-2 md:px-4';

const accentGhostBtn =
  'btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-accent hover:text-accent hover:bg-accent/10 px-2 md:px-4 font-semibold';
---

<ActionBar className={className} ariaLabel="Transaction actions">
  {/* Import CSV */}
  <div class="tooltip tooltip-bottom" data-tip="Import transactions from CSV">
    <button
      type="button"
      class={ghostBtn}
      data-import-csv-button
      aria-label="Import CSV"
      data-transaction-actions-bar
    >
      <Upload size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Upload size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden md:inline">Import</span>
    </button>
  </div>

  {/* Export CSV */}
  <div class="tooltip tooltip-bottom" data-tip="Export transactions to CSV">
    <button type="button" class={ghostBtn} data-export-csv-button aria-label="Export CSV">
      <Download size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Download size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden md:inline">Export</span>
    </button>
  </div>

  {/* Scan Receipt */}
  <div class="tooltip tooltip-bottom" data-tip="Scan receipt with AI">
    <button
      type="button"
      class="btn btn-ghost btn-sm md:btn-md min-h-[44px] min-w-[44px] gap-1 md:gap-2 rounded-lg md:rounded-xl text-accent hover:text-accent hover:bg-accent/10 px-2 md:px-4"
      data-scan-receipt-button
      aria-label="Scan receipt"
    >
      <Sparkles size={16} class="stroke-current md:hidden" aria-hidden="true" />
      <Sparkles size={18} class="stroke-current hidden md:block" aria-hidden="true" />
      <span class="hidden md:inline">Scan Receipt</span>
    </button>
  </div>

  {/* Right side: Expense + Income with accent ghost style */}
  <div slot="primary" class="flex items-center gap-1 md:gap-2">
    <div class="tooltip tooltip-bottom" data-tip="Add new expense">
      <button type="button" class={accentGhostBtn} data-add-expense-button aria-label="Add expense">
        <CircleMinus size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <CircleMinus size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="hidden md:inline">Expense</span>
      </button>
    </div>

    <div class="tooltip tooltip-bottom" data-tip="Add new income">
      <button type="button" class={accentGhostBtn} data-add-income-button aria-label="Add income">
        <CirclePlus size={16} class="stroke-current md:hidden" aria-hidden="true" />
        <CirclePlus size={18} class="stroke-current hidden md:block" aria-hidden="true" />
        <span class="hidden md:inline">Income</span>
      </button>
    </div>
  </div>
</ActionBar>

<script>
  import { addToast } from '@/lib/stores/toastStore';

  function initTransactionActionsBar() {
    const actionsBar = document.querySelector(
      '[data-transaction-actions-bar]'
    ) as HTMLElement | null;
    if (!actionsBar) return;

    // Use closest ActionBar container for scoped queries
    const container = actionsBar.closest('[role="toolbar"]');
    if (!container) return;

    // Prevent duplicate initialization
    if ((container as HTMLElement).dataset.initialized === 'true') return;
    (container as HTMLElement).dataset.initialized = 'true';

    // Add Expense button
    const addExpenseBtn = container.querySelector('[data-add-expense-button]');
    addExpenseBtn?.addEventListener('click', () => {
      const modal = document.getElementById('expense-modal') as HTMLDialogElement | null;
      if (modal) {
        modal.showModal();
      }
    });

    // Add Income button
    const addIncomeBtn = container.querySelector('[data-add-income-button]');
    addIncomeBtn?.addEventListener('click', () => {
      const modal = document.getElementById('income-modal') as HTMLDialogElement | null;
      if (modal) {
        modal.showModal();
      }
    });

    // Scan Receipt button
    const scanBtn = container.querySelector('[data-scan-receipt-button]');
    scanBtn?.addEventListener('click', () => {
      addToast('Receipt scanning coming soon!', 'info');
    });

    // Import CSV button
    const importBtn = container.querySelector('[data-import-csv-button]');
    importBtn?.addEventListener('click', () => {
      window.location.href = '/transactions/import';
    });

    // Export CSV button
    const exportBtn = container.querySelector('[data-export-csv-button]');
    exportBtn?.addEventListener('click', async () => {
      try {
        // Get current filters from URL
        const url = new URL(window.location.href);
        const params = new URLSearchParams(url.search);

        // Build export URL with filters
        const exportUrl = `/api/transactions/export?${params.toString()}`;

        // Trigger download
        const response = await fetch(exportUrl);
        if (!response.ok) {
          throw new Error('Failed to export transactions');
        }

        const blob = await response.blob();
        const downloadUrl = window.URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = downloadUrl;
        link.download = `transactions-${new Date().toISOString().split('T')[0]}.csv`;
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        window.URL.revokeObjectURL(downloadUrl);

        addToast('Transactions exported successfully!', 'success');
      } catch (err) {
        console.error('Export failed:', err);
        addToast('Failed to export transactions. Please try again.', 'error');
      }
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionActionsBar);
  } else {
    initTransactionActionsBar();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initTransactionActionsBar);
</script>
