---
/**
 * ForgotPasswordForm Component
 *
 * Form for requesting a password reset email.
 * Uses JSON API for password reset request.
 *
 * @param {string} errorMessage - Error message to display
 * @param {string} successMessage - Success message to display
 */

import Input from '../atoms/Input.astro';
import Label from '../atoms/Label.astro';
import Button from '../atoms/Button.astro';
import ErrorMessage from '../atoms/ErrorMessage.astro';

export interface Props {
  errorMessage?: string;
  successMessage?: string;
}

const { errorMessage = '', successMessage = '' } = Astro.props;
---

<div class="card bg-base-100 shadow-xl">
  <div class="card-body">
    <h2 class="card-title text-2xl font-bold mb-2">Forgot Password</h2>
    <p class="text-sm text-base-content/70 mb-4">
      Enter your email address and we'll send you a link to reset your password.
    </p>

    <div id="forgot-password-messages" aria-live="polite" aria-atomic="true">
      {errorMessage && <ErrorMessage message={errorMessage} />}
      {
        successMessage && (
          <div role="status" class="alert alert-success">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="stroke-current shrink-0 h-6 w-6"
              fill="none"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
              />
            </svg>
            <span>{successMessage}</span>
          </div>
        )
      }
    </div>

    <form id="forgot-password-form" class="space-y-4" novalidate>
      <!-- Email Field -->
      <div class="form-control">
        <Label htmlFor="email" required>Email</Label>
        <Input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          className="w-full"
        />
      </div>

      <!-- Submit Button -->
      <Button id="forgot-password-submit-button" type="submit" variant="primary" className="w-full">
        <span data-button-text>Send Reset Link</span>
        <span data-loading-spinner class="hidden">
          <span class="loading loading-spinner"></span>
          Sending...
        </span>
      </Button>

      <!-- Back to Login Link -->
      <div class="text-center text-sm">
        Remember your password?
        <a href="/login" class="text-primary hover:underline font-medium ml-1">Sign in</a>
      </div>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById('forgot-password-form');
  const messagesContainer = document.getElementById('forgot-password-messages');
  const emailInput = document.getElementById('email');
  const submitButton = document.getElementById('forgot-password-submit-button');
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  if (!form || !emailInput || !submitButton) {
    console.error('Forgot password form elements not found');
  } else {
    // Add autocomplete attribute for security and UX
    emailInput.setAttribute('autocomplete', 'email');
    emailInput.required = true;

    // Email validation pattern
    emailInput.pattern = '[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$';
    emailInput.title = 'Please enter a valid email address';

    // Clear messages on input
    emailInput.addEventListener('input', () => {
      if (messagesContainer) {
        const existingMessage = messagesContainer.querySelector('[role="alert"], [role="status"]');
        if (existingMessage) {
          existingMessage.remove();
        }
      }
    });

    // Form submission with fetch API
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous messages
      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      // Client-side validation
      const errors = [];

      if (!emailInput.value || !emailInput.checkValidity()) {
        errors.push('Please enter a valid email address');
      }

      // Display validation errors
      if (errors.length > 0) {
        if (messagesContainer) {
          messagesContainer.innerHTML = `
            <div role="alert" class="alert alert-error">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>${escapeHtml(errors.join(', '))}</span>
            </div>
          `;
        }
        return;
      }

      // Show loading state
      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      if (submitButton) submitButton.disabled = true;

      try {
        const formData = new FormData(form);
        const data = {
          email: formData.get('email'),
        };

        const response = await fetch('/api/auth/forgot-password', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (response.ok && result.success) {
          // Request successful - show success message
          if (messagesContainer) {
            messagesContainer.innerHTML = `
              <div role="status" class="alert alert-success">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>If an account exists with this email, we've sent a password reset link. Please check your inbox.</span>
              </div>
            `;
          }

          // Clear the form
          form.reset();
        } else {
          // Request failed - show error message
          if (messagesContainer) {
            messagesContainer.innerHTML = `
              <div role="alert" class="alert alert-error">
                <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <span>${escapeHtml(result.error?.message || 'An error occurred. Please try again.')}</span>
              </div>
            `;
          }
        }
      } catch (error) {
        console.error('Forgot password error:', error);
        // Show error message
        if (messagesContainer) {
          messagesContainer.innerHTML = `
            <div role="alert" class="alert alert-error">
              <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              <span>An error occurred. Please try again.</span>
            </div>
          `;
        }
      } finally {
        // Reset loading state
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        if (submitButton) submitButton.disabled = false;
      }
    });
  }

  // HTML escaping utility to prevent XSS
  const escapeHtml = (text: string) => {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  };
</script>
