---
/**
 * ForgotPasswordForm Component
 *
 * Form for requesting a password reset email.
 * Uses JSON API for password reset request.
 *
 * @param {string} errorMessage - Error message to display
 * @param {string} successMessage - Success message to display
 */

import Input from '../atoms/Input.astro';
import Button from '../atoms/Button.astro';
import ErrorMessage from '../atoms/ErrorMessage.astro';
import FormField from '../molecules/FormField.astro';
import { CircleCheck, CircleX } from '@lucide/astro';
import Turnstile from '../atoms/Turnstile.astro';

export interface Props {
  errorMessage?: string;
  successMessage?: string;
}

const { errorMessage = '', successMessage = '' } = Astro.props;
---

<div class="card bg-base-100 shadow-2xl border border-base-300">
  <div class="card-body p-8">
    <h2 class="card-title text-2xl font-bold mb-2 justify-center">Forgot Password</h2>
    <p class="text-sm text-base-content/60 mb-6 text-center">
      Enter your email address and we'll send you a link to reset your password.
    </p>

    <div id="forgot-password-messages" aria-live="polite" aria-atomic="true">
      {errorMessage && <ErrorMessage message={errorMessage} />}
      {
        successMessage && (
          <div role="status" class="alert alert-success">
            <CircleCheck size={24} class="shrink-0" aria-hidden="true" />
            <span>{successMessage}</span>
          </div>
        )
      }
    </div>

    <form id="forgot-password-form" class="space-y-5" novalidate>
      <!-- Email Field -->
      <FormField label="Email" htmlFor="email" required>
        <Input
          type="email"
          id="email"
          name="email"
          placeholder="you@example.com"
          className="w-full"
        />
      </FormField>

      <Turnstile />

      <!-- Submit Button -->
      <div class="pt-2">
        <Button
          id="forgot-password-submit-button"
          type="submit"
          variant="accent"
          className="w-full"
        >
          <span data-button-text>Send Reset Link</span>
          <span data-loading-spinner class="hidden">
            <span class="loading loading-spinner"></span>
            Sending...
          </span>
        </Button>
      </div>

      <!-- Back to Login Link -->
      <div class="text-center text-sm pt-4 border-t border-base-300">
        Remember your password?
        <a href="/login" class="link link-primary font-semibold ml-1" data-astro-reload>Sign in</a>
      </div>
    </form>
  </div>
</div>

<!-- Hidden icon templates for client-side cloning -->
<div id="icon-error-template" class="hidden" aria-hidden="true">
  <CircleX size={24} class="shrink-0" />
</div>
<div id="icon-success-template" class="hidden" aria-hidden="true">
  <CircleCheck size={24} class="shrink-0" />
</div>

<script>
  import { authClient } from '@/lib/auth/client';
  import {
    buildCaptchaHeaders,
    hasCaptchaWidget,
    resetCaptchaWidget,
  } from '@/lib/auth/captcha-client';

  const form = document.getElementById('forgot-password-form') as HTMLFormElement | null;
  const messagesContainer = document.getElementById('forgot-password-messages');
  const emailInput = document.getElementById('email') as HTMLInputElement | null;
  const submitButton = document.getElementById(
    'forgot-password-submit-button'
  ) as HTMLButtonElement | null;
  const buttonText = submitButton?.querySelector('[data-button-text]');
  const loadingSpinner = submitButton?.querySelector('[data-loading-spinner]');

  // Helper function to clone icon templates
  const cloneIcon = (templateId: string): HTMLElement | null => {
    const template = document.getElementById(templateId);
    if (!template?.firstElementChild) return null;
    return template.firstElementChild.cloneNode(true) as HTMLElement;
  };

  // Helper function to show alert messages
  const showAlert = (message: string, type: 'error' | 'success'): void => {
    if (!messagesContainer) return;

    const iconTemplateId = type === 'error' ? 'icon-error-template' : 'icon-success-template';
    const role = type === 'error' ? 'alert' : 'status';
    const alertClass = type === 'error' ? 'alert alert-error' : 'alert alert-success';

    const icon = cloneIcon(iconTemplateId);
    messagesContainer.innerHTML = '';

    const alertDiv = document.createElement('div');
    alertDiv.setAttribute('role', role);
    alertDiv.className = alertClass;

    if (icon) {
      alertDiv.appendChild(icon);
    }

    const textSpan = document.createElement('span');
    textSpan.textContent = message;
    alertDiv.appendChild(textSpan);

    messagesContainer.appendChild(alertDiv);
  };

  if (!form || !emailInput || !submitButton) {
    console.error('Forgot password form elements not found');
  } else {
    // Add autocomplete attribute for security and UX
    emailInput.setAttribute('autocomplete', 'email');
    emailInput.required = true;

    // Email validation pattern
    emailInput.pattern = '[a-z0-9._%+-]+@[a-z0-9.-]+\\.[a-z]{2,}$';
    emailInput.title = 'Please enter a valid email address';

    // Clear messages on input
    emailInput.addEventListener('input', () => {
      if (messagesContainer) {
        const existingMessage = messagesContainer.querySelector('[role="alert"], [role="status"]');
        if (existingMessage) {
          existingMessage.remove();
        }
      }
    });

    // Form submission with fetch API
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      // Clear previous messages
      if (messagesContainer) {
        messagesContainer.innerHTML = '';
      }

      // Client-side validation
      const errors = [];

      if (!emailInput.value || !emailInput.checkValidity()) {
        errors.push('Please enter a valid email address');
      }

      const captchaHeaders = buildCaptchaHeaders(form);
      if (hasCaptchaWidget(form) && !captchaHeaders['x-captcha-response']) {
        errors.push('Please complete the bot protection check');
      }

      // Display validation errors
      if (errors.length > 0) {
        showAlert(errors.join(', '), 'error');
        return;
      }

      // Show loading state
      if (buttonText) buttonText.classList.add('hidden');
      if (loadingSpinner) loadingSpinner.classList.remove('hidden');
      if (submitButton) submitButton.disabled = true;

      try {
        const result = await authClient.requestPasswordReset({
          email: emailInput.value.trim(),
          redirectTo: '/reset-password',
          fetchOptions: {
            headers: captchaHeaders,
          },
        });

        if (result.error) {
          showAlert(result.error.message || 'An error occurred. Please try again.', 'error');
          return;
        }

        if (result.data?.status) {
          showAlert(
            "If an account exists with this email, we've sent a password reset link. Please check your inbox.",
            'success'
          );
          form.reset();
          return;
        }

        showAlert('An error occurred. Please try again.', 'error');
      } catch (error) {
        console.error('Forgot password error:', error);
        // Show error message
        showAlert('An error occurred. Please try again.', 'error');
      } finally {
        // Reset loading state
        if (buttonText) buttonText.classList.remove('hidden');
        if (loadingSpinner) loadingSpinner.classList.add('hidden');
        if (submitButton) submitButton.disabled = false;
        resetCaptchaWidget();
      }
    });
  }
</script>
