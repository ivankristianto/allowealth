---
import { CalendarDays, List } from '@lucide/astro';

export interface Props {
  view: 'list' | 'calendar';
  className?: string;
}

const { view, className = '' } = Astro.props;
---

<div
  class:list={['flex items-center justify-end', className]}
  data-recurring-view-controls
  aria-label="Recurring view controls"
>
  <div
    class="flex items-center gap-1 rounded-xl border border-base-300 bg-base-100 p-1"
    role="group"
  >
    <button
      type="button"
      class:list={['btn btn-sm btn-ghost h-9 min-h-0 rounded-lg', view === 'list' && 'btn-active']}
      data-recurring-view="list"
      data-recurring-view-toggle
      aria-label="List view"
      aria-pressed={view === 'list'}
      aria-controls="recurring-list-view"
    >
      <List size={16} class="stroke-current" aria-hidden="true" />
      <span class="hidden sm:inline">List</span>
    </button>
    <button
      type="button"
      class:list={[
        'btn btn-sm btn-ghost h-9 min-h-0 rounded-lg',
        view === 'calendar' && 'btn-active',
      ]}
      data-recurring-view="calendar"
      data-recurring-view-toggle
      aria-label="Calendar view"
      aria-pressed={view === 'calendar'}
      aria-controls="recurring-calendar-view"
    >
      <CalendarDays size={16} class="stroke-current" aria-hidden="true" />
      <span class="hidden sm:inline">Calendar</span>
    </button>
  </div>
</div>
