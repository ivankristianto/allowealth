---
/**
 * Transaction Row Component
 *
 * Single transaction display for list/table view.
 *
 * @param {Object} transaction - Transaction data
 * @param {string} editUrl - URL to edit transaction
 * @param {boolean} showActions - Show edit/delete actions
 */

import Currency from '../atoms/Currency.astro';
import IconBadge from '../atoms/IconBadge.astro';
import {
  Banknote,
  Briefcase,
  Car,
  CreditCard,
  Film,
  House,
  Pencil,
  Pill,
  ShoppingBasket,
  Trash2,
  UtensilsCrossed,
  Wallet,
  Zap,
} from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  transaction: TransactionOutput;
  editUrl?: string;
  deleteUrl?: string;
  showActions?: boolean;
  className?: string;
}

const {
  transaction,
  editUrl = '',
  deleteUrl = '',
  showActions = true,
  className = '',
} = Astro.props;

const amount = parseFloat(transaction.amount) || 0;
const isExpense = transaction.type === 'expense';
const date = new Date(transaction.transaction_date);

// Format date nicely
const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const primaryText = transaction.description?.trim() || transaction.category.name;

type CategoryIconComponent =
  | typeof ShoppingBasket
  | typeof Zap
  | typeof Film
  | typeof Car
  | typeof Pill
  | typeof UtensilsCrossed
  | typeof House
  | typeof Banknote
  | typeof Briefcase
  | typeof Wallet;

type CategoryMeta = {
  icon: CategoryIconComponent;
  variant: 'primary' | 'accent' | 'success' | 'warning' | 'error' | 'info' | 'neutral';
};

const getCategoryMeta = (name: string, type: TransactionOutput['type']): CategoryMeta => {
  const normalized = name.toLowerCase();

  if (type === 'income') {
    return { icon: Banknote, variant: 'success' as const };
  }

  if (
    normalized.includes('grocery') ||
    normalized.includes('market') ||
    normalized.includes('food')
  ) {
    return { icon: ShoppingBasket, variant: 'warning' as const };
  }
  if (
    normalized.includes('utility') ||
    normalized.includes('electric') ||
    normalized.includes('water') ||
    normalized.includes('gas')
  ) {
    return { icon: Zap, variant: 'info' as const };
  }
  if (
    normalized.includes('entertainment') ||
    normalized.includes('movie') ||
    normalized.includes('netflix')
  ) {
    return { icon: Film, variant: 'error' as const };
  }
  if (
    normalized.includes('transport') ||
    normalized.includes('uber') ||
    normalized.includes('taxi') ||
    normalized.includes('ride')
  ) {
    return { icon: Car, variant: 'accent' as const };
  }
  if (
    normalized.includes('health') ||
    normalized.includes('pharmacy') ||
    normalized.includes('medical')
  ) {
    return { icon: Pill, variant: 'primary' as const };
  }
  if (normalized.includes('dining') || normalized.includes('restaurant')) {
    return { icon: UtensilsCrossed, variant: 'warning' as const };
  }
  if (
    normalized.includes('housing') ||
    normalized.includes('rent') ||
    normalized.includes('mortgage')
  ) {
    return { icon: House, variant: 'primary' as const };
  }
  if (normalized.includes('freelance') || normalized.includes('contract')) {
    return { icon: Briefcase, variant: 'info' as const };
  }

  return { icon: Wallet, variant: type === 'expense' ? ('error' as const) : ('success' as const) };
};

const categoryMeta = getCategoryMeta(transaction.category.name, transaction.type);
const CategoryIcon = categoryMeta.icon;

const rowClasses = [
  'group flex items-center gap-5 p-5',
  'transition-all cursor-pointer',
  'border-l-4 border-transparent',
  isExpense ? 'hover:border-error/30' : 'hover:border-success/30',
  'hover:bg-base-200/40',
  className,
]
  .filter(Boolean)
  .join(' ');
---

<div class={rowClasses} data-transaction-row="true">
  <!-- Date -->
  <div class="flex-shrink-0 w-24 text-sm">
    <div class="font-medium">{formattedDate}</div>
  </div>

  <!-- Category & Description -->
  <div class="flex-1 min-w-0 flex items-center gap-4">
    <IconBadge
      variant={categoryMeta.variant}
      size="sm"
      className="rounded-2xl transition-transform group-hover:rotate-2"
    >
      <CategoryIcon size={18} class="stroke-current" aria-hidden="true" />
    </IconBadge>
    <div class="min-w-0">
      <div class="font-bold tracking-tight truncate text-base leading-none">{primaryText}</div>
      <div class="mt-2 flex flex-wrap items-center gap-2 leading-none">
        <span
          class="text-[10px] font-bold tracking-widest uppercase text-base-content/60 bg-base-200 px-2 py-0.5 rounded"
        >
          {transaction.category.name}
        </span>
      </div>
    </div>
  </div>

  <!-- Payment Method -->
  <div class="flex-shrink-0 hidden sm:block">
    <div
      class="flex items-center gap-1.5 text-[10px] uppercase tracking-widest text-base-content/60"
    >
      <CreditCard size={12} class="stroke-current" aria-hidden="true" />
      <span>{transaction.payment_method.name}</span>
    </div>
  </div>

  <!-- Amount -->
  <div class="flex-shrink-0 text-right min-w-[120px]">
    <Currency
      amount={amount}
      currency={transaction.currency}
      showSign={true}
      variant={isExpense ? 'negative' : 'positive'}
      size="md"
      className="font-bold tracking-tight"
    />
  </div>

  <!-- Actions -->
  {
    showActions && (editUrl || deleteUrl) && (
      <div class="flex-shrink-0 flex gap-1">
        {editUrl && (
          <a href={editUrl} class="btn btn-ghost btn-sm" aria-label="Edit transaction">
            <Pencil size={16} class="stroke-current" aria-hidden="true" />
          </a>
        )}
        {deleteUrl && (
          <button
            type="button"
            class="btn btn-ghost btn-sm text-error"
            aria-label="Delete transaction"
            data-delete-transaction={transaction.id}
            data-transaction-details={JSON.stringify(transaction)}
          >
            <Trash2 size={16} class="stroke-current" aria-hidden="true" />
          </button>
        )}
      </div>
    )
  }
</div>
