---
/**
 * Transaction Card Component
 *
 * Unified transaction display component used across dashboard and transaction pages.
 * - Mobile: Stacked layout with dropdown menu for actions
 * - Desktop: Horizontal layout with inline edit/delete buttons
 *
 * @param {Object} transaction - Transaction data (optional when loading)
 * @param {boolean} showActions - Show edit/delete actions
 * @param {boolean} loading - Show skeleton loading state
 * @param {string} className - Additional CSS classes
 */

import Currency from '../atoms/Currency.astro';
import CategoryIcon from '../atoms/CategoryIcon.astro';
import { CreditCard, Ellipsis, History, Pencil, Trash2 } from '@lucide/astro';
import type { TransactionOutput } from '@/lib/types/transaction';

export interface Props {
  transaction?: TransactionOutput;
  showActions?: boolean;
  loading?: boolean;
  className?: string;
}

const { transaction, showActions = true, loading = false, className = '' } = Astro.props;

// Safely extract transaction data (only when not loading)
const amount = transaction ? parseFloat(transaction.amount) || 0 : 0;
const isExpense = transaction?.type === 'expense';
const isDeleted = !!transaction?.deleted_at;
const hasHistory = !!transaction?.has_history;
// Parse date as local date to avoid timezone shift (UTC midnight → previous day in UTC- zones)
const parseLocalDate = (dateStr: string | Date): Date => {
  if (dateStr instanceof Date) {
    return new Date(dateStr.getFullYear(), dateStr.getMonth(), dateStr.getDate());
  }
  const str = dateStr.split('T')[0];
  const [y, m, d] = str.split('-').map(Number);
  return new Date(y, m - 1, d);
};
const date = transaction ? parseLocalDate(transaction.transaction_date) : new Date();

// Format date with relative context
const formatDate = (d: Date): string => {
  const now = new Date();
  const startOfToday = new Date(now.getFullYear(), now.getMonth(), now.getDate());
  const startOfDate = new Date(d.getFullYear(), d.getMonth(), d.getDate());
  const diffDays = Math.round((startOfToday.getTime() - startOfDate.getTime()) / 86400000);

  if (diffDays === 0) return 'Today';
  if (diffDays === 1) return 'Yesterday';

  // Include year if different from current year
  if (d.getFullYear() !== now.getFullYear()) {
    return d.toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  return d.toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
  });
};

const formattedDate = formatDate(date);
const primaryText =
  transaction?.description?.trim() ||
  transaction?.category?.name ||
  (transaction?.type === 'transfer' ? 'Transfer' : '');
const createdByName = transaction?.created_by_user_name;

// Get category display properties from database, with fallbacks
const categoryIcon =
  transaction?.category?.icon ||
  (transaction?.type === 'transfer' ? 'arrow-left-right' : 'credit-card');
const categoryColor = transaction?.category?.color || 'bg-base-300';

// Extract color name for WCAG-compliant tinted pill background on mobile
// Uses color-mix() to create a light tint with dark text (always passes contrast)
const categoryColorName = categoryColor.replace('bg-', '');
const categoryPillStyle = `background-color: color-mix(in srgb, var(--color-${categoryColorName}) 18%, transparent)`;

// Prepare transaction data for edit action (reused in both layouts)
const transactionDataJson = transaction
  ? JSON.stringify({
      id: transaction.id,
      type: transaction.type,
      title: transaction.description,
      amount: transaction.amount,
      currency: transaction.currency,
      category_id: transaction.category?.id,
      asset_id: transaction.asset.id,
      transaction_date: `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, '0')}-${String(date.getDate()).padStart(2, '0')}`,
    })
  : '';

const transactionDetailsJson = transaction ? JSON.stringify(transaction) : '';

const cardClasses = [
  '@container group p-3 @xs:p-4 transition-all',
  'border-l-4 border-transparent',
  !loading && !isDeleted && isExpense && 'hover:border-error/30 active:border-error/30',
  !loading && !isDeleted && !isExpense && 'hover:border-success/30 active:border-success/30',
  !loading && !isDeleted && 'hover:bg-base-200/40 active:bg-base-200/40',
  isDeleted && 'opacity-50',
  className,
]
  .filter(Boolean)
  .join(' ');
---

{
  loading ? (
    <div
      class={`@container p-3 @xs:p-4 ${className}`}
      role="status"
      aria-label="Loading transaction"
      data-transaction-card-skeleton
    >
      <div class="flex items-center gap-2.5">
        <div class="flex-1 min-w-0">
          <div class="h-4 bg-base-200 rounded w-2/3" aria-hidden="true" />
        </div>
        <div class="h-4 bg-base-200 rounded w-20 shrink-0" aria-hidden="true" />
      </div>
      <div class="mt-1 flex items-center gap-1.5">
        <div class="h-3.5 bg-base-200 rounded w-20" aria-hidden="true" />
        <div class="h-3 bg-base-200 rounded w-32" aria-hidden="true" />
      </div>
    </div>
  ) : (
    <article
      class={cardClasses}
      data-transaction-card
      data-transaction-id={transaction?.id}
      aria-label={`${transaction?.type === 'income' ? 'Income' : 'Expense'}: ${primaryText}, ${amount} ${transaction?.currency}`}
    >
      {/* Mobile Layout (2-row compact) - shown below @lg container width */}
      <div class="@lg:hidden">
        {/* Row 1: Description + Amount (+ menu when actions) */}
        <div class="flex items-center gap-2.5">
          <div class="flex-1 min-w-0">
            <div
              class:list={[
                'font-bold text-sm tracking-tight leading-tight truncate',
                isDeleted && 'line-through',
              ]}
              data-expandable-text
              title={primaryText}
            >
              {primaryText}
            </div>
          </div>

          <Currency
            amount={amount}
            currency={transaction?.currency || 'IDR'}
            showSign={false}
            variant={isExpense ? 'negative' : 'positive'}
            size="sm"
            className={`font-bold tracking-tight shrink-0${isDeleted ? ' line-through' : ''}`}
          />

          {transaction && (
            <div class="dropdown dropdown-end shrink-0 -mr-1.5">
              <button
                type="button"
                tabindex={0}
                class="btn btn-ghost btn-xs btn-square min-h-[44px] min-w-[44px]"
                aria-label="Transaction actions"
                aria-haspopup="menu"
              >
                <Ellipsis size={16} class="stroke-current opacity-40" aria-hidden="true" />
              </button>
              <ul
                tabindex={0}
                class="dropdown-content z-50 menu p-2 shadow-lg bg-base-100 rounded-xl w-40 border border-base-300"
                role="menu"
              >
                <li role="none" class:list={[!hasHistory && 'disabled opacity-40']}>
                  <button
                    type="button"
                    role="menuitem"
                    class="flex items-center gap-2"
                    aria-label={
                      hasHistory ? `View history for: ${primaryText}` : 'No history available'
                    }
                    aria-disabled={!hasHistory}
                    {...(hasHistory ? { 'data-toggle-history': transaction.id } : {})}
                  >
                    <History size={16} class="stroke-current" aria-hidden="true" />
                    History
                  </button>
                </li>
                {showActions && !isDeleted && (
                  <>
                    <li role="none">
                      <button
                        type="button"
                        role="menuitem"
                        class="flex items-center gap-2"
                        aria-label={`Edit transaction: ${primaryText}`}
                        data-edit-transaction={transaction.id}
                        data-transaction-data={transactionDataJson}
                      >
                        <Pencil size={16} class="stroke-current" aria-hidden="true" />
                        Edit
                      </button>
                    </li>
                    <li role="none">
                      <button
                        type="button"
                        role="menuitem"
                        class="flex items-center gap-2 text-error"
                        aria-label={`Delete transaction: ${primaryText}`}
                        data-delete-transaction={transaction.id}
                        data-transaction-details={transactionDetailsJson}
                      >
                        <Trash2 size={16} class="stroke-current" aria-hidden="true" />
                        Delete
                      </button>
                    </li>
                  </>
                )}
              </ul>
            </div>
          )}
        </div>

        {/* Row 2: Date · Category · Asset · User */}
        <div class="mt-1 flex flex-wrap items-center gap-x-1.5 gap-y-1 text-xs text-base-content/40">
          <time
            datetime={date.toISOString()}
            class="whitespace-nowrap font-medium text-base-content/60"
          >
            {formattedDate}
          </time>
          <span aria-hidden="true">&middot;</span>
          {(transaction?.category?.name || transaction?.type === 'transfer') && (
            <span
              class="font-semibold text-base-content/80 px-1.5 py-0.5 rounded text-xs"
              style={categoryPillStyle}
            >
              {transaction?.category?.name || 'Transfer'}
            </span>
          )}
          {isDeleted && <span class="badge badge-ghost badge-sm text-xs">Deleted</span>}
          <span class="inline-flex items-center gap-1 min-w-0">
            <CreditCard size={10} class="stroke-current shrink-0" aria-hidden="true" />
            <span class="truncate">{transaction?.asset?.name}</span>
          </span>
          {createdByName && (
            <span class="inline-flex items-center gap-1 whitespace-nowrap min-w-0">
              <span aria-hidden="true">&middot;</span>
              <span class="truncate">{createdByName}</span>
            </span>
          )}
        </div>
      </div>

      {/* Desktop Layout (horizontal with inline buttons) - shown at @lg container width */}
      <div class="hidden @lg:flex items-center gap-3 @2xl:gap-4">
        {/* Date & User */}
        <div class="flex-shrink-0 w-20 @2xl:w-24 text-sm">
          <div class="font-medium">{formattedDate}</div>
          {createdByName && (
            <div class="text-xs text-base-content/40 truncate mt-0.5">{createdByName}</div>
          )}
        </div>

        {/* Category & Description */}
        <div class="flex-1 min-w-0 flex items-center gap-3">
          <CategoryIcon
            icon={categoryIcon}
            color={categoryColor}
            size="sm"
            className="transition-transform group-hover:rotate-2"
          />
          <div class="min-w-0">
            <div
              class:list={[
                'font-bold tracking-tight truncate text-sm leading-none',
                isDeleted && 'line-through',
              ]}
              data-expandable-text
              title={primaryText}
            >
              {primaryText}
            </div>
            <div class="mt-1.5 flex flex-wrap items-center gap-1.5 leading-none">
              {(transaction?.category?.name || transaction?.type === 'transfer') && (
                <span
                  class="text-xs font-semibold text-base-content/80 px-1.5 py-0.5 rounded"
                  style={categoryPillStyle}
                >
                  {transaction?.category?.name || 'Transfer'}
                </span>
              )}
              {isDeleted && <span class="badge badge-ghost badge-sm text-xs">Deleted</span>}
            </div>
          </div>
        </div>

        {/* Asset */}
        <div class="flex-shrink-0">
          <div class="flex items-center gap-1.5 text-[11px] uppercase tracking-widest text-base-content/40">
            <CreditCard size={11} class="stroke-current" aria-hidden="true" />
            <span>{transaction?.asset?.name}</span>
          </div>
        </div>

        {/* Amount */}
        <div class="flex-shrink-0 text-right min-w-[100px]">
          <Currency
            amount={amount}
            currency={transaction?.currency || 'IDR'}
            showSign={false}
            variant={isExpense ? 'negative' : 'positive'}
            size="md"
            className={`font-bold tracking-tight${isDeleted ? ' line-through' : ''}`}
          />
        </div>

        {/* Actions (fixed-width column for alignment) */}
        <div class:list={['flex-shrink-0 flex justify-end gap-0.5', showActions ? 'w-24' : 'w-8']}>
          {transaction && (
            <div class="tooltip tooltip-bottom" data-tip={hasHistory ? 'History' : 'No history'}>
              <button
                type="button"
                class:list={[
                  'btn btn-ghost btn-sm btn-square',
                  !hasHistory && 'btn-disabled opacity-30',
                ]}
                aria-label={
                  hasHistory ? `View history for: ${primaryText}` : 'No history available'
                }
                aria-disabled={!hasHistory}
                {...(hasHistory ? { 'data-toggle-history': transaction.id } : {})}
              >
                <History size={16} class="stroke-current" aria-hidden="true" />
              </button>
            </div>
          )}
          {transaction && showActions && !isDeleted && (
            <>
              <div class="tooltip tooltip-bottom" data-tip="Edit">
                <button
                  type="button"
                  class="btn btn-ghost btn-sm btn-square"
                  aria-label={`Edit transaction: ${primaryText}`}
                  data-edit-transaction={transaction.id}
                  data-transaction-data={transactionDataJson}
                >
                  <Pencil size={16} class="stroke-current" aria-hidden="true" />
                </button>
              </div>
              <div class="tooltip tooltip-bottom" data-tip="Delete">
                <button
                  type="button"
                  class="btn btn-ghost btn-sm btn-square text-error"
                  aria-label={`Delete transaction: ${primaryText}`}
                  data-delete-transaction={transaction.id}
                  data-transaction-details={transactionDetailsJson}
                >
                  <Trash2 size={16} class="stroke-current" aria-hidden="true" />
                </button>
              </div>
            </>
          )}
        </div>
      </div>

      {/* Expandable history container */}
      {transaction && hasHistory && (
        <div
          class="hidden"
          data-history-container={transaction.id}
          aria-label={`Transaction history for: ${primaryText}`}
        />
      )}
    </article>
  )
}

<script>
  import { initTransactionHistory } from './TransactionHistory.client';
  import {
    initExpandableText,
    markTruncated,
    observeExpandableContainers,
  } from './ExpandableText.client';

  initTransactionHistory();
  initExpandableText();
  markTruncated();
  observeExpandableContainers();

  // Keyboard navigation for dropdown menus (mobile)
  document.querySelectorAll('[data-transaction-card] .dropdown').forEach((dropdown) => {
    const menu = dropdown.querySelector('[role="menu"]');
    if (!menu) return;

    const items = menu.querySelectorAll('[role="menuitem"]');

    menu.addEventListener('keydown', (e: Event) => {
      const event = e as KeyboardEvent;
      const currentIndex = Array.from(items).indexOf(document.activeElement as Element);

      if (event.key === 'ArrowDown') {
        event.preventDefault();
        const nextIndex = currentIndex < items.length - 1 ? currentIndex + 1 : 0;
        (items[nextIndex] as HTMLElement).focus();
      } else if (event.key === 'ArrowUp') {
        event.preventDefault();
        const prevIndex = currentIndex > 0 ? currentIndex - 1 : items.length - 1;
        (items[prevIndex] as HTMLElement).focus();
      } else if (event.key === 'Escape') {
        event.preventDefault();
        const trigger = dropdown.querySelector('button[aria-haspopup]') as HTMLElement;
        trigger?.focus();
        (document.activeElement as HTMLElement)?.blur();
      }
    });
  });
</script>
