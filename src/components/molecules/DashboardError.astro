---
/**
 * Dashboard Error Component (Organism)
 *
 * User-friendly error state for the dashboard with retry functionality.
 * Shows a clear error message and provides a retry button.
 *
 * @param {string} message - Error message to display
 * @param {string} details - Additional error details (optional)
 * @param {boolean} showRetry - Show retry button (default: true)
 * @param {string} supportUrl - URL to support page (optional)
 * @param {string} className - Additional CSS classes
 */

import Card from '../atoms/Card.astro';
import Button from '../atoms/Button.astro';
import { TriangleAlert, RefreshCw, Info } from '@lucide/astro';

export interface Props {
  message?: string;
  details?: string;
  showRetry?: boolean;
  supportUrl?: string;
  className?: string;
}

const {
  message = 'Unable to load dashboard data',
  details,
  showRetry = true,
  supportUrl,
  className = '',
} = Astro.props;
---

<Card className={className} data-dashboard-error aria-live="assertive">
  <div class="card-body">
    <div class="flex flex-col items-center text-center py-8">
      <!-- Error Icon -->
      <div class="mb-4">
        <TriangleAlert size={32} class="text-error" aria-hidden="true" />
      </div>

      <!-- Error Message -->
      <h3 class="text-xl font-bold text-error mb-2">Could not load your data</h3>
      <p class="text-base-content/60 mb-4 max-w-md">{message}</p>

      {
        details && (
          <div class="mb-4">
            <details class="text-left">
              <summary class="cursor-pointer text-sm text-base-content/60 hover:text-base-content">
                Technical details
              </summary>
              <pre class="mt-2 p-3 bg-base-200 rounded text-xs overflow-auto max-w-md">
                <code>{details}</code>
              </pre>
            </details>
          </div>
        )
      }

      <!-- Actions -->
      <div class="flex gap-3 flex-wrap justify-center">
        {
          showRetry && (
            <button
              type="button"
              data-action="reload-page"
              class="btn btn-accent rounded-lg sm:rounded-xl flex items-center gap-2"
            >
              <RefreshCw size={16} class="stroke-current" aria-hidden="true" />
              Try Again
            </button>
          )
        }

        {
          supportUrl && (
            <Button variant="outline" href={supportUrl} className="flex items-center gap-2">
              <Info size={16} class="stroke-current" aria-hidden="true" />
              Get Help
            </Button>
          )
        }
      </div>

      <!-- Suggestion -->
      <p class="text-sm text-base-content/60 mt-4">
        Check your connection and try again. Contact support if the problem continues.
      </p>
    </div>
  </div>
</Card>

<script>
  function initDashboardError() {
    document.querySelectorAll('[data-dashboard-error]').forEach((container) => {
      const reloadBtn = container.querySelector('[data-action="reload-page"]');
      reloadBtn?.addEventListener('click', () => {
        window.location.reload();
      });
    });
  }

  // Initialize on DOM ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initDashboardError);
  } else {
    initDashboardError();
  }

  // Re-initialize on Astro page transitions
  document.addEventListener('astro:page-load', initDashboardError);
</script>
