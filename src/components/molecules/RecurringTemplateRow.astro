---
import { CircleMinus, CirclePlus, EllipsisVertical, Pause, Play, Ban, Pencil } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import ProgressBar from '@/components/atoms/ProgressBar.astro';
import type { RecurringTemplateOutput } from '@/lib/types/recurring';

export interface Props {
  template: RecurringTemplateOutput;
}

const { template } = Astro.props;

const templatePayload = JSON.stringify(template);

const statusClassMap: Record<RecurringTemplateOutput['status'], string> = {
  active: 'badge-success',
  paused: 'badge-warning',
  completed: 'badge-ghost',
  cancelled: 'badge-error',
};

const statusClass = statusClassMap[template.status];

function daySuffix(day: number): string {
  const mod10 = day % 10;
  const mod100 = day % 100;
  if (mod10 === 1 && mod100 !== 11) return `${day}st`;
  if (mod10 === 2 && mod100 !== 12) return `${day}nd`;
  if (mod10 === 3 && mod100 !== 13) return `${day}rd`;
  return `${day}th`;
}

const installmentProgress =
  template.is_installment && template.total_occurrences
    ? Math.min(100, Math.round((template.confirmedCount / template.total_occurrences) * 100))
    : 0;
---

<tr
  class:list={[
    'border-b border-base-300 last:border-b-0 hover:bg-base-200/50 transition-colors duration-150',
    template.status === 'paused' && 'opacity-60',
  ]}
  data-testid="recurring-template-row"
>
  <td class="py-3.5 px-4">
    <div class="flex items-center gap-2.5 min-w-0">
      {
        template.type === 'expense' ? (
          <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-error/10 shrink-0">
            <CircleMinus size={14} class="text-error" aria-hidden="true" />
          </div>
        ) : (
          <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-success/10 shrink-0">
            <CirclePlus size={14} class="text-success" aria-hidden="true" />
          </div>
        )
      }
      <div class="min-w-0">
        <span class="font-semibold truncate block" title={template.name}>{template.name}</span>
        {
          template.is_installment && template.total_occurrences && (
            <div class="mt-1.5 flex items-center gap-2">
              <ProgressBar value={installmentProgress} size="sm" className="w-16" />
              <span class="text-xs text-base-content/50 font-medium">
                {template.confirmedCount}/{template.total_occurrences}
              </span>
            </div>
          )
        }
      </div>
    </div>
  </td>
  <td class="py-3.5 px-4 text-sm font-bold">{formatCurrency(template.amount, template.currency)}</td
  >
  <td class="py-3.5 px-4 text-sm text-base-content/60 font-medium"
    >{daySuffix(template.day_of_month)}</td
  >
  <td class="py-3.5 px-4 text-sm text-base-content/60 font-medium">{template.nextDueDate ?? '—'}</td
  >
  <td class="py-3.5 px-4">
    <span class={`badge badge-sm font-bold ${statusClass}`}>{template.status}</span>
  </td>
  <td class="py-3.5 px-4 text-right">
    <div class="dropdown dropdown-end">
      <button
        type="button"
        tabindex={0}
        class="btn btn-ghost btn-sm btn-square rounded-xl"
        aria-label="Template actions"
      >
        <EllipsisVertical size={16} aria-hidden="true" />
      </button>
      <ul
        tabindex={0}
        class="dropdown-content z-40 menu p-2 shadow-lg bg-base-100 rounded-2xl w-44 border border-base-300"
      >
        <li>
          <button
            type="button"
            class="rounded-xl"
            data-template-action="edit"
            data-template={templatePayload}
          >
            <Pencil size={15} aria-hidden="true" />
            Edit
          </button>
        </li>
        {
          template.status === 'active' ? (
            <li>
              <button
                type="button"
                class="rounded-xl"
                data-template-action="pause"
                data-template-id={template.id}
              >
                <Pause size={15} aria-hidden="true" />
                Pause
              </button>
            </li>
          ) : template.status === 'paused' ? (
            <li>
              <button
                type="button"
                class="rounded-xl"
                data-template-action="resume"
                data-template-id={template.id}
              >
                <Play size={15} aria-hidden="true" />
                Resume
              </button>
            </li>
          ) : null
        }
        {
          template.status !== 'cancelled' && template.status !== 'completed' && (
            <li>
              <button
                type="button"
                data-template-action="cancel"
                data-template-id={template.id}
                data-template-name={template.name}
                class="text-error rounded-xl"
              >
                <Ban size={15} aria-hidden="true" />
                Cancel
              </button>
            </li>
          )
        }
      </ul>
    </div>
  </td>
</tr>
