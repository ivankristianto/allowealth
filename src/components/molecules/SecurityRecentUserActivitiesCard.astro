---
import { History } from '@lucide/astro';
import { toneDotClasses, type SecurityEvent } from '@/services/audit-log.service';

export interface Props {
  events: SecurityEvent[];
}

const { events } = Astro.props;
---

<section class="card bg-base-200/60 border border-base-300 shadow">
  <div class="card-body p-6 space-y-5">
    <div class="flex items-center gap-2 text-base-content/70">
      <History size={18} class="stroke-current" aria-hidden="true" />
      <h3 class="text-sm font-semibold">Recent User Activities</h3>
    </div>

    <div class="space-y-4">
      {
        events.length === 0 ? (
          <p class="text-sm text-base-content/50 text-center py-2">
            No recent security activity found.
          </p>
        ) : (
          events.map((event) => (
            <div class="flex items-center justify-between gap-4 text-sm">
              <div class="flex items-center gap-3">
                <span class={`w-2 h-2 rounded-full ${toneDotClasses[event.tone]}`} />
                <span class="text-base-content/70">{event.label}</span>
              </div>
              <span class="text-xs text-base-content/50 uppercase tracking-wide">
                {event.timestamp}
              </span>
            </div>
          ))
        )
      }
    </div>

    <a
      href="/api/security/audit-logs"
      class="btn btn-outline btn-sm rounded-lg w-full text-xs uppercase tracking-widest"
    >
      Download Security Audit
    </a>
  </div>
</section>
