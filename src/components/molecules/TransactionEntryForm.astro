---
/**
 * Transaction Entry Form Component — Quick Capture Layout
 *
 * Optimized for speed: amount hero input, category chips, date quick-picks.
 * Used within TransactionDrawer for expense and income entries.
 *
 * @param {string} type - Transaction type: 'expense' | 'income'
 * @param {'create' | 'edit'} mode - Form mode
 * @param {string} transactionId - Transaction ID for edit mode
 * @param {string} action - Form action URL (API endpoint)
 * @param {Object} values - Default form values
 * @param {Array} categories - Available categories
 * @param {Array} assets - Available assets (bank accounts, wallets)
 * @param {Array} categoryUsageCounts - Category usage frequency for chip sorting
 * @param {Object} errors - Form errors {field: message}
 * @param {string} modalId - Parent modal ID for closing on success
 */

import Button from '../atoms/Button.astro';
import AmountInput from '../atoms/AmountInput.astro';
import { CalendarDays } from '@lucide/astro';
import { CURRENCY_META, DEFAULT_CURRENCY } from '@/lib/constants/currency';

export interface Props {
  type: 'expense' | 'income';
  mode?: 'create' | 'edit';
  transactionId?: string;
  action: string;
  values?: {
    title?: string;
    amount?: string;
    currency?: 'IDR' | 'USD';
    category_id?: string;
    asset_id?: string;
    transaction_date?: string;
  };
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  assets: Array<{ id: string; name: string; type: string; account_class: string }>;
  categoryUsageCounts?: Array<{ category_id: string; count: number }>;
  errors?: Record<string, string>;
  modalId?: string;
  bulk?: boolean;
  formId?: string;
}

const {
  type,
  mode = 'create',
  transactionId = '',
  action,
  values = {},
  categories = [],
  assets = [],
  categoryUsageCounts = [],
  errors = {},
  modalId = '',
  bulk = false,
  formId: propFormId,
} = Astro.props;

const isEditMode = mode === 'edit';

// Filter assets based on transaction type:
// - Expense: liquid + credit_card (you can spend from these)
// - Income: liquid only (income goes to liquid accounts)
const filteredAssets =
  type === 'income'
    ? assets.filter((a) => a.account_class === 'liquid')
    : assets.filter((a) => a.account_class === 'liquid' || a.type === 'credit_card');

const today = new Date().toISOString().split('T')[0];
const yesterdayDate = new Date();
yesterdayDate.setDate(yesterdayDate.getDate() - 1);
const yesterday = yesterdayDate.toISOString().split('T')[0];

// Filter categories by type
const typeCategories = categories.filter((c) => c.type === type);

// Sort categories by usage frequency, then alphabetically
const usageMap = new Map(categoryUsageCounts.map((u) => [u.category_id, u.count]));
const sortedCategories = [...typeCategories].sort((a, b) => {
  const countA = usageMap.get(a.id) || 0;
  const countB = usageMap.get(b.id) || 0;
  if (countB !== countA) return countB - countA;
  return a.name.localeCompare(b.name);
});

// Split categories: show top N initially, rest behind expand toggle
const INITIAL_CHIP_COUNT = 8;
const visibleCategories = sortedCategories.slice(0, INITIAL_CHIP_COUNT);
const hiddenCategories = sortedCategories.slice(INITIAL_CHIP_COUNT);
const hasHiddenCategories = hiddenCategories.length > 0;
// If the selected category is in the hidden set, start expanded
const selectedInHidden =
  hasHiddenCategories && hiddenCategories.some((c) => c.id === values.category_id);

// Serialize data for client-side JavaScript
const categoriesJson = JSON.stringify(
  typeCategories.map((c) => ({
    id: c.id,
    name: c.name,
    type: c.type,
    currency: c.currency || DEFAULT_CURRENCY,
  }))
);
const assetsJson = JSON.stringify(
  filteredAssets.map((a) => ({ id: a.id, name: a.name, type: a.type }))
);

// Default currency
const defaultCurrency = values.currency || DEFAULT_CURRENCY;
const currencyMeta = CURRENCY_META[defaultCurrency];

// Generate unique form ID
const formId = propFormId || `transaction-entry-form-${type}`;

// Determine default date state
const defaultDate = values.transaction_date || today;
const defaultDatePick =
  defaultDate === today ? 'today' : defaultDate === yesterday ? 'yesterday' : 'custom';
---

<form
  id={formId}
  data-transaction-form
  data-testid="transaction-form"
  data-type={type}
  data-mode={mode}
  data-transaction-id={transactionId}
  data-action={action}
  data-modal-id={modalId}
  data-categories-json={categoriesJson}
  data-assets-json={assetsJson}
  data-bulk={bulk ? 'true' : 'false'}
  data-today={today}
  data-yesterday={yesterday}
  class="flex flex-col gap-3"
  novalidate
>
  <!-- Hidden fields -->
  <input type="hidden" name="type" value={type} />
  <input type="hidden" name="currency" value={defaultCurrency} />

  <!-- Global error message container -->
  <div id={`${formId}-error`} class="hidden alert alert-error text-sm" role="alert"></div>

  <!-- Amount Input (hero) -->
  <div class="form-control">
    <div class="relative">
      <AmountInput
        id={`${formId}-amount`}
        name="amount"
        value={values.amount || ''}
        currency={defaultCurrency}
        required
        placeholder="0"
        className={[
          'input input-bordered w-full',
          'h-16 rounded-lg border border-base-300 bg-base-100',
          'text-3xl font-bold text-center tracking-tight',
          'placeholder:text-base-content/20',
          'focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30',
          errors.amount && 'input-error',
        ]
          .filter(Boolean)
          .join(' ')}
        ariaLabel="Amount"
        ariaInvalid={!!errors.amount}
        ariaRequired={true}
        data-testid="transaction-amount-input"
      />
      <!-- Currency badge -->
      <button
        type="button"
        class="absolute top-1/2 -translate-y-1/2 right-3 text-xs font-bold text-neutral/50 cursor-pointer hover:text-neutral transition-colors"
        data-currency-badge
        aria-label={`Currency: ${defaultCurrency}. Tap to change`}
      >
        {currencyMeta.symbol}
        {defaultCurrency}
      </button>
    </div>
    {
      errors.amount && (
        <span class="text-error text-sm mt-1" role="alert">
          {errors.amount}
        </span>
      )
    }
  </div>

  <!-- Title Input -->
  <div class="form-control">
    <input
      type="text"
      id={`${formId}-title`}
      name="title"
      value={values.title || ''}
      required
      placeholder="What was this for?"
      class:list={[
        'input input-bordered w-full',
        'h-11 rounded-lg border border-base-300 bg-base-100',
        'text-sm font-medium px-3',
        'placeholder:text-base-content/30',
        'focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30',
        errors.title && 'input-error',
      ]}
      aria-label="Title"
      aria-invalid={!!errors.title}
      aria-required="true"
      data-testid="transaction-description-input"
    />
    {
      errors.title && (
        <span class="text-error text-sm mt-1" role="alert">
          {errors.title}
        </span>
      )
    }
  </div>

  <!-- Category Chips -->
  <div class="form-control">
    <span class="text-xs font-semibold text-neutral/50 uppercase tracking-wider mb-1.5"
      >Category</span
    >
    <div
      class="flex flex-wrap gap-1.5"
      role="radiogroup"
      aria-label="Category selection"
      data-category-chips
    >
      {
        visibleCategories.map((cat) => (
          <button
            type="button"
            class:list={[
              'px-3 py-1.5 rounded-full cursor-pointer transition-all',
              'text-xs font-semibold',
              'focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-1',
              values.category_id === cat.id
                ? 'bg-accent text-white'
                : 'bg-base-200 text-base-content/70 hover:bg-accent/10 hover:text-accent',
            ]}
            data-category-chip={cat.id}
            role="radio"
            aria-checked={values.category_id === cat.id ? 'true' : 'false'}
            aria-label={cat.name}
          >
            {cat.name}
          </button>
        ))
      }
      {
        hasHiddenCategories && (
          <>
            {hiddenCategories.map((cat) => (
              <button
                type="button"
                class:list={[
                  'px-3 py-1.5 rounded-full cursor-pointer transition-all',
                  'text-xs font-semibold',
                  'focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-1',
                  values.category_id === cat.id
                    ? 'bg-accent text-white'
                    : 'bg-base-200 text-base-content/70 hover:bg-accent/10 hover:text-accent',
                  selectedInHidden ? '' : 'hidden',
                ]}
                data-category-chip={cat.id}
                data-category-overflow
                role="radio"
                aria-checked={values.category_id === cat.id ? 'true' : 'false'}
                aria-label={cat.name}
              >
                {cat.name}
              </button>
            ))}
            <button
              type="button"
              class:list={[
                'px-3 py-1.5 rounded-full cursor-pointer transition-all',
                'text-xs font-semibold',
                'bg-base-300/60 text-base-content/50 hover:bg-base-300 hover:text-base-content/70',
                'focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-1',
              ]}
              data-category-toggle
              aria-expanded={selectedInHidden ? 'true' : 'false'}
              aria-label={
                selectedInHidden
                  ? `Show less categories`
                  : `Show ${hiddenCategories.length} more categories`
              }
            >
              {selectedInHidden ? 'Less' : `+${hiddenCategories.length} more`}
            </button>
          </>
        )
      }
    </div>
    <!-- Hidden select for form submission -->
    <select
      name="category_id"
      id={`${formId}-category`}
      class="hidden"
      aria-hidden="true"
      required
      data-testid="transaction-category-select"
    >
      <option value="">Select category...</option>
      {
        sortedCategories.map((cat) => (
          <option value={cat.id} selected={cat.id === (values.category_id || '')}>
            {cat.name}
          </option>
        ))
      }
    </select>
    {
      errors.category_id && (
        <span class="text-error text-sm mt-1" role="alert">
          {errors.category_id}
        </span>
      )
    }
  </div>

  <!-- Date Quick-Picks -->
  <div class="form-control">
    <span class="text-xs font-semibold text-neutral/50 uppercase tracking-wider mb-1.5">Date</span>
    <div class="grid grid-cols-3 gap-1" data-date-picks>
      <button
        type="button"
        class:list={[
          'btn btn-sm rounded-lg text-xs font-semibold',
          defaultDatePick === 'today' ? 'btn-accent text-accent-content' : 'btn-ghost',
        ]}
        data-date-pick="today"
        aria-pressed={defaultDatePick === 'today' ? 'true' : 'false'}
      >
        Today
      </button>
      <button
        type="button"
        class:list={[
          'btn btn-sm rounded-lg text-xs font-semibold',
          defaultDatePick === 'yesterday' ? 'btn-accent text-accent-content' : 'btn-ghost',
        ]}
        data-date-pick="yesterday"
        aria-pressed={defaultDatePick === 'yesterday' ? 'true' : 'false'}
      >
        Yesterday
      </button>
      <label
        class:list={[
          'btn btn-sm rounded-lg relative overflow-hidden text-xs font-semibold gap-1',
          defaultDatePick === 'custom' ? 'btn-accent text-accent-content' : 'btn-ghost',
        ]}
        data-date-pick="custom"
        aria-pressed={defaultDatePick === 'custom' ? 'true' : 'false'}
      >
        <CalendarDays size={14} class="pointer-events-none stroke-current" aria-hidden="true" />
        <span class="pointer-events-none" data-date-label>
          {
            defaultDatePick === 'custom'
              ? new Date(defaultDate + 'T00:00:00').toLocaleDateString('en-GB', {
                  day: '2-digit',
                  month: 'short',
                })
              : 'Other'
          }
        </span>
        <input
          type="date"
          id={`${formId}-date`}
          class="absolute inset-0 opacity-0 cursor-pointer"
          value={defaultDate}
          max={today}
          data-date-custom
          aria-label="Pick a date"
          data-testid="transaction-date-input"
        />
      </label>
    </div>
    <!-- Hidden date input for form submission -->
    <input type="hidden" name="transaction_date" value={defaultDate} />
    {
      errors.transaction_date && (
        <span class="text-error text-sm mt-1" role="alert">
          {errors.transaction_date}
        </span>
      )
    }
  </div>

  <!-- Account Select -->
  {
    filteredAssets.length > 1 ? (
      <div class="form-control">
        <span class="text-xs font-semibold text-neutral/50 uppercase tracking-wider mb-1.5">
          Account
        </span>
        <select
          id={`${formId}-asset`}
          name="asset_id"
          required
          class:list={[
            'select select-bordered w-full',
            'h-10 rounded-lg border border-base-300 bg-base-100',
            'text-sm font-medium',
            'focus:outline-none focus:border-accent focus-visible:ring-2 focus-visible:ring-accent/30',
            errors.asset_id && 'select-error border-error',
          ]}
          aria-label="Account"
          aria-invalid={!!errors.asset_id}
          aria-required="true"
          data-testid="transaction-asset-select"
        >
          <option value="">Select account...</option>
          {filteredAssets.map((asset) => (
            <option value={asset.id} selected={asset.id === (values.asset_id || '')}>
              {asset.name}
            </option>
          ))}
        </select>
        {errors.asset_id && (
          <span class="text-error text-sm mt-1" role="alert">
            {errors.asset_id}
          </span>
        )}
      </div>
    ) : (
      <input type="hidden" name="asset_id" value={filteredAssets[0]?.id || ''} />
    )
  }

  <!-- Save Button -->
  <Button
    type="submit"
    variant="accent"
    className="w-full h-12 rounded-2xl font-bold text-sm mt-1"
    data-testid="transaction-submit-btn"
  >
    {isEditMode ? 'Save Changes' : 'Save Entry'}
  </Button>
</form>

<script>
  import { addToast } from '@/lib/stores/toastStore';
  import { getCsrfHeaders } from '@/lib/csrf-client';
  import { CURRENCY_META, AVAILABLE_CURRENCIES, DEFAULT_CURRENCY } from '@/lib/constants/currency';
  import type { Currency } from '@/lib/constants/currency';
  import { attachAmountFormatter, stripAmountFormatting } from '@/lib/formatting/amount-input';
  import type { AmountFormatterHandle } from '@/lib/formatting/amount-input';

  function initTransactionEntryForms() {
    document.querySelectorAll<HTMLFormElement>('[data-transaction-form]').forEach(initForm);
  }

  function initForm(form: HTMLFormElement) {
    if (form.dataset.initialized === 'true') return;
    form.dataset.initialized = 'true';

    const formId = form.id;
    const formError = document.getElementById(`${formId}-error`);
    const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement | null;
    const action = form.dataset.action || '/api/transactions';
    const modalId = form.dataset.modalId || '';
    const todayStr = form.dataset.today || new Date().toISOString().split('T')[0];
    const yesterdayStr = form.dataset.yesterday || '';

    const categories = JSON.parse(form.dataset.categoriesJson || '[]');

    // === Category chip handlers ===
    const categoryChips = form.querySelectorAll<HTMLButtonElement>('[data-category-chip]');
    const categorySelect = form.querySelector(
      'select[name="category_id"]'
    ) as HTMLSelectElement | null;
    function setActiveChip(categoryId: string) {
      categoryChips.forEach((chip) => {
        const isActive = chip.dataset.categoryChip === categoryId;
        chip.classList.toggle('bg-accent', isActive);
        chip.classList.toggle('text-white', isActive);
        chip.classList.toggle('bg-base-200', !isActive);
        chip.classList.toggle('text-base-content/70', !isActive);
        chip.classList.toggle('hover:bg-accent/10', !isActive);
        chip.classList.toggle('hover:text-accent', !isActive);
        chip.setAttribute('aria-checked', isActive ? 'true' : 'false');
      });
      if (categorySelect) {
        categorySelect.value = categoryId;
        categorySelect.dispatchEvent(new Event('change', { bubbles: true }));
      }
      validateField('category_id', categoryId);
      updateCurrencyForCategory();
      ensureCategoryVisible(categoryId);
    }

    categoryChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const catId = chip.dataset.categoryChip || '';
        setActiveChip(catId);
      });
    });

    // === Category expand/collapse toggle ===
    const overflowChips = form.querySelectorAll<HTMLButtonElement>('[data-category-overflow]');
    const toggleBtn = form.querySelector('[data-category-toggle]') as HTMLButtonElement | null;

    if (toggleBtn && overflowChips.length > 0) {
      toggleBtn.addEventListener('click', () => {
        const isExpanded = toggleBtn.getAttribute('aria-expanded') === 'true';
        if (isExpanded) {
          // Collapsing: hide overflow chips except the active one
          overflowChips.forEach((chip) => {
            const isActive = chip.getAttribute('aria-checked') === 'true';
            chip.classList.toggle('hidden', !isActive);
          });
        } else {
          // Expanding: show all overflow chips
          overflowChips.forEach((chip) => chip.classList.remove('hidden'));
        }
        toggleBtn.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
        const label = isExpanded ? `+${overflowChips.length} more` : 'Less';
        toggleBtn.textContent = label;
        toggleBtn.setAttribute(
          'aria-label',
          isExpanded ? `Show ${overflowChips.length} more categories` : 'Show less categories'
        );
      });
    }

    // Auto-expand if selecting a hidden category (e.g., in edit mode)
    function ensureCategoryVisible(categoryId: string) {
      if (!toggleBtn || overflowChips.length === 0) return;
      const isOverflow = Array.from(overflowChips).some(
        (c) => c.dataset.categoryChip === categoryId
      );
      if (isOverflow && toggleBtn.getAttribute('aria-expanded') !== 'true') {
        overflowChips.forEach((chip) => chip.classList.remove('hidden'));
        toggleBtn.setAttribute('aria-expanded', 'true');
        toggleBtn.textContent = 'Less';
        toggleBtn.setAttribute('aria-label', 'Show less categories');
      }
    }

    // === Date quick-pick handlers ===
    const datePickBtns = form.querySelectorAll<HTMLElement>('[data-date-pick]');
    const dateCustomInput = form.querySelector('[data-date-custom]') as HTMLInputElement | null;
    const dateLabel = form.querySelector('[data-date-label]') as HTMLElement | null;
    const hiddenDateInput = form.querySelector(
      'input[name="transaction_date"]'
    ) as HTMLInputElement | null;

    function formatDateLabel(dateStr: string): string {
      const d = new Date(dateStr + 'T00:00:00');
      return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' });
    }

    function setDateValue(dateStr: string, activePick: string) {
      if (hiddenDateInput) hiddenDateInput.value = dateStr;
      if (dateCustomInput) dateCustomInput.value = dateStr;

      // Update the label to show the selected custom date
      if (dateLabel) {
        dateLabel.textContent = activePick === 'custom' ? formatDateLabel(dateStr) : 'Other';
      }

      datePickBtns.forEach((btn) => {
        const pick = btn.dataset.datePick || '';
        const isActive = pick === activePick;
        btn.classList.toggle('btn-accent', isActive);
        btn.classList.toggle('text-accent-content', isActive);
        btn.classList.toggle('btn-ghost', !isActive);
        btn.setAttribute('aria-pressed', isActive ? 'true' : 'false');
      });

      validateField('transaction_date', dateStr);
    }

    datePickBtns.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        const pick = btn.dataset.datePick || '';
        if (pick === 'today') {
          e.preventDefault();
          setDateValue(todayStr, 'today');
        } else if (pick === 'yesterday') {
          e.preventDefault();
          setDateValue(yesterdayStr, 'yesterday');
        } else if (pick === 'custom' && dateCustomInput) {
          e.preventDefault();
          try {
            dateCustomInput.showPicker();
          } catch {
            dateCustomInput.focus();
            dateCustomInput.click();
          }
        }
      });
    });

    if (dateCustomInput) {
      dateCustomInput.addEventListener('change', () => {
        const val = dateCustomInput.value;
        if (val) {
          const activePick =
            val === todayStr ? 'today' : val === yesterdayStr ? 'yesterday' : 'custom';
          setDateValue(val, activePick);
        }
      });
    }

    // === Currency badge toggle ===
    const currencyBadge = form.querySelector('[data-currency-badge]') as HTMLButtonElement | null;
    const currencyInput = form.querySelector('input[name="currency"]') as HTMLInputElement | null;

    if (currencyBadge && currencyInput) {
      currencyBadge.addEventListener('click', () => {
        const currentIdx = AVAILABLE_CURRENCIES.indexOf(currencyInput.value as Currency);
        const nextIdx = (currentIdx + 1) % AVAILABLE_CURRENCIES.length;
        const nextCurrency = AVAILABLE_CURRENCIES[nextIdx] as Currency;
        currencyInput.value = nextCurrency;
        const meta = CURRENCY_META[nextCurrency];
        currencyBadge.textContent = `${meta.symbol} ${nextCurrency}`;
        currencyBadge.setAttribute('aria-label', `Currency: ${nextCurrency}. Tap to change`);
      });
    }

    // === Validation ===
    const validators: Record<string, { validate: (value: string) => string | null }> = {
      title: {
        validate: (value) => {
          if (!value || value.trim() === '') return 'Title is required';
          if (value.length > 200) return 'Title must not exceed 200 characters';
          return null;
        },
      },
      amount: {
        validate: (value) => {
          if (!value || value.trim() === '') return 'Amount is required';
          const currentCurrency = (currencyInput?.value || DEFAULT_CURRENCY) as Currency;
          const cleanValue = stripAmountFormatting(value, currentCurrency);
          const num = Number(cleanValue);
          if (isNaN(num)) return 'Amount must be a valid number';
          if (num <= 0) return 'Amount must be greater than 0';
          return null;
        },
      },
      transaction_date: {
        validate: (value) => {
          if (!value || value.trim() === '') return 'Date is required';
          if (!/^\d{4}-\d{2}-\d{2}$/.test(value)) return 'Date must be in YYYY-MM-DD format';
          const date = new Date(value);
          if (isNaN(date.getTime())) return 'Invalid date';
          const todayUTC = Date.now();
          const inputDateUTC = new Date(value).getTime();
          if (inputDateUTC > todayUTC) return 'Date cannot be in the future';
          return null;
        },
      },
      category_id: {
        validate: (value) => {
          if (!value || value.trim() === '') return 'Category is required';
          return null;
        },
      },
      asset_id: {
        validate: (value) => {
          if (!value || value.trim() === '') return 'Account is required';
          return null;
        },
      },
    };

    const fieldErrors: Record<string, string | null> = {};
    let isResetting = false;

    function updateFieldErrorUI(fieldName: string, errorMessage: string | null) {
      // For chip-based fields, look for the form-control container differently
      let fieldContainer: Element | null = null;

      if (fieldName === 'category_id') {
        fieldContainer =
          form.querySelector('[data-category-chips]')?.closest('.form-control') || null;
      } else {
        const field = form.querySelector(`[name="${fieldName}"]`) as HTMLElement | null;
        if (!field) return;
        fieldContainer = field.closest('.form-control');
      }

      if (!fieldContainer) return;

      const existingError = fieldContainer.querySelector('.field-error');
      if (existingError) existingError.remove();

      const errorDivId = `${formId}-${fieldName}-error`;

      if (errorMessage) {
        const field = form.querySelector(`[name="${fieldName}"]`) as HTMLElement | null;
        if (field) {
          field.classList.add('input-error', 'border-error');
          field.setAttribute('aria-invalid', 'true');
          field.setAttribute('aria-describedby', errorDivId);
        }

        const errorDiv = document.createElement('div');
        errorDiv.className = 'field-error text-error text-sm mt-1';
        errorDiv.id = errorDivId;
        errorDiv.textContent = errorMessage;
        errorDiv.setAttribute('role', 'alert');
        fieldContainer.appendChild(errorDiv);
      } else {
        const field = form.querySelector(`[name="${fieldName}"]`) as HTMLElement | null;
        if (field) {
          field.classList.remove('input-error', 'border-error');
          field.setAttribute('aria-invalid', 'false');
          field.removeAttribute('aria-describedby');
        }
      }
    }

    function validateField(fieldName: string, value: string): string | null {
      if (isResetting) return null;
      const validator = validators[fieldName];
      if (!validator) return null;

      const error = validator.validate(value);
      fieldErrors[fieldName] = error;
      updateFieldErrorUI(fieldName, error);
      updateSubmitButton();
      return error;
    }

    function validateForm(): boolean {
      const formData = new FormData(form);
      let isValid = true;

      for (const fieldName of Object.keys(validators)) {
        const value = String(formData.get(fieldName) || '');
        const error = validateField(fieldName, value);
        if (error) isValid = false;
      }

      return isValid;
    }

    function updateSubmitButton() {
      if (!submitButton) return;

      const requiredFields = ['title', 'amount', 'transaction_date', 'category_id', 'asset_id'];
      let allValid = true;

      for (const fieldName of requiredFields) {
        const field = form.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | null;
        const value = field?.value || '';
        const hasError = fieldErrors[fieldName] !== null && fieldErrors[fieldName] !== undefined;

        if (hasError || !value || value.trim() === '') {
          allValid = false;
          break;
        }
      }

      submitButton.disabled = !allValid;
    }

    function clearFieldErrors() {
      form.querySelectorAll('.field-error').forEach((el) => el.remove());
      form.querySelectorAll('.input-error, .border-error').forEach((el) => {
        el.classList.remove('input-error', 'border-error');
      });
      if (formError) {
        formError.classList.add('hidden');
        formError.textContent = '';
      }
    }

    function setFieldError(fieldName: string, message: string) {
      let fieldContainer: Element | null = null;
      if (fieldName === 'category_id') {
        fieldContainer =
          form.querySelector('[data-category-chips]')?.closest('.form-control') || null;
      } else {
        fieldContainer =
          form.querySelector(`[name="${fieldName}"]`)?.closest('.form-control') || null;
      }
      if (!fieldContainer) return;

      const existingError = fieldContainer.querySelector('.field-error');
      if (existingError) existingError.remove();

      const input = fieldContainer.querySelector('input, select, textarea');
      if (input) {
        input.classList.add('input-error', 'border-error');
      }

      const errorDiv = document.createElement('div');
      errorDiv.className = 'field-error text-error text-sm mt-1';
      errorDiv.textContent = message;
      fieldContainer.appendChild(errorDiv);
    }

    // Update currency based on category selection
    function updateCurrencyForCategory() {
      if (!categorySelect || !currencyInput) return;

      const selectedCategoryId = categorySelect.value;
      const selectedCategory = categories.find(
        (c: { id: string; currency?: string }) => c.id === selectedCategoryId
      );

      if (selectedCategory && selectedCategory.currency) {
        currencyInput.value = selectedCategory.currency;
        // Update badge text
        if (currencyBadge) {
          const meta = CURRENCY_META[selectedCategory.currency as Currency];
          if (meta) {
            currencyBadge.textContent = `${meta.symbol} ${selectedCategory.currency}`;
          }
        }
        // Sync amount formatter locale with new currency
        amountFormatter?.updateCurrency(selectedCategory.currency as Currency);
      }
    }

    // Attach validation listeners
    function attachValidationListeners() {
      const titleInput = form.querySelector('input[name="title"]');
      titleInput?.addEventListener('input', (e: Event) => {
        validateField('title', (e.target as HTMLInputElement).value);
      });

      const amountInput = form.querySelector('input[name="amount"]');
      amountInput?.addEventListener('input', (e: Event) => {
        validateField('amount', (e.target as HTMLInputElement).value);
      });

      const assetSelect = form.querySelector('select[name="asset_id"]');
      assetSelect?.addEventListener('change', (e: Event) => {
        validateField('asset_id', (e.target as HTMLSelectElement).value);
      });
    }

    // Close modal or drawer helper
    function closeModal() {
      if (modalId) {
        const modal = document.getElementById(modalId) as HTMLDialogElement | null;
        if (modal) {
          modal.close();
          return;
        }
      }
      const parentDrawer = form.closest('[data-drawer]') as HTMLElement | null;
      if (parentDrawer) {
        parentDrawer.dispatchEvent(new CustomEvent('drawer:close'));
      }
    }

    // Handle form submission
    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const transactionType = form.dataset.type || 'expense';
      const formMode = form.dataset.mode || 'create';
      const transactionId = form.dataset.transactionId || '';
      const isEditMode = formMode === 'edit';

      const isFormValid = validateForm();
      if (!isFormValid) {
        const firstErrorField = form.querySelector('[aria-invalid="true"]') as HTMLElement | null;
        firstErrorField?.focus();
        return;
      }

      clearFieldErrors();

      if (submitButton) {
        submitButton.disabled = true;
        submitButton.textContent = 'Saving...';
      }

      try {
        const formData = new FormData(form);
        const data = {
          type: transactionType,
          description: String(formData.get('title') || ''),
          amount: stripAmountFormatting(
            String(formData.get('amount') || '0'),
            (formData.get('currency') || DEFAULT_CURRENCY) as Currency
          ),
          currency: String(formData.get('currency') || DEFAULT_CURRENCY),
          category_id: String(formData.get('category_id') || ''),
          asset_id: String(formData.get('asset_id') || ''),
          transaction_date: String(
            formData.get('transaction_date') || new Date().toISOString().split('T')[0]
          ),
        };

        const apiUrl = isEditMode ? `${action}/${transactionId}` : action;
        const method = isEditMode ? 'PUT' : 'POST';

        const response = await fetch(apiUrl, {
          method,
          headers: getCsrfHeaders({ 'Content-Type': 'application/json' }),
          body: JSON.stringify(data),
        });

        const result = await response.json();

        if (!response.ok || !result.success) {
          if (result.error?.details) {
            result.error.details.forEach(
              (issue: { path: (string | number)[]; message: string }) => {
                const fieldName = issue.path.join('.') || 'general';
                setFieldError(fieldName, issue.message);
              }
            );
            const firstInvalidField = form.querySelector(
              '.input-error, .select-error, .border-error'
            ) as HTMLElement | null;
            firstInvalidField?.focus();
          } else {
            if (formError) {
              formError.textContent = result.error?.message || 'Failed to save transaction';
              formError.classList.remove('hidden');
            }
          }
          addToast(result.error?.message || 'Failed to save transaction', 'error');
        } else {
          const actionWord = isEditMode ? 'updated' : 'saved';
          addToast(
            `${transactionType === 'expense' ? 'Expense' : 'Income'} ${actionWord} successfully!`,
            'success'
          );

          const isBulk = form.dataset.bulk === 'true';

          if (isBulk) {
            form.dispatchEvent(
              new CustomEvent('transaction-submitted', {
                detail: result.data,
                bubbles: true,
              })
            );

            // Preserve date, account, and category on reset
            const prevDate = hiddenDateInput?.value || todayStr;
            const prevAsset = (form.querySelector('select[name="asset_id"]') as HTMLSelectElement)
              ?.value;
            const prevCategory = categorySelect?.value || '';
            const prevCurrency = currencyInput?.value || DEFAULT_CURRENCY;

            // Determine which date pick was active
            let prevDatePick = 'today';
            datePickBtns.forEach((btn) => {
              if (btn.getAttribute('aria-pressed') === 'true') {
                prevDatePick = btn.dataset.datePick || 'today';
              }
            });

            // Suppress validation during programmatic reset to prevent
            // input event listeners from showing errors on empty fields
            isResetting = true;

            // Reset title and amount only
            const titleInput = form.querySelector('input[name="title"]') as HTMLInputElement;
            const amountInput = form.querySelector('input[name="amount"]') as HTMLInputElement;
            if (titleInput) titleInput.value = '';
            if (amountInput) amountInput.value = '';

            // Restore preserved values
            if (hiddenDateInput) hiddenDateInput.value = prevDate;
            if (dateCustomInput) dateCustomInput.value = prevDate;
            setDateValue(prevDate, prevDatePick);

            const assetSel = form.querySelector('select[name="asset_id"]') as HTMLSelectElement;
            if (assetSel && prevAsset) assetSel.value = prevAsset;

            if (prevCategory) {
              setActiveChip(prevCategory);
            }

            if (currencyInput) currencyInput.value = prevCurrency;
            if (currencyBadge) {
              const meta = CURRENCY_META[prevCurrency as Currency];
              if (meta) {
                currencyBadge.textContent = `${meta.symbol} ${prevCurrency}`;
              }
            }
            // Sync amount formatter locale with restored currency
            amountFormatter?.updateCurrency(prevCurrency as Currency);

            isResetting = false;

            // Clear field error state and UI after reset
            Object.keys(fieldErrors).forEach((k) => {
              fieldErrors[k] = null;
            });
            clearFieldErrors();

            updateSubmitButton();
            // Auto-focus amount for rapid entry
            amountInput?.focus();
          } else {
            closeModal();
            document.dispatchEvent(new CustomEvent('transactions-changed'));
          }
        }
      } catch (err) {
        if (formError) {
          formError.textContent = 'Network error. Please try again.';
          formError.classList.remove('hidden');
        }
        addToast('Network error. Please try again.', 'error');
      } finally {
        if (submitButton) {
          submitButton.disabled = false;
          const currentMode = form.dataset.mode || 'create';
          submitButton.textContent = currentMode === 'edit' ? 'Save Changes' : 'Save Entry';
        }
      }
    });

    // Initialize
    attachValidationListeners();
    updateSubmitButton();

    // Attach amount formatter for thousand separators
    const amountInputEl = form.querySelector('input[name="amount"]') as HTMLInputElement;
    let amountFormatter: AmountFormatterHandle | null = null;
    if (amountInputEl) {
      const initialCurrency = (currencyInput?.value || DEFAULT_CURRENCY) as Currency;
      amountFormatter = attachAmountFormatter(amountInputEl, initialCurrency);
    }

    // Update formatter currency when currency badge is clicked.
    // This listener runs AFTER the badge click handler (in initCurrencyToggle)
    // which updates currencyInput.value, so we read the new value here.
    if (currencyBadge && amountFormatter) {
      currencyBadge.addEventListener('click', () => {
        const newCurrency = (currencyInput?.value || DEFAULT_CURRENCY) as Currency;
        amountFormatter!.updateCurrency(newCurrency);
      });
    }

    // Auto-focus amount field on initial load (only for create mode)
    if (form.dataset.mode === 'create') {
      const amountInput = form.querySelector('input[name="amount"]') as HTMLInputElement;
      // Delay focus to avoid conflicts with drawer animation
      setTimeout(() => amountInput?.focus(), 100);
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTransactionEntryForms);
  } else {
    initTransactionEntryForms();
  }

  document.addEventListener('astro:page-load', initTransactionEntryForms);
</script>
