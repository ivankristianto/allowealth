---
/**
 * HeroSection Component
 *
 * Landing page hero with badge, headline, description, and dual CTAs.
 * Auth state is detected client-side via auth_hint cookie (see PublicAuthCta.client.ts).
 */

import { Sparkles, ArrowRight } from '@lucide/astro';
import { heroContent } from '@/lib/landing-content';
import Button from '@/components/atoms/Button.astro';
import GitHubIcon from '@/components/atoms/GitHubIcon.astro';
---

<header class="relative z-10 pt-36 sm:pt-48 pb-16 sm:pb-32 px-6 overflow-hidden">
  <!-- Hero Background Gradient -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
    <div
      class="absolute top-[-20%] left-[-10%] w-[70%] h-[70%] bg-accent/10 blur-[140px] rounded-full animate-pulse"
    >
    </div>
    <div
      class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[60%] bg-accent/5 blur-[120px] rounded-full"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto text-center">
    <!-- AI Badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full mb-8 sm:mb-12"
    >
      <Sparkles size={14} class="text-accent" aria-hidden="true" />
      <span class="text-xs font-bold text-accent uppercase tracking-widest">
        {heroContent.badge}
      </span>
    </div>

    <!-- Main Headline -->
    <h1
      class="text-4xl sm:text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter text-base-content leading-[0.85] mb-6 sm:mb-10"
    >
      {heroContent.title}
      <br class="hidden lg:block" />
      <span class="italic"
        >{heroContent.titleHighlightPrefix}<span class="text-accent"
          >{heroContent.titleHighlight}</span
        ></span
      >
    </h1>

    <!-- Description -->
    <p
      class="text-base-content/60 text-base sm:text-lg md:text-2xl font-medium max-w-3xl mx-auto leading-relaxed mb-10 sm:mb-16"
    >
      {heroContent.description}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
      <!-- Primary CTA -->
      <Button
        variant="primary"
        href="/signup"
        size="xl"
        className="w-full sm:w-auto"
        data-auth-cta
        data-auth-href="/dashboard"
        dataAstroReload
      >
        <span data-auth-cta-text data-auth-text={heroContent.ctaLoggedIn}
          >{heroContent.ctaGuest}</span
        >
        <ArrowRight size={20} class="stroke-current" aria-hidden="true" />
      </Button>

      <!-- Secondary CTA -->
      <Button
        variant="secondary"
        href={heroContent.ctaSecondaryHref ?? '#showcase'}
        size="xl"
        className="w-full sm:w-auto"
      >
        <GitHubIcon size={20} class="fill-current" />
        {heroContent.ctaSecondary}
      </Button>
    </div>
  </div>
</header>

<style>
  /* Entrance animations */
  @keyframes fade-in-down {
    from {
      opacity: 0;
      transform: translateY(-16px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes fade-in-up {
    from {
      opacity: 0;
      transform: translateY(32px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Apply animations only when user prefers motion */
  @media (prefers-reduced-motion: no-preference) {
    .animate-fade-in-down {
      animation: fade-in-down 0.7s ease-out both;
    }

    .animate-fade-in-up {
      animation: fade-in-up 0.7s ease-out both;
    }

    .animate-fade-in-up-delay {
      animation: fade-in-up 1s ease-out 0.2s both;
    }

    .animate-fade-in-up-delay-2 {
      animation: fade-in-up 1s ease-out 0.4s both;
    }
  }
</style>
