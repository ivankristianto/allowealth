---
/**
 * FeaturesGrid Component
 *
 * Bento-style grid of feature cards with varying sizes.
 * Uses a 12-column grid layout on desktop.
 */

import { Globe, Users, Shield, Zap, Lock, TrendingUp } from '@lucide/astro';
import { featureGridItems } from '@/lib/landing-content';

// Map icon names to components
const iconMap: Record<string, typeof Globe> = {
  Globe,
  Users,
  Shield,
  Zap,
  Lock,
  TrendingUp,
};
---

<section
  id="features"
  class="relative z-10 px-6 py-16 sm:py-24 bg-base-200/30"
  aria-labelledby="features-title"
>
  <div class="max-w-7xl mx-auto">
    <!-- Section Header -->
    <header class="text-center mb-12 sm:mb-20">
      <h2
        id="features-title"
        class="text-3xl sm:text-4xl md:text-6xl font-bold text-base-content tracking-tighter mb-4"
      >
        Built right.
      </h2>
      <p class="text-neutral text-base sm:text-lg font-medium max-w-lg mx-auto">
        Every tool you need to track and understand your wealth.
      </p>
    </header>

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 md:grid-cols-12 gap-4 sm:gap-6">
      {
        featureGridItems.map((item) => {
          const IconComponent = iconMap[item.icon];
          const isDark = item.variant === 'dark';
          const isLarge = item.size === 'large';

          return (
            <article
              class={`${item.colSpan} p-8 sm:p-12 rounded-2xl sm:rounded-3xl overflow-hidden group transition-transform hover:scale-[1.02] ${
                isDark
                  ? 'bg-primary text-primary-content relative'
                  : 'bg-base-100 border border-base-300 shadow-sm'
              }`}
            >
              {/* Glow effect for dark cards */}
              {isDark && (
                <div
                  class="absolute top-0 right-0 w-64 h-64 bg-accent/20 blur-[100px] pointer-events-none"
                  aria-hidden="true"
                />
              )}

              <div class="relative z-10">
                {/* Icon */}
                <div
                  class={`w-12 h-12 sm:w-14 sm:h-14 ${item.iconBg} ${item.iconColor} rounded-2xl flex items-center justify-center mb-6 sm:mb-8 group-hover:scale-110 transition-transform`}
                >
                  {IconComponent && (
                    <IconComponent size={28} class="stroke-current" aria-hidden="true" />
                  )}
                </div>

                {/* Title */}
                <h3
                  class={`font-bold tracking-tight mb-4 ${
                    isLarge ? 'text-2xl sm:text-3xl' : 'text-xl sm:text-2xl'
                  } ${isDark ? 'text-primary-content' : 'text-base-content'}`}
                >
                  {item.title}
                </h3>

                {/* Description */}
                <p
                  class={`leading-relaxed ${isLarge ? 'text-base sm:text-lg max-w-md' : 'text-sm'} ${
                    isDark ? 'text-primary-content/60' : 'text-neutral'
                  }`}
                >
                  {item.description}
                </p>
              </div>
            </article>
          );
        })
      }
    </div>
  </div>
</section>
