---
/**
 * Transaction Form Component
 *
 * Form for adding/editing transactions with validation.
 *
 * @param {string} action - Form action URL (API endpoint)
 * @param {string} method - Form method (POST or PUT)
 * @param {Object} values - Default form values
 * @param {Array} categories - Available categories
 * @param {Array} paymentMethods - Available payment methods
 * @param {string} transactionType - Pre-selected type (expense/income)
 * @param {Array} errors - Form errors {field: message}
 * @param {string} submitLabel - Submit button label
 * @param {string} cancelUrl - URL to cancel and go back
 * @param {boolean} showBudgetWarning - Show budget warning
 * @param {string} budgetRemaining - Budget remaining amount
 * @param {Object} budgetInfo - Budget info with percentage used
 */

import Label from '../atoms/Label.astro';
import CurrencyInput from '../atoms/CurrencyInput.astro';
import CategorySelect from '../atoms/CategorySelect.astro';
import PaymentMethodSelect from '../atoms/PaymentMethodSelect.astro';
import DatePicker from '../atoms/DatePicker.astro';
import Button from '../atoms/Button.astro';
import Currency from '../atoms/Currency.astro';
import { TriangleAlert } from '@lucide/astro';

export interface Props {
  action: string;
  method?: 'POST' | 'PUT';
  values?: {
    type?: 'expense' | 'income';
    amount?: string;
    currency?: 'IDR' | 'USD';
    category_id?: string;
    payment_method_id?: string;
    transaction_date?: string;
    description?: string;
  };
  categories: Array<{ id: string; name: string; type: string; currency?: string }>;
  paymentMethods: Array<{ id: string; name: string; type: string }>;
  transactionType?: 'expense' | 'income';
  errors?: Record<string, string>;
  submitLabel?: string;
  cancelUrl?: string;
  showBudgetWarning?: boolean;
  budgetRemaining?: string;
  budgetRemainingCurrency?: 'IDR' | 'USD';
  budgetInfo?: {
    category_id: string;
    remaining: string;
    percentage_used: string;
    budget_amount: string;
  } | null;
}

const {
  action,
  method = 'POST',
  values = {},
  categories = [],
  paymentMethods = [],
  transactionType,
  errors = {},
  submitLabel = 'Save Transaction',
  cancelUrl = '/transactions',
  showBudgetWarning = false,
  budgetRemaining = '0',
  budgetRemainingCurrency = 'IDR',
  budgetInfo = null,
} = Astro.props;

const formType = values.type || transactionType || 'expense';
const today = new Date().toISOString().split('T')[0];

// Serialize budget info for client-side JavaScript
const budgetInfoJson = budgetInfo
  ? JSON.stringify({
      category_id: budgetInfo.category_id,
      remaining: budgetInfo.remaining,
      percentage_used: budgetInfo.percentage_used,
      budget_amount: budgetInfo.budget_amount,
    })
  : 'null';

// Serialize categories and payment methods for client-side JavaScript
const categoriesJson = JSON.stringify(
  categories.map((c) => ({ id: c.id, name: c.name, type: c.type, currency: c.currency || 'IDR' }))
);
const paymentMethodsJson = JSON.stringify(
  paymentMethods.map((pm) => ({ id: pm.id, name: pm.name, type: pm.type }))
);
---

<form
  id="transaction-form"
  data-action={action}
  data-method={method}
  data-categories-json={categoriesJson}
  data-payment-methods-json={paymentMethodsJson}
  data-budget-info-json={budgetInfoJson}
  class="flex flex-col gap-4"
  novalidate
>
  <!-- Global error message container -->
  <div id="form-error" class="hidden alert alert-error" role="alert"></div>
  <!-- Transaction Type -->
  <div class="form-control">
    <Label required htmlFor="type" id="type-label">Type</Label>
    <div class="join w-full">
      <input
        type="radio"
        name="type"
        value="expense"
        id="type-expense"
        aria-labelledby="type-label"
        class="join-item btn btn-sm flex-1"
        checked={formType === 'expense'}
      />
      <label for="type-expense" class="join-item btn btn-sm flex-1"> Expense </label>

      <input
        type="radio"
        name="type"
        value="income"
        id="type-income"
        aria-labelledby="type-label"
        class="join-item btn btn-sm flex-1"
        checked={formType === 'income'}
      />
      <label for="type-income" class="join-item btn btn-sm flex-1"> Income </label>
    </div>
  </div>

  <!-- Date -->
  <div class="form-control">
    <Label required htmlFor="transaction_date" id="date-label" helpText="Default: Today">
      Date
    </Label>
    <DatePicker
      id="transaction_date"
      name="transaction_date"
      value={values.transaction_date || today}
      max={today}
      required={true}
      error={!!errors.transaction_date}
      errorMessage={errors.transaction_date}
    />
  </div>

  <!-- Amount -->
  <div class="form-control">
    <Label required htmlFor="amount-input" id="amount-label">Amount</Label>
    <CurrencyInput
      id="amount"
      name="amount"
      value={values.amount || ''}
      currency={values.currency || 'IDR'}
      required={true}
      error={!!errors.amount}
      errorMessage={errors.amount}
    />
  </div>

  <!-- Category -->
  <div class="form-control">
    <Label required htmlFor="category_id-select" id="category-label">Category</Label>
    <CategorySelect
      id="category_id"
      categories={categories}
      value={values.category_id || ''}
      type={formType}
      required={true}
      error={!!errors.category_id}
      errorMessage={errors.category_id}
    />
  </div>

  <!-- Payment Method -->
  <div class="form-control">
    <Label required htmlFor="payment_method_id-select" id="payment-label">Payment Method</Label>
    <PaymentMethodSelect
      id="payment_method_id"
      paymentMethods={paymentMethods}
      value={values.payment_method_id || ''}
      required={true}
      error={!!errors.payment_method_id}
      errorMessage={errors.payment_method_id}
    />
  </div>

  <!-- Description -->
  <div class="form-control">
    <Label htmlFor="description" id="description-label">Description</Label>
    <textarea
      id="description"
      name="description"
      class="textarea textarea-bordered w-full bg-base-200 text-xs pt-2 pb-2 px-3 focus:ring-2 focus:ring-accent focus:ring-opacity-20 focus:outline-none"
      placeholder="Optional notes..."
      rows="3"
    >
      {values.description || ''}
    </textarea>
  </div>

  <!-- Budget Warning (for expenses) -->
  {
    showBudgetWarning && formType === 'expense' && (
      <div role="alert" class="alert alert-warning">
        <TriangleAlert size={16} class="shrink-0 stroke-current" aria-hidden="true" />
        <span>
          Budget remaining:{' '}
          <Currency amount={parseFloat(budgetRemaining) || 0} currency={budgetRemainingCurrency} />
        </span>
      </div>
    )
  }

  <!-- Actions -->
  <div class="card-actions justify-end gap-2 mt-6">
    <Button href={cancelUrl} variant="ghost">Cancel</Button>
    <Button type="submit" variant="primary">
      {submitLabel}
    </Button>
  </div>
</form>

<script>
  import { getCsrfHeaders } from '@/lib/csrf-client';

  // Get data from form data attributes
  const form = document.getElementById('transaction-form') as HTMLFormElement | null;
  const formError = document.getElementById('form-error');
  const submitButton = form?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
  const formSuccess = document.getElementById('form-success');

  // Parse categories and budget info from data attributes (server-serialized JSON)
  const categories = JSON.parse(form?.dataset.categoriesJson || '[]');
  const paymentMethods = JSON.parse(form?.dataset.paymentMethodsJson || '[]');
  const action = form?.dataset.action || '/api/transactions';
  const method = form?.dataset.method || 'POST';

  // Format currency for display
  function formatCurrency(amount: number, currency: string) {
    return new Intl.NumberFormat('id-ID', {
      style: 'currency',
      currency: currency,
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(amount);
  }

  // === Form Validation ===

  // Client-side validation rules matching server-side validation
  const validators: Record<
    string,
    { validate: (value: FormDataEntryValue | null) => string | null }
  > = {
    amount: {
      validate: (value) => {
        const strValue = String(value || '');
        // Strip currency formatting before validation
        const cleanValue = strValue.replace(/[^\d.-]/g, '');
        const num = parseFloat(cleanValue);
        if (!strValue || strValue.trim() === '') return 'Amount is required';
        if (isNaN(num)) return 'Amount must be a valid number';
        if (num <= 0) return 'Amount must be greater than 0';
        // Check for max 2 decimal places on clean value
        const decimalPlaces = cleanValue.split('.')[1]?.length || 0;
        if (decimalPlaces > 2) return 'Amount can have at most 2 decimal places';
        return null;
      },
    },
    transaction_date: {
      validate: (value) => {
        const strValue = String(value || '');
        if (!strValue || strValue.trim() === '') return 'Transaction date is required';
        // Check YYYY-MM-DD format
        if (!/^\d{4}-\d{2}-\d{2}$/.test(strValue)) return 'Date must be in YYYY-MM-DD format';
        const date = new Date(strValue);
        if (isNaN(date.getTime())) return 'Invalid date';
        // Check if date is in the future using UTC timestamp comparison
        const todayUTC = Date.now();
        const inputDateUTC = new Date(strValue).getTime();
        if (inputDateUTC > todayUTC) return 'Transaction date cannot be in the future';
        return null;
      },
    },
    category_id: {
      validate: (value) => {
        const strValue = String(value || '');
        if (!strValue || strValue.trim() === '') return 'Category is required';
        return null;
      },
    },
    payment_method_id: {
      validate: (value) => {
        const strValue = String(value || '');
        if (!strValue || strValue.trim() === '') return 'Payment method is required';
        return null;
      },
    },
    description: {
      validate: (value) => {
        const strValue = String(value || '');
        if (strValue && strValue.length > 500) return 'Description must not exceed 500 characters';
        return null;
      },
    },
  };

  // Field validation state
  const fieldErrors: Record<string, string | null> = {};

  // Validate a single field
  function validateField(fieldName: string, value: FormDataEntryValue | null) {
    const validator = validators[fieldName];
    if (!validator) return null;

    const error = validator.validate(value);
    fieldErrors[fieldName] = error;

    // Update UI
    updateFieldErrorUI(fieldName, error);
    updateSubmitButton();

    return error;
  }

  // Update field error UI
  function updateFieldErrorUI(fieldName: string, errorMessage: string | null) {
    const field = form?.querySelector(`[name="${fieldName}"]`) as HTMLElement | null;
    if (!field) return;

    const fieldContainer = field.closest('.form-control');
    if (!fieldContainer) return;

    // Remove existing error
    const existingError = fieldContainer.querySelector('.field-error');
    if (existingError) {
      existingError.remove();
    }

    const errorDivId = `${fieldName}-error`;

    // Update input styling and ARIA attributes
    if (errorMessage) {
      field.classList.add('input-error', 'border-error');
      field.setAttribute('aria-invalid', 'true');
      field.setAttribute('aria-describedby', errorDivId);

      // Add error message
      const errorDiv = document.createElement('div');
      errorDiv.className = 'field-error text-error text-sm mt-1';
      errorDiv.id = errorDivId;
      errorDiv.textContent = errorMessage;
      errorDiv.setAttribute('role', 'alert');
      fieldContainer.appendChild(errorDiv);
    } else {
      field.classList.remove('input-error', 'border-error');
      field.setAttribute('aria-invalid', 'false');
      field.removeAttribute('aria-describedby');
    }
  }

  // Validate all fields
  function validateForm() {
    const formData = new FormData(form);
    let isValid = true;

    // Validate each field
    for (const fieldName in validators) {
      const value = formData.get(fieldName);
      const error = validateField(fieldName, value);
      if (error) isValid = false;
    }

    return isValid;
  }

  // Update submit button state
  function updateSubmitButton() {
    if (!submitButton) return;

    // Check required fields only (description is optional)
    const requiredFields = ['amount', 'transaction_date', 'category_id', 'payment_method_id'];
    let allValid = true;

    for (const fieldName of requiredFields) {
      const field = form?.querySelector(`[name="${fieldName}"]`) as HTMLInputElement | null;
      const value = field?.value || '';
      const error = fieldErrors[fieldName];

      // Invalid if: has error OR value is empty/undefined
      if (error || !value || value.trim() === '') {
        allValid = false;
        break;
      }
    }

    if (submitButton) {
      submitButton.disabled = !allValid;
    }
  }

  // Attach real-time validation listeners
  function attachValidationListeners() {
    // Amount input - validate on input
    const amountInput = form?.querySelector('input[name="amount"]');
    amountInput?.addEventListener('input', (e: Event) => {
      validateField('amount', (e.target as HTMLInputElement).value);
    });

    // Date input - validate on change
    const dateInput = form?.querySelector('input[name="transaction_date"]');
    dateInput?.addEventListener('change', (e: Event) => {
      validateField('transaction_date', (e.target as HTMLInputElement).value);
    });

    // Category select - validate on change
    const categorySelect = form?.querySelector('select[name="category_id"]');
    categorySelect?.addEventListener('change', (e: Event) => {
      validateField('category_id', (e.target as HTMLSelectElement).value);
    });

    // Payment method select - validate on change
    const paymentMethodSelect = form?.querySelector('select[name="payment_method_id"]');
    paymentMethodSelect?.addEventListener('change', (e: Event) => {
      validateField('payment_method_id', (e.target as HTMLSelectElement).value);
    });

    // Description textarea - validate on input (for max length)
    const descriptionTextarea = form?.querySelector('textarea[name="description"]');
    descriptionTextarea?.addEventListener('input', (e: Event) => {
      validateField('description', (e.target as HTMLTextAreaElement).value);
    });
  }

  // Show success message
  function showSuccessMessage(message: string) {
    if (!formSuccess) {
      // Create success element if it doesn't exist
      const successEl = document.createElement('div');
      successEl.id = 'form-success';
      successEl.className = 'alert alert-success mb-4';
      successEl.setAttribute('role', 'status');

      // Create Check icon SVG (Lucide style)
      const iconSvg = document.createElementNS('http://www.w3.org/2000/svg', 'svg');
      iconSvg.setAttribute('xmlns', 'http://www.w3.org/2000/svg');
      iconSvg.classList.add('stroke-current', 'shrink-0', 'h-6', 'w-6');
      iconSvg.setAttribute('fill', 'none');
      iconSvg.setAttribute('viewBox', '0 0 24 24');
      iconSvg.setAttribute('aria-hidden', 'true');
      const poly1 = document.createElementNS('http://www.w3.org/2000/svg', 'polyline');
      poly1.setAttribute('points', '20 6 9 17 4 12');
      poly1.setAttribute('stroke-linecap', 'round');
      poly1.setAttribute('stroke-linejoin', 'round');
      poly1.setAttribute('stroke-width', '2');
      iconSvg.appendChild(poly1);

      // Create text span with safe textContent
      const span = document.createElement('span');
      span.textContent = message;

      successEl.appendChild(iconSvg);
      successEl.appendChild(span);
      form?.insertBefore(successEl, form.firstChild);
    } else {
      formSuccess.classList.remove('hidden');
      const successText = formSuccess.querySelector('span');
      if (successText) successText.textContent = message;
    }

    // Scroll success message into view
    formSuccess?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  // Hide success message
  function hideSuccessMessage() {
    if (formSuccess) {
      formSuccess.classList.add('hidden');
    }
  }

  // === End Form Validation ===

  // === localStorage helpers for remembering last used selections ===
  // Namespace prefix to prevent collisions with other code on same origin
  const STORAGE_PREFIX = 'expensesApp.';

  // Storage keys with namespace prefix
  const STORAGE_KEYS = {
    lastExpenseCategory: STORAGE_PREFIX + 'lastExpenseCategory',
    lastIncomeCategory: STORAGE_PREFIX + 'lastIncomeCategory',
    lastPaymentMethod: STORAGE_PREFIX + 'lastPaymentMethod',
  };

  const DEFAULT_TRANSACTION_TYPE = 'expense';

  // Helper: Get localStorage key for category based on transaction type
  function getCategoryStorageKey(transactionType: string) {
    return transactionType === 'expense'
      ? STORAGE_KEYS.lastExpenseCategory
      : STORAGE_KEYS.lastIncomeCategory;
  }

  function getLastUsedCategory(transactionType: string) {
    try {
      const key = getCategoryStorageKey(transactionType);
      const value = localStorage.getItem(key);
      // Sanitize: ensure it's a string matching expected ID format
      if (value && /^[a-zA-Z0-9\-]+$/.test(value)) {
        return value;
      }
      return null;
    } catch (e) {
      // localStorage unavailable (private mode, quota exceeded, etc.)
      console.warn('localStorage unavailable:', e);
      return null;
    }
  }

  function setLastUsedCategory(transactionType: string, categoryId: string) {
    try {
      const key = getCategoryStorageKey(transactionType);
      localStorage.setItem(key, categoryId);
    } catch (e) {
      // Quota exceeded or localStorage unavailable
      console.warn('Failed to save category to localStorage:', e);
      // Try to clear old data and retry
      try {
        localStorage.clear();
        const key = getCategoryStorageKey(transactionType);
        localStorage.setItem(key, categoryId);
      } catch (e2) {
        // Still failing - give up silently
      }
    }
  }

  function getLastUsedPaymentMethod() {
    try {
      const value = localStorage.getItem(STORAGE_KEYS.lastPaymentMethod);
      // Sanitize: ensure it's a string matching expected ID format
      if (value && /^[a-zA-Z0-9\-]+$/.test(value)) {
        return value;
      }
      return null;
    } catch (e) {
      console.warn('localStorage unavailable:', e);
      return null;
    }
  }

  function setLastUsedPaymentMethod(paymentMethodId: string) {
    try {
      localStorage.setItem(STORAGE_KEYS.lastPaymentMethod, paymentMethodId);
    } catch (e) {
      console.warn('Failed to save payment method to localStorage:', e);
      // Try to clear old data and retry
      try {
        localStorage.clear();
        localStorage.setItem(STORAGE_KEYS.lastPaymentMethod, paymentMethodId);
      } catch (e2) {
        // Still failing - give up silently
      }
    }
  }

  // Pre-select last used values on form load
  // Returns true if a category was pre-selected, false otherwise
  function preselectLastUsedValues() {
    const checkedTypeRadio = document.querySelector(
      'input[name="type"]:checked'
    ) as HTMLInputElement | null;
    const formType = checkedTypeRadio?.value || DEFAULT_TRANSACTION_TYPE;
    const categorySelect = document.querySelector(
      'select[name="category_id"]'
    ) as HTMLSelectElement | null;
    const paymentMethodSelect = document.querySelector(
      'select[name="payment_method_id"]'
    ) as HTMLSelectElement | null;
    let categoryPreselected = false;

    // Only pre-select if the form doesn't already have a value (server-rendered)
    if (categorySelect && !categorySelect.value) {
      const lastCategory = getLastUsedCategory(formType);
      if (lastCategory) {
        // Check if the category still exists and is valid for current type
        const category = categories.find(
          (c: { id: string; type: string }) => c.id === lastCategory && c.type === formType
        );
        if (category) {
          categorySelect.value = lastCategory;
          categoryPreselected = true;
          // Trigger change event to update currency and budget display
          categorySelect.dispatchEvent(new Event('change'));
        } else {
          console.warn(`Last used category "${lastCategory}" no longer available`);
        }
      }
    }

    // Only pre-select payment method if the form doesn't already have a value
    if (paymentMethodSelect && !paymentMethodSelect.value) {
      const lastPaymentMethod = getLastUsedPaymentMethod();
      if (lastPaymentMethod) {
        // Validate payment method still exists
        const paymentMethod = paymentMethods.find(
          (pm: { id: string }) => pm.id === lastPaymentMethod
        );
        if (paymentMethod) {
          paymentMethodSelect.value = lastPaymentMethod;
        } else {
          console.warn(`Last used payment method "${lastPaymentMethod}" no longer available`);
        }
      }
    }

    return categoryPreselected;
  }

  // === End localStorage helpers ===

  // Update currency based on selected category
  function updateCurrencyForCategory() {
    const categorySelect = document.querySelector(
      'select[name="category_id"]'
    ) as HTMLSelectElement | null;
    const currencyInput = document.querySelector(
      'input[name="currency"]'
    ) as HTMLInputElement | null;
    if (!categorySelect || !currencyInput) return;

    const selectedCategoryId = categorySelect.value;
    const selectedCategory = categories.find(
      (c: { id: string; currency?: string }) => c.id === selectedCategoryId
    );

    if (selectedCategory && selectedCategory.currency) {
      currencyInput.value = selectedCategory.currency;
      // Trigger currency change event to update the formatted display
      currencyInput.dispatchEvent(new Event('change'));
    }
  }

  // Update category options when transaction type changes
  const typeRadios = document.querySelectorAll('input[name="type"]');
  const categorySelect = document.querySelector(
    'select[name="category_id"]'
  ) as HTMLSelectElement | null;

  // Update budget display based on selected category
  async function updateBudgetDisplay() {
    if (!categorySelect) return;

    const selectedCategoryId = categorySelect.value;
    const checkedTypeRadio = document.querySelector(
      'input[name="type"]:checked'
    ) as HTMLInputElement | null;
    const formType = checkedTypeRadio?.value;

    // Only update budget for expense categories
    if (formType !== 'expense' || !selectedCategoryId) {
      hideBudgetWarning();
      return;
    }

    try {
      const response = await fetch(`/api/budget/category/${selectedCategoryId}/remaining`);
      if (!response.ok) {
        // Category might not have budget or other error - hide warning
        hideBudgetWarning();
        return;
      }

      const data = await response.json();
      if (data.success && data.data) {
        const budgetData = data.data;
        showBudgetWarning(budgetData);
      } else {
        hideBudgetWarning();
      }
    } catch (error) {
      // Network error or category not found - hide warning
      hideBudgetWarning();
    }
  }

  // Show budget warning with data
  function showBudgetWarning(budgetData: {
    category_id: string;
    percentage_used: string;
    remaining: string;
    budget_amount: string;
    spent_amount: string;
  }) {
    let budgetWarningEl = document.getElementById('budget-warning');
    if (!budgetWarningEl) {
      // Create budget warning element if it doesn't exist
      const descriptionField = document
        .querySelector('textarea[name="description"]')
        ?.closest('.form-control');
      if (descriptionField) {
        budgetWarningEl = document.createElement('div');
        budgetWarningEl.id = 'budget-warning';
        budgetWarningEl.className = 'alert alert-warning';
        budgetWarningEl.setAttribute('role', 'alert');
        budgetWarningEl.innerHTML = `
          <svg xmlns="http://www.w3.org/2000/svg" class="stroke-current shrink-0 h-6 w-6" fill="none" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v4" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 17h.01" />
          </svg>
          <span id="budget-warning-text"></span>
        `;
        descriptionField.parentNode?.insertBefore(budgetWarningEl, descriptionField);
      }
    }

    if (budgetWarningEl) {
      const warningText = budgetWarningEl.querySelector('#budget-warning-text');
      const percentageUsed = parseFloat(budgetData.percentage_used) || 0;
      const remaining = parseFloat(budgetData.remaining) || 0;
      const budgetAmount = parseFloat(budgetData.budget_amount) || 0;
      const spentAmount = parseFloat(budgetData.spent_amount) || 0;

      // Determine currency from category
      const selectedCategory = categories.find(
        (c: { id: string; currency?: string }) => c.id === budgetData.category_id
      );
      const currency = selectedCategory?.currency || 'IDR';

      // Update alert styling based on budget status
      budgetWarningEl.classList.remove('alert-warning', 'alert-error', 'alert-success');
      if (percentageUsed >= 100) {
        budgetWarningEl.classList.add('alert-error');
      } else if (percentageUsed >= 80) {
        budgetWarningEl.classList.add('alert-warning');
      } else {
        budgetWarningEl.classList.add('alert-success');
      }

      // Format message
      let message = '';
      if (percentageUsed >= 100) {
        message = `Budget exceeded by ${formatCurrency(Math.abs(remaining), currency)}!`;
      } else if (percentageUsed >= 80) {
        message = `Budget remaining: ${formatCurrency(remaining, currency)} (${Math.round(percentageUsed)}% used)`;
      } else {
        message = `Budget: ${formatCurrency(spentAmount, currency)} of ${formatCurrency(budgetAmount, currency)} used (${Math.round(percentageUsed)}%)`;
      }

      if (warningText) {
        warningText.textContent = message;
      }

      budgetWarningEl.classList.remove('hidden');
    }
  }

  // Hide budget warning
  function hideBudgetWarning() {
    const budgetWarningEl = document.getElementById('budget-warning');
    if (budgetWarningEl) {
      budgetWarningEl.classList.add('hidden');
    }
  }

  typeRadios.forEach((radio) => {
    radio?.addEventListener('change', (e: Event) => {
      const target = e.target as HTMLInputElement;
      const newType = target.value;

      // Get all categories from the select options
      const catSelect = categorySelect;
      if (catSelect) {
        const allOptions = Array.from(catSelect.options).slice(1); // Skip first option

        // Filter and update options based on type
        allOptions.forEach((option) => {
          const categoryType = option.getAttribute('data-type');
          if (categoryType === newType) {
            option.removeAttribute('disabled');
            option.hidden = false;
          } else {
            option.setAttribute('disabled', 'true');
            option.hidden = true;
          }
        });

        // Reset category selection
        catSelect.value = '';

        // Try to pre-select the last used category for the new type
        const lastCategory = getLastUsedCategory(newType);
        if (lastCategory) {
          const category = categories.find(
            (c: { id: string; type: string }) => c.id === lastCategory && c.type === newType
          );
          if (category) {
            catSelect.value = lastCategory;
          }
        }
      }

      // Update currency when category changes
      updateCurrencyForCategory();

      // Update budget display
      updateBudgetDisplay();
    });
  });

  // Update currency and budget when category changes
  categorySelect?.addEventListener('change', () => {
    updateCurrencyForCategory();
    updateBudgetDisplay();
  });

  // Display field-specific errors
  function setFieldError(fieldName: string, message: string) {
    const fieldContainer = document
      .querySelector(`[name="${fieldName}"]`)
      ?.closest('.form-control');

    if (fieldContainer) {
      // Remove existing error if any
      const existingError = fieldContainer.querySelector('.field-error');
      if (existingError) {
        existingError.remove();
      }

      // Add error styling to input
      const input = fieldContainer.querySelector('input, select, textarea');
      if (input) {
        input.classList.add('input-error', 'border-error');
      }

      // Add error message
      const errorDiv = document.createElement('div');
      errorDiv.className = 'field-error text-error text-sm mt-1';
      errorDiv.textContent = message;
      fieldContainer.appendChild(errorDiv);
    }
  }

  // Clear all field errors
  function clearFieldErrors() {
    document.querySelectorAll('.field-error').forEach((el) => el.remove());
    document.querySelectorAll('.input-error, .border-error').forEach((el) => {
      el.classList.remove('input-error', 'border-error');
    });
    if (formError) {
      formError.classList.add('hidden');
      formError.textContent = '';
    }
  }

  // Handle form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    // Hide any previous success message
    hideSuccessMessage();

    // Run client-side validation first
    const isFormValid = validateForm();
    if (!isFormValid) {
      // Focus first field with error
      const firstErrorField = form?.querySelector('[aria-invalid="true"]') as HTMLElement | null;
      firstErrorField?.focus();
      return;
    }

    clearFieldErrors();

    if (submitButton) {
      submitButton.disabled = true;
      submitButton.textContent = 'Saving...';
    }

    try {
      const formData = new FormData(form);
      const data = {
        type: String(formData.get('type') || DEFAULT_TRANSACTION_TYPE),
        amount: String(formData.get('amount') || '0'),
        currency: String(formData.get('currency') || 'IDR'),
        category_id: String(formData.get('category_id') || ''),
        payment_method_id: String(formData.get('payment_method_id') || ''),
        transaction_date: String(
          formData.get('transaction_date') || new Date().toISOString().split('T')[0]
        ),
        description: String(formData.get('description') || ''),
      };

      // Clean amount value (remove formatting)
      const rawAmount = String(data.amount).replace(/[^\d.-]/g, '');
      data.amount = rawAmount;

      const response = await fetch(action, {
        method: method,
        headers: getCsrfHeaders({
          'Content-Type': 'application/json',
        }),
        body: JSON.stringify(data),
      });

      const result = await response.json();

      if (!response.ok || !result.success) {
        // Handle validation errors
        if (result.error?.details) {
          // Field-specific errors from Zod validation
          result.error.details.forEach((issue: { path: (string | number)[]; message: string }) => {
            const fieldPath = issue.path.join('.');
            const fieldName = fieldPath || 'general';
            setFieldError(fieldName, issue.message);
          });
        } else {
          // Global error
          if (formError) {
            formError.textContent = result.error?.message || 'Failed to save transaction';
            formError.classList.remove('hidden');
          }
        }
      } else {
        // Success - save last used values to localStorage
        const formType = data.type;
        const categoryId = data.category_id;
        const paymentMethodId = data.payment_method_id;

        if (categoryId) {
          setLastUsedCategory(formType, categoryId);
        }
        if (paymentMethodId) {
          setLastUsedPaymentMethod(paymentMethodId);
        }

        // Show success message before redirect
        showSuccessMessage('Transaction saved successfully!');

        // Redirect to transactions list after short delay
        setTimeout(() => {
          window.location.href = '/transactions';
        }, 500);
      }
    } catch (err) {
      // Network or other error
      if (formError) {
        formError.textContent = 'Network error. Please try again.';
        formError.classList.remove('hidden');
      }
    } finally {
      // Keep button disabled if showing success message
      if (submitButton) {
        const isShowingSuccess = formSuccess && !formSuccess.classList.contains('hidden');
        if (!isShowingSuccess) {
          submitButton.disabled = false;
          submitButton.textContent = 'Save Transaction';
        }
      }
    }
  });

  // Initialize form with pre-selected values, validation listeners, and update displays
  attachValidationListeners();
  const wasCategoryPreselected = preselectLastUsedValues();
  // Only update currency if category was NOT pre-selected (pre-selection triggers change event)
  if (!wasCategoryPreselected) {
    updateCurrencyForCategory();
  }
  updateBudgetDisplay();
</script>
