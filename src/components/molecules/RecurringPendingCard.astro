---
import { AlertCircle, Clock, CalendarDays, CircleCheckBig, CircleMinus } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import type { RecurringOccurrenceOutput } from '@/lib/types/recurring';

export interface Props {
  occurrence: RecurringOccurrenceOutput;
}

const { occurrence } = Astro.props;

const todayIso = new Date().toISOString().slice(0, 10);
const isOverdue = occurrence.status === 'pending' && occurrence.due_date < todayIso;
const canAct = occurrence.status === 'pending' && occurrence.due_date <= todayIso;
const borderClass = isOverdue ? 'border-l-error' : 'border-l-warning';
const dueDate = new Date(`${occurrence.due_date}T00:00:00`);
const dueDateLabel = dueDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const occurrencePayload = JSON.stringify(occurrence);
const amountLabel = formatCurrency(occurrence.templateAmount, occurrence.currency);

const installmentLabel =
  occurrence.isInstallment && occurrence.totalOccurrences
    ? `${String(occurrence.occurrence_number).padStart(2, '0')}/${String(occurrence.totalOccurrences).padStart(2, '0')}`
    : null;
---

<article
  class={`card bg-base-100 border border-base-300 rounded-2xl shadow-sm overflow-hidden border-l-4 ${borderClass} hover:shadow-md transition-shadow duration-200`}
  data-testid="recurring-pending-card"
  data-occurrence-id={occurrence.id}
>
  <div class="card-body p-4 sm:p-5 gap-3">
    <div class="flex items-start justify-between gap-3">
      <div class="min-w-0 flex-1">
        <div class="flex items-center gap-2">
          {
            isOverdue ? (
              <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-error/10 shrink-0">
                <AlertCircle size={14} class="text-error" aria-hidden="true" />
              </div>
            ) : (
              <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-warning/10 shrink-0">
                <Clock size={14} class="text-warning" aria-hidden="true" />
              </div>
            )
          }
          <h3 class="font-semibold text-base-content truncate" title={occurrence.templateName}>
            {occurrence.templateName}
          </h3>
        </div>
        <p class="text-sm text-base-content/60 mt-1.5 inline-flex items-center gap-1.5 ml-9">
          <CalendarDays size={13} class="shrink-0" aria-hidden="true" />
          <span>Due {dueDateLabel}</span>
        </p>
      </div>

      {isOverdue && <span class="badge badge-error badge-sm font-bold">Overdue</span>}
    </div>

    <div class="flex flex-wrap items-center gap-2 ml-9">
      <p class="text-lg font-bold text-base-content">{amountLabel}</p>
      {
        installmentLabel && (
          <span class="badge badge-outline badge-sm font-medium">
            {occurrence.installmentLabel || 'Installment'} {installmentLabel}
          </span>
        )
      }
    </div>

    {
      canAct ? (
        <div class="flex gap-2 pt-1 ml-9">
          <button
            type="button"
            class="btn btn-accent btn-sm flex-1 min-h-[44px] rounded-xl font-semibold"
            data-open-confirm-modal
            data-occurrence={occurrencePayload}
          >
            <CircleCheckBig size={15} aria-hidden="true" />
            Confirm
          </button>
          <button
            type="button"
            class="btn btn-outline btn-warning btn-sm flex-1 min-h-[44px] rounded-xl font-semibold"
            data-open-skip-modal
            data-occurrence={occurrencePayload}
          >
            <CircleMinus size={15} aria-hidden="true" />
            Skip
          </button>
        </div>
      ) : (
        <div class="ml-9 rounded-xl border border-base-300 bg-base-200/50 px-3 py-2">
          <p class="text-xs font-medium text-base-content/60">Available on {dueDateLabel}</p>
        </div>
      )
    }
  </div>
</article>
