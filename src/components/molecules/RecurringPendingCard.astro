---
import { CircleAlert, CircleCheckBig, CircleMinus, CirclePlus } from '@lucide/astro';
import { formatCurrency } from '@/lib/formatting';
import type { RecurringOccurrenceOutput } from '@/lib/types/recurring';

export interface Props {
  occurrence: RecurringOccurrenceOutput;
}

const { occurrence } = Astro.props;

const todayIso = new Date().toISOString().slice(0, 10);
const isOverdue = occurrence.status === 'pending' && occurrence.due_date < todayIso;
const canAct = occurrence.status === 'pending' && occurrence.due_date <= todayIso;
const isExpense = occurrence.templateType === 'expense';
const typeLabel = isExpense ? 'Expense' : 'Income';
const borderClass = isExpense ? 'border-l-error' : 'border-l-success';
const typeBadgeClass = isExpense ? 'badge-error' : 'badge-success';
const typeIconWrapClass = isExpense ? 'bg-error/10' : 'bg-success/10';
const amountClass = isExpense ? 'text-error' : 'text-success';
const dueDate = new Date(`${occurrence.due_date}T00:00:00`);
const dueDateLabel = dueDate.toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
});
const dueBadgeClass = isOverdue ? 'badge-error' : canAct ? 'badge-warning' : 'badge-ghost';
const dueBadgeLabel = isOverdue ? `Overdue · ${dueDateLabel}` : `Due ${dueDateLabel}`;

const occurrencePayload = JSON.stringify(occurrence);
const amountLabel = formatCurrency(occurrence.templateAmount, occurrence.currency);

const installmentLabel =
  occurrence.isInstallment && occurrence.totalOccurrences
    ? `${String(occurrence.occurrence_number).padStart(2, '0')}/${String(occurrence.totalOccurrences).padStart(2, '0')}`
    : null;
---

<article
  class:list={[
    'rounded-2xl border border-base-300 bg-base-100 shadow-sm border-l-4 px-3 sm:px-4 py-3',
    borderClass,
  ]}
  data-testid="recurring-pending-card"
  data-occurrence-id={occurrence.id}
>
  <div class="space-y-3">
    <div class="flex min-w-0 items-start gap-3">
      <div
        class={`flex h-7 w-7 shrink-0 items-center justify-center rounded-lg ${typeIconWrapClass}`}
      >
        {
          isExpense ? (
            <CircleMinus size={14} class="text-error" aria-hidden="true" />
          ) : (
            <CirclePlus size={14} class="text-success" aria-hidden="true" />
          )
        }
      </div>

      <div class="min-w-0 flex-1 space-y-1.5">
        <div class="flex flex-wrap items-center gap-2">
          <h3
            class="truncate text-sm font-semibold text-base-content"
            title={occurrence.templateName}
          >
            {occurrence.templateName}
          </h3>
          <span class={`badge badge-sm font-bold ${typeBadgeClass}`}>{typeLabel}</span>
          {isOverdue && <CircleAlert size={14} class="text-error shrink-0" aria-hidden="true" />}
        </div>

        <div class="flex flex-wrap items-center gap-1.5">
          <span class={`text-sm font-bold ${amountClass}`}>{amountLabel}</span>
          <span class={`badge badge-sm font-semibold ${dueBadgeClass}`}>{dueBadgeLabel}</span>
          {
            installmentLabel && (
              <span class="badge badge-outline badge-sm font-medium">{installmentLabel}</span>
            )
          }
        </div>
      </div>
    </div>

    {
      canAct ? (
        <div class="grid grid-cols-1 gap-2 sm:ml-auto sm:max-w-sm sm:grid-cols-2">
          <button
            type="button"
            class="btn btn-accent h-11 min-h-11 w-full rounded-lg font-semibold sm:h-10 sm:min-h-10 sm:rounded-xl"
            data-open-confirm-modal
            data-occurrence={occurrencePayload}
          >
            <CircleCheckBig size={14} aria-hidden="true" />
            Confirm
          </button>
          <button
            type="button"
            class="btn btn-outline btn-warning h-11 min-h-11 w-full rounded-lg font-semibold sm:h-10 sm:min-h-10 sm:rounded-xl"
            data-open-skip-modal
            data-occurrence={occurrencePayload}
          >
            <CircleMinus size={14} aria-hidden="true" />
            Skip
          </button>
        </div>
      ) : (
        <p class="text-xs text-base-content/50">Available on {dueDateLabel}</p>
      )
    }
  </div>
</article>
