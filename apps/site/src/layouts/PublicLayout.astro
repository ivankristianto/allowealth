---
/**
 * PublicLayout
 *
 * Layout for public-facing pages (landing, terms, privacy, contact).
 * Includes PublicNavbar, PublicFooter, dynamic background, and theme toggle.
 */

import BaseLayout from './BaseLayout.astro';
import PublicNavbar from '@/components/layouts/PublicNavbar.astro';
import PublicFooter from '@/components/layouts/PublicFooter.astro';
import ThemeToggle from '@/components/atoms/ThemeToggle.astro';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  showBackground?: boolean;
}

const {
  title = 'allowealth',
  description,
  canonical,
  ogImage,
  ogType,
  showBackground = true,
} = Astro.props;
---

<BaseLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  ogType={ogType}
>
  <slot name="head" slot="head" />
  <!-- Skip to content link for accessibility -->
  <a
    href="#main-content"
    class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-accent focus:text-white focus:rounded-lg focus:font-bold"
  >
    Skip to content
  </a>

  <!-- Dynamic Background — lightweight radial gradients, no blur compositing -->
  {
    showBackground && (
      <div
        class="fixed inset-0 pointer-events-none z-0"
        style="background: radial-gradient(ellipse 60% 60% at 10% 10%, color-mix(in srgb, var(--color-primary) 7%, transparent) 0%, transparent 70%), radial-gradient(ellipse 50% 50% at 90% 90%, color-mix(in srgb, var(--color-accent) 7%, transparent) 0%, transparent 70%);"
        aria-hidden="true"
      />
    )
  }

  <!-- Navigation -->
  <PublicNavbar />

  <!-- Main Content -->
  <main id="main-content" class="relative z-10 min-h-screen">
    <slot />
  </main>

  <!-- Footer -->
  <PublicFooter />

  <!-- Floating Theme Toggle -->
  <ThemeToggle className="fixed bottom-6 right-6 z-50" />
</BaseLayout>

<style is:global>
  /* Smooth scroll for anchor links */
  html {
    scroll-behavior: smooth;
  }

  /* Custom animation for slow bounce */
  @keyframes bounce-slow {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-20px);
    }
  }

  /* Apply animations only when user prefers motion */
  @media (prefers-reduced-motion: no-preference) {
    .animate-bounce-slow {
      animation: bounce-slow 8s ease-in-out infinite;
    }
  }

  /* Ensure anchor targets account for fixed navbar */
  [id] {
    scroll-margin-top: 100px;
  }
</style>
