---
/**
 * 404 Page
 *
 * Playful, on-brand error page that turns a dead end into a delight.
 */

import PublicLayout from '@/layouts/PublicLayout.astro';
import { ArrowLeft, Home, Search, Ghost } from '@lucide/astro';

// Fun money-related 404 messages
const messages = [
  'This page is like that $20 you swore was in your wallet. Gone.',
  'We checked under the couch cushions. Page not found.',
  '404: Page has left to find itself. Probably at a coffee shop.',
  'This URL is currently experiencing financial difficulties.',
  "Looks like this page invested in crypto. It's vanished.",
  "We audited everywhere. This page isn't in the books.",
  "404: This link has been categorized under 'mystery expenses'.",
  "Sorry, we can't track down this page. No receipt either.",
];

// Pick a random message (using a simple hash of the current date for consistency)
const randomMessage = messages[Math.floor(Math.random() * messages.length)];
---

<PublicLayout
  title="Page Not Found | allowealth"
  description="Oops! That page seems to have vanished like unaccounted expenses."
  showBackground={false}
>
  <div class="relative min-h-screen flex items-center justify-center px-6 py-32">
    <!-- Animated background elements -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
      <div
        class="absolute top-20 left-10 w-32 h-32 bg-accent/5 rounded-full blur-3xl animate-pulse"
      >
      </div>
      <div
        class="absolute bottom-20 right-10 w-48 h-48 bg-primary/5 rounded-full blur-3xl animate-pulse"
        style="animation-delay: 1s;"
      >
      </div>
      <div
        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-accent/3 rounded-full blur-3xl"
      >
      </div>

      {/* Floating money symbols */}
      <div
        class="absolute top-1/4 left-1/4 text-6xl opacity-10 animate-bounce"
        style="animation-duration: 3s;"
      >
        💸
      </div>
      <div
        class="absolute top-1/3 right-1/4 text-4xl opacity-10 animate-bounce"
        style="animation-duration: 4s; animation-delay: 1s;"
      >
        💰
      </div>
      <div
        class="absolute bottom-1/4 left-1/3 text-5xl opacity-10 animate-bounce"
        style="animation-duration: 3.5s; animation-delay: 0.5s;"
      >
        📊
      </div>
      <div
        class="absolute bottom-1/3 right-1/3 text-4xl opacity-10 animate-bounce"
        style="animation-duration: 5s; animation-delay: 2s;"
      >
        🧾
      </div>
    </div>

    <div class="relative z-10 max-w-2xl mx-auto text-center">
      <!-- Large 404 with ghost -->
      <div class="relative inline-block mb-8">
        <div
          class="text-[8rem] sm:text-[12rem] font-black text-base-content/5 leading-none tracking-tighter select-none"
        >
          404
        </div>
        <div class="absolute inset-0 flex items-center justify-center">
          <div
            class="w-24 h-24 sm:w-32 sm:h-32 bg-accent/10 rounded-full flex items-center justify-center animate-bounce"
            style="animation-duration: 2s;"
          >
            <Ghost size={64} class="text-accent sm:w-20 sm:h-20" aria-hidden="true" />
          </div>
        </div>
      </div>

      <!-- Funny message -->
      <h1 class="text-3xl sm:text-5xl font-black text-base-content tracking-tighter mb-6">
        Page not found
      </h1>

      <p
        class="text-xl sm:text-2xl text-base-content/70 font-medium mb-4 max-w-lg mx-auto leading-relaxed"
      >
        {randomMessage}
      </p>

      <p class="text-base-content/50 mb-12">
        The page you're looking for doesn't exist or has been moved.
      </p>

      <!-- Action buttons -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href="/"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-accent text-white font-bold rounded-full hover:bg-accent-hover transition-colors shadow-lg shadow-accent/25"
        >
          <Home size={20} aria-hidden="true" />
          Take me home
        </a>

        <button
          onclick="history.back()"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-base-200 text-base-content font-bold rounded-full hover:bg-base-300 transition-colors"
        >
          <ArrowLeft size={20} aria-hidden="true" />
          Go back
        </button>
      </div>

      <!-- Suggested links -->
      <div class="mt-16 pt-8 border-t border-base-300/50">
        <p class="text-sm text-base-content/50 mb-6">Looking for something specific?</p>

        <div class="flex flex-wrap items-center justify-center gap-3">
          <a
            href="/#features"
            class="px-4 py-2 bg-base-200/50 hover:bg-base-200 rounded-full text-sm font-medium text-base-content/70 hover:text-base-content transition-colors"
          >
            Features
          </a>
          <a
            href="https://preview.allowealth.io"
            class="px-4 py-2 bg-base-200/50 hover:bg-base-200 rounded-full text-sm font-medium text-base-content/70 hover:text-base-content transition-colors"
          >
            Try Demo
          </a>
          <a
            href="https://docs.allowealth.io"
            class="px-4 py-2 bg-base-200/50 hover:bg-base-200 rounded-full text-sm font-medium text-base-content/70 hover:text-base-content transition-colors"
          >
            Documentation
          </a>
          <a
            href="https://github.com/ivankristianto/allowealth"
            class="px-4 py-2 bg-base-200/50 hover:bg-base-200 rounded-full text-sm font-medium text-base-content/70 hover:text-base-content transition-colors"
          >
            GitHub
          </a>
        </div>
      </div>

      <!-- Easter egg: Hidden Konami code hint -->
      <div class="mt-12 text-xs text-base-content/30">
        <span class="font-mono">↑↑↓↓←→←→BA</span>
      </div>
    </div>
  </div>

  <!-- Fun confetti easter egg on Konami code -->
  <script>
    // Simple Konami code implementation
    let konamiCode = [
      'ArrowUp',
      'ArrowUp',
      'ArrowDown',
      'ArrowDown',
      'ArrowLeft',
      'ArrowRight',
      'ArrowLeft',
      'ArrowRight',
      'b',
      'a',
    ];
    let konamiIndex = 0;

    document.addEventListener('keydown', (e) => {
      if (e.key === konamiCode[konamiIndex]) {
        konamiIndex++;
        if (konamiIndex === konamiCode.length) {
          activateEasterEgg();
          konamiIndex = 0;
        }
      } else {
        konamiIndex = 0;
      }
    });

    function activateEasterEgg() {
      // Create confetti effect
      const colors = ['#15803d', '#22c55e', '#0ea5e9', '#f59e0b', '#f43f5e'];

      for (let i = 0; i < 50; i++) {
        setTimeout(() => {
          const confetti = document.createElement('div');
          confetti.style.cssText = `
            position: fixed;
            width: 10px;
            height: 10px;
            background: ${colors[Math.floor(Math.random() * colors.length)]};
            left: ${Math.random() * 100}vw;
            top: -10px;
            border-radius: ${Math.random() > 0.5 ? '50%' : '0'};
            pointer-events: none;
            z-index: 9999;
            animation: confetti-fall ${1 + Math.random()}s linear forwards;
          `;
          document.body.appendChild(confetti);

          setTimeout(() => confetti.remove(), 2000);
        }, i * 30);
      }

      // Show fun message
      const message = document.createElement('div');
      message.textContent = '🎉 Cheat code activated! You found the secret!';
      message.style.cssText = `
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%);
        background: var(--color-accent);
        color: white;
        padding: 1rem 2rem;
        border-radius: 1rem;
        font-weight: bold;
        z-index: 10000;
        animation: fade-in-out 3s ease forwards;
      `;
      document.body.appendChild(message);

      setTimeout(() => message.remove(), 3000);
    }
  </script>

  <style>
    @keyframes confetti-fall {
      to {
        transform: translateY(100vh) rotate(720deg);
        opacity: 0;
      }
    }

    @keyframes fade-in-out {
      0% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
      }
      20% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
      80% {
        opacity: 1;
        transform: translate(-50%, -50%) scale(1);
      }
      100% {
        opacity: 0;
        transform: translate(-50%, -50%) scale(0.8);
      }
    }
  </style>
</PublicLayout>
