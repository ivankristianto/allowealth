---
/**
 * SpotIllustrations Component
 *
 * Custom, hand-crafted SVG illustrations to replace generic Lucide icons.
 * These add personality and a human-made feel to the landing page.
 */

interface Props {
  name:
    | 'dashboard'
    | 'transactions'
    | 'budget'
    | 'accounts'
    | 'reports'
    | 'fast'
    | 'secure'
    | 'multicultural'
    | 'households'
    | 'opensource'
    | 'forecast';
  class?: string;
}

const { name, class: className = 'w-full h-full' } = Astro.props;
---

<div class={className}>
  {
    name === 'dashboard' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <rect
          x="8"
          y="8"
          width="48"
          height="48"
          rx="8"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
        />
        <rect x="16" y="16" width="16" height="16" rx="4" fill="currentColor" opacity="0.2" />
        <rect x="36" y="16" width="12" height="8" rx="2" fill="currentColor" opacity="0.4" />
        <rect x="36" y="28" width="12" height="4" rx="2" fill="currentColor" opacity="0.3" />
        <rect x="16" y="40" width="32" height="12" rx="4" fill="currentColor" opacity="0.15" />
        <circle cx="24" cy="24" r="4" fill="currentColor" />
        <path
          d="M16 46 L24 40 L30 44 L40 36"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
      </svg>
    )
  }

  {
    name === 'transactions' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <rect
          x="8"
          y="12"
          width="48"
          height="40"
          rx="6"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
        />
        <line
          x1="16"
          y1="24"
          x2="48"
          y2="24"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          opacity="0.3"
        />
        <circle cx="20" cy="34" r="3" fill="currentColor" />
        <rect x="28" y="32" width="20" height="4" rx="2" fill="currentColor" opacity="0.3" />
        <circle cx="20" cy="46" r="3" fill="currentColor" opacity="0.5" />
        <rect x="28" y="44" width="14" height="4" rx="2" fill="currentColor" opacity="0.3" />
        <path
          d="M44 46 L48 50 L54 42"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
      </svg>
    )
  }

  {
    name === 'budget' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <rect
          x="12"
          y="8"
          width="40"
          height="48"
          rx="8"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
        />
        <circle cx="32" cy="28" r="12" stroke="currentColor" stroke-width="3" fill="none" />
        <path d="M32 28 L32 18" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
        <path d="M32 28 L40 32" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
        <rect x="20" y="48" width="24" height="4" rx="2" fill="currentColor" opacity="0.3" />
      </svg>
    )
  }

  {
    name === 'accounts' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <rect
          x="8"
          y="16"
          width="48"
          height="32"
          rx="6"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
        />
        <rect x="16" y="12" width="8" height="8" rx="2" fill="currentColor" opacity="0.5" />
        <rect x="28" y="12" width="8" height="8" rx="2" fill="currentColor" opacity="0.3" />
        <rect x="40" y="12" width="8" height="8" rx="2" fill="currentColor" opacity="0.2" />
        <text
          x="32"
          y="40"
          text-anchor="middle"
          font-family="monospace"
          font-size="14"
          font-weight="bold"
          fill="currentColor"
        >
          $ € £
        </text>
        <rect x="20" y="46" width="24" height="2" rx="1" fill="currentColor" opacity="0.3" />
      </svg>
    )
  }

  {
    name === 'reports' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <rect
          x="8"
          y="8"
          width="48"
          height="48"
          rx="8"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
        />
        <rect x="16" y="40" width="8" height="12" rx="2" fill="currentColor" />
        <rect x="28" y="32" width="8" height="20" rx="2" fill="currentColor" opacity="0.7" />
        <rect x="40" y="24" width="8" height="28" rx="2" fill="currentColor" opacity="0.4" />
        <path
          d="M14 28 L24 20 L34 26 L50 14"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <circle cx="14" cy="28" r="2" fill="currentColor" />
        <circle cx="24" cy="20" r="2" fill="currentColor" />
        <circle cx="34" cy="26" r="2" fill="currentColor" />
        <circle cx="50" cy="14" r="2" fill="currentColor" />
      </svg>
    )
  }

  {
    name === 'fast' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="2" fill="none" />
        <path
          d="M32 16 L32 32 L44 40"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <path
          d="M16 32 L20 32"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          opacity="0.4"
        />
        <path
          d="M44 32 L48 32"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          opacity="0.4"
        />
        <path
          d="M32 48 L32 52"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          opacity="0.4"
        />
      </svg>
    )
  }

  {
    name === 'secure' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <path d="M32 8 L32 4" stroke="currentColor" stroke-width="3" stroke-linecap="round" />
        <rect
          x="16"
          y="20"
          width="32"
          height="36"
          rx="4"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
        />
        <rect
          x="24"
          y="8"
          width="16"
          height="16"
          rx="2"
          stroke="currentColor"
          stroke-width="2"
          fill="none"
        />
        <circle cx="32" cy="38" r="6" stroke="currentColor" stroke-width="2" fill="none" />
        <circle cx="32" cy="38" r="2" fill="currentColor" />
        <path d="M32 44 L32 48" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
      </svg>
    )
  }

  {
    name === 'multicultural' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="2" fill="none" />
        <path d="M32 8 L32 56" stroke="currentColor" stroke-width="1" opacity="0.3" />
        <path d="M8 32 L56 32" stroke="currentColor" stroke-width="1" opacity="0.3" />
        <circle cx="32" cy="18" r="4" fill="currentColor" />
        <text x="42" y="36" font-family="system-ui" font-size="8" fill="currentColor">
          IDR
        </text>
        <text x="16" y="48" font-family="system-ui" font-size="8" fill="currentColor" opacity="0.7">
          USD
        </text>
        <text x="42" y="48" font-family="system-ui" font-size="8" fill="currentColor" opacity="0.5">
          EUR
        </text>
      </svg>
    )
  }

  {
    name === 'households' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <circle cx="20" cy="20" r="8" fill="currentColor" opacity="0.6" />
        <circle cx="44" cy="20" r="8" fill="currentColor" opacity="0.6" />
        <circle cx="32" cy="44" r="10" fill="currentColor" opacity="0.3" />
        <path d="M20 28 L20 36" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        <path d="M44 28 L44 36" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        <path d="M24 36 L40 36" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
        <path
          d="M8 56 L56 56"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          opacity="0.3"
        />
      </svg>
    )
  }

  {
    name === 'opensource' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="2" fill="none" />
        <path
          d="M32 16 C24 16 20 24 20 30 C20 38 26 44 28 46 C28 48 26 52 26 52 L32 48 L38 52 C38 52 36 48 36 46 C38 44 44 38 44 30 C44 24 40 16 32 16 Z"
          fill="currentColor"
          opacity="0.2"
          stroke="currentColor"
          stroke-width="2"
        />
      </svg>
    )
  }

  {
    name === 'forecast' && (
      <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
        <path
          d="M8 48 L20 36 L32 40 L44 24 L56 32"
          stroke="currentColor"
          stroke-width="3"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
        />
        <circle cx="8" cy="48" r="3" fill="currentColor" opacity="0.6" />
        <circle cx="20" cy="36" r="3" fill="currentColor" />
        <circle cx="32" cy="40" r="3" fill="currentColor" opacity="0.8" />
        <circle cx="44" cy="24" r="3" fill="currentColor" />
        <circle cx="56" cy="32" r="3" fill="currentColor" opacity="0.5" />
        <path
          d="M48 8 L52 12 L56 8"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          fill="none"
          opacity="0.5"
        />
        <path
          d="M52 12 L52 16"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          opacity="0.5"
        />
      </svg>
    )
  }
</div>
