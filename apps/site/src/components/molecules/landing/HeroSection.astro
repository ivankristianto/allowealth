---
/**
 * HeroSection Component
 *
 * Asymmetric two-column hero with animated typing headline,
 * product dashboard preview, and committed forest-green presence.
 */

import { Image } from 'astro:assets';
import { ArrowRight } from '@lucide/astro';
import { heroContent } from '@/lib/landing-content';
import Button from '@/components/atoms/Button.astro';
import dashboardImg from '@/assets/screenshots/dashboard.jpg';

const { typingHeadlines } = heroContent;
---

<header class="relative z-10 pt-36 sm:pt-48 pb-16 sm:pb-32 px-6 overflow-hidden">
  <!-- Background — committed forest presence, anchored to top-left -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 80% 80% at 0% 0%, color-mix(in srgb, var(--color-accent) 15%, transparent) 0%, transparent 60%), radial-gradient(ellipse 50% 50% at 100% 100%, color-mix(in srgb, var(--color-accent) 8%, transparent) 0%, transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-center">
      <!-- Content -->
      <div class="lg:col-span-7 space-y-8 sm:space-y-10">
        <!-- Label — plain text, no badge pill -->
        <span class="inline-block text-sm font-bold text-accent uppercase tracking-widest">
          {heroContent.badge}
        </span>

        <!-- Main Headline with Typing Animation -->
        <h1
          class="text-5xl sm:text-7xl md:text-8xl lg:text-[7rem] font-black tracking-tighter text-base-content leading-[0.88] mb-6 sm:mb-10"
        >
          <span class="sr-only">{typingHeadlines.join(', ')} {heroContent.titleSuffix}</span>
          <span
            class="hero-typing-wrapper block"
            data-headlines={JSON.stringify(typingHeadlines)}
            style="min-height: 2em; contain: layout;"
            aria-hidden="true"
          >
            <span class="hero-typing-text">{typingHeadlines[0]}</span>
            <span class="typing-cursor">|</span>
          </span>
          <span class="text-accent">{heroContent.titleSuffix}</span>
        </h1>

        <!-- Description -->
        <p
          class="text-base-content/70 text-lg sm:text-xl md:text-2xl font-medium max-w-xl leading-relaxed"
        >
          {heroContent.description}
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-start gap-4 sm:gap-6">
          <Button
            variant="primary"
            href={heroContent.ctaGuestHref}
            size="xl"
            className="w-full sm:w-auto"
          >
            <span>{heroContent.ctaGuest}</span>
            <ArrowRight size={20} class="stroke-current" aria-hidden="true" />
          </Button>

          <Button
            variant="secondary"
            href={heroContent.ctaSecondaryHref ?? '#showcase'}
            size="xl"
            className="w-full sm:w-auto"
          >
            {heroContent.ctaSecondary}
          </Button>
        </div>
      </div>

      <!-- Product Preview -->
      <div class="lg:col-span-5 hidden lg:block">
        <div class="relative group">
          <div
            class="relative p-2 bg-base-200/40 rounded-3xl border border-base-300 shadow-2xl overflow-hidden"
          >
            <Image
              src={dashboardImg}
              alt="allowealth Dashboard"
              class="w-full h-auto rounded-2xl grayscale-[0.1] group-hover:grayscale-0 transition-all duration-700"
              loading="eager"
              widths={[400, 600, 800]}
              sizes="(min-width: 1024px) 40vw, 100vw"
            />
          </div>
          <!-- Accent glow behind the card — radial gradient, no blur compositing -->
          <div
            class="absolute -inset-6 -z-10 pointer-events-none"
            style="background: radial-gradient(ellipse at center, color-mix(in srgb, var(--color-accent) 18%, transparent) 0%, transparent 65%);"
            aria-hidden="true"
          >
          </div>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Typing animation for hero headline
  document.addEventListener('DOMContentLoaded', () => {
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const wrapper = document.querySelector('.hero-typing-wrapper') as HTMLElement | null;
    const typingElement = wrapper?.querySelector('.hero-typing-text') as HTMLElement | null;

    if (!wrapper || !typingElement) return;

    const headlines = JSON.parse(wrapper.dataset.headlines || '[]');
    if (!Array.isArray(headlines) || headlines.length === 0) return;

    let currentIndex = 0;
    let isTyping = true;
    let charIndex = 0;
    let timeoutId: ReturnType<typeof setTimeout> | null = null;
    let isActive = true;

    const TYPING_SPEED = 60;
    const DELETING_SPEED = 40;
    const PAUSE_AFTER_TYPE = 3000;
    const PAUSE_AFTER_DELETE = 500;

    function cleanup() {
      isActive = false;
      if (timeoutId) {
        clearTimeout(timeoutId);
        timeoutId = null;
      }
    }

    function scheduleNext(callback: () => void, delay: number) {
      if (!isActive) return;
      timeoutId = setTimeout(() => {
        if (isActive) callback();
      }, delay);
    }

    function type() {
      if (!isActive) return;

      const fullText = headlines[currentIndex];

      if (isTyping) {
        if (charIndex < fullText.length) {
          typingElement!.textContent = fullText.slice(0, charIndex + 1);
          charIndex++;
          scheduleNext(type, TYPING_SPEED);
        } else {
          isTyping = false;
          scheduleNext(type, PAUSE_AFTER_TYPE);
        }
      } else {
        if (charIndex > 0) {
          typingElement!.textContent = fullText.slice(0, charIndex - 1);
          charIndex--;
          scheduleNext(type, DELETING_SPEED);
        } else {
          currentIndex = (currentIndex + 1) % headlines.length;
          isTyping = true;
          scheduleNext(type, PAUSE_AFTER_DELETE);
        }
      }
    }

    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cleanup();
      } else {
        isActive = true;
        type();
      }
    });

    scheduleNext(type, 800);
  });
</script>

<style>
  .hero-typing-wrapper {
    text-wrap: balance;
    word-break: normal;
    overflow-wrap: break-word;
  }

  .typing-cursor {
    animation: blink 1s step-end infinite;
    color: var(--color-accent);
    margin-left: 2px;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  @media (max-width: 639px) {
    .hero-typing-wrapper {
      min-height: 2.4em;
    }
  }

  @media (min-width: 640px) and (max-width: 767px) {
    .hero-typing-wrapper {
      min-height: 2.2em;
    }
  }

  @media (min-width: 768px) {
    .hero-typing-wrapper {
      min-height: 2em;
    }
  }
</style>
