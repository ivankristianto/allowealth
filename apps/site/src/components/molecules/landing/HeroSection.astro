---
/**
 * HeroSection Component
 *
 * Landing page hero with animated typing headline, badge, description, and CTAs.
 */

import { Sparkles, ArrowRight } from '@lucide/astro';
import { heroContent } from '@/lib/landing-content';
import Button from '@/components/atoms/Button.astro';

const { typingHeadlines } = heroContent;
---

<header class="relative z-10 pt-36 sm:pt-48 pb-16 sm:pb-32 px-6 overflow-hidden">
  <!-- Hero Background Gradient — lightweight radial, no blur compositing -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 70% 70% at 20% 20%, color-mix(in srgb, var(--color-accent) 10%, transparent) 0%, transparent 70%), radial-gradient(ellipse 60% 60% at 80% 80%, color-mix(in srgb, var(--color-accent) 5%, transparent) 0%, transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-7xl mx-auto text-center">
    <!-- Badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-1.5 bg-accent/10 border border-accent/20 rounded-full mb-8 sm:mb-12"
    >
      <Sparkles size={14} class="text-accent" aria-hidden="true" />
      <span class="text-xs font-bold text-accent uppercase tracking-widest">
        {heroContent.badge}
      </span>
    </div>

    <!-- Main Headline with Typing Animation -->
    <h1
      class="text-4xl sm:text-6xl md:text-8xl lg:text-9xl font-black tracking-tighter text-base-content leading-[0.9] mb-6 sm:mb-10"
    >
      <span class="sr-only">{typingHeadlines.join(', ')} {heroContent.titleSuffix}</span>
      <span
        class="hero-typing-wrapper block"
        data-headlines={JSON.stringify(typingHeadlines)}
        style="min-height: 2em; contain: layout;"
        aria-hidden="true"
      >
        <span class="hero-typing-text">{typingHeadlines[0]}</span>
        <span class="typing-cursor">|</span>
      </span>
      <span class="text-accent">{heroContent.titleSuffix}</span>
    </h1>

    <!-- Description -->
    <p
      class="text-base-content/70 text-base sm:text-lg md:text-2xl font-medium max-w-3xl mx-auto leading-relaxed mb-10 sm:mb-16"
    >
      {heroContent.description}
    </p>

    <!-- CTA Buttons -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
      <!-- Primary CTA -->
      <Button
        variant="primary"
        href={heroContent.ctaGuestHref}
        size="xl"
        className="w-full sm:w-auto"
      >
        <span>{heroContent.ctaGuest}</span>
        <ArrowRight size={20} class="stroke-current" aria-hidden="true" />
      </Button>

      <!-- Secondary CTA -->
      <Button
        variant="secondary"
        href={heroContent.ctaSecondaryHref ?? '#showcase'}
        size="xl"
        className="w-full sm:w-auto"
      >
        {heroContent.ctaSecondary}
      </Button>
    </div>
  </div>
</header>

<script>
  // Typing animation for hero headline
  document.addEventListener('DOMContentLoaded', () => {
    // Respect user's motion preferences
    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) return;

    const wrapper = document.querySelector('.hero-typing-wrapper') as HTMLElement | null;
    const typingElement = wrapper?.querySelector('.hero-typing-text') as HTMLElement | null;

    if (!wrapper || !typingElement) return;

    const headlines = JSON.parse(wrapper.dataset.headlines || '[]');
    if (!Array.isArray(headlines) || headlines.length === 0) return;

    let currentIndex = 0;
    let isTyping = true;
    let charIndex = 0;
    let timeoutId: ReturnType<typeof setTimeout> | null = null;
    let isActive = true;

    const TYPING_SPEED = 60; // ms per character
    const DELETING_SPEED = 40; // ms per character
    const PAUSE_AFTER_TYPE = 3000; // ms to pause after typing
    const PAUSE_AFTER_DELETE = 500; // ms to pause after deleting

    function cleanup() {
      isActive = false;
      if (timeoutId) {
        clearTimeout(timeoutId);
        timeoutId = null;
      }
    }

    function scheduleNext(callback: () => void, delay: number) {
      if (!isActive) return;
      timeoutId = setTimeout(() => {
        if (isActive) callback();
      }, delay);
    }

    function type() {
      if (!isActive) return;

      const fullText = headlines[currentIndex];

      if (isTyping) {
        // Typing forward
        if (charIndex < fullText.length) {
          typingElement!.textContent = fullText.slice(0, charIndex + 1);
          charIndex++;
          scheduleNext(type, TYPING_SPEED);
        } else {
          // Finished typing, pause before deleting
          isTyping = false;
          scheduleNext(type, PAUSE_AFTER_TYPE);
        }
      } else {
        // Deleting backward
        if (charIndex > 0) {
          typingElement!.textContent = fullText.slice(0, charIndex - 1);
          charIndex--;
          scheduleNext(type, DELETING_SPEED);
        } else {
          // Finished deleting, move to next headline
          currentIndex = (currentIndex + 1) % headlines.length;
          isTyping = true;
          scheduleNext(type, PAUSE_AFTER_DELETE);
        }
      }
    }

    // Cleanup on page hide/unload
    document.addEventListener('visibilitychange', () => {
      if (document.hidden) {
        cleanup();
      } else {
        // Resume animation when page becomes visible again
        isActive = true;
        type();
      }
    });

    // Start the typing animation
    scheduleNext(type, 800);
  });
</script>

<style>
  /* Wrapper for typing animation */
  .hero-typing-wrapper {
    text-wrap: balance;
    word-break: normal;
    overflow-wrap: break-word;
  }

  /* Blinking cursor */
  .typing-cursor {
    animation: blink 1s step-end infinite;
    color: var(--color-accent);
    margin-left: 2px;
  }

  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  /* Ensure consistent height across breakpoints */
  @media (max-width: 639px) {
    .hero-typing-wrapper {
      min-height: 2.4em;
    }
  }

  @media (min-width: 640px) and (max-width: 767px) {
    .hero-typing-wrapper {
      min-height: 2.2em;
    }
  }

  @media (min-width: 768px) {
    .hero-typing-wrapper {
      min-height: 2em;
    }
  }
</style>
