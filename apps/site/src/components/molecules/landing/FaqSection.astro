---
/**
 * FaqSection Component
 *
 * An interactive, polished FAQ section with animated accordions.
 */

import { faqItems } from '@/lib/landing-content';
import { Plus } from '@lucide/astro';
---

<section
  id="faq"
  class="relative z-10 px-6 py-24 sm:py-32 bg-base-100 overflow-hidden"
  aria-labelledby="faq-title"
>
  <!-- Background decoration — lightweight radial, no blur compositing -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 60% 40% at 50% 0%, color-mix(in srgb, var(--color-accent) 5%, transparent) 0%, transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="relative max-w-4xl mx-auto">
    <!-- Section Header -->
    <header class="text-center mb-16 sm:mb-24 faq-header opacity-0 translate-y-8">
      <div
        class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-base-200 border border-base-300 text-sm font-medium text-base-content/60 mb-6"
      >
        <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
        Got questions?
      </div>
      <h2
        id="faq-title"
        class="text-4xl sm:text-5xl md:text-7xl font-black text-base-content tracking-tighter mb-6 leading-[1.1]"
      >
        Clear answers,<br />
        <span class="text-accent italic">no confusion.</span>
      </h2>
      <p class="text-base-content/70 text-lg sm:text-xl font-medium max-w-2xl mx-auto">
        Everything you need to know before you take control of your finances.
      </p>
    </header>

    <!-- FAQ Accordion -->
    <div class="space-y-4 sm:space-y-6 faq-list">
      {
        faqItems.map((item, index) => (
          <article class="faq-item group opacity-0 translate-y-8 rounded-3xl bg-base-200/50 border border-base-300/50 hover:border-accent/30 hover:bg-base-200 transition-colors duration-300 overflow-hidden">
            <button
              class="faq-button flex w-full items-center justify-between p-6 sm:p-8 text-left focus:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-base-100 rounded-3xl"
              aria-expanded="false"
              aria-controls={`faq-answer-${index}`}
              id={`faq-question-${index}`}
            >
              <h3 class="text-xl sm:text-2xl font-bold text-base-content tracking-tight pr-8">
                {item.question}
              </h3>
              <div class="faq-icon-wrapper flex-shrink-0 w-10 h-10 rounded-full bg-base-100 border border-base-300 flex items-center justify-center text-base-content/60 group-hover:text-accent group-hover:border-accent/30 transition-all duration-300">
                <Plus
                  size={20}
                  class="faq-icon transition-transform duration-500"
                  aria-hidden="true"
                />
              </div>
            </button>
            <div
              id={`faq-answer-${index}`}
              role="region"
              aria-labelledby={`faq-question-${index}`}
              class="faq-content faq-collapsed"
            >
              <div class="p-6 sm:p-8 pt-0 text-base-content/70 sm:text-lg leading-relaxed border-t border-base-300/30">
                <p>{item.answer}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <!-- Secondary CTA -->
    <div class="mt-20 text-center faq-footer opacity-0">
      <div
        class="inline-flex flex-col sm:flex-row items-center justify-center gap-4 p-8 rounded-3xl bg-base-200/80 border border-base-300/80 shadow-sm w-full relative overflow-hidden group"
      >
        <!-- Glow effect -->
        <div
          class="absolute inset-0 bg-gradient-to-r from-accent/0 via-accent/5 to-info/0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 pointer-events-none"
        >
        </div>

        <p class="text-base-content text-lg font-bold relative z-10">Still have questions?</p>
        <div class="hidden sm:block w-1 h-1 rounded-full bg-base-content/20 relative z-10"></div>
        <a
          href="https://github.com/ivankristianto/allowealth/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="relative z-10 inline-flex items-center gap-2 text-accent font-bold hover:text-accent-focus transition-colors"
        >
          <span>Ask us on GitHub</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform group-hover:translate-x-1"
            ><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  // Wait for the DOM to be fully loaded
  document.addEventListener('DOMContentLoaded', () => {
    const faqSection = document.getElementById('faq');
    if (!faqSection) return;

    const observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          observer.disconnect();
          initFaq();
        }
      },
      { rootMargin: '200px' }
    );

    observer.observe(faqSection);

    async function initFaq() {
      const { animate } = await import('motion/mini');

      // 1. Entrance Animations
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (!prefersReducedMotion) {
        // Header animation
        const header = document.querySelector('.faq-header');
        if (header) {
          animate(
            header,
            { opacity: [0, 1], y: [32, 0] },
            { duration: 0.8, ease: [0.16, 1, 0.3, 1] }
          );
        }

        // Staggered list animation
        const items = document.querySelectorAll('.faq-item');
        items.forEach((item, index) => {
          animate(
            item,
            { opacity: [0, 1], y: [32, 0] },
            { duration: 0.8, delay: 0.1 + index * 0.1, ease: [0.16, 1, 0.3, 1] }
          );
        });

        // Footer animation
        const footer = document.querySelector('.faq-footer');
        if (footer) {
          animate(footer, { opacity: [0, 1] }, { duration: 1, delay: 0.6 });
        }
      } else {
        // Fallback for reduced motion
        document.querySelectorAll('.faq-header, .faq-item, .faq-footer').forEach((el) => {
          el.classList.remove('opacity-0', 'translate-y-8');
        });
      }

      // 2. Accordion Logic — uses grid-template-rows, not height
      const faqButtons = document.querySelectorAll('.faq-button');

      faqButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const isExpanded = button.getAttribute('aria-expanded') === 'true';
          const content = button.nextElementSibling as HTMLElement;
          const icon = button.querySelector('.faq-icon') as HTMLElement;
          const iconWrapper = button.querySelector('.faq-icon-wrapper') as HTMLElement;

          // Close all other accordions
          faqButtons.forEach((otherButton) => {
            if (otherButton !== button && otherButton.getAttribute('aria-expanded') === 'true') {
              const otherIcon = otherButton.querySelector('.faq-icon') as HTMLElement;
              const otherIconWrapper = otherButton.querySelector(
                '.faq-icon-wrapper'
              ) as HTMLElement;
              const otherContent = otherButton.nextElementSibling as HTMLElement;

              otherButton.setAttribute('aria-expanded', 'false');
              otherIcon.style.transform = 'rotate(0deg)';
              otherIconWrapper.classList.remove('bg-accent', 'text-white', 'border-accent');
              otherIconWrapper.classList.add('bg-base-100', 'text-base-content/60');
              otherContent.classList.add('faq-collapsed');
              otherContent.classList.remove('faq-expanded');
            }
          });

          // Toggle current accordion
          if (!isExpanded) {
            button.setAttribute('aria-expanded', 'true');
            icon.style.transform = 'rotate(45deg)';
            iconWrapper.classList.remove('bg-base-100', 'text-base-content/60');
            iconWrapper.classList.add('bg-accent', 'text-white', 'border-accent');
            content.classList.remove('faq-collapsed');
            content.classList.add('faq-expanded');
          } else {
            button.setAttribute('aria-expanded', 'false');
            icon.style.transform = 'rotate(0deg)';
            iconWrapper.classList.remove('bg-accent', 'text-white', 'border-accent');
            iconWrapper.classList.add('bg-base-100', 'text-base-content/60');
            content.classList.add('faq-collapsed');
            content.classList.remove('faq-expanded');
          }
        });
      });
    }
  });
</script>

<style>
  /* Accordion expand/collapse via grid-template-rows (no layout animation) */
  .faq-content {
    display: grid;
    grid-template-rows: 1fr;
    transition: grid-template-rows 0.4s cubic-bezier(0.32, 0.72, 0, 1);
  }

  .faq-content.faq-collapsed {
    grid-template-rows: 0fr;
  }

  .faq-content > div {
    overflow: hidden;
  }

  /* Ensure smooth transitions on the icon wrapper */
  .faq-icon-wrapper {
    transition-property: color, background-color, border-color, text-decoration-color, fill, stroke;
    transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    transition-duration: 300ms;
  }
</style>
