      "info": "#6366f1"
    }
  },
  "typography": {
    "fontFamily": {
      "primary": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "fallback": "sans-serif"
    },
    "fontWeights": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSizes": {
      "xs": "0.625rem",
      "sm": "0.75rem",
      "base": "0.8125rem",
      "md": "0.875rem",
      "lg": "1rem",
      "xl": "1.25rem",
      "2xl": "1.5rem",
      "3xl": "1.875rem"
    },
    "lineHeights": {
      "none": "1",
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.625"
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em"
    }
  },
  "spacing": {
    "0": "0",
    "0.5": "0.125rem",
    "1": "0.25rem",
    "1.5": "0.375rem",
    "2": "0.5rem",
    "2.5": "0.625rem",
    "3": "0.75rem",
    "3.5": "0.875rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "7": "1.75rem",
    "8": "2rem",
    "9": "2.25rem",
    "10": "2.5rem",
    "12": "3rem",
    "24": "6rem"
  },
  "borderRadius": {
    "sm": "0.25rem",
    "md": "0.5rem",
    "lg": "0.75rem",
    "xl": "1rem",
    "2xl": "1.25rem",
    "full": "9999px",
    "premium": "0.75rem",
    "premiumLg": "1.25rem"
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
    "premium": "0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px 0 rgba(0, 0, 0, 0.03)",
    "md": "0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06)",
    "lg": "0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05)",
    "xl": "0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04)",
    "2xl": "0 25px 50px -12px rgba(0, 0, 0, 0.25)",
    "accentGlow": "0 10px 15px -3px rgba(99, 102, 241, 0.2)",
    "accentGlowLg": "0 25px 50px -12px rgba(99, 102, 241, 0.3)"
  },
  "effects": {
    "blur": {
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "2xl": "24px",
      "3xl": "48px"
    },
    "backdropBlur": {
      "glass": "12px"
    },
    "transitions": {
      "fast": "150ms",
      "base": "300ms",
      "slow": "500ms",
      "slower": "1000ms"
    },
    "opacity": {
      "glass": {
        "light": "0.8",
        "dark": "0.8"
      },
      "overlay": "0.1",
      "disabled": "0.5"
    }
  },
  "components": {
    "button": {
      "sizes": {
        "sm": {
          "padding": "0.375rem 0.75rem",
          "fontSize": "0.75rem",
          "height": "2rem"
        },
        "md": {
          "padding": "0.625rem 1.25rem",
          "fontSize": "0.875rem",
          "height": "2.5rem"
        },
        "lg": {
          "padding": "0.75rem 1.5rem",
          "fontSize": "0.875rem",
          "height": "3rem"
        }
      },
      "variants": {
        "primary": {
          "background": "#6366f1",
          "color": "#ffffff",
          "shadow": "0 10px 15px -3px rgba(99, 102, 241, 0.2)"
        },
        "secondary": {
          "background": "#0f172a",
          "color": "#ffffff"
        },
        "ghost": {
          "background": "transparent",
          "border": "1px solid #e2e8f0"
        }
      }
    },
    "card": {
      "padding": "1.75rem",
      "borderRadius": "1.25rem",
      "border": "1px solid",
      "borderColor": {
        "light": "#e2e8f0",
        "dark": "#1e293b"
      },
      "background": {
        "light": "#ffffff",
        "dark": "#0f172a"
      },
      "shadow": "0 1px 3px 0 rgba(0, 0, 0, 0.05), 0 1px 2px 0 rgba(0, 0, 0, 0.03)"
    },
    "input": {
      "height": "2.5rem",
      "padding": "0.5rem 2.5rem 0.5rem 0.75rem",
      "fontSize": "0.75rem",
      "borderRadius": "0.75rem",
      "background": {
        "light": "#f1f5f9",
        "dark": "#1e293b"
      },
      "focusRing": "2px solid rgba(99, 102, 241, 0.2)"
    },
    "badge": {
      "padding": "0.25rem 0.625rem",
      "fontSize": "0.625rem",
      "borderRadius": "9999px",
      "fontWeight": 700
    },
    "sidebar": {
      "width": "16rem",
      "background": {
        "light": "#ffffff",
        "dark": "#0f172a"
      },
      "border": {
        "light": "#e2e8f0",
        "dark": "#1e293b"
      },
      "navItem": {
        "padding": "0.625rem 1rem",
        "gap": "0.75rem",
        "iconSize": "22px"
      },
      "activeGradient": "linear-gradient(90deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0) 100%)",
      "activeBorder": "2px solid #6366f1"
    },
    "table": {
      "headerBackground": {
        "light": "rgba(248, 250, 252, 0.5)",
        "dark": "rgba(30, 41, 59, 0.5)"
      },
      "rowHover": {
        "light": "#f8fafc",
        "dark": "rgba(30, 41, 59, 0.4)"
      },
      "cellPadding": "1rem 1.5rem",
      "iconSize": "22px"
    }
  },
  "layout": {
    "container": {
      "maxWidth": "1400px",
      "padding": {
        "mobile": "1.5rem",
        "desktop": "3rem"
      }
    },
    "header": {
      "height": "5rem",
      "padding": "1.25rem"
    },
    "bottomNav": {
      "height": "4rem",
      "padding": "0.75rem 1rem"
    },
    "breakpoints": {
      "sm": "640px",
      "md": "768px",
      "lg": "1024px",
      "xl": "1280px",
      "2xl": "1536px"
    }
  },
  "icons": {
    "library": "lucide",
    "package": "lucide-astro",
    "usage": "import { IconName } from 'lucide-astro'; <IconName size={size} />",
    "sizes": {
      "xs": 16,
      "sm": 20,
      "md": 22,
      "lg": 24,
      "xl": 32
    },
    "strokeWidth": {
      "thin": 1.5,
      "regular": 2,
      "bold": 2.5
    },
    "categories": {
      "groceries": "ShoppingBasket",
      "utilities": "Zap",
      "media": "Film",
      "income": "Wallet",
      "wallet": "Wallet",
      "shopping": "ShoppingCart",
      "dashboard": "LayoutDashboard",
      "transactions": "Receipt",
      "budgets": "PieChart",
      "assets": "GitBranch",
      "analytics": "BarChart3",
      "settings": "Settings",
      "notifications": "Bell",
      "search": "Search",
      "add": "Plus",
      "trendingUp": "TrendingUp",
      "arrowDown": "ArrowDown",
      "arrowUp": "ArrowUp",
      "tips": "Lightbulb",
      "chevronRight": "ChevronRight",
      "unfoldMore": "ChevronsUpDown",
      "contrast": "Sun",
      "moon": "Moon",
      "menu": "Menu",
      "close": "X",
      "check": "Check",
      "info": "Info",
      "alertCircle": "AlertCircle",
      "alertTriangle": "AlertTriangle",
      "chevronDown": "ChevronDown",
      "chevronLeft": "ChevronLeft",
      "externalLink": "ExternalLink",
      "download": "Download",
      "upload": "Upload",
      "edit": "Pencil",
      "trash": "Trash2",
      "moreVertical": "MoreVertical",
      "moreHorizontal": "MoreHorizontal",
      "filter": "Filter",
      "calendar": "Calendar",
      "clock": "Clock",
      "user": "User",
      "users": "Users",
      "creditCard": "CreditCard",
      "dollarSign": "DollarSign",
      "home": "Home",
      "folder": "Folder",
      "file": "FileText",
      "image": "Image",
      "eye": "Eye",
      "eyeOff": "EyeOff",
      "lock": "Lock",
      "unlock": "Unlock",
      "mail": "Mail",
      "phone": "Phone",
      "mapPin": "MapPin",
      "globe": "Globe",
      "share": "Share2",
      "copy": "Copy",
      "link": "Link",
      "refresh": "RefreshCw",
      "logout": "LogOut"
    }
  },
  "resources": {
    "fonts": {
      "inter": {
        "url": "https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap",
        "weights": [300, 400, 500, 600, 700]
      }
    },
    "cdn": {
      "tailwind": "https://cdn.tailwindcss.com?plugins=forms,container-queries"
    },
    "packages": {
      "icons": {
        "name": "lucide-astro",
        "version": "latest",
        "install": "bun add lucide-astro"
      }
    }
  },
  "animation": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms",
      "slower": "1000ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "transforms": {
      "buttonPress": "scale(0.98)",
      "hover": "scale(1.1)"
    }
  },
  "patterns": {
    "glass": {
      "backdropFilter": "blur(12px)",
      "background": {
        "light": "rgba(255, 255, 255, 0.8)",
        "dark": "rgba(15, 23, 42, 0.8)"
      }
    },
    "gradient": {
      "sidebarActive": "linear-gradient(90deg, rgba(99, 102, 241, 0.1) 0%, rgba(99, 102, 241, 0) 100%)",
      "accentGlow": "radial-gradient(circle, rgba(255, 255, 255, 0.1) 0%, transparent 70%)"
    }
  },
  "accessibility": {
    "focusRing": {
      "width": "2px",
      "color": "rgba(99, 102, 241, 0.2)",
      "offset": "2px"
    },
    "minTouchTarget": "44px",
    "contrastRatios": {
      "normalText": "4.5:1",
      "largeText": "3:1",
      "uiComponents": "3:1"
    }
  }
}
