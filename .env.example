# Environment
NODE_ENV=development

# API Configuration
# Base URL for API endpoints (default: /api for same-origin requests)
# Use absolute URL for production with separate API domain
# Examples:
# - Development (same origin): PUBLIC_API_URL=/api
# - Production (same origin): PUBLIC_API_URL=/api
# - Production (separate domain): PUBLIC_API_URL=https://api.example.com
PUBLIC_API_URL=/api

# Database Configuration
# Auto-detects type from URL format:
#
# SQLite (Development - default):
DATABASE_URL=db/.dev.db
#
# PostgreSQL (Local):
# DATABASE_URL=postgresql://user:password@localhost:5432/expenses
#
# Supabase (Staging/Production):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Session Secret (generate a secure random string)
SESSION_SECRET=change-this-in-production

# Server
PORT=4321

# Development Host
# Set a custom hostname for local development (e.g., for use with dnsmasq)
# Leave empty or remove to listen on all interfaces (0.0.0.0)
# DEV_HOST=k2-expenses.local
