# Environment
NODE_ENV=development

# API Configuration
# Base URL for API endpoints (default: /api for same-origin requests)
# Use absolute URL for production with separate API domain
# Examples:
# - Development (same origin): PUBLIC_API_URL=/api
# - Production (same origin): PUBLIC_API_URL=/api
# - Production (separate domain): PUBLIC_API_URL=https://api.example.com
PUBLIC_API_URL=/api

# Public URL of the application (used in email links, etc.)
# Examples:
# - Development: PUBLIC_URL=http://whatever.expenses.local:4322
# - Production: PUBLIC_URL=https://allowealth.io
# PUBLIC_URL=https://allowealth.io

# App mode
# full = marketing site and app routes are available
# app_only = /, /terms, and /privacy redirect into the app
APP_MODE=full

# Signup Policy
# invite_only = registration requires invitation token
# public = open registration allowed
SIGNUP_MODE=invite_only

# Database Configuration
# Auto-detects type from URL format:
#
# SQLite (Development - default):
DATABASE_URL=db/.dev.db
#
# PostgreSQL (Local):
# DATABASE_URL=postgresql://user:password@localhost:5432/expenses
#
# Supabase (Staging/Production):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Session Secret (generate a secure random string)
SESSION_SECRET=change-this-in-production

# Server
PORT=4321

# Development Host
# Set a custom hostname for local development (e.g., for use with dnsmasq)
# Leave empty or remove to listen on all interfaces (0.0.0.0)
# DEV_HOST=k2.expenses.local

# Email Configuration
# "console" = log emails to console (for development)
# "real" = send via configured provider (default for production)
EMAIL_MODE=console

# Email provider: "resend" | "sendgrid"
EMAIL_PROVIDER=resend

# API key from your email provider dashboard (plain text)
EMAIL_API_KEY=

# Sender display name and verified email address
EMAIL_SENDER_NAME=Allowealth
EMAIL_SENDER_ADDRESS=

# Encryption Key (required for encrypted secrets)
# Base64-encoded 32-byte key used for sensitive data encryption
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
EMAIL_ENCRYPTION_KEY=

# MFA Configuration
# Reuses EMAIL_ENCRYPTION_KEY for TOTP secret encryption (AES-256-GCM)
# If you need separate keys, add MFA_ENCRYPTION_KEY here

# Cookie signing (recommended dedicated secret)
# Falls back to GOOGLE_CLIENT_SECRET or EMAIL_ENCRYPTION_KEY when unset.
COOKIE_SIGNING_SECRET=

# Cache Configuration
# Driver: "upstash" | "memory" | "none"
CACHE_DRIVER=memory

# Upstash Redis (required when CACHE_DRIVER=upstash)
# Get credentials from https://console.upstash.com/
UPSTASH_REDIS_REST_TOKEN=
UPSTASH_REDIS_REST_URL=

# Performance Debugging
# Enable Server-Timing header for performance metrics
# View in browser DevTools > Network > select request > Timing tab
PERF_DEBUG=false

# Cloudflare Turnstile (Bot Protection)
# Get keys from: https://dash.cloudflare.com/?to=/:account/turnstile
# Test keys for development:
#   Site Key (always passes): 1x00000000000000000000AA
#   Site Key (always fails):  2x00000000000000000000AB
#   Secret Key (always passes): 1x0000000000000000000000000000000AA
#   Secret Key (always fails):  2x0000000000000000000000000000000AA
PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Google OAuth (SSO)
# Get credentials from: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:4322/api/auth/google/callback (dev)
# Uses PUBLIC_URL (above) for OAuth redirect URI
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cloudflare D1 (CLI remote access)
# Required for `bun run aw --target d1` commands.
# Generate at: https://dash.cloudflare.com/profile/api-tokens
# Permissions needed: D1 Edit
# CLOUDFLARE_TOKEN=
