{
  "name": "allowealth",
  "version": "0.29.2",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --bun astro dev",
    "docs:dev": "bun run --cwd apps/docs dev",
    "docs:build": "bun run --cwd apps/docs build",
    "docs:preview": "bun run --cwd apps/docs preview",
    "docs:check": "bun run --cwd apps/docs astro check",
    "docs:deploy": "bun run docs:build && cd apps/docs && wrangler pages deploy",
    "landing:dev": "bun run --cwd apps/site dev",
    "landing:build": "bun run --cwd apps/site build",
    "landing:preview": "bun run --cwd apps/site preview",
    "landing:check": "bun run --cwd apps/site astro check",
    "landing:deploy": "bun run landing:build && cd apps/site && wrangler pages deploy",
    "build": "astro build",
    "build:analyze": "bun run build && echo '\n📊 Bundle analysis available at dist/stats.html'",
    "build:node": "DEPLOY_TARGET=node astro build",
    "build:cloudflare": "DEPLOY_TARGET=cloudflare astro build",
    "deploy:cloudflare": "bun run build:cloudflare && wrangler deploy",
    "docker:start": "./scripts/docker-start.sh",
    "docker:seed": "./scripts/docker-seed.sh",
    "docker:stop": "docker compose -f docker/docker-compose.yml down",
    "bundle:report": "bun run build && bun run scripts/analyze-bundle.ts",
    "preview": "bun --bun --env-file=.env astro preview",
    "preview:prod": "bun --bun --env-file=.env.production astro preview",
    "astro": "astro",
    "lint": "eslint . --format ./scripts/eslint-minimal-formatter.cjs --no-warn-ignored",
    "lint:fix": "eslint . --fix --format ./scripts/eslint-minimal-formatter.cjs --no-warn-ignored",
    "format": "prettier --list-different .",
    "format:fix": "prettier --write . --log-level error",
    "stylelint": "stylelint \"**/*.css\" --quiet --formatter compact",
    "stylelint:fix": "stylelint \"**/*.css\" --fix --quiet --formatter compact",
    "typecheck": "astro check --minimumSeverity hint --minimumFailingSeverity error",
    "prepare": "husky install",
    "db:setup": "bun run src/db/setup.ts",
    "db:migrate": "bun run src/db/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:seed": "bun run src/db/seed/index.ts",
    "db:seed:stress": "bun run src/db/seed/index.ts --stress",
    "db:reset": "mkdir -p db && rm -f db/.dev.db db/.dev.db-wal db/.dev.db-shm && bun run db:migrate && bun run db:seed",
    "db:empty": "bun run src/db/empty.ts",
    "test": "bun test --only-failures --dots",
    "tests": "bun run test",
    "test:watch": "bun test --watch",
    "test:coverage": "bun test --coverage",
    "test:e2e:setup": "./scripts/setup-e2e.sh",
    "test:e2e": "playwright test --config=e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=e2e/playwright.config.ts --headed",
    "test:e2e:debug": "playwright test --config=e2e/playwright.config.ts --debug",
    "test:e2e:report": "playwright show-report test-results/playwright-report",
    "test:e2e:critical": "playwright test --config=e2e/playwright.config.ts --grep @critical",
    "release": "bun run scripts/release.ts",
    "aw": "bun run src/cli/index.ts"
  },
  "dependencies": {
    "@astrojs/node": "^10.0.3",
    "@better-auth/passkey": "^1.5.5",
    "@lucide/astro": "^0.562.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@tailwindcss/vite": "^4.1.18",
    "@upstash/redis": "^1.36.2",
    "astro": "6.0.8",
    "better-auth": "^1.5.4",
    "chart.js": "^4.5.1",
    "citty": "^0.2.1",
    "consola": "^3.4.2",
    "daisyui": "^5.5.14",
    "decimal.js": "^10.6.0",
    "drizzle-orm": "^0.45.1",
    "hash-wasm": "^4.12.0",
    "lucide": "^0.562.0",
    "motion": "^12.29.2",
    "nanoid": "^5.1.6",
    "nanostores": "^1.1.0",
    "qrcode": "^1.5.4",
    "simple-icons": "^16.6.1",
    "tailwindcss": "^4.1.18",
    "valibot": "^1.1.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.3",
    "@astrojs/ts-plugin": "^1.10.7",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/decimal.js": "^7.4.3",
    "@types/qrcode": "^1.5.6",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "bun-types": "^1.3.8",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^1.6.0",
    "eslint-plugin-prettier": "^5.5.5",
    "happy-dom": "^20.7.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rollup-plugin-visualizer": "^6.0.5",
    "stylelint": "^16.26.1",
    "stylelint-config-recommended": "^17.0.0",
    "stylelint-config-standard": "^39.0.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.61.1"
  },
  "lint-staged": {
    "*.{js,ts,astro,mjs,cjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.css": [
      "stylelint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
