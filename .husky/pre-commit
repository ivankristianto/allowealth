#!/usr/bin/env sh
. "$(dirname "$0")/_/husky.sh"

echo "Running pre-commit quality gates..."

# Run format:fix first
echo "▸ Running prettier..."
bun run format:fix

# Stage any formatting changes
git add -A

# Then run lint
echo "▸ Running eslint..."
bun run lint:fix

# Stage any linting changes
git add -A

# Check if there are any uncommitted changes after formatting/linting
if ! git diff --cached --exit-code --quiet; then
  echo "✅ Files were formatted/linted and staged. Proceeding with commit..."
else
  echo "✅ Pre-commit checks passed (no formatting needed)"
fi
